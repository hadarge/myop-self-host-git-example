        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\r\n    <meta name=\"myop:size\" content='{\"width\":430,\"height\":800}'>\r\n    <title>Kim Floral - Inside a Gallery</title>\r\n\r\n    <script type=\"myop/types\">\r\n// =============================================================================\r\n// MYOP COMPONENT TYPE DEFINITIONS\r\n// =============================================================================\r\n\r\n/**\r\n * Data structure passed to myop_init_interface(data)\r\n */\r\ninterface MyopInitData {\r\n  id: string;\r\n  name: string;\r\n  title: string;\r\n  initials?: string;\r\n  avatarColor?: string;\r\n  profileImage?: string;\r\n  description?: string;\r\n  connectionState?: 'online' | 'offline';\r\n  socials?: {\r\n    instagram?: string;\r\n    email?: string;\r\n    website?: string;\r\n  };\r\n  galleryImages?: Array<{\r\n    id: string;\r\n    url: string;\r\n    order?: number;\r\n    tagged_vendors?: string[];\r\n  }>;\r\n}\r\n\r\n/**\r\n * Actions and payloads for myop_cta_handler(action, payload)\r\n */\r\ninterface MyopCtaPayloads {\r\n  'add_photo': null;\r\n  'edit_profile': { context?: string } | null;\r\n  'reload': void;\r\n  'share_profile': string;\r\n  'social': { type: 'instagram' | 'email' | 'website'; value: string };\r\n  'view_photo': { id: string; tagged_vendors: string[] };\r\n}\r\n\r\n// =============================================================================\r\n// DO NOT EDIT BELOW - Standard Myop type declarations\r\n// =============================================================================\r\n\r\ndeclare function myop_init_interface(): MyopInitData;\r\ndeclare function myop_init_interface(data: MyopInitData): void;\r\n\r\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\r\n  action: K,\r\n  payload: MyopCtaPayloads[K]\r\n): void;\r\n    </script>\r\n\r\n    <style>\r\n        /* Fonts */\r\n        @font-face {\r\n            font-family: 'TT Norms Pro';\r\n            src: url('https://fonts.cdnfonts.com/s/29009/TTNormsPro-Regular.woff') format('woff');\r\n            font-weight: 400;\r\n            font-style: normal;\r\n        }\r\n\r\n        @font-face {\r\n            font-family: 'TT Norms Pro';\r\n            src: url('https://fonts.cdnfonts.com/s/29009/TTNormsPro-Medium.woff') format('woff');\r\n            font-weight: 500;\r\n            font-style: normal;\r\n        }\r\n\r\n        /* Reset & Base */\r\n        * {\r\n            margin: 0;\r\n            padding: 0;\r\n            box-sizing: border-box;\r\n            -webkit-tap-highlight-color: transparent;\r\n        }\r\n\r\n        html, body {\r\n            width: 100%;\r\n            height: 100%;\r\n            overflow: hidden;\r\n        }\r\n\r\n        body {\r\n            font-family: 'TT Norms Pro', sans-serif;\r\n            background-color: #f5f5f5;\r\n            color: #222;\r\n            display: flex;\r\n            justify-content: center;\r\n        }\r\n\r\n        /* Layout */\r\n        .app-container {\r\n            background: white;\r\n            width: 100%;\r\n            max-width: 430px;\r\n            height: 100%;\r\n            position: relative;\r\n            overflow-y: auto;\r\n            padding-bottom: 20px;\r\n            box-shadow: 0 0 20px rgba(0, 0, 0, 0.05);\r\n        }\r\n\r\n        /* Header */\r\n        .header {\r\n            display: flex;\r\n            justify-content: flex-end;\r\n            align-items: center;\r\n            padding: 24px 24px 10px 24px;\r\n            margin-top: 10px;\r\n        }\r\n\r\n        .share-btn {\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 8px;\r\n            font-size: 16px;\r\n            cursor: pointer;\r\n        }\r\n\r\n        /* Profile Header */\r\n        .profile-header {\r\n            display: flex;\r\n            align-items: center;\r\n            padding: 20px 24px;\r\n            gap: 20px;\r\n        }\r\n\r\n        .avatar {\r\n            width: 84px;\r\n            height: 84px;\r\n            background-color: #A46D3A;\r\n            border-radius: 50%;\r\n            display: flex;\r\n            justify-content: center;\r\n            align-items: center;\r\n            color: white;\r\n            font-size: 32px;\r\n            flex-shrink: 0;\r\n            text-transform: uppercase;\r\n            overflow: hidden;\r\n        }\r\n\r\n        .profile-info {\r\n            display: flex;\r\n            flex-direction: column;\r\n            justify-content: center;\r\n        }\r\n\r\n        .profile-name {\r\n            font-size: 26px;\r\n            font-weight: 500;\r\n            margin-bottom: 4px;\r\n        }\r\n\r\n        .profile-title {\r\n            font-size: 16px;\r\n            color: #222;\r\n        }\r\n\r\n        /* Profile Body (Desc/Info) */\r\n        .profile-body {\r\n            padding: 0 24px;\r\n            margin-bottom: 24px;\r\n        }\r\n\r\n        .description-text {\r\n            font-size: 14px;\r\n            line-height: 1.5;\r\n            color: #222;\r\n            white-space: pre-wrap;\r\n            display: none;\r\n        }\r\n\r\n        .info-box {\r\n            background: #faf4e7;\r\n            border-radius: 6px;\r\n            padding: 20px;\r\n            display: none;\r\n        }\r\n\r\n        .info-title {\r\n            font-weight: 500;\r\n            font-size: 18px;\r\n            margin-bottom: 12px;\r\n            line-height: 1.4;\r\n        }\r\n\r\n        .info-text {\r\n            font-size: 13px;\r\n            line-height: 1.5;\r\n            margin-bottom: 16px;\r\n        }\r\n\r\n        .info-link {\r\n            font-size: 13px;\r\n            text-decoration: underline;\r\n            cursor: pointer;\r\n        }\r\n\r\n        /* Actions */\r\n        .actions-row {\r\n            padding: 0 24px;\r\n            display: flex;\r\n            justify-content: space-between;\r\n            align-items: center;\r\n            margin-bottom: 40px;\r\n        }\r\n\r\n        .social-icons {\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 24px;\r\n        }\r\n\r\n        .social-icon {\r\n            width: 24px;\r\n            height: 24px;\r\n            transition: opacity 0.2s, filter 0.2s;\r\n        }\r\n\r\n        .social-icon.empty-state {\r\n            opacity: 0.15;\r\n            filter: grayscale(1);\r\n            cursor: default;\r\n        }\r\n\r\n        .social-icon.active-state {\r\n            opacity: 1;\r\n            filter: grayscale(0);\r\n            cursor: pointer;\r\n        }\r\n\r\n        .social-icon.active-state:hover {\r\n            opacity: 0.7;\r\n        }\r\n\r\n        .edit-profile-btn {\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 8px;\r\n            border: 1px solid #d4d4d4;\r\n            padding: 6px 16px;\r\n            border-radius: 8px;\r\n            font-size: 16px;\r\n            cursor: pointer;\r\n            height: 36px;\r\n        }\r\n\r\n        /* Gallery */\r\n        .gallery-section {\r\n            padding-bottom: 20px;\r\n        }\r\n\r\n        .gallery-title {\r\n            padding: 0 24px;\r\n            font-size: 16px;\r\n            margin-bottom: 16px;\r\n        }\r\n\r\n        .gallery-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(3, 1fr);\r\n            gap: 2px;\r\n        }\r\n\r\n        .gallery-item {\r\n            aspect-ratio: 1;\r\n            background: #eee;\r\n            position: relative;\r\n            overflow: hidden;\r\n            cursor: pointer;\r\n        }\r\n\r\n        .gallery-item img {\r\n            width: 100%;\r\n            height: 100%;\r\n            object-fit: cover;\r\n        }\r\n\r\n        .add-photo-btn {\r\n            display: flex;\r\n            justify-content: center;\r\n            align-items: center;\r\n            background-color: #FAFAFA;\r\n            border: 1px solid #E0E0E0;\r\n        }\r\n\r\n        .add-photo-btn:hover {\r\n            background-color: #F0F0F0;\r\n        }\r\n\r\n        /* No Internet Empty State */\r\n        .no-internet-overlay {\r\n            display: none;\r\n            position: absolute;\r\n            inset: 0;\r\n            background: white;\r\n            z-index: 100;\r\n            flex-direction: column;\r\n            justify-content: center;\r\n            align-items: center;\r\n            gap: 16px;\r\n            padding: 40px 32px;\r\n            text-align: center;\r\n        }\r\n\r\n        .no-internet-overlay.visible {\r\n            display: flex;\r\n        }\r\n\r\n        .no-internet-icon {\r\n            width: 64px;\r\n            height: 64px;\r\n            color: #bbb;\r\n        }\r\n\r\n        .no-internet-title {\r\n            font-size: 16px;\r\n            font-weight: 500;\r\n            color: #222;\r\n            line-height: 1.4;\r\n        }\r\n\r\n        .no-internet-btn {\r\n            margin-top: 8px;\r\n            padding: 10px 28px;\r\n            border: 1.5px solid #222;\r\n            border-radius: 8px;\r\n            font-size: 15px;\r\n            font-family: inherit;\r\n            background: #222;\r\n            color: white;\r\n            cursor: pointer;\r\n            font-weight: 500;\r\n        }\r\n\r\n        .no-internet-btn:hover {\r\n            background: #444;\r\n        }\r\n    </style>\r\n</head>\r\n\r\n<body>\r\n\r\n    <div class=\"app-container\">\r\n\r\n        <!-- No Internet Connection Empty State -->\r\n        <div class=\"no-internet-overlay\" id=\"no-internet-overlay\">\r\n            <svg class=\"no-internet-icon\" viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"ht