051 15.9603C4.08551 14.4418 7.43017 13.5386 11.0001 13.5386C14.57 13.5386 17.9147 14.4426 19.9497 15.9568C20.241 16.1751 20.3605 16.5558 20.2453 16.9013C20.1302 17.2467 19.8062 17.4796 19.4427 17.4796L19.4434 17.4814Z\"\r\n                                fill=\"black\" />\r\n                            <path\r\n                                d=\"M11 8.46142C7.43006 8.46142 4.0854 7.55821 2.0504 6.04318C1.70837 5.75443 1.64993 5.24911 1.91806 4.89075C2.18531 4.53154 2.68634 4.44389 3.06016 4.68966C4.81242 5.99076 7.78423 6.76934 11 6.76934C14.2157 6.76934 17.1875 5.99074 18.9398 4.68621C19.1177 4.53582 19.3497 4.46535 19.5817 4.49199C19.8138 4.51863 20.0243 4.6398 20.1635 4.82628C20.3027 5.01362 20.3595 5.24995 20.3182 5.47941C20.2778 5.70887 20.1446 5.91167 19.9495 6.03973C17.9145 7.55824 14.5699 8.46142 11 8.46142Z\"\r\n                                fill=\"black\" />\r\n                        </g>\r\n                    </svg>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"edit-profile-btn\" onclick=\"window.myop_cta_handler('edit_profile', null)\">\r\n                <svg width=\"18\" height=\"18\" viewBox=\"0 0 29 29\" fill=\"none\">\r\n                    <path\r\n                        d=\"M23.6565 10.3211L18.6766 5.34122L5.34325 18.6789V23.6588H10.3231L23.6565 10.3211ZM18.6789 7.94333L21.0567 10.3211L20.0587 11.3202L17.6809 8.94247L18.6789 7.94333ZM16.3793 10.2429L18.7571 12.6207L10.8604 20.5174L8.48259 18.1385L16.3793 10.2429ZM7.18194 21.818V19.4402L9.5597 21.818H7.18194Z\"\r\n                        fill=\"black\" />\r\n                </svg>\r\n                <span>Edit profile</span>\r\n            </div>\r\n        </section>\r\n\r\n        <section class=\"gallery-section\">\r\n            <h3 class=\"gallery-title\">Photos of my work</h3>\r\n            <div class=\"gallery-grid\" id=\"gallery-grid\"></div>\r\n        </section>\r\n    </div>\r\n\r\n    <script>\r\n    (function() {\r\n        // Private scope - all implementation details\r\n        let currentState = null;\r\n\r\n        // DOM Elements Cache\r\n        const els = {\r\n            name: document.getElementById('profile-name'),\r\n            title: document.getElementById('profile-title'),\r\n            avatar: document.getElementById('avatar-container'),\r\n            share: document.getElementById('share-btn'),\r\n            desc: document.getElementById('profile-description'),\r\n            infoBox: document.getElementById('info-box-empty'),\r\n            gallery: document.getElementById('gallery-grid'),\r\n            noInternet: document.getElementById('no-internet-overlay')\r\n        };\r\n\r\n        function render(config) {\r\n            currentState = config;\r\n\r\n            // 0. No Internet Empty State\r\n            if (config.connectionState === 'offline') {\r\n                els.noInternet.classList.add('visible');\r\n                return;\r\n            }\r\n            els.noInternet.classList.remove('visible');\r\n\r\n            // 1. Set Identity Information\r\n            if (config.name) els.name.textContent = config.name;\r\n            if (config.title) els.title.textContent = config.title;\r\n\r\n            if (config.profileImage) {\r\n                els.avatar.style.backgroundColor = 'transparent';\r\n                els.avatar.innerHTML = `<img src=\"${config.profileImage}\" alt=\"Profile\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">`;\r\n            } else {\r\n                els.avatar.innerHTML = '';\r\n                if (config.initials) els.avatar.textContent = config.initials;\r\n                if (config.avatarColor) els.avatar.style.backgroundColor = config.avatarColor;\r\n            }\r\n\r\n            // 2. Header Actions\r\n            if (config.id && els.share) {\r\n                 els.share.onclick = () => window.myop_cta_handler('share_profile', config.id);\r\n            }\r\n\r\n            // 3. Bio Logic (Description vs Incomplete Info Box)\r\n            const hasBio = config.description && config.description.trim().length > 0;\r\n            els.desc.textContent = hasBio ? config.description : '';\r\n            els.desc.style.display = hasBio ? 'block' : 'none';\r\n            els.infoBox.style.display = hasBio ? 'none' : 'block';\r\n\r\n            // 4. Social Links Handling\r\n            const socialMap = {\r\n                instagram: 'social-instagram',\r\n                email: 'social-email',\r\n                website: 'social-website'\r\n            };\r\n            const socials = config.socials || {};\r\n\r\n            Object.keys(socialMap).forEach(key => {\r\n                const el = document.getElementById(socialMap[key]);\r\n                if (!el) return;\r\n\r\n                const url = socials[key];\r\n                if (url) {\r\n                    el.classList.replace('empty-state', 'active-state');\r\n                    el.onclick = () => {\r\n                        // Hook triggered for all active icons.\r\n                        // Redirection logic is handled by the host application.\r\n                        window.myop_cta_handler('social', { type: key, value: url });\r\n                    };\r\n                } else {\r\n                    el.classList.add('empty-state');\r\n                    el.classList.remove('active-state');\r\n                    el.onclick = null;\r\n                }\r\n            });\r\n\r\n            // 5. Gallery Grid Rendering\r\n            if (config.galleryImages && Array.isArray(config.galleryImages)) {\r\n                els.gallery.innerHTML = '';\r\n\r\n                // Sort by provided order and render items\r\n                [...config.galleryImages]\r\n                    .sort((a, b) => (a.order || 0) - (b.order || 0))\r\n                    .forEach((photo) => {\r\n                        const div = document.createElement('div');\r\n                        div.className = 'gallery-item';\r\n\r\n                        const img = document.createElement('img');\r\n                        img.src = photo.url;\r\n                        img.loading = 'lazy';\r\n                        img.alt = photo.id || 'Work photo';\r\n                        img.onclick = () => window.myop_cta_handler('view_photo', {\r\n                            id: photo.id,\r\n                            tagged_vendors: photo.tagged_vendors || []\r\n                        });\r\n\r\n                        div.appendChild(img);\r\n                        els.gallery.appendChild(div);\r\n                    });\r\n\r\n                // Add Photo Button (The Plus Card)\r\n                const addCard = document.createElement('div');\r\n                addCard.className = 'gallery-item add-photo-btn';\r\n                addCard.innerHTML = `\r\n                    <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\">\r\n                        <path d=\"M12 4V20\" stroke=\"#222222\" stroke-width=\"1\" stroke-linecap=\"round\"/>\r\n                        <path d=\"M4 12H20\" stroke=\"#222222\" stroke-width=\"1\" stroke-linecap=\"round\"/>\r\n                    </svg>\r\n                `;\r\n                addCard.onclick = () => window.myop_cta_handler('add_photo', null);\r\n                els.gallery.appendChild(addCard);\r\n            }\r\n        }\r\n\r\n        // Public API exposed to window\r\n        window.myop_init_interface = function(data) {\r\n            if (!data) return currentState; // Getter mode\r\n            render(data);\r\n        };\r\n\r\n        window.myop_cta_handler = function(action_id, payload) {\r\n            // Will be overridden by host application\r\n            console.log('Action Triggered:', { action_id, payload });\r\n        };\r\n    })();\r\n    </script>\r\n\r\n    <!-- Preview script - replaced in production -->\r\n    <script id=\"myop_preview\">\r\n        window.myop_init_interface({\r\n            id: \"kim_floral_12345\",\r\n            name: \"Kim Floral\",\r\n            title: \"Florist\",\r\n            initials: \"KF\",\r\n            avatarColor: \"#A46D3A\",\r\n            description: \"\",\r\n            socials: {\r\n                instagram: \"test\",\r\n                email: \"kim@floral.com\",\r\n                website: \"https://kimfloral.com\"\r\n            },\r\n            galleryImages: [\r\n                { id: \"p1\", url: \"https://images.unsplash.com/photo-1606800052052-a08af7148866?w=400\", order: 1 },\r\n                { id: \"p2\", url: \"https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=400\", order: 2 },\r\n                { id: \"p3\", url: \"https://images.unsplash.com/photo-1520763185298-1b434c919102?w=400\", order: 3 }\r\n            ]\r\n        });\r\n    </script>\r\n</body>\r\n\r\n</html>"
        }
      }
    ]
  }
