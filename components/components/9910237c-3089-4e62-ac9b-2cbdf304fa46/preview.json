          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\"}'>\n    <title>Payment Success</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --purple-5: #F0E8FF;\n            --purple-10: #DECCFF;\n            --grey-20: #D3D1D5;\n            --white: #FFF;\n            --bg-color: #ffffff;\n            --border-color: #e5e5e5;\n            --text-color: #18181b;\n            --text-secondary: #71717a;\n            --accent-blue: #9A70DF;\n            --accent-green: #10b981;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n        }\n\n        /* Modal Container */\n        .modal {\n            display: flex;\n            width: 480px;\n            height: 360px;\n            flex-direction: column;\n            align-items: flex-start;\n            background: transparent;\n            padding: 32px 36px 32px;\n            text-align: left;\n            position: relative;\n            overflow: visible;\n        }\n\n        /* Success Icon Container */\n        .icon-container {\n            width: 58px;\n            height: 58px;\n            margin: 0 0 24px 0;\n            position: relative;\n            overflow: visible;\n        }\n\n        .icon-container svg {\n            width: 100%;\n            height: 100%;\n            overflow: visible;\n        }\n\n        /* Animated gradient squares */\n        .gradient-square-1,\n        .gradient-square-2,\n        .gradient-square-3 {\n            transform-origin: center center;\n            transform-box: fill-box;\n        }\n\n        .gradient-square-1 {\n            animation: flyOut1 4s ease-in-out infinite;\n        }\n\n        .gradient-square-2 {\n            animation: flyOut2 4s ease-in-out infinite;\n            animation-delay: 0.8s;\n        }\n\n        .gradient-square-3 {\n            animation: flyOut3 4s ease-in-out infinite;\n            animation-delay: 1.6s;\n        }\n\n        @keyframes flyOut1 {\n            0% { transform: translate(12px, 40px) scale(0.5) rotate(0deg); opacity: 0; }\n            20% { transform: translate(6px, 20px) scale(0.8) rotate(5deg); opacity: 0.5; }\n            50% { transform: translate(0, 0) scale(1) rotate(15deg); opacity: 0.5; }\n            80% { transform: translate(-8px, -20px) scale(0.9) rotate(18deg); opacity: 0.3; }\n            100% { transform: translate(-15px, -40px) scale(0.7) rotate(20deg); opacity: 0; }\n        }\n\n        @keyframes flyOut2 {\n            0% { transform: translate(8px, 35px) scale(0.4) rotate(8.7057deg); opacity: 0; }\n            20% { transform: translate(4px, 18px) scale(0.7) rotate(10deg); opacity: 0.5; }\n            50% { transform: translate(0, 0) scale(1) rotate(8.7057deg); opacity: 0.5; }\n            80% { transform: translate(-6px, -18px) scale(0.9) rotate(6deg); opacity: 0.3; }\n            100% { transform: translate(-12px, -35px) scale(0.6) rotate(3deg); opacity: 0; }\n        }\n\n        @keyframes flyOut3 {\n            0% { transform: translate(0, 8px) scale(0.7) rotate(0deg); opacity: 0; }\n            25% { transform: translate(0, 0) scale(1) rotate(0deg); opacity: 0.4; }\n            75% { transform: translate(0, 0) scale(1) rotate(0deg); opacity: 0.4; }\n            100% { transform: translate(0, 0) scale(1) rotate(0deg); opacity: 0.4; }\n        }\n\n        /* Typography */\n        .modal-title {\n            color: var(--Grey-dark, #373539);\n            font-family: \"DM Sans\";\n            font-size: 24px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 32px;\n            margin-bottom: 24px;\n        }\n\n        .modal-subtitle {\n            color: var(--Grey-90, #3E3D3E);\n            font-family: \"DM Sans\";\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 24px;\n        }\n\n        /* Buttons Container */\n        .buttons-container {\n            display: flex;\n            flex-direction: row;\n            gap: 8px;\n            justify-content: flex-start;\n            margin-top: auto;\n        }\n\n        /* Primary Button */\n        .btn-primary {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            padding: 0 12px;\n            height: 34px;\n            background: var(--Grey-90, #3E3D3E);\n            border: none;\n            border-radius: 6px;\n            color: white;\n            font-family: 'DM Sans', sans-serif;\n            font-size: 13px;\n            font-weight: 400;\n            cursor: pointer;\n            white-space: nowrap;\n        }\n\n        .btn-primary:hover {\n            border-radius: 6px;\n            background: #9747FF;\n        }\n\n        /* Secondary Button */\n        .btn-secondary {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            padding: 0 12px;\n            height: 36px;\n            background: var(--bg-color);\n            border: 1px solid var(--grey-20);\n            border-radius: 6px;\n            color: var(--text-color);\n            font-family: 'DM Sans', sans-serif;\n            font-size: 13px;\n            font-weight: 400;\n            cursor: pointer;\n            transition: all 0.15s ease;\n            white-space: nowrap;\n        }\n\n        .btn-secondary:hover {\n            background: var(--purple-5);\n            border-color: var(--purple-10);\n        }\n\n        .btn-secondary:active {\n            transform: scale(0.98);\n        }\n\n        #loader-container {\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"loader-container\">\n        <div class=\"loader-spinner\"></div>\n    </div>\n\n    <div id=\"app-root\">\n        <div class=\"modal\">\n            <!-- Success Icon -->\n            <div class=\"icon-container\">\n                <svg viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <g>\n                        <rect x=\"13.633\" y=\"52\" width=\"72.5748\" height=\"46.3243\" rx=\"2.98529\" fill=\"white\" stroke=\"black\" stroke-width=\"1.49265\"/>\n                        <path d=\"M89.347 99.8682C90.1714 99.8682 90.8396 99.1999 90.8396 98.3755L90.8396 96.7284C90.8396 95.904 90.1713 95.2358 89.347 95.2358L10.4927 95.2358C9.66829 95.2358 9.00001 95.904 9.00001 96.7284L9.00001 98.3756C9.00001 99.1999 9.66829 99.8682 10.4927 99.8682L89.347 99.8682Z\" fill=\"#DCCAF5\" stroke=\"black\" stroke-width=\"1.49265\"/>\n                        <rect class=\"gradient-square-3\" opacity=\"0.4\" x=\"17.6992\" y=\"55.9743\" width=\"64.1838\" height=\"34.3309\" rx=\"1.49265\" fill=\"url(#paint0_linear_3605_80624)\"/>\n                        <rect class=\"gradient-square-1\" opacity=\"0.4\" x=\"11.7754\" y=\"0.591064\" width=\"50.2284\" height=\"30.9068\" rx=\"1.49265\" transform=\"rotate(15 11.7754 0.591064)\" fill=\"url(#paint1_linear_3605_80624)\"/>\n                        <rect class=\"gradient-square-2\" opacity=\"0.4\" x=\"17.457\" y=\"28.1278\" width=\"62.1943\" height=\"34.6082\" rx=\"1.49265\" transform=\"rotate(8.7057 17.457 28.1278)\" fill=\"url(#paint2_linear_3605_80624)\"/>\n                    </g>\n                    <defs>\n                        <linearGradient id=\"paint0_linear_3605_80624\" x1=\"83.1132\" y1=\"73.1397\" x2=\"66.4733\" y2