      </div>\n    </div>\n\n    <script id=\"myop_preview\">\n        (function() {\n            let isInitialized = false;\n\n            function initializeComponent(data) {\n                isInitialized = true;\n                if (data && data.title) {\n                    document.querySelector('.modal-title').textContent = data.title;\n                }\n                if (data && data.subtitle) {\n                    document.querySelector('.modal-subtitle').textContent = data.subtitle;\n                }\n            }\n\n            function handleButtonClick(actionId, payload) {\n                if (typeof window.myop_cta_handler === 'function') {\n                    window.myop_cta_handler(actionId, payload);\n                } else {\n                    console.log('CTA Handler called:', actionId, payload);\n                }\n            }\n\n            document.getElementById('btn-admin').addEventListener('click', function() {\n                handleButtonClick('navigate_admin_settings', { source: 'payment_success_modal' });\n            });\n\n            document.getElementById('btn-home').addEventListener('click', function() {\n                handleButtonClick('navigate_homepage', { source: 'payment_success_modal' });\n            });\n\n            window.myop_init_interface = function(data) {\n                if (arguments.length === 0) {\n                    return { isInitialized };\n                }\n                initializeComponent(data);\n            };\n\n            window.myop_cta_handler = function(actionId, payload) {\n                console.log('Action:', actionId, 'Payload:', payload);\n            };\n\n            setTimeout(() => {\n                window.myop_init_interface({\n                    title: \"Payment Successful!\",\n                    subtitle: \"Your subscription is now active. You're all set to start building amazing components.\"\n                });\n            }, 100);\n        })();\n    </script>\n<