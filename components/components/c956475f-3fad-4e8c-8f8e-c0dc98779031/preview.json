      {
        "name": "Version 60",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n  <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n  <meta charset=\"UTF-8\">\n  <script src=\"https://player.vimeo.com/api/player.js\"></script>\n  <script type=\"myop/types\">\n  interface FontConfig { id: string; style?: string; weight?: string; }\n  interface MyopInitData {\n    fonts?: { main?: FontConfig };\n  }\n  interface MyopCtaPayloads {\n    'close_screenTakeover': void;\n  }\n  declare function myop_init_interface(): MyopInitData;\n  declare function myop_init_interface(data: MyopInitData): void;\n  declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(action: K, payload: MyopCtaPayloads[K]): void;\n  </script>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    html, body {\n      width: 100%; height: 100%;\n      overflow: hidden;\n      background: #F1EEE8;\n      font-family: 'TT Norms Pro', 'Helvetica Neue', Arial, sans-serif;\n    }\n\n    #app-root {\n      width: 100%; height: 100%;\n      position: relative;\n      overflow: hidden;\n    }\n\n    /* SLIDES */\n    .slide {\n      position: absolute;\n      inset: 0;\n      background: #F1EEE8;\n      display: flex;\n      flex-direction: column;\n      opacity: 0;\n      pointer-events: none;\n    }\n    .slide.active {\n      opacity: 1;\n      pointer-events: all;\n    }\n    /* Fade transition only for intro screens */\n    #slide-1, #slide-2 {\n      transition: opacity 0.6s ease;\n    }\n\n    /* TYPOGRAPHY */\n    .slide-title {\n      color: #232323;\n      font-weight: 400;\n      letter-spacing: 0.2px;\n      line-height: 1.15;\n    }\n\n    /* SLIDE 1: Welcome */\n    #slide-1 {\n      align-items: center;\n      justify-content: center;\n    }\n    #slide-1 .slide-title {\n      font-size: clamp(2rem, 4vw, 3.2rem);\n      text-align: center;\n      max-width: 720px;\n      padding: 0 40px;\n    }\n\n    /* SLIDE 2: Pic-Time 2.0 */\n    #slide-2 {\n      align-items: center;\n      justify-content: center;\n      gap: 32px;\n    }\n    #slide-2 .slide-title {\n      font-size: clamp(2.5rem, 5vw, 4rem);\n      text-align: center;\n      letter-spacing: -0.02em;\n    }\n\n    .cta-btn {\n      background: #232323;\n      color: #fff;\n      border: none;\n      border-radius: 4px;\n      padding: 14px 32px;\n      font-size: 0.95rem;\n      font-weight: 500;\n      font-family: inherit;\n      cursor: pointer;\n      letter-spacing: 0.01em;\n      transition: transform 0.18s ease, background 0.18s ease;\n      transform: scale(1);\n    }\n    @media (hover: hover) {\n    .cta-btn:hover {\n      transform: scale(1.04);\n      background: #3d3d3d;\n    }\n    }\n    .cta-btn:active {\n      transform: scale(0.97);\n      background: #0d0d0d;\n      transition: transform 0.08s ease, background 0.08s ease;\n    }\n\n    /* SLIDES 3-5: Feature slides */\n    .feature-slide {\n      padding: 56px 80px 56px;\n      align-items: center;\n      justify-content: center;\n      gap: 24px;\n    }\n    .feature-slide .slide-title {\n      font-size: clamp(1.585rem, 3.17vw, 2.537rem);\n      text-align: center;\n      width: 100%;\n      flex-shrink: 0;\n    }\n\n    .feature-middle {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      width: 100%;\n      gap: 24px;\n    }\n\n    .feature-image-wrap {\n      width: 50vw;\n      max-width: 50vw;\n      overflow: hidden;\n      background: #F1EEE8;\n      position: relative;\n      flex-shrink: 0;\n      aspect-ratio: 1 / 0.5208;\n    }\n    .feature-image-wrap iframe {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      border: none;\n    }\n    /* Transparent overlay on mobile to intercept swipe touches over the iframe */\n    .video-touch-guard {\n      display: none;\n    }\n    @media (max-width: 600px) {\n      .video-touch-guard {\n        display: block;\n        position: absolute;\n        inset: 0;\n        z-index: 2;\n        background: transparent;\n      }\n    }\n\n    /* Dot pagination */\n    .dots {\n      display: flex;\n      gap: 8px;\n      margin-top: 0;\n      align-items: center;\n    }\n    .dot {\n      width: 8px;\n      height: 8px;\n      border-radius: 50%;\n      background: #c8c4be;\n      cursor: pointer;\n      transition: background 0.3s;\n    }\n    .dot.active { background: #232323; }\n\n    /* SLIDE 6: Ready */\n    #slide-6 {\n      align-items: center;\n      justify-content: center;\n      gap: 32px;\n    }\n    #slide-6 .slide-title {\n      font-size: clamp(2.5rem, 5vw, 4rem);\n      text-align: center;\n      letter-spacing: -0.02em;\n    }\n\n    /* NAV BUTTONS */\n    .nav-area {\n      display: none; /* hidden on desktop — nav is inside feature-middle */\n    }\n    /* Desktop feature nav row (inside content flow, aligned to video) */\n    .feature-nav-row {\n      display: flex;\n      width: 50vw;\n      max-width: 50vw;\n      justify-content: space-between;\n      align-items: center;\n      margin-top: 7px;\n    }\n    /* Invisible spacer so dots stay centered when back button is absent */\n    .feature-nav-placeholder {\n      width: 110px; /* matches approx nav-btn width */\n    }\n    .nav-btn {\n      pointer-events: all;\n      background: transparent;\n      border: 1.5px solid #232323;\n      border-radius: 4px;\n      color: #232323;\n      font-family: inherit;\n      font-size: 0.82rem;\n      font-weight: 500;\n      letter-spacing: 0.1em;\n      padding: 13px 26px;\n      cursor: pointer;\n      display: flex;\n      align-items: center;\n      gap: 10px;\n      transition: background 0.2s, color 0.2s;\n    }\n    /* Back button: no frame */\n    .nav-btn.nav-btn-back {\n      border: none;\n      padding: 13px 0;\n    }\n    @media (hover: hover) {\n    .nav-btn:hover {\n      background: #232323;\n      color: #F1EEE8;\n    }\n    .nav-btn:hover .arrow-path { stroke: #F1EEE8; }\n    /* Back button: no fill on hover, just opacity */\n    .nav-btn.nav-btn-back:hover {\n      background: transparent;\n      color: #232323;\n      opacity: 0.6;\n    }\n    .nav-btn.nav-btn-back:hover .arrow-path { stroke: #232323; }\n    }\n    .nav-btn.hidden { visibility: hidden; }\n\n    .nav-btn svg {\n      width: 20px;\n      height: 12px;\n      flex-shrink: 0;\n    }\n    .arrow-path {\n      stroke: #232323;\n      transition: stroke 0.2s;\n    }\n\n    /* TOPBAR */\n    .feature-topbar {\n      position: absolute;\n      top: 40px;\n      left: 0; right: 0;\n      display: flex;\n      justify-content: space-between;\n      padding: 0 40px;\n      font-size: 1.05rem;\n      font-weight: 500;\n      color: #232323;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      z-index: 5;\n    }\n\n  /* Responsive text variants */\n  .mobile-text { display: none; }\n  .desktop-text { display: inline; }\n  @media (max-width: 600px) {\n    .mobile-text { display: inline; }\n    .desktop-text { display: none; }\n  }\n\n  /* ===================== MOBILE ===================== */\n  @media (max-width: 600px) {\n\n    /* Swipe track: all slides laid out horizontally */\n    #app-root {\n      overflow: hidden;\n    }\n    .slide {\n      position: absolute;\n      inset: 0;\n      opacity: 0;\n      pointer-events: none;\n      will-change: transform;\n      transition: none;\n    }\n    /* Slides 3-6: visible at full opacity, positioned by translateX */\n    #slide-3, #slide-4, #slide-5, #slide-6 {\n      opacity: 1;\n    }\n    /* Slides 1 & 2: fade in/out via opacity — fixed at center, no translateX */\n    #slide-1, #slide-2 {\n      opacity: 0;\n      transform: none !important;\n    }\n    #slide-1.active {\n      opacity: 1;\n      transition: opacity 0.6s ease;\n      pointer-events: all;\n    }\n    /* Fade out slide 1 */\n    #slide-1.intro-fade-out {\n      opacity: 0;\n      transition: opacity 0.6s ease;\n    }\n    /* Fade in slide 2 */\n    #slide-2.intro-fade-in {\n      opacity: 1;\n      transition: opacity 0.6s ease;\n    }\n    #slide-2.active {\n      opacity: 1;\n      pointer-events: all;\n    }\n    /* Slides 3-6: active = pointer events only (opacity already 1) */\n    #slide-3.active, #slide-4.active, #slide-5.active, #slide-6.active {\n      pointer-events: all;\n    }\n\n    /* All titles: Regular weight */\n    .slide-title { font-weight: 350 !important; }\n\n    /* Hide topbar on mobile */\n    .feature-topbar { display: none !important; }\n\n    /* ---- Slide 1: title vertically centered ---- */\n    #slide-1 {\n      align-items: center;\n      justify-content: center;\n      padding: 0 40px;\n    }\n    #slide-1 .slide-title {\n      font-size: 2.07rem;\n      text-align: center;\n      line-height: 1.3;\n      padding: 0;\n    }\n\n    /* ---- Slide 2: title + button as a centered group ---- */\n    #slide-2 {\n      align-items: center;\n      justify-content: center;\n      flex-direction: column;\n      gap: 24px;\n      padding: 0 40px;\n    }\n    #slide-2 .slide-title {\n      font-size: 2.48rem;\n      text-align: center;\n      letter-spacing: 0.5px;\n    }\n    #slide-2 .slide-title .version-num {\n      letter-spacing: 0;\n    }\n    #see-whats-new-btn {\n      position: static !important;\n      width: auto !important;\n      left: auto !important;\n      bottom: auto !important;\n      transform: none !important;\n      margin: 0 !important;\n      padding: 13px 28px !important;\n      font-size: 0.874rem !important;\n      font-weight: 500 !important;\n    }\n\n    /* ---- Feature slides 3-5 ---- */\n    .feature-slide {\n      padding: 0;\n      gap: 0;\n      justify-content: center;\n      align-items: center;\n    }\n    .feature-slide .slide-title {\n      font-size: 2.07rem;\n      text-align: center;\n      padding: 0 24px;\n      margin: 0 0 40px 0;\n      flex-shrink: 0;\n    }\n    .feature-middle {\n      gap: 0;\n      width: 100%;\n      flex-shrink: 0;\n    }\n    .feature-image-wrap {\n      width: 85vw !important;\n      max-width: 85vw !important;\n      margin-left: auto !important;\n      margin-right: auto !important;\n      border-radius: 4px;\n      background: transparent !important;\n      aspect-ratio: 1 / 0.5208; /* fallback, overridden by JS per video */\n    }\n    .dots {\n      position: static !important;\n      display: flex !important;\n      justify-content: center;\n      left: auto !important;\n      bottom: auto !important;\n      transform: none !important;\n      margin-top: 40px;\n    }\n\n    /* Hide desktop nav rows on mobile */\n    .feature-nav-row {\n      display: none !important;\n    }\n\n    /* Nav buttons at very bottom */\n    .nav-area {\n      display: flex !important;\n      position: absolute;\n      bottom: 6vh;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 85vw;\n      padding: 0;\n      justify-content: space-between;\n      gap: 8px;\n      pointer-events: none;\n    }\n    .nav-btn {\n      font-size: 0.874rem;\n      font-weight: 500;\n      padding: 10px 20px;\n      gap: 8px;\n    }\n    .nav-btn.hidden { display: none; }\n    #btn-next { margin-left: auto; }\n    .nav-btn svg {\n      width: 16px;\n      height: 10px;\n    }\n\n    /* ---- Slide 6: title + button centered ---- */\n    #slide-6 {\n      align-items: center;\n      justify-content: center;\n      flex-direction: column;\n      gap: 24px;\n      padding: 0 40px;\n    }\n    #slide-6 .slide-title {\n      font-size: 2.48rem;\n      text-align: center;\n      font-style: normal;\n    }\n    #dashboard-btn {\n      position: static !important;\n      width: auto !important;\n      left: auto !important;\n      bottom: auto !important;\n      transform: none !important;\n      margin: 0 !important;\n      padding: 13px 28px !important;\n      font-size: 0.874rem !important;\n      font-weight: 500 !important;\n    }\n    /* BACK button stays in shared nav-area at the bottom */\n    .slide-6-back {\n      display: none !important;\n    }\n\n    /* Shared mobile dots — fixed overlay, never moves */\n    #mobile-dots {\n      position: absolute;\n      left: 0;\n      right: 0;\n      top: 0; /* set dynamically by JS */\n      display: flex;\n      justify-content: center;\n      gap: 8px;\n      z-index: 10;\n      pointer-events: none;\n    }\n    #mobile-dots .dot {\n      pointer-events: all;\n    }\n    /* Hide per-slide dots on mobile (they were removed from HTML but keep rule as safety) */\n    .feature-middle .dots {\n      display: none !important;\n    }\n  }\n  </style>\n</head>\n<body>\n<div id=\"app-root\">\n\n  <!-- SLIDE 1: Welcome -->\n  <div class=\"slide\" id=\"slide-1\">\n    <h1 class=\"slide-title\"><span class=\"desktop-text\">Welcome to a Whole<br>New Delivery Experience</span><span class=\"mobile-text\">Welcome to a<br>Whole New Delivery<br>Experience</span></h1>\n  </div>\n\n  <!-- SLIDE 2: Pic-Time 2.0 -->\n  <div class=\"slide\" id=\"slide-2\">\n    <h1 class=\"slide-title\">Pic-Time <span class=\"version-num\">2.0</span></h1>\n    <button class=\"cta-btn\" id=\"see-whats-new-btn\" style=\"opacity:0;transition:opacity 0.6s ease;\">Explore what's new</button>\n  </div>\n\n  <!-- SLIDE 3: Brand-forward -->\n  <div class=\"slide feature-slide\" id=\"slide-3\">\n    <div class=\"feature-topbar\"><span>PIC-TIME 2.0</span><span>YOUR VISION, DELIVERED</span></div>\n    <h2 class=\"slide-title\"><span class=\"desktop-text\">New Design Possibilities</span><span class=\"mobile-text\">New Design<br>Possibilities</span></h2>\n    <div class=\"feature-middle\">\n      <div class=\"feature-image-wrap ratio-video\">\n        <div class=\"video-touch-guard\"></div>\n        <iframe src=\"https://player.vimeo.com/video/1174750232?h=7a5424b11e&badge=0&autopause=0&autoplay=1&muted=1&loop=1&controls=0&title=0&byline=0&portrait=0&transparent=0&player_id=0&app_id=58479\" allow=\"autoplay; fullscreen; picture-in-picture\" referrerpolicy=\"strict-origin-when-cross-origin\"></iframe>\n      </div>\n      <div class=\"feature-nav-row\">\n        <span class=\"feature-nav-placeholder\"></span>\n        <div class=\"dots\">\n          <div class=\"dot active\" data-slide=\"3\"></div>\n          <div class=\"dot\" data-slide=\"4\"></div>\n          <div class=\"dot\" data-slide=\"5\"></div>\n        </div>\n        <button class=\"nav-btn\" data-nav=\"next\">NEXT <svg viewBox=\"0 0 20 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path class=\"arrow-path\" d=\"M13 1L19 6L13 11\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path class=\"arrow-path\" d=\"M19 6H1\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg></button>\n      </div>\n    </div>\n  </div>\n\n  <!-- SLIDE 4: Seamless curation -->\n  <div class=\"slide feature-slide\" id=\"slide-4\">\n    <div class=\"feature-topbar\"><span>PIC-TIME 2.0</span><span>YOUR VISION, DELIVERED</span></div>\n    <h2 class=\"slide-title\"><span class=\"desktop-text\">Rebuilt Client Flow</span><span class=\"mobile-text\">Rebuilt Client<br>Flow</span></h2>\n    <div class=\"feature-middle\">\n      <div class=\"feature-image-wrap ratio-video\">\n        <div class=\"video-touch-guard\"></div>\n        <iframe src=\"https://player.vimeo.com/video/1175873829?h=fe24945052&badge=0&autopause=0&autoplay=1&muted=1&loop=1&controls=0&title=0&byline=0&portrait=0&transparent=0&player_id=0&app_id=58479\" allow=\"autoplay; fullscreen; picture-in-picture\" referrerpolicy=\"strict-origin-when-cross-origin\"></iframe>\n      </div>\n      <div class=\"feature-nav-row\">\n        <button class=\"nav-btn nav-btn-back\" data-nav=\"back\"><svg viewBox=\"0 0 20 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path class=\"arrow-path\" d=\"M7 1L1 6L7 11\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path class=\"arrow-path\" d=\"M1 6H19\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg> BACK</button>\n        <div class=\"dots\">\n          <div class=\"dot\" data-slide=\"3\"></div>\n          <div class=\"dot active\" data-slide=\"4\"></div>\n          <div class=\"dot\" data-slide=\"5\"></div>\n        </div>\n        <button class=\"nav-btn\" data-nav=\"next\">NEXT <svg viewBox=\"0 0 20 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path class=\"arrow-path\" d=\"M13 1L19 6L13 11\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path class=\"arrow-path\" d=\"M19 6H1\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg></button>\n      </div>\n    </div>\n  </div>\n\n  <!-- SLIDE 5: Engaging shop -->\n  <div class=\"slide feature-slide\" id=\"slide-5\">\n    <div class=\"feature-topbar\"><span>PIC-TIME 2.0</span><span>YOUR VISION, DELIVERED</span></div>\n    <h2 class=\"slide-title\"><span class=\"desktop-text\">Redesigned Shop Experience</span><span class=\"mobile-text\">Redesigned<br>Shop Experience</span></h2>\n    <div class=\"feature-middle\">\n      <div class=\"feature-image-wrap ratio-video\">\n        <div class=\"video-touch-guard\"></div>\n        <iframe src=\"https://player.vimeo.com/video/1174751678?h=817a81e9c6&badge=0&autopause=0&autoplay=1&muted=1&loop=1&controls=0&title=0&byline=0&portrait=0&transparent=0&player_id=0&app_id=58479\" allow=\"autoplay; fullscreen; picture-in-picture\" referrerpolicy=\"strict-origin-when-cross-origin\"></iframe>\n      </div>\n      <div class=\"feature-nav-row\">\n        <button class=\"nav-btn nav-btn-back\" data-nav=\"back\"><svg viewBox=\"0 0 20 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path class=\"arrow-path\" d=\"M7 1L1 6L7 11\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path class=\"arrow-path\" d=\"M1 6H19\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg> BACK</button>\n        <div class=\"dots\">\n          <div class=\"dot\" data-slide=\"3\"></div>\n          <div class=\"dot\" data-slide=\"4\"></div>\n          <div class=\"dot active\" data-slide=\"5\"></div>\n        </div>\n        <button class=\"nav-btn\" data-nav=\"next\">NEXT <svg viewBox=\"0 0 20 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path class=\"arrow-path\" d=\"M13 1L19 6L13 11\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path class=\"arrow-path\" d=\"M19 6H1\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg></button>\n      </div>\n    </div>\n  </div>\n\n  <!-- SLIDE 6: Ready to try it? -->\n  <div class=\"slide\" id=\"slide-6\">\n    <div class=\"feature-topbar\"><span>PIC-TIME 2.0</span><span>YOUR VISION, DELIVERED</span></div>\n    <h1 class=\"slide-title\">Ready to Try It?</h1>\n    <button class=\"cta-btn\" id=\"dashboard-btn\">Go to new dashboard</button>\n  </div>\n\n  <!-- SHARED MOBILE DOTS (static overlay, shown only on feature slides 3-5) -->\n  <div id=\"mobile-dots\" style=\"display:none;\">\n    <div class=\"dot active\" data-slide=\"3\"></div>\n    <div class=\"dot\" data-slide=\"4\"></div>\n    <div class=\"dot\" data-slide=\"5\"></div>\n  </div>\n\n  <!-- SHARED NAV -->\n  <div class=\"nav-area\" id=\"nav-area\">\n    <button class=\"nav-btn nav-btn-back hidden\" id=\"btn-back\">\n      <svg viewBox=\"0 0 20 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path class=\"arrow-path\" d=\"M7 1L1 6L7 11\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        <path class=\"arrow-path\" d=\"M1 6H19\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n      </svg>\n      BACK\n    </button>\n    <button class=\"nav-btn hidden\" id=\"btn-next\">\n      NEXT\n      <svg viewBox=\"0 0 20 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path class=\"arrow-path\" d=\"M13 1L19 6L13 11\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        <path class=\"arrow-path\" d=\"M19 6H1\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n      </svg>\n    </button>\n  </div>\n\n</div>\n\n<script>\n(function() {\n  var current = 1;\n  var total = 6;\n  var currentState = {};\n\n  // Swipe helpers — defined early so goTo can call them\n  function isMobile() { return window.innerWidth <= 600; }\n  function snapSlides(activeIdx) {\n    // Slides 1 & 2 use opacity fade only — exclude from translateX system\n    for (var i = 3; i <= total; i++) {\n      var el = document.getElementById('slide-' + i);\n      var px = (i - activeIdx) * window.innerWidth;\n      el.style.transition = 'transform 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94)';\n      el.style.transform = 'translateX(' + px + 'px)';\n    }\n  }\n\n  var btnBack = document.getElementById('btn-back');\n  var btnNext = document.getElementById('btn-next');\n\n  // Initialize Vimeo Player instances — pause all on ready so they don't auto-play\n  var vimeoPlayers = {};\n  var vimeoReadyCount = 0;\n  function initVimeoPlayers() {\n    [3, 4, 5].forEach(function(slideNum) {\n      var iframe = document.querySelector('#slide-' + slideNum + ' iframe');\n      if (iframe && window.Vimeo) {\n        var p = new Vimeo.Player(iframe);\n        vimeoPlayers[slideNum] = p;\n        // Pause immediately so only the active slide plays\n        p.ready().then(function() {\n          p.pause();\n          vimeoReadyCount++;\n          if (vimeoReadyCount === 3) {\n            adjustMobileVideoRatios();\n            // Re-position dots after ratio adjustment\n            setTimeout(positionMobileDots, 100);\n          }\n        });\n      }\n    });\n  }\n  if (document.readyState === 'complete') {\n    initVimeoPlayers();\n  } else {\n    window.addEventListener('load', initVimeoPlayers);\n  }\n\n  function restartVideo(slideNum) {\n    if (slideNum < 3 || slideNum > 5) return;\n    var p = vimeoPlayers[slideNum];\n    if (!p) return;\n    // Must play() first — setCurrentTime fails on unstarted players\n    p.play().then(function() {\n      p.setCurrentTime(0);\n    }).catch(function() {\n      // Fallback: try seek first then play\n      try { p.setCurrentTime(0); } catch(e) {}\n      setTimeout(function() { p.play(); }, 100);\n    });\n  }\n\n  function pauseVideo(slideNum) {\n    if (slideNum < 3 || slideNum > 5) return;\n    var p = vimeoPlayers[slideNum];\n    if (!p) return;\n    p.pause();\n  }\n\n  function goTo(n) {\n    if (n < 1 || n > total) return;\n    var prev = current;\n    document.getElementById('slide-' + prev).classList.remove('active');\n    current = n;\n    document.getElementById('slide-' + current).classList.add('active');\n    updateNav();\n    // Pause leaving video, restart incoming video\n    if (prev !== n) pauseVideo(prev);\n    restartVideo(n);\n    // Slide 2: fade in button after title appears\n    if (n === 2) {\n      var btn = document.getElementById('see-whats-new-btn');\n      btn.style.opacity = '0';\n      setTimeout(function() { btn.style.opacity = '1'; }, 800);\n    }\n    // Sync swipe track position on mobile (buttons / dots navigation)\n    if (isMobile()) snapSlides(current);\n  }\n\n  function updateNav() {\n    // Mobile nav-area buttons\n    btnBack.classList.toggle('hidden', current < 4);\n    btnNext.classList.toggle('hidden', current < 3 || current > 5);\n    // Mobile dots: show only on slides 3–5, update active dot\n    if (isMobile()) {\n      var mobileDots = document.getElementById('mobile-dots');\n      var onFeature = current >= 3 && current <= 5;\n      mobileDots.style.display = onFeature ? 'flex' : 'none';\n      if (onFeature) {\n        mobileDots.querySelectorAll('.dot').forEach(function(d) {\n          d.classList.toggle('active', parseInt(d.getAttribute('data-slide')) === current);\n        });\n      }\n    }\n    // Desktop: update all dots in feature-nav-rows\n    document.querySelectorAll('.feature-nav-row .dot').forEach(function(d) {\n      d.classList.toggle('active', parseInt(d.getAttribute('data-slide')) === current);\n    });\n  }\n\n  // Mobile nav-area buttons\n  btnBack.addEventListener('click', function() { goTo(current - 1); });\n  btnNext.addEventListener('click', function() { goTo(current + 1); });\n\n  // Desktop feature-nav-row buttons (data-nav=\"back\"/\"next\")\n  document.querySelectorAll('[data-nav=\"back\"]').forEach(function(btn) {\n    btn.addEventListener('click', function() { goTo(current - 1); });\n  });\n  document.querySelectorAll('[data-nav=\"next\"]').forEach(function(btn) {\n    btn.addEventListener('click', function() { goTo(current + 1); });\n  });\n\n  // All dot clicks (desktop + mobile)\n  document.querySelectorAll('.dot').forEach(function(dot) {\n    dot.addEventListener('click', function() {\n      var t = parseInt(dot.getAttribute('data-slide'));\n      if (t) goTo(t);\n    });\n  });\n\n  document.getElementById('see-whats-new-btn').addEventListener('click', function() {\n    goTo(3);\n  });\n\n  document.getElementById('dashboard-btn').addEventListener('click', function() {\n    window.myop_cta_handler('close_screenTakeover', undefined);\n  });\n\n  // Fade in slide 1 on load\n  setTimeout(function() {\n    var s1 = document.getElementById('slide-1');\n    s1.classList.add('active');\n  }, 50);\n\n  // After 2s: fade slide 1 OUT fully, then fade slide 2 IN after transition completes\n  setTimeout(function() {\n    var s1 = document.getElementById('slide-1');\n    var s2 = document.getElementById('slide-2');\n\n    if (isMobile()) {\n      // On mobile: use opacity fade for intro sequence (swipe handles slides 2+)\n      // Pre-position slide 2 at center so it's ready to fade in\n      s2.style.transform = 'translateX(0)';\n      s2.style.transition = 'none';\n      // Fade out slide 1\n      s1.classList.add('intro-fade-out');\n      setTimeout(function() {\n        s1.classList.remove('active');\n        s1.classList.remove('intro-fade-out');\n        s1.style.transform = 'translateX(-' + window.innerWidth + 'px)';\n        current = 2;\n        s2.classList.add('active');\n        s2.classList.add('intro-fade-in');\n        updateNav();\n        // Clean up fade class after animation, then enable swipe\n        setTimeout(function() {\n          s2.classList.remove('intro-fade-in');\n          introComplete = true;\n          // Position slides 3–6 for swipe now that intro is done\n          if (isMobile()) { positionSlides(2, 0); positionMobileDots(); }\n        }, 700);\n        // Button appears 1000ms after slide 2 fades in\n        var btn = document.getElementById('see-whats-new-btn');\n        btn.style.opacity = '0';\n        setTimeout(function() { btn.style.opacity = '1'; }, 1000);\n      }, 700);\n    } else {\n      // Desktop: original fade via .active class + CSS transition\n      s1.classList.remove('active');\n      setTimeout(function() {\n        current = 2;\n        s2.classList.add('active');\n        updateNav();\n        var btn = document.getElementById('see-whats-new-btn');\n        btn.style.opacity = '0';\n        setTimeout(function() { btn.style.opacity = '1'; }, 1000);\n      }, 1200);\n    }\n  }, 2000);\n\n  // ── SWIPE (mobile only) ─────────────────────────────────────────────────\n  var introComplete = false; // gates swipe until after intro fade sequence\n\n  // Position slides without animation (during drag) — skips slides 1 & 2 (fade-only)\n  function positionSlides(activeIdx, dragOffset) {\n    dragOffset = dragOffset || 0;\n    for (var i = 3; i <= total; i++) {\n      var el = document.getElementById('slide-' + i);\n      var px = (i - activeIdx) * window.innerWidth + dragOffset;\n      el.style.transition = 'none';\n      el.style.transform = 'translateX(' + px + 'px)';\n    }\n  }\n\n  var touchStartX = 0;\n  var touchStartY = 0;\n  var isDragging = false;\n  var isVertical = null;\n  var SWIPE_THRESHOLD = 50; // px to commit a swipe\n\n  document.getElementById('app-root').addEventListener('touchstart', function(e) {\n    if (!isMobile() || !introComplete) return;\n    touchStartX = e.touches[0].clientX;\n    touchStartY = e.touches[0].clientY;\n    isDragging = false;\n    isVertical = null;\n    positionSlides(current, 0);\n  }, { passive: true });\n\n  document.getElementById('app-root').addEventListener('touchmove', function(e) {\n    if (!isMobile() || !introComplete) return;\n    var dx = e.touches[0].clientX - touchStartX;\n    var dy = e.touches[0].clientY - touchStartY;\n\n    // Determine axis on first meaningful move\n    if (isVertical === null && (Math.abs(dx) > 4 || Math.abs(dy) > 4)) {\n      isVertical = Math.abs(dy) > Math.abs(dx);\n    }\n    if (isVertical) return; // let page scroll naturally\n\n    isDragging = true;\n    e.preventDefault();\n\n    // Slide 2: no dragging allowed in either direction — slides 3-6 stay fully off-screen\n    if (current === 2) return;\n\n    // Clamp at edges: can't swipe back before slide 3, or past last slide\n    var clamped = dx;\n    if (current === 3 && dx > 0) clamped = dx * 0.2;\n    if (current === total && dx < 0) clamped = dx * 0.2;\n\n    positionSlides(current, clamped);\n  }, { passive: false });\n\n  document.getElementById('app-root').addEventListener('touchend', function(e) {\n    if (!isMobile() || !introComplete || !isDragging) return;\n    var dx = e.changedTouches[0].clientX - touchStartX;\n    var target = current;\n\n    if (dx < -SWIPE_THRESHOLD && current < total && current !== 2) {\n      target = current + 1;\n    } else if (dx > SWIPE_THRESHOLD && current > 3) {\n      target = current - 1;\n    }\n\n    if (target !== current) {\n      if (target >= 1 && target <= total) {\n        var prev = current;\n        current = target;\n        document.getElementById('slide-' + prev).classList.remove('active');\n        document.getElementById('slide-' + current).classList.add('active');\n        updateNav();\n        pauseVideo(prev);\n        restartVideo(current);\n        if (current === 2) {\n          var btn = document.getElementById('see-whats-new-btn');\n          btn.style.opacity = '0';\n          setTimeout(function() { btn.style.opacity = '1'; }, 800);\n        }\n      }\n    }\n    snapSlides(current);\n    isDragging = false;\n  }, { passive: true });\n\n  // Position the shared dots overlay so it sits the same distance below\n  // the video as the title sits above it (title margin-bottom: 20px)\n  function positionMobileDots() {\n    if (!isMobile()) return;\n    var videoWrap = document.querySelector('#slide-3 .feature-image-wrap');\n    var mobileDots = document.getElementById('mobile-dots');\n    if (!videoWrap || !mobileDots) return;\n    var rect = videoWrap.getBoundingClientRect();\n    var appRect = document.getElementById('app-root').getBoundingClientRect();\n    // top of dots = bottom of video + 40px (same gap as title margin-bottom)\n    mobileDots.style.top = (rect.bottom - appRect.top + 40) + 'px';\n  }\n\n  // Adjust mobile video containers to match each video's native aspect ratio\n  function adjustMobileVideoRatios() {\n    if (!isMobile()) return;\n    [3, 4, 5].forEach(function(slideNum) {\n      var p = vimeoPlayers[slideNum];\n      if (!p) return;\n      Promise.all([p.getVideoWidth(), p.getVideoHeight()]).then(function(dims) {\n        var w = dims[0], h = dims[1];\n        if (w && h) {\n          var ratio = (h / w) * 100;\n          var wrap = document.querySelector('#slide-' + slideNum + ' .feature-image-wrap');\n          if (wrap) {\n            wrap.style.setProperty('aspect-ratio', '1 / ' + (h / w), 'important');\n          }\n        }\n      }).catch(function() {});\n    });\n  }\n\n  // Init swipe positions when mobile\n  function initSwipe() {\n    if (isMobile()) {\n      positionSlides(current, 0);\n      positionMobileDots();\n    }\n  }\n  window.addEventListener('resize', function() {\n    if (isMobile()) {\n      positionSlides(current, 0);\n      adjustMobileVideoRatios();\n      setTimeout(positionMobileDots, 50);\n    } else {\n      // Reset transforms for desktop\n      for (var i = 1; i <= total; i++) {\n        document.getElementById('slide-' + i).style.transform = '';\n        document.getElementById('slide-' + i).style.transition = '';\n      }\n      // Reset video containers to default desktop ratio\n      [3, 4, 5].forEach(function(slideNum) {\n        var wrap = document.querySelector('#slide-' + slideNum + ' .feature-image-wrap');\n        if (wrap) wrap.style.removeProperty('aspect-ratio');\n      });\n    }\n  });\n  setTimeout(initSwipe, 100);\n  // ── END SWIPE ────────────────────────────────────────────────────────────\n\n  window.myop_init_interface = function(data) {\n    if (!data) return currentState;\n    currentState = data;\n    if (data.fonts && data.fonts.main) {\n      var f = data.fonts.main;\n      document.body.style.fontFamily = \"'\" + f.id + \"', 'Helvetica Neue', Arial, sans-serif\";\n    }\n  };\n\n  window.myop_cta_handler = function(action_id, payload) {};\n})();\n</script>\n\n<script id=\"myop_preview\">\n  window.myop_init_interface({\n    fonts: { main: { id: 'TT Norms Pro', weight: '300' } }\n  });\n</script>\n</body>\n</html>\n"
        },
        "id": "202cd3d5-b59b-450d-9789-278ff9940b26"
      }
    ]
