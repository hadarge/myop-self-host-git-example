    "name": "Myop live - Preview Content",
    "id": "a1e18256-ee7b-4ec1-99e2-27b265129310",
    "organizationId": "myop2000-0000-0000-0000-000000000000",
    "consume_variant": [
      {
        "name": "fixes",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Modal Content Component</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link\n        href=\"https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap\"\n        rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        :root {\n            --white: #FFFFFF;\n            --grey-90: #3E3D3E;\n            --grey-dark: #373539;\n            --purple-80: #9157F7;\n            --border-color: #E8E1EF;\n            --gradient-start: rgba(252, 251, 255, 1);\n            --gradient-end: rgba(255, 244, 244, 1);\n            --tooltip-bg: #FFF;\n            --tooltip-color: #0A090A;\n            --tooltip-border: #D3D1D5;\n        }\n\n        body {\n            font-family: 'DM Sans', sans-serif;\n        }\n\n        /* Loader Styles */\n        #loader-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            min-height: 200px;\n            gap: 12px;\n        }\n\n        .loader-spinner {\n            width: 32px;\n            height: 32px;\n            border: 3px solid var(--border-color);\n            border-top-color: var(--purple-80);\n            border-radius: 50%;\n            animation: spin 0.8s linear infinite;\n        }\n\n        @keyframes spin {\n            to {\n                transform: rotate(360deg);\n            }\n        }\n\n        .loader-text {\n            font-size: 14px;\n            color: var(--grey-dark);\n        }\n\n        /* App Root - hidden by default */\n        #app-root {\n            opacity: 0;\n            transition: opacity 0.3s ease;\n            display: none;\n        }\n\n        #app-root.visible {\n            opacity: 1;\n            display: flex;\n        }\n\n        /* Modal Content Container */\n        .modal-content {\n            display: flex;\n            flex-direction: column;\n            gap: 24px;\n            padding: 0 32px 32px 32px;\n            width: 100%;\n            height: 100%;\n            min-height: 400px;\n        }\n\n        /* Title Area */\n        .modal-title {\n            color: var(--grey-dark, #373539);\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 24px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 32px;\n        }\n\n        /* Dynamic Content Container */\n        .content-container {\n            flex: 1;\n            min-height: 200px;\n            border: 1px solid var(--border-color);\n            border-radius: 8px;\n            background: var(--white);\n            overflow: auto;\n        }\n\n        .content-slot {\n            width: 100%;\n            min-height: 100%;\n        }\n\n        /* Placeholder for when no content is provided */\n        .content-placeholder {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            width: 100%;\n            height: 100%;\n            min-height: 200px;\n            color: #999;\n            font-size: 14px;\n        }\n\n        /* Button Container */\n        .button-container {\n            display: flex;\n            gap: 8px;\n            align-items: center;\n        }\n\n        /* Base Button Styles */\n        .btn {\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            gap: 4px;\n            padding: 6px 12px;\n            border-radius: 6px;\n            border: none;\n            cursor: pointer;\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 18px;\n            color: var(--white, #FFF);\n            text-align: right;\n            transition: background-color 0.2s ease;\n        }\n\n        .btn:focus {\n            outline: none;\n        }\n\n        .btn:focus-visible {\n            outline: 2px solid var(--purple-80);\n            outline-offset: 2px;\n        }\n\n        .btn-icon {\n            width: 16px;\n            height: 16px;\n            flex-shrink: 0;\n        }\n\n        /* Edit with Claude Button */\n        .btn-claude {\n            background-color: var(--grey-90);\n        }\n\n        .btn-claude:hover {\n            background-color: #2e2d2e;\n        }\n\n        /* Myop Agent Button */\n        .btn-myop-agent {\n            background-image: linear-gradient(266deg, #FF5B14 -2.48%, #715EF0 109.11%);\n            background-color: var(--purple-80);\n        }\n\n        .btn-myop-agent:hover {\n            background-image: none;\n            cursor: not-allowed;\n        }\n\n        /* Tooltip Styles */\n        .myop-tooltip {\n            position: fixed;\n            background: var(--tooltip-bg);\n            color: var(--tooltip-color);\n            border-radius: 4px;\n            border: 1px solid var(--tooltip-border);\n            box-shadow: 0 4px 12px 0 rgba(0, 0, 0, 0.12);\n            display: inline-flex;\n            padding: 6px 8px;\n            align-items: center;\n            gap: 4px;\n            font-family: inherit;\n            font-size: 11px;\n            font-weight: 400;\n            line-height: 1.4;\n            white-space: normal;\n            max-width: 200px;\n            text-align: left;\n            z-index: 2147483647;\n            pointer-events: none;\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n\n        .myop-tooltip.show {\n            opacity: 1;\n        }\n\n        .myop-tooltip.nowrap {\n            white-space: nowrap;\n            max-width: none;\n        }\n    </style>\n</head>\n\n<body>\n    <!-- Loader Container -->\n    <div id=\"loader-container\">\n        <div class=\"loader-spinner\"></div>\n        <div class=\"loader-text\">Loading...</div>\n    </div>\n\n    <!-- App Root -->\n    <div id=\"app-root\">\n        <div class=\"modal-content\">\n            <h1 class=\"modal-title\" id=\"modal-title\">Top area</h1>\n\n            <div class=\"content-container\">\n                <div class=\"content-slot\" id=\"content-slot\">\n                    <div class=\"content-placeholder\" id=\"content-placeholder\">\n                        Component will be rendered here\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"button-container\">\n                <button type=\"button\" class=\"btn btn-claude\" id=\"btn-claude\">\n                <svg class=\"btn-icon\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <g clip-path=\"url(#clip0_claude)\">\n                        <path d=\"M3.13933 10.6367L6.286 8.872L6.33933 8.71867L6.286 8.63333H6.13333L5.60667 8.60133L3.808 8.55267L2.24867 8.488L0.738 8.40667L0.357333 8.326L0 7.856L0.0366667 7.62133L0.356667 7.40733L0.814 7.44733L1.82733 7.516L3.346 7.62133L4.44733 7.686L6.08 7.856H6.33933L6.376 7.75133L6.28667 7.686L6.218 7.62133L4.646 6.55733L2.94467 5.432L2.054 4.784L1.57133 4.45667L1.32867 4.14867L1.22333 3.47667L1.66067 2.99533L2.248 3.03533L2.398 3.076L2.99333 3.53333L4.26533 4.51733L5.926 5.73933L6.16933 5.942L6.266 5.87333L6.27867 5.82467L6.16933 5.642L5.266 4.01133L4.302 2.35133L3.87267 1.66333L3.75933 1.25067C3.71615 1.09217 3.69286 0.928916 3.69 0.764667L4.18867 0.0893333L4.464 0L5.128 0.0893333L5.408 0.332L5.82133 1.27467L6.48933 2.76067L7.526 4.78067L7.83 5.37933L7.992 5.934L8.05267 6.104H8.158V6.00667L8.24333 4.86933L8.40133 3.47267L8.55467 1.676L8.608 1.16933L8.85867 0.562667L9.35667 0.234667L9.746 0.421333L10.066 0.878L10.0213 1.174L9.83067 2.408L9.458 4.34333L9.21533 5.638H9.35667L9.51867 5.47667L10.1753 4.606L11.2767 3.23L11.7633 2.68333L12.33 2.08067L12.6947 1.79333H13.3833L13.89 2.546L13.6633 3.32333L12.954 4.22133L12.3667 4.98267L11.524 6.116L10.9973 7.02267L11.046 7.096L11.1713 7.08267L13.0753 6.67867L14.104 6.492L15.3313 6.282L15.8867 6.54067L15.9473 6.804L15.7287 7.342L14.416 7.666L12.8767 7.974L10.584 8.516L10.556 8.536L10.5887 8.57667L11.6213 8.674L12.0627 8.698H13.144L15.1573 8.848L15.684 9.196L16 9.62133L15.9473 9.94467L15.1373 10.358L14.044 10.0987L11.4913 9.492L10.6167 9.27267H10.4953V9.346L11.224 10.058L12.5613 11.2647L14.234 12.818L14.3187 13.2033L14.104 13.5067L13.8773 13.474L12.4073 12.3693L11.84 11.8713L10.556 10.7913H10.4707V10.9047L10.7667 11.3373L12.33 13.6847L12.4113 14.4047L12.298 14.64L11.8927 14.782L11.4473 14.7007L10.5313 13.4173L9.588 11.9727L8.826 10.6773L8.73267 10.7307L8.28333 15.5667L8.07267 15.8133L7.58667 16L7.182 15.6927L6.96733 15.1947L7.182 14.2107L7.44133 12.928L7.65133 11.908L7.842 10.6413L7.95533 10.22L7.94733 10.192L7.854 10.204L6.898 11.5153L5.44467 13.4787L4.294 14.7087L4.018 14.818L3.54 14.5713L3.58467 14.13L3.852 13.7373L5.444 11.7133L6.404 10.4587L7.024 9.73467L7.02 9.62933H6.98333L2.75467 12.3733L2.00133 12.4707L1.67667 12.1667L1.71733 11.6693L1.87133 11.5073L3.14333 10.6327L3.13933 10.6367Z\" fill=\"white\"/>\n                    </g>\n                    <defs>\n                        <clipPath id=\"clip0_claude\">\n                            <rect width=\"16\" height=\"16\" fill=\"white\"/>\n                        </clipPath>\n                    </defs>\n                </svg>\n                Edit with Claude\n            </button>\n                <button type=\"button\" class=\"btn btn-myop-agent\" id=\"btn-myop-agent\" data-tooltip=\"Coming soon!\">\n                <svg class=\"btn-icon\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <g clip-path=\"url(#clip0_myop)\">\n                        <path d=\"M5 10C5.65661 10 6.30679 9.87067 6.91342 9.6194C7.52005 9.36812 8.07124 8.99983 8.53553 8.53553C8.99983 8.07124 9.36812 7.52005 9.6194 6.91342C9.87067 6.30679 10 5.65661 10 5C10 6.32608 10.5268 7.59785 11.4645 8.53553C12.4021 9.47322 13.6739 10 15 10C13.6739 10 12.4021 10.5268 11.4645 11.4645C10.5268 12.4021 10 13.6739 10 15C10 14.3434 9.87067 13.6932 9.6194 13.0866C9.36812 12.48 8.99983 11.9288 8.53553 11.4645C8.07124 11.0002 7.52005 10.6319 6.91342 10.3806C6.30679 10.1293 5.65661 10 5 10Z\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                        <path d=\"M1 4C1.79565 4 2.55871 3.68393 3.12132 3.12132C3.68393 2.55871 4 1.79565 4 1C4 1.79565 4.31607 2.55871 4.87868 3.12132C5.44129 3.68393 6.20435 4 7 4C6.20435 4 5.44129 4.31607 4.87868 4.87868C4.31607 5.44129 4 6.20435 4 7C4 6.20435 3.68393 5.44129 3.12132 4.87868C2.55871 4.31607 1.79565 4 1 4Z\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                        <circle cx=\"3\" cy=\"13\" r=\"1\" stroke=\"white\"/>\n                    </g>\n                    <defs>\n                        <clipPath id=\"clip0_myop\">\n                            <rect width=\"16\" height=\"16\" fill=\"white\"/>\n                        </clipPath>\n                    </defs>\n                </svg>\n                Myop agent\n            </button>\n            </div>\n        </div>\n    </div>\n\n    <!-- Preview Script -->\n    <script id=\"myop_preview\">\n        setTimeout(() => {\n        // Mock table content for preview\n        const mockTableHTML = `\n            <style>\n                .mock-table {\n                    width: 100%;\n                    border-collapse: collapse;\n                    font-family: 'DM Sans', sans-serif;\n                    font-size: 14px;\n                }\n                .mock-table th {\n                    text-align: left;\n                    padding: 16px 20px;\n                    color: #6A696A;\n                    font-weight: 400;\n                    font-size: 12px;\n                    border-bottom: 1px solid #E8E1EF;\n                    background: transparent;\n                }\n                .mock-table td {\n                    padding: 16px 20px;\n                    color: #373539;\n                    border-bottom: 1px solid #F0EDF3;\n                }\n                .mock-table tr:last-child td {\n                    border-bottom: none;\n                }\n                .member-cell {\n                    display: flex;\n                    align-items: center;\n                    gap: 12px;\n                }\n                .avatar {\n                    width: 32px;\n                    height: 32px;\n                    border-radius: 50%;\n                    display: flex;\n                    align-items: center;\n                    justify-content: center;\n                    color: white;\n                    font-size: 12px;\n                    font-weight: 500;\n                }\n                .skill-tag {\n                    display: inline-block;\n                    padding: 4px 8px;\n                    border-radius: 4px;\n                    border: 1px solid #E8E1EF;\n                    font-size: 12px;\n                    color: #373539;\n                    margin-right: 4px;\n                    margin-bottom: 4px;\n                    background: white;\n                }\n                .skills-cell {\n                    max-width: 280px;\n                }\n            </style>\n            <table class=\"mock-table\">\n                <thead>\n                    <tr>\n                        <th>Member</th>\n                        <th>Title</th>\n                        <th>Location</th>\n                        <th>Tenure</th>\n                        <th>Experience</th>\n                        <th>Skills</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>\n                            <div class=\"member-cell\">\n                                <div class=\"avatar\" style=\"background: #F59E0B;\">AR</div>\n                                <span>Alex Rivera</span>\n                            </div>\n                        </td>\n                        <td>Design Director</td>\n                        <td>San Francisco, CA</td>\n                        <td>5.2y</td>\n                        <td>12y</td>\n                        <td class=\"skills-cell\">\n                            <span class=\"skill-tag\">Design Leadership</span>\n                            <span class=\"skill-tag\">Strategy</span>\n                            <span class=\"skill-tag\">Team Management</span>\n                        </td>\n                    </tr>\n                    <tr>\n                        <td>\n                            <div class=\"member-cell\">\n                                <div class=\"avatar\" style=\"background: #8B5CF6;\">JP</div>\n                                <span>Jamie Park</span>\n                            </div>\n                        </td>\n                        <td>Product Designer</td>\n                        <td>Seattle, WA</td>\n                        <td>1.5y</td>\n                        <td>3y</td>\n                        <td class=\"skills-cell\">\n                            <span class=\"skill-tag\">UI Design</span>\n                            <span class=\"skill-tag\">Mobile Design</span>\n                            <span class=\"skill-tag\">Prototyping</span>\n                        </td>\n                    </tr>\n                    <tr>\n                        <td>\n                            <div class=\"member-cell\">\n                                <div class=\"avatar\" style=\"background: #10B981;\">SF</div>\n                                <span>Sam Foster</span>\n                            </div>\n                        </td>\n                        <td>UX Researcher</td>\n                        <td>Austin, TX</td>\n                        <td>2.1y</td>\n                        <td>4y</td>\n                        <td class=\"skills-cell\">\n                            <span class=\"skill-tag\">User Research</span>\n                            <span class=\"skill-tag\">Data Analysis</span>\n                            <span class=\"skill-tag\">Usability Testing</span>\n                        </td>\n                    </tr>\n                    <tr>\n                        <td>\n                            <div class=\"member-cell\">\n                                <div class=\"avatar\" style=\"background: #EF4444;\">RK</div>\n                                <span>Riley Kim</span>\n                            </div>\n                        </td>\n                        <td>Senior Product Designer</td>\n                        <td>New York, NY</td>\n                        <td>3.5y</td>\n                        <td>7y</td>\n                        <td class=\"skills-cell\">\n                            <span class=\"skill-tag\">Product Design</span>\n                            <span class=\"skill-tag\">Design Systems</span>\n                            <span class=\"skill-tag\">Accessibility</span>\n                        </td>\n                    </tr>\n                    <tr>\n                        <td>\n                            <div class=\"member-cell\">\n                                <div class=\"avatar\" style=\"background: #14B8A6;\">TB</div>\n                                <span>Taylor Brooks</span>\n                            </div>\n                        </td>\n                        <td>Senior UX Designer</td>\n                        <td>Remote</td>\n                        <td>2.3y</td>\n                        <td>5.5y</td>\n                        <td class=\"skills-cell\">\n                            <span class=\"skill-tag\">UX Design</span>\n                            <span class=\"skill-tag\">Information Architecture</span>\n                            <span class=\"skill-tag\">Wireframing</span>\n                        </td>\n                    </tr>\n                </tbody>\n            </table>\n        `;\n\n        // Initialize component with title and content from host\n        window.myop_init_interface({\n            title: \"Team Members\",\n            content: mockTableHTML\n        });\n    }, 500);\n    </script>\n\n    <script>\n        (function() {\n        'use strict';\n\n        // ==========================================\n        // Tooltip Class\n        // ==========================================\n        class Tooltip {\n            constructor(options = {}) {\n                this.options = {\n                    showDelay: options.showDelay ?? 500,\n                    hideDelay: options.hideDelay ?? 4000,\n                    position: options.position ?? 'top',\n                    containerClass: options.containerClass ?? 'myop-tooltip',\n                    ...options\n                };\n                this.tooltipEl = null;\n                this.tooltipTimeout = null;\n                this.tooltipShowDelay = null;\n                this.registeredElements = new Set();\n                this._createTooltipElement();\n            }\n\n            _createTooltipElement() {\n                if (document.getElementById('myop-tooltip-container')) {\n                    this.tooltipEl = document.getElementById('myop-tooltip-container');\n                    return;\n                }\n                this.tooltipEl = document.createElement('div');\n                this.tooltipEl.id = 'myop-tooltip-container';\n                this.tooltipEl.className = this.options.containerClass;\n                document.body.appendChild(this.tooltipEl);\n            }\n\n            show(element, options = {}) {\n                const tooltipText = element.getAttribute('data-tooltip');\n                if (!tooltipText) return;\n\n                const shouldShow = options.shouldShow ?? (() => true);\n                if (!shouldShow(element)) return;\n\n                this._clearShowDelay();\n\n                const showDelay = options.showDelay ?? this.options.showDelay;\n                const hideDelay = options.hideDelay ?? this.options.hideDelay;\n                const position = options.position ?? this.options.position;\n                const nowrap = options.nowrap ?? true;\n\n                this.tooltipShowDelay = setTimeout(() => {\n                    const rect = element.getBoundingClientRect();\n                    this.tooltipEl.textContent = tooltipText;\n                    this._positionTooltip(rect, position);\n                    this.tooltipEl.classList.toggle('nowrap', nowrap);\n                    this.tooltipEl.classList.add('show');\n\n                    if (hideDelay > 0) {\n                        this._clearHideTimeout();\n                        this.tooltipTimeout = setTimeout(() => this.hide(), hideDelay);\n                    }\n                }, showDelay);\n            }\n\n            _positionTooltip(rect, position) {\n                const gap = 8;\n                switch (position) {\n                    case 'top':\n                        this.tooltipEl.style.left = rect.left + (rect.width / 2) + 'px';\n                        this.tooltipEl.style.top = (rect.top - gap) + 'px';\n                        this.tooltipEl.style.transform = 'translateX(-50%) translateY(-100%)';\n                        break;\n                    case 'left':\n                        this.tooltipEl.style.left = (rect.left - gap) + 'px';\n                        this.tooltipEl.style.top = rect.top + (rect.height / 2) + 'px';\n                        this.tooltipEl.style.transform = 'translateX(-100%) translateY(-50%)';\n                        break;\n                    case 'right':\n                        this.tooltipEl.style.left = (rect.right + gap) + 'px';\n                        this.tooltipEl.style.top = rect.top + (rect.height / 2) + 'px';\n                        this.tooltipEl.style.transform = 'translateY(-50%)';\n                        break;\n                    default: // bottom\n                        this.tooltipEl.style.left = rect.left + (rect.width / 2) + 'px';\n                        this.tooltipEl.style.top = (rect.bottom + gap) + 'px';\n                        this.tooltipEl.style.transform = 'translateX(-50%)';\n                }\n            }\n\n            hide() {\n                this._clearShowDelay();\n                this.tooltipEl.classList.remove('show');\n                this._clearHideTimeout();\n            }\n\n            _clearShowDelay() {\n                if (this.tooltipShowDelay) {\n                    clearTimeout(this.tooltipShowDelay);\n                    this.tooltipShowDelay = null;\n                }\n            }\n\n            _clearHideTimeout() {\n                if (this.tooltipTimeout) {\n                    clearTimeout(this.tooltipTimeout);\n                    this.tooltipTimeout = null;\n                }\n            }\n\n            register(element, options = {}) {\n                if (this.registeredElements.has(element)) return;\n\n                const showHandler = () => this.show(element, options);\n                const hideHandler = () => this.hide();\n\n                element.addEventListener('mouseenter', showHandler);\n                element.addEventListener('mouseleave', hideHandler);\n                element.addEventListener('click', hideHandler);\n\n                element._tooltipHandlers = { showHandler, hideHandler };\n                this.registeredElements.add(element);\n            }\n\n            unregister(element) {\n                if (!this.registeredElements.has(element)) return;\n\n                const handlers = element._tooltipHandlers;\n                if (handlers) {\n                    element.removeEventListener('mouseenter', handlers.showHandler);\n                    element.removeEventListener('mouseleave', handlers.hideHandler);\n                    element.removeEventListener('click', handlers.hideHandler);\n                    delete element._tooltipHandlers;\n                }\n                this.registeredElements.delete(element);\n            }\n\n            destroy() {\n                this.registeredElements.forEach(el => this.unregister(el));\n                this.tooltipEl?.remove();\n                this._clearShowDelay();\n                this._clearHideTimeout();\n            }\n        }\n\n        // ==========================================\n        // Private State\n        // ==========================================\n        let isInitialized = false;\n        let tooltip = null;\n        let currentConfig = {\n            title: 'Top area',\n            content: null\n        };\n\n        // DOM References\n        const loaderContainer = document.getElementById('loader-container');\n        const appRoot = document.getElementById('app-root');\n        const modalTitle = document.getElementById('modal-title');\n        const contentSlot = document.getElementById('content-slot');\n        const contentPlaceholder = document.getElementById('content-placeholder');\n        const btnClaude = document.getElementById('btn-claude');\n        const btnMyopAgent = document.getElementById('btn-myop-agent');\n\n        // ==========================================\n        // Private Functions\n        // ==========================================\n        function hideLoader() {\n            loaderContainer.style.display = 'none';\n            appRoot.classList.add('visible');\n        }\n\n        function showLoader() {\n            loaderContainer.style.display = 'flex';\n            appRoot.classList.remove('visible');\n        }\n\n        function updateTitle(title) {\n            if (title && modalTitle) {\n                modalTitle.textContent = title;\n                currentConfig.title = title;\n            }\n        }\n\n        function updateContent(content) {\n            if (content && contentSlot) {\n                // Hide placeholder\n                if (contentPlaceholder) {\n                    contentPlaceholder.style.display = 'none';\n                }\n                // Render content (can be HTML string)\n                contentSlot.innerHTML = content;\n                currentConfig.content = content;\n            }\n        }\n\n        function initializeComponent(config) {\n            // Update configuration\n            if (config.title) {\n                updateTitle(config.title);\n            }\n\n            // Update content if provided\n            if (config.content) {\n                updateContent(config.content);\n            }\n\n            // Initialize tooltip for Myop agent button\n            if (!tooltip) {\n                tooltip = new Tooltip({\n                    showDelay: 300,\n                    hideDelay: 3000,\n                    position: 'top'\n                });\n            }\n\n            // Register tooltip on Myop agent button\n            tooltip.register(btnMyopAgent, {\n                position: 'top',\n                nowrap: true\n            });\n\n            // Attach event listeners (only once)\n            if (!isInitialized) {\n                btnClaude.addEventListener('click', () => {\n                    if (typeof window.myop_cta_handler === 'function') {\n                        window.myop_cta_handler('edit_with_claude_clicked', {});\n                    }\n                });\n\n                btnMyopAgent.addEventListener('click', () => {\n                    if (typeof window.myop_cta_handler === 'function') {\n                        window.myop_cta_handler('myop_agent_clicked', {});\n                    }\n                });\n\n                isInitialized = true;\n            }\n\n            // Hide loader and show app\n            hideLoader();\n        }\n\n        // ==========================================\n        // Public API\n        // ==========================================\n\n        /**\n         * Initialize or update the component with configuration\n         * @param {Object} data - Configuration object\n         * @param {string} data.title - The modal title text\n         * @param {string} data.content - HTML content to render in the content slot\n         * @param {string} data.action - Optional action type ('setTitle', 'setContent', 'getConfig', 'getContentSlot')\n         * @param {any} data.payload - Optional payload for the action\n         * @returns {Object|HTMLElement|undefined} - Returns config, content slot element, or undefined\n         */\n        window.myop_init_interface = function(data) {\n            // Getter: return current configuration\n            if (!data) {\n                return { ...currentConfig };\n            }\n\n            // Handle action-based calls\n            if (data.action) {\n                switch (data.action) {\n                    case 'setTitle':\n                        updateTitle(data.payload);\n                        return;\n                    case 'setContent':\n                        updateContent(data.payload);\n                        return;\n                    case 'getConfig':\n                        return { ...currentConfig };\n                    case 'getContentSlot':\n                        // Return the content slot element for the host to render into\n                        return contentSlot;\n                    default:\n                        console.warn('Unknown action:', data.action);\n                        return;\n                }\n            }\n\n            // Standard initialization\n            initializeComponent(data);\n        };\n\n        /**\n         * Handle CTA (Call To Action) events from the component\n         * This is set by the host application\n         * @param {string} action_id - The action identifier\n         * @param {Object} payload - The action payload\n         */\n        window.myop_cta_handler = window.myop_cta_handler || function(action_id, payload) {\n            console.log('CTA Handler (default):', action_id, payload);\n        };\n\n    })();\n    </script>\n</body>\n\n</html>"
