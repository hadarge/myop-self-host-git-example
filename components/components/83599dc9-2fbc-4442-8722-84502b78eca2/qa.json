        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Edit with Claude Modal</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap\"\n        rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;\n            background: #fff;\n            min-height: 100vh;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            padding: 20px;\n        }\n\n        .modal-content {\n            width: 100%;\n            max-width: 610px;\n            background: #fff;\n        }\n\n        .modal-title {\n            overflow: hidden;\n            color: var(--Black, #0A090A);\n            text-overflow: ellipsis;\n            font-family: \"DM Sans\";\n            font-size: 19px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 24px;\n            margin-bottom: 16px;\n        }\n\n        /* Carousel Styles */\n        .carousel-container {\n            position: relative;\n            overflow: hidden;\n        }\n\n        .carousel-track {\n            display: flex;\n            transition: transform 0.4s ease;\n        }\n\n        .carousel-slide {\n            min-width: 100%;\n            padding: 0;\n        }\n\n        .slide-content {\n            min-height: 240px;\n        }\n\n        .video-placeholder {\n            width: 100%;\n            aspect-ratio: 16 / 9;\n            background: #f5f5f0;\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            margin-bottom: 16px;\n            border: 1px solid #e0e0db;\n        }\n\n        .video-placeholder svg {\n            width: 48px;\n            height: 48px;\n            color: #9747FF;\n            opacity: 0.6;\n        }\n\n        .video-container {\n            width: 100%;\n            aspect-ratio: 16 / 9;\n            background: #000;\n            border-radius: 8px;\n            overflow: hidden;\n            margin-bottom: 16px;\n            position: relative;\n        }\n\n        .video-container video {\n            width: 100%;\n            height: 100%;\n            object-fit: contain;\n        }\n\n        .step-title {\n            color: var(--Black, #0A090A);\n            font-family: \"DM Sans\";\n            font-size: 16px;\n            font-weight: 500;\n            line-height: 24px;\n            margin-bottom: 8px;\n        }\n\n        .step-text {\n            color: var(--Grey-dark, #373539);\n            font-family: \"DM Sans\";\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 300;\n            line-height: 24px;\n            letter-spacing: -0.16px;\n            margin-bottom: 6px;\n        }\n\n        .step-text:last-of-type {\n            margin-bottom: 0;\n        }\n\n        .mcp-link {\n            display: inline-flex;\n            align-items: center;\n            gap: 6px;\n            background: #f5f5f0;\n            border: 1px solid #e0e0db;\n            border-radius: 6px;\n            padding: 6px 10px;\n            font-family: \"DM Sans\";\n            font-size: 14px;\n            font-weight: 400;\n            color: #373539;\n            cursor: pointer;\n            transition: background 0.2s;\n            margin: 4px 0 6px 0;\n            position: relative;\n        }\n\n        .mcp-link:hover {\n            background: #eaeae5;\n        }\n\n        .mcp-link svg {\n            flex-shrink: 0;\n        }\n\n        .quote-text {\n            color: var(--Grey-dark, #373539);\n            font-family: \"DM Sans\";\n            font-size: 16px;\n            font-style: italic;\n            font-weight: 400;\n            line-height: 24px;\n            letter-spacing: -0.16px;\n            margin: 8px 0;\n        }\n\n        /* Footer with navigation and button */\n        .carousel-footer {\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            margin-top: 24px;\n            padding-top: 20px;\n            border-top: 1px solid #E5E5E5;\n        }\n\n        .carousel-nav {\n            display: flex;\n            align-items: center;\n            gap: 12px;\n        }\n\n        .nav-arrow {\n            width: 32px;\n            height: 32px;\n            border: 1px solid #D3D1D5;\n            background: transparent;\n            border-radius: 6px;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            transition: all 0.2s;\n        }\n\n        .nav-arrow:hover:not(:disabled) {\n            background: #F4F0FF;\n            border-color: #D3D1D5;\n        }\n\n        .nav-arrow:disabled {\n            opacity: 0.3;\n            cursor: not-allowed;\n        }\n\n        .nav-arrow svg {\n            width: 16px;\n            height: 16px;\n            color: #373539;\n        }\n\n        .step-counter {\n            font-family: \"DM Sans\";\n            font-size: 14px;\n            font-weight: 400;\n            color: #373539;\n        }\n\n        .open-claude-btn {\n            display: inline-flex;\n            align-items: center;\n            gap: 8px;\n            background: #111;\n            color: var(--White, #FFF);\n            border: none;\n            border-radius: 6px;\n            padding: 0 16px;\n            height: 30px;\n            font-family: \"DM Sans\";\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 30px;\n            cursor: pointer;\n            transition: background 0.2s;\n        }\n\n        .open-claude-btn:hover {\n            background: #9747FF;\n        }\n\n        .claude-icon {\n            width: 16px;\n            height: 16px;\n            flex-shrink: 0;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"modal-content\">\n        <h2 class=\"modal-title\" id=\"modalTitle\">Edit with Claude Pro</h2>\n\n        <!-- Claude + Screenshot -->\n        <div class=\"tab-content active\" id=\"tab-claude-screenshot\">\n            <div class=\"carousel-container\">\n                <div class=\"carousel-track\" data-carousel=\"claude-screenshot\">\n                    <!-- Step 1 -->\n                    <div class=\"carousel-slide\">\n                        <div class=\"slide-content\">\n                            <div class=\"video-container\" id=\"videoContainer2\">\n                                <video id=\"stepVideo2\" controls playsinline>\n                                    <source\n                                        src=\"https://user-components-assets.s3.eu-south-1.amazonaws.com/myop2/1765750849516-MCPguide.mp4\"\n                                        type=\"video/mp4\">\n                                </video>\n                            </div>\n                            <h3 class=\"step-title\">Step 1: Connect Claude to Myop</h3>\n                            <p class=\"step-text\">Install the Myop MCP connector so Claude can talk directly to Myop.\n                            </p>\n                            <button class=\"mcp-link copy-link-btn\" data-url=\"https://mcp.myop.dev/mcp\">\n                                        https://mcp.myop.dev/mcp\n                                        <svg class=\"copy-icon\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                                            <rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\" ry=\"2\"></rect>\n                                            <path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"></path>\n                                        </svg>\n                                        <svg class=\"check-icon\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"display: none;\">\n                                            <polyline points=\"20 6 9 17 4 12\"></polyline>\n                                        </svg>\n                                    </button>\n                        </div>\n                    </div>\n\n                    <!-- Step 2 -->\n                    <div class=\"carousel-slide\">\n                        <div class=\"slide-content\">\n                            <div class=\"video-placeholder\">\n                                <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                                    <path d=\"M8 5v14l11-7z\" />\n                                </svg>\n                            </div>\n                            <h3 class=\"step-title\">Step 2: Enter the prompt in Claude</h3>\n                            <p class=\"step-text\">In Claude, enter the following prompt:</p>\n                            <p class=\"step-text\">\n                                <em>Edit Myop <span id=\"componentNameDisplay\">My Component</span></em> + explain\n                                what you want to change, in your own words.</p>\n                        </div>\n                    </div>\n\n                    <!-- Step 3 -->\n                    <div class=\"carousel-slide\">\n                        <div class=\"slide-content\">\n                            <div class=\"video-placeholder\">\n                                <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                                    <path d=\"M8 5v14l11-7z\" />\n                                </svg>\n                            </div>\n                            <h3 class=\"step-title\">Step 3: Save and Test in Myop</h3>\n                            <p class=\"step-text\">When the component looks right, type:\n                                <em>\"Create a new variant in Myop.\"</em></p>\n                            <p class=\"step-text\">Claude and Myop handle the handoff. In Myop, you can test different\n                                scenarios and validate data flow.</p>\n                        </div>\n                    </div>\n\n                    <!-- Step 4 -->\n                    <div class=\"carousel-slide\">\n                        <div class=\"slide-content\">\n                            <div class=\"video-placeholder\">\n                                <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                                    <path d=\"M8 5v14l11-7z\" />\n                                </svg>\n                            </div>\n                            <h3 class=\"step-title\">Step 4: Publish</h3>\n                            <p class=\"step-text\">When you're ready, click\n                                <strong style=\"font-weight: 600;\">Publish</strong> to see the update live.</p>\n                            <p class=\"step-text\">From there, you can share it with other people, keep editing, or\n                                move on to another area in the playground.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"carousel-footer\">\n            <button class=\"open-claude-btn\" id=\"openClaudeBtn\">\n                        <svg class=\"claude-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                            <g clip-path=\"url(#clip0_1450_21130)\">\n                                <path d=\"M3.13933 10.6367L6.286 8.872L6.33933 8.71867L6.286 8.63333H6.13333L5.60667 8.60133L3.808 8.55267L2.24867 8.488L0.738 8.40667L0.357333 8.326L0 7.856L0.0366667 7.62133L0.356667 7.40733L0.814 7.44733L1.82733 7.516L3.346 7.62133L4.44733 7.686L6.08 7.856H6.33933L6.376 7.75133L6.28667 7.686L6.218 7.62133L4.646 6.55733L2.94467 5.432L2.054 4.784L1.57133 4.45667L1.32867 4.14867L1.22333 3.47667L1.66067 2.99533L2.248 3.03533L2.398 3.076L2.99333 3.53333L4.26533 4.51733L5.926 5.73933L6.16933 5.942L6.266 5.87333L6.27867 5.82467L6.16933 5.642L5.266 4.01133L4.302 2.35133L3.87267 1.66333L3.75933 1.25067C3.71615 1.09217 3.69286 0.928916 3.69 0.764667L4.18867 0.0893333L4.464 0L5.128 0.0893333L5.408 0.332L5.82133 1.27467L6.48933 2.76067L7.526 4.78067L7.83 5.37933L7.992 5.934L8.05267 6.104H8.158V6.00667L8.24333 4.86933L8.40133 3.47267L8.55467 1.676L8.608 1.16933L8.85867 0.562667L9.35667 0.234667L9.746 0.421333L10.066 0.878L10.0213 1.174L9.83067 2.408L9.458 4.34333L9.21533 5.638H9.35667L9.51867 5.47667L10.1753 4.606L11.2767 3.23L11.7633 2.68333L12.33 2.08067L12.6947 1.79333H13.3833L13.89 2.546L13.6633 3.32333L12.954 4.22133L12.3667 4.98267L11.524 6.116L10.9973 7.02267L11.046 7.096L11.1713 7.08267L13.0753 6.67867L14.104 6.492L15.3313 6.282L15.8867 6.54067L15.9473 6.804L15.7287 7.342L14.416 7.666L12.8767 7.974L10.584 8.516L10.556 8.536L10.5887 8.57667L11.6213 8.674L12.0627 8.698H13.144L15.1573 8.848L15.684 9.196L16 9.62133L15.9473 9.94467L15.1373 10.358L14.044 10.0987L11.4913 9.492L10.6167 9.27267H10.4953V9.346L11.224 10.058L12.5613 11.2647L14.234 12.818L14.3187 13.2033L14.104 13.5067L13.8773 13.474L12.4073 12.3693L11.84 11.8713L10.556 10.7913H10.4707V10.9047L10.7667 11.3373L12.33 13.6847L12.4113 14.4047L12.298 14.64L11.8927 14.782L11.4473 14.7007L10.5313 13.4173L9.588 11.9727L8.826 10.6773L8.73267 10.7307L8.28333 15.5667L8.07267 15.8133L7.58667 16L7.182 15.6927L6.96733 15.1947L7.182 14.2107L7.44133 12.928L7.65133 11.908L7.842 10.6413L7.95533 10.22L7.94733 10.192L7.854 10.204L6.898 11.5153L5.44467 13.4787L4.294 14.7087L4.018 14.818L3.54 14.5713L3.58467 14.13L3.852 13.7373L5.444 11.7133L6.404 10.4587L7.024 9.73467L7.02 9.62933H6.98333L2.75467 12.3733L2.00133 12.4707L1.67667 12.1667L1.71733 11.6693L1.87133 11.5073L3.14333 10.6327L3.13933 10.6367Z\" fill=\"white\"/>\n                            </g>\n                            <defs>\n                                <clipPath id=\"clip0_1450_21130\">\n                                    <rect width=\"16\" height=\"16\" fill=\"white\"/>\n                                </clipPath>\n                            </defs>\n                        </svg>\n                        Open Claude\n                    </button>\n\n            <div class=\"carousel-nav\">\n                <button class=\"nav-arrow\" id=\"prevBtn\" aria-label=\"Previous step\">\n                            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M15.75 19.5L8.25 12l7.5-7.5\" />\n                            </svg>\n                        </button>\n                <span class=\"step-counter\" id=\"stepCounter\">1 / 4</span>\n                <button class=\"nav-arrow\" id=\"nextBtn\" aria-label=\"Next step\">\n                            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8.25 4.5l7.5 7.5-7.5 7.5\" />\n                            </svg>\n                        </button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        (function() {\n            let currentSlide = 0;\n            const totalSlides = 4;\n\n            function updateCarousel() {\n                const track = document.querySelector('.carousel-track');\n                const stepCounter = document.getElementById('stepCounter');\n\n                if (track) {\n                    track.style.transform = `translateX(-${currentSlide * 100}%)`;\n                }\n\n                stepCounter.textContent = `${currentSlide + 1} / ${totalSlides}`;\n            }\n\n            function nextSlide() {\n                currentSlide = (currentSlide + 1) % totalSlides;\n                updateCarousel();\n            }\n\n            function prevSlide() {\n                currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;\n                updateCarousel();\n            }\n\n            // Copy link button handlers\n            document.querySelectorAll('.copy-link-btn').forEach(btn => {\n                btn.addEventListener('click', function() {\n                    const url = this.dataset.url;\n                    navigator.clipboard.writeText(url).then(() => {\n                        const copyIcon = this.querySelector('.copy-icon');\n                        const checkIcon = this.querySelector('.check-icon');\n                        copyIcon.style.display = 'none';\n                        checkIcon.style.display = 'block';\n                        setTimeout(() => {\n                            copyIcon.style.display = 'block';\n                            checkIcon.style.display = 'none';\n                        }, 1500);\n                        window.myop_cta_handler('link_copied', { url: url });\n                    });\n                });\n            });\n\n            // Navigation buttons\n            document.getElementById('prevBtn').addEventListener('click', prevSlide);\n            document.getElementById('nextBtn').addEventListener('click', nextSlide);\n\n            // Open Claude button handler\n            document.getElementById('openClaudeBtn').addEventListener('click', function() {\n                window.myop_cta_handler('open_claude', {});\n            });\n\n            // Public API\n            window.myop_init_interface = function(data) {\n                if (data === undefined) {\n                    return { currentSlide, totalSlides };\n                }\n                // Update component name if provided\n                if (data?.componentName) {\n                    document.getElementById('componentNameDisplay').textContent = data.componentName;\n                }\n            };\n\n            window.myop_cta_handler = function(action_id, payload) {\n                console.log('CTA Handler:', action_id, payload);\n                // Host application will override this\n            };\n        })();\n    </script>\n</body>\n\n</html>\n"
        }
      }
