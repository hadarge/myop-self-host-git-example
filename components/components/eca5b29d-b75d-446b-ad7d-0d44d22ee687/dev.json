    "consume_variant": [
      {
        "name": "Version 17",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":350}'>\n\n    <script type=\"myop/types\">\n        // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    interface GalleryItem {\n        projectId: number;\n        projectName: string;\n        thumbUrl: string;\n        projectHeroUrl: string;\n        qrInviteUrl: string;\n        videoUrl: string;\n        createDate: string;\n        expiryDate: string;\n    }\n\n    interface FontConfig {\n        id: string;\n        family: string;\n        style?: string;\n        weight?: number;\n        url: string;\n    }\n\n    interface LangStrings {\n        phDashSocialVideo_title: string;\n        phDashSocialVideo_sharePreview: string;\n        phDashSocialVideo_noGalleries: string;\n        phDashSocialVideo_loading: string;\n        phDashSocialVideo_scanToShare?: string;\n    }\n\n    interface MyopInitData {\n        galleries: GalleryItem[];\n        lang: LangStrings;\n        fonts?: FontConfig[];\n    }\n\n    interface MyopCtaPayloads {\n        'share-preview-clicked': { projectId: number };\n        'size-requested': {\n            width?: number | null;\n            height?: number | null;\n            minWidth?: number | null;\n            maxWidth?: number | null;\n            minHeight?: number | null;\n            maxHeight?: number | null;\n            required?: boolean;\n        };\n    }\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <style>\n        * {\n            box-sizing: border-box;\n        }\n\n        :root {\n            --font_main_family: sans-serif;\n            --font_main_weight: 400;\n            --font_main_style: normal;\n        }\n\n        html,\n        body {\n            width: 100%;\n            height: fit-content;\n            margin: 0;\n            padding: 0;\n            overflow: hidden;\n        }\n\n        #app-root {\n            width: 100%;\n            background: #FFF;\n            display: flex;\n            flex-direction: column;\n            padding: 24px 24px 16px 24px;\n            font-family: var(--font_main_family), sans-serif;\n            font-weight: var(--font_main_weight);\n            font-style: var(--font_main_style);\n            border: 1px solid #DDDDD1;\n            border-radius: 8px;\n        }\n\n        #app-root:empty {\n            display: none;\n        }\n\n        .header-title {\n            color: #222;\n            font-feature-settings: 'liga' off, 'clig' off;\n            font-family: var(--font_main_family), sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 130%;\n            margin-bottom: 16px;\n            text-align: left;\n        }\n\n        .gallery-content {\n            display: flex;\n            flex-direction: column;\n            gap: 12px;\n            align-items: center;\n        }\n\n        .gallery-preview {\n            position: relative;\n            width: 100%;\n            aspect-ratio: 282 / 184;\n            cursor: pointer;\n            overflow: hidden;\n        }\n\n        .gallery-image-wrapper {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n        }\n\n        .gallery-image {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        /* Slide animation for gallery transitions */\n        @keyframes slideInFromRight {\n            from { transform: translateX(100%); opacity: 0; }\n            to { transform: translateX(0); opacity: 1; }\n        }\n\n        @keyframes slideInFromLeft {\n            from { transform: translateX(-100%); opacity: 0; }\n            to { transform: translateX(0); opacity: 1; }\n        }\n\n        .gallery-image-wrapper.slide-right {\n            animation: slideInFromRight 0.8s ease-out forwards;\n        }\n\n        .gallery-image-wrapper.slide-left {\n            animation: slideInFromLeft 0.8s ease-out forwards;\n        }\n\n        /* Also animate QR code */\n        .qr-code-wrapper.slide-right {\n            animation: slideInFromRight 0.8s ease-out forwards;\n        }\n\n        .qr-code-wrapper.slide-left {\n            animation: slideInFromLeft 0.8s ease-out forwards;\n        }\n\n        /* Animate gallery name */\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        .gallery-name.animate {\n            animation: fadeIn 0.6s ease-out forwards;\n        }\n\n        /* Dark overlay - hidden by default, shown on hover */\n        .gallery-overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(34, 34, 34, 0.64);\n            opacity: 0;\n            transition: opacity 0.2s ease;\n        }\n\n        .gallery-preview:hover .gallery-overlay {\n            opacity: 1;\n        }\n\n        /* Scan text - hidden by default, shown on hover */\n        .scan-text {\n            position: absolute;\n            top: 47px;\n            left: 24px;\n            transform: translateY(-50%);\n            color: #FFF;\n            font-feature-settings: 'liga' off, 'clig' off;\n            font-family: var(--font_main_family), sans-serif;\n            font-size: 18px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 130%;\n            white-space: nowrap;\n            opacity: 0;\n            transition: opacity 0.2s ease;\n        }\n\n        .gallery-preview:hover .scan-text {\n            opacity: 1;\n        }\n\n        /* QR Code - positioned at bottom right, changes size on hover */\n        .qr-code-wrapper {\n            position: absolute;\n            background: #FFF;\n            transition: all 0.2s ease;\n            /* Default state: smaller QR */\n            width: 77px;\n            height: 77px;\n            right: 0;\n            bottom: 0;\n        }\n\n        .gallery-preview:hover .qr-code-wrapper {\n            /* Hover state: larger QR */\n            width: 100px;\n            height: 100px;\n        }\n\n        .qr-code {\n            width: calc(100% - 4px);\n            height: calc(100% - 4px);\n            margin: 2px;\n            object-fit: contain;\n            display: block;\n        }\n\n        .navigation {\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            width: 100%;\n        }\n\n        .nav-button {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            width: 32px;\n            height: 32px;\n            flex-shrink: 0;\n            background: transparent;\n            border: none;\n            padding: 0;\n            cursor: pointer;\n            aspect-ratio: 1/1;\n            border-radius: 60px;\n            transition: background-color 0.2s;\n        }\n\n        .nav-button:hover {\n            background: #F2F2ED;\n        }\n\n        .nav-button.prev svg {\n            transform: rotate(180deg);\n        }\n\n        .gallery-name {\n            flex: 1;\n            color: #222;\n            text-align: center;\n            font-feature-settings: 'liga' off, 'clig' off;\n            font-family: var(--font_main_family), sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 130%;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n            padding: 0 12px;\n        }\n    </style>\n</head>\n\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n        (function() {\n        var currentState = null;\n        var currentIndex = 0;\n        var validGalleries = [];\n        var slideDirection = 'right'; // Track slide direction for animations\n        var lang = {\n            phDashSocialVideo_title: '',\n            phDashSocialVideo_sharePreview: '',\n            phDashSocialVideo_noGalleries: '',\n            phDashSocialVideo_loading: '',\n            phDashSocialVideo_scanToShare: 'Scan to share\\ngallery preview'\n        };\n\n        function isVideoExpired(expiryDate) {\n            if (!expiryDate) return true;\n            var expiry = new Date(expiryDate);\n            var now = new Date();\n            return expiry < now;\n        }\n\n        function filterValidGalleries(galleries) {\n            if (!galleries || !Array.isArray(galleries)) return [];\n            return galleries.filter(function(gallery) {\n                return !isVideoExpired(gallery.expiryDate);\n            });\n        }\n\n        function loadFonts(fonts) {\n            if (!fonts || !Array.isArray(fonts)) return;\n\n            fonts.forEach(function(font) {\n                if (font.url) {\n                    var link = document.createElement('link');\n                    link.rel = 'stylesheet';\n                    link.href = font.url;\n                    document.head.appendChild(link);\n                }\n\n                var varPrefix = '--font_' + font.id;\n                document.documentElement.style.setProperty(varPrefix + '_family', font.family);\n                if (font.weight !== undefined) {\n                    document.documentElement.style.setProperty(varPrefix + '_weight', font.weight);\n                }\n                if (font.style !== undefined) {\n                    document.documentElement.style.setProperty(varPrefix + '_style', font.style);\n                }\n            });\n        }\n\n        function buildHTML() {\n            if (validGalleries.length === 0) {\n                return '';\n            }\n\n            var gallery = validGalleries[currentIndex];\n\n            // Parse scan text for line breaks\n            var scanText = lang.phDashSocialVideo_scanToShare || 'Scan to share\\ngallery preview';\n            var scanLines = scanText.split('\\n');\n            var scanTextHtml = scanLines.map(function(line) { return escapeHtml(line); }).join('<br>');\n\n            var html = '<div class=\"header-title\">' + escapeHtml(lang.phDashSocialVideo_title) + '</div>';\n            html += '<div class=\"gallery-content\">';\n\n            // Gallery preview area with image, overlay, text and QR\n            html += '<div class=\"gallery-preview\" data-action=\"gallery-click\" data-project-id=\"' + gallery.projectId + '\">';\n\n            // Gallery image (using projectHeroUrl) - with slide animation class\n            var slideClass = validGalleries.length > 1 ? ' slide-' + slideDirection : '';\n            html += '<div class=\"gallery-image-wrapper' + slideClass + '\">';\n            html += '<img class=\"gallery-image\" src=\"' + escapeHtml(gallery.projectHeroUrl) + '\" alt=\"' + escapeHtml(gallery.projectName) + '\">';\n            html += '</div>';\n\n            // Dark overlay (shown on hover)\n            html += '<div class=\"gallery-overlay\"></div>';\n\n            // Scan text (shown on hover)\n            html += '<div class=\"scan-text\">' + scanTextHtml + '</div>';\n\n            // QR code (always visible, changes size on hover) - with slide animation\n            html += '<div class=\"qr-code-wrapper' + slideClass + '\">';\n            if (gallery.qrInviteUrl) {\n                html += '<img class=\"qr-code\" src=\"' + escapeHtml(gallery.qrInviteUrl) + '\" alt=\"QR Code\">';\n            }\n            html += '</div>';\n\n            html += '</div>';\n\n            // Navigation - only show arrows if more than one gallery\n            var showArrows = validGalleries.length > 1;\n            html += '<div class=\"navigation\">';\n            if (showArrows) {\n                html += '<button class=\"nav-button prev\" data-action=\"prev\">';\n                html += '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">';\n                html += '<path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M4.46967 1.53033C4.17678 1.23744 4.17678 0.762675 4.46967 0.469783C4.76256 0.176889 5.23732 0.176889 5.53022 0.469783L12.5302 7.46978C12.6709 7.61043 12.7499 7.80114 12.7499 8.00006C12.7499 8.19897 12.6709 8.38968 12.5302 8.53033L5.53022 15.5303C5.23732 15.8232 4.76256 15.8232 4.46967 15.5303C4.17678 15.2374 4.17678 14.7627 4.46967 14.4698L10.9394 8.00006L4.46967 1.53033Z\" fill=\"#222222\"/>';\n                html += '</svg>';\n                html += '</button>';\n            }\n            var animateClass = validGalleries.length > 1 ? ' animate' : '';\n            html += '<span class=\"gallery-name' + animateClass + '\">' + escapeHtml(gallery.projectName) + '</span>';\n            if (showArrows) {\n                html += '<button class=\"nav-button next\" data-action=\"next\">';\n                html += '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">';\n                html += '<path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M4.46967 1.53033C4.17678 1.23744 4.17678 0.762675 4.46967 0.469783C4.76256 0.176889 5.23732 0.176889 5.53022 0.469783L12.5302 7.46978C12.6709 7.61043 12.7499 7.80114 12.7499 8.00006C12.7499 8.19897 12.6709 8.38968 12.5302 8.53033L5.53022 15.5303C5.23732 15.8232 4.76256 15.8232 4.46967 15.5303C4.17678 15.2374 4.17678 14.7627 4.46967 14.4698L10.9394 8.00006L4.46967 1.53033Z\" fill=\"#222222\"/>';\n                html += '</svg>';\n                html += '</button>';\n            }\n            html += '</div>';\n\n            html += '</div>';\n\n            return html;\n        }\n\n        function escapeHtml(str) {\n            if (!str) return '';\n            return String(str)\n                .replace(/&/g, '&amp;')\n                .replace(/</g, '&lt;')\n                .replace(/>/g, '&gt;')\n                .replace(/\"/g, '&quot;')\n                .replace(/'/g, '&#039;');\n        }\n\n        function render() {\n            var container = document.getElementById('app-root');\n            var html = buildHTML();\n            container.innerHTML = html;\n            container.style.display = html === '' ? 'none' : '';\n        }\n\n        // Attach event listener once using event delegation\n        document.getElementById('app-root').addEventListener('click', function(e) {\n            var target = e.target.closest('[data-action]');\n            if (!target) return;\n\n            var action = target.getAttribute('data-action');\n            var projectId = target.getAttribute('data-project-id');\n\n            if (action === 'gallery-click' && projectId) {\n                window.myop_cta_handler('share-preview-clicked', { projectId: parseInt(projectId, 10) });\n            } else if (action === 'prev') {\n                slideDirection = 'left'; // Slide in from left when going back\n                currentIndex = (currentIndex - 1 + validGalleries.length) % validGalleries.length;\n                render();\n            } else if (action === 'next') {\n                slideDirection = 'right'; // Slide in from right when going forward\n                currentIndex = (currentIndex + 1) % validGalleries.length;\n                render();\n            }\n        });\n\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n\n            currentState = data;\n\n            if (data.lang) {\n                lang = Object.assign({}, lang, data.lang);\n            }\n\n            if (data.fonts) {\n                loadFonts(data.fonts);\n            }\n\n            validGalleries = filterValidGalleries(data.galleries);\n            currentIndex = 0;\n\n            render();\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n            console.log('CTA:', action_id, payload);\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            lang: {\n                phDashSocialVideo_title: \"Share gallery video\",\n                phDashSocialVideo_sharePreview: \"Scan to share gallery preview video\",\n                phDashSocialVideo_noGalleries: \"No galleries available\",\n                phDashSocialVideo_loading: \"Loading...\",\n                phDashSocialVideo_scanToShare: \"Scan to share gallery\\npreview video\"\n            },\n            galleries: [\n                {\n                    projectId: 23423,\n                    projectName: \"Annie & Alexander\",\n                    thumbUrl: \"https://images.unsplash.com/photo-1519741497674-611481863552?w=300&h=300&fit=crop\",\n                    projectHeroUrl: \"https://images.unsplash.com/photo-1519741497674-611481863552?w=600&h=400&fit=crop\",\n                    qrInviteUrl: \"https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://example.com/gallery/23423\",\n                    videoUrl: \"https://example.com/video1.mp4\",\n                    createDate: \"2025-10-10T00:00:00Z\",\n                    expiryDate: \"2027-10-10T00:00:00Z\"\n                },\n                {\n                    projectId: 23424,\n                    projectName: \"Danney and Sarah wedding\",\n                    thumbUrl: \"https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=300&h=300&fit=crop\",\n                    projectHeroUrl: \"https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=600&h=400&fit=crop\",\n                    qrInviteUrl: \"https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://example.com/gallery/23424\",\n                    videoUrl: \"https://example.com/video2.mp4\",\n                    createDate: \"2025-09-15T00:00:00Z\",\n                    expiryDate: \"2027-09-15T00:00:00Z\"\n                },\n                {\n                    projectId: 23425,\n                    projectName: \"Michael & Emily celebration\",\n                    thumbUrl: \"https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=300&h=300&fit=crop\",\n                    projectHeroUrl: \"https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=600&h=400&fit=crop\",\n                    qrInviteUrl: \"https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://example.com/gallery/23425\",\n                    videoUrl: \"https://example.com/video3.mp4\",\n                    createDate: \"2025-08-20T00:00:00Z\",\n                    expiryDate: \"2027-08-20T00:00:00Z\"\n                },\n                {\n                    projectId: 23426,\n                    projectName: \"Jessica & David reception\",\n                    thumbUrl: \"https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=300&h=300&fit=crop\",\n                    projectHeroUrl: \"https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=600&h=400&fit=crop\",\n                    qrInviteUrl: \"https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://example.com/gallery/23426\",\n                    videoUrl: \"https://example.com/video4.mp4\",\n                    createDate: \"2025-07-10T00:00:00Z\",\n                    expiryDate: \"2027-07-10T00:00:00Z\"\n                }\n            ],\n            fonts: [\n                {\n                    id: \"main\",\n                    family: \"TT Norms Pro\",\n                    style: \"normal\",\n                    weight: 400,\n                    url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n                }\n            ]\n        });\n    </script>\n</body>\n\n</html>"
