    "consume_variant": [
      {
        "id": "7c1178f8-21fd-41b9-9b0a-d18e2785cacc",
        "name": "Version 3",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <title>Design Tab - Loading</title>\n\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Font definition for dynamic font loading via CSS variables\n     */\n    interface MyopFont {\n        /** Font identifier used for CSS variable naming (e.g. \"main\" → --font_main) */\n        id: string;\n        /** Font family name */\n        family: string;\n        /** Optional font style (e.g. \"normal\", \"italic\") */\n        style?: string;\n        /** Optional font weight (e.g. 400, 700) */\n        weight?: number;\n        /** URL to the font CSS file */\n        url: string;\n    }\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n        /** Array of rotating status messages to display during loading */\n        messages: string[];\n        /** Subtitle text explaining the wait */\n        subtitle: string;\n        /** Text for the skip button CTA */\n        buttonText: string;\n        /** Interval in ms between message rotations (default: 4000) */\n        cycleSpeed?: number;\n        /** Configuration options */\n        config?: {\n            /** Array of font definitions to load and apply via CSS variables */\n            fonts?: MyopFont[];\n        };\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n        /** User clicked to skip waiting and design without media */\n        'skip-media-design': { origin: string; timestamp: number };\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <style>\n        /* Reset and base styles for Myop */\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n        }\n\n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            background-color: #ffffff;\n            color: #444444;\n            font-family: var(--font_main, sans-serif);\n            font-style: var(--font_main_style, normal);\n            font-weight: var(--font_main_weight, 400);\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .loading-container {\n            max-width: 400px;\n            width: 90%;\n            text-align: center;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        /* === Animation Keyframes === */\n        @keyframes ring-rotate {\n            0% { transform: rotate(0deg); }\n            100% { transform: rotate(360deg); }\n        }\n\n        /* === Visual Elements Styling === */\n        .spinner-wrapper {\n            margin: 0 auto 2rem auto;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 3rem;\n        }\n\n        .gentle-loader {\n            width: 24px;\n            height: 24px;\n            border: 2px solid #444444;\n            border-top: 2px solid #ffffff;\n            border-radius: 50%;\n            animation: ring-rotate 1.5s linear infinite;\n        }\n\n        /* Main Status Text Container */\n        #status-text-container {\n            height: 27px;\n            margin-top: 1rem;\n            margin-bottom: 1rem;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            width: 100%;\n        }\n\n        .status-inner-wrapper {\n            display: flex;\n            align-items: center;\n        }\n\n        .status-star-icon {\n            width: 18px;\n            height: 21px;\n            margin-right: 12px;\n            opacity: 0.8;\n            flex-shrink: 0;\n        }\n\n        #status-text {\n            font-size: 18px;\n            font-family: var(--font_main_bold, var(--font_main, sans-serif));\n            font-weight: var(--font_main_bold_weight, 700);\n            font-style: var(--font_main_bold_style, var(--font_main_style, normal));\n            line-height: 150%;\n            color: #444444;\n            margin: 0;\n            width: 200px;\n            text-align: left;\n            transition: opacity 0.5s;\n        }\n\n        /* Subtitle Text Styling */\n        #subtitle-text {\n            font-size: 1rem;\n            margin: 0 0 3rem 0;\n            opacity: 0.7;\n            line-height: 150%;\n            max-width: 340px;\n        }\n\n        /* Secondary Button (Link style) */\n        .secondary-btn {\n            padding: 0;\n            border: none;\n            box-shadow: none;\n            background: none;\n            cursor: pointer;\n            color: #1C1C1C;\n            text-align: center;\n            font-family: var(--font_main, sans-serif);\n            font-size: 1rem;\n            font-style: var(--font_main_style, normal);\n            font-weight: var(--font_main_weight, 400);\n            line-height: normal;\n            letter-spacing: 0.2px;\n            text-decoration: underline;\n            text-decoration-style: solid;\n            text-underline-offset: auto;\n            text-underline-position: from-font;\n            display: inline-block;\n            transition: color 0.2s;\n        }\n\n        .secondary-btn:hover {\n            color: rgb(100, 100, 100);\n        }\n    </style>\n</head>\n<body>\n\n<div id=\"app-root\">\n    <div class=\"loading-container\">\n        <!-- Spinner Section -->\n        <div class=\"spinner-wrapper\">\n            <div class=\"gentle-loader\"></div>\n        </div>\n\n        <!-- Main Status Text Section -->\n        <div id=\"status-text-container\">\n            <div class=\"status-inner-wrapper\">\n                <!-- Static Stars Icon -->\n                <svg class=\"status-star-icon\" viewBox=\"0 0 16 19\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M14.9173 12.4412C9.38201 13.0068 8.92411 13.4647 8.35848 19C7.79293 13.4647 7.33501 13.0068 1.79968 12.4412C7.33495 11.8756 7.79285 11.4177 8.35848 5.8824C8.92404 11.4177 9.38195 11.8763 14.9173 12.4412Z\" fill=\"#444444\"/>\n                    <path d=\"M11.2056 0C10.8189 3.79183 10.505 4.10571 6.71308 4.49255C10.5049 4.87998 10.8188 5.19392 11.2056 8.9851C11.5931 5.19327 11.907 4.87939 15.6982 4.49255C11.9071 4.10586 11.5932 3.79193 11.2056 0Z\" fill=\"#444444\"/>\n                    <path d=\"M3.64933 3.05178C3.33465 6.13187 3.08007 6.38723 0 6.70111C3.08009 7.01579 3.33545 7.27037 3.64933 10.3504C3.96401 7.27035 4.21859 7.01499 7.29942 6.70111C4.21933 6.38717 3.96397 6.13185 3.64933 3.05178Z\" fill=\"#444444\"/>\n                </svg>\n                <h1 id=\"status-text\"></h1>\n            </div>\n        </div>\n\n        <!-- Explanatory Subtitle -->\n        <p id=\"subtitle-text\"></p>\n\n        <!-- Call to Action Button -->\n        <button id=\"skip-btn\" class=\"secondary-btn\"></button>\n    </div>\n</div>\n\n<script>\n(function() {\n    // Private state\n    let currentState = null;\n    let intervalId = null;\n    let messageIndex = 0;\n\n    // DOM References\n    const statusTextEl = document.getElementById('status-text');\n    const subtitleTextEl = document.getElementById('subtitle-text');\n    const skipBtn = document.getElementById('skip-btn');\n\n    /**\n     * Cycles through the status messages with a fade transition.\n     */\n    function updateStatusText() {\n        if (!currentState || !currentState.messages) return;\n\n        statusTextEl.style.opacity = '0';\n\n        setTimeout(() => {\n            messageIndex = (messageIndex + 1) % currentState.messages.length;\n            statusTextEl.textContent = currentState.messages[messageIndex];\n            statusTextEl.style.opacity = '1';\n        }, 500);\n    }\n\n    /** Track loaded font URLs to avoid duplicate link elements */\n    var loadedFontUrls = {};\n\n    /**\n     * Loads fonts from config and sets CSS variables on :root\n     */\n    function applyFonts(fonts) {\n        if (!fonts || !fonts.length) return;\n        var root = document.documentElement;\n\n        fonts.forEach(function(font) {\n            // Load font CSS if not already loaded\n            if (font.url && !loadedFontUrls[font.url]) {\n                var link = document.createElement('link');\n                link.rel = 'stylesheet';\n                link.href = font.url;\n                document.head.appendChild(link);\n                loadedFontUrls[font.url] = true;\n            }\n\n            // Set CSS variables using font id (e.g. --font_main, --font_main_style, --font_main_weight)\n            var varPrefix = '--font_' + font.id;\n            root.style.setProperty(varPrefix, font.family);\n            if (font.style) {\n                root.style.setProperty(varPrefix + '_style', font.style);\n            }\n            if (font.weight != null) {\n                root.style.setProperty(varPrefix + '_weight', String(font.weight));\n            }\n        });\n    }\n\n    /**\n     * Renders the component synchronously\n     */\n    function render(data) {\n        // Apply fonts from config\n        if (data.config && data.config.fonts) {\n            applyFonts(data.config.fonts);\n        }\n\n        // Populate content from lang data\n        statusTextEl.textContent = data.messages[0];\n        subtitleTextEl.textContent = data.subtitle;\n        skipBtn.textContent = data.buttonText;\n\n        // Reset and setup the cycling interval\n        messageIndex = 0;\n        if (intervalId) clearInterval(intervalId);\n        intervalId = setInterval(updateStatusText, data.cycleSpeed || 4000);\n    }\n\n    /**\n     * Public API: Initialize or get current state\n     */\n    window.myop_init_interface = function(data) {\n        if (!data) return currentState; // Getter mode\n\n        currentState = data;\n        render(data);\n    };\n\n    /**\n     * Public API: Handle CTA actions (overridden by host in production)\n     */\n    window.myop_cta_handler = function(action_id, payload) {\n        console.log('[MYOP CTA Handler] Action:', action_id, 'Payload:', payload);\n    };\n\n    // Attach click handler\n    skipBtn.addEventListener('click', function() {\n        window.myop_cta_handler('skip-media-design', {\n            origin: 'loading_screen',\n            timestamp: Date.now()\n        });\n    });\n})();\n</script>\n\n<!-- Preview script - replaced in production -->\n<script id=\"myop_preview\">\n    window.myop_init_interface({\n        messages: [\n            \"Preparing your gallery\",\n            \"Curating strong visuals\",\n            \"Selecting focal points\",\n            \"Creating initial design\"\n        ],\n        subtitle: \"This process can take a few minutes as our visual algorithms work their magic\",\n        buttonText: \"I don't want to wait - I will select manually\",\n        cycleSpeed: 4000,\n        config: {\n            fonts: [\n                {\n                    id: \"main\",\n                    family: \"tt_norms_pro\",\n                    style: \"normal\",\n                    weight: 400,\n                    url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n                },\n                {\n                    id: \"main_bold\",\n                    family: \"tt_norms_pro\",\n                    style: \"normal\",\n                    weight: 700,\n                    url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n                }\n            ]\n        }\n    });\n</script>\n\n</body>\n</html>\n"
        }
      }
    ]
  }
}