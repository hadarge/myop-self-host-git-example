        slot.classList.add('playing');\n                } else {\n                    if (video && !video.paused) {\n                        video.pause();\n                        video.currentTime = 0;\n                    }\n                    slot.classList.remove('playing');\n                }\n            });\n        }\n\n        function navigateTo(index) {\n            if (!currentData) return;\n            var total = currentData.videos.length;\n            if (total === 0) return;\n\n            // Pause current center video\n            var currentCenter = document.querySelector('.video-slot.center video');\n            if (currentCenter && !currentCenter.paused) {\n                currentCenter.pause();\n                currentCenter.currentTime = 0;\n            }\n            var currentSlot = document.querySelector('.video-slot.center');\n            if (currentSlot) currentSlot.classList.remove('playing');\n\n            activeIndex = ((index % total) + total) % total;\n            positionSlots();\n        }\n\n        function render(data) {\n            currentData = data;\n            var videos = data.videos || [];\n            var lang = data.lang || {};\n            var ctaText = lang.ctaText || 'Start now';\n            var title = lang.title || 'Experience your work in these designs';\n            var scratchText = lang.scratchText || 'or start from scratch';\n\n            if (videos.length > 0 && activeIndex >= videos.length) {\n                activeIndex = 0;\n            }\n\n            loadFonts(data.fonts);\n\n            var root = document.getElementById('app-root');\n\n            // Title\n            var titleHTML = '<div class=\"gallery-title\">' + title + '</div>';\n\n            // Carousel card\n            var cardHTML = '<div class=\"carousel-card\">';\n\n            // Track with video slots\n            cardHTML += '<div class=\"carousel-track\">';\n            videos.forEach(function(v, i) {\n                cardHTML += '<div class=\"video-slot\" data-index=\"' + i + '\" data-design-id=\"' + v.designSetID + '\">' +\n                    '<video muted loop playsinline preload=\"metadata\">' +\n                        '<source src=\"' + v.url + '\" type=\"video/mp4\">' +\n                    '</video>' +\n                    '<div class=\"video-overlay\">' +\n                        '<button class=\"cta-btn\">' + ctaText + '</button>' +\n                    '</div>' +\n                '</div>';\n            });\n\n            // Navigation area with arrows (inside carousel-track)\n            cardHTML += '<div class=\"nav-area\">';\n            if (videos.length > 1) {\n                cardHTML += '<div class=\"nav-arrows\">' +\n                    '<button class=\"nav-arrow\" data-dir=\"prev\">' +\n                        '<svg viewBox=\"0 0 15 11\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M5.5 1L1 5.5M1 5.5L5.5 10M1 5.5H14\" stroke=\"black\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>' +\n                    '</button>' +\n                    '<button class=\"nav-arrow\" data-dir=\"next\">' +\n                        '<svg viewBox=\"0 0 15 11\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M9.5 1L14 5.5M14 5.5L9.5 10M14 5.5H1\" stroke=\"black\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>' +\n                    '</button>' +\n                '</div>';\n            }\n            cardHTML += '</div>'; // close nav-area\n            cardHTML += '</div>'; // close carousel-track\n\n            // \"or start from scratch\" link\n            cardHTML += '<button class=\"scratch-link\">' + scratchText + '</button>';\n\n            cardHTML += '</div>'; // close carousel-card\n\n            root.innerHTML = titleHTML + cardHTML;\n\n            // Position slots and compute card height\n            positionSlots();\n\n            // Request host to resize to fit content\n            var totalHeight = root.scrollHeight;\n            window.myop_cta_handler('size-requested', { height: totalHeight });\n\n            // Attach event listeners only once (root persists across renders)\n            if (!listenersAttached) {\n                attachListeners(root, videos);\n                listenersAttached = true;\n            }\n        }\n\n        function attachListeners(root, videos) {\n            var total = videos.length;\n\n            // Hover on side slots -> navigate after delay\n            // Hover on center slot -> play video\n            root.addEventListener('mouseenter', function(e) {\n                var slot = e.target.closest('.video-slot');\n                if (!slot) return;\n\n                if (slot.classList.contains('left')) {\n                    clearTimeout(hoverTimeout);\n                    hoverTimeout = setTimeout(function() {\n                        navigateTo(activeIndex - 1);\n                    }, 1000);\n                } else if (slot.classList.contains('right')) {\n                    clearTimeout(hoverTimeout);\n                    hoverTimeout = setTimeout(function() {\n                        navigateTo(activeIndex + 1);\n                    }, 1000);\n                } else if (slot.classList.contains('center')) {\n                    // Play center video on hover\n                    var video = slot.querySelector('video');\n                    if (video && video.paused) {\n                        video.play().catch(function(){});\n                    }\n                }\n            }, true);\n\n            root.addEventListener('mouseleave', function(e) {\n                var slot = e.target.closest('.video-slot');\n                if (!slot) return;\n                clearTimeout(hoverTimeout);\n\n                // Pause center video when mouse leaves\n                if (slot.classList.contains('center')) {\n                    var video = slot.querySelector('video');\n                    if (video && !video.paused) {\n                        video.pause();\n                        video.currentTime = 0;\n                    }\n                }\n            }, true);\n\n            // Click handlers\n            root.addEventListener('click', function(e) {\n                // CTA button\n                var btn = e.target.closest('.cta-btn');\n                if (btn) {\n                    var slot = btn.closest('.video-slot');\n                    var designId = slot ? slot.getAttribute('data-design-id') : '';\n                    window.myop_cta_handler('new_gallery_clicked', { designSetID: designId });\n                    return;\n                }\n\n                // \"or start from scratch\" link\n                var scratch = e.target.closest('.scratch-link');\n                if (scratch) {\n                    window.myop_cta_handler('new_gallery_clicked', {});\n                    return;\n                }\n\n                // Arrow click\n                var arrow = e.target.closest('.nav-arrow');\n                if (arrow) {\n                    var dir = arrow.getAttribute('data-dir');\n                    if (dir === 'prev') navigateTo(activeIndex - 1);\n                    else navigateTo(activeIndex + 1);\n                    return;\n                }\n\n                // Click on side slot -> navigate\n                var clickedSlot = e.target.closest('.video-slot');\n                if (clickedSlot && !clickedSlot.classList.contains('center')) {\n                    var idx = parseInt(clickedSlot.getAttribute('data-index'), 10);\n                    navigateTo(idx);\n                }\n            });\n\n            // Resize handler — recompute layout and request new height\n            var resizeTimer;\n            window.addEventListener('resize', function() {\n                clearTimeout(resizeTimer);\n                resizeTimer = setTimeout(function() {\n                    positionSlots();\n                    var root = document.getElementById('app-root');\n                    if (root) {\n                        window.myop_cta_handler('size-requested', { height: root.scrollHeight });\n                    }\n                }, 50);\n            });\n        }\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentData;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            videos: [\n                {\n                    designSetID: \"ds-001\",\n                    url: \"https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4\"\n                },\n                {\n                    designSetID: \"ds-002\",\n                    url: \"https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerEscapes.mp4\"\n                },\n                {\n                    designSetID: \"ds-003\",\n                    url: \"https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerFun.mp4\"\n                },\n                {\n                    designSetID: \"ds-004\",\n                    url: \"https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerJoyrides.mp4\"\n                },\n                {\n                    designSetID: \"ds-005\",\n                    url: \"https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerMeltdowns.mp4\"\n                }\n            ],\n            fonts: [\n                {\n                    id: \"main\",\n                    family: \"TT Norms Pro\",\n                    weight: 400,\n                    url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n                }\n            ],\n            lang: {\n                ctaText: \"Start now\",\n                title: \"Experience your work in these designs\",\n                scratchText: \"Start from scratch\"\n            }\n        });\n    </script>\n</body>\n</html>"
