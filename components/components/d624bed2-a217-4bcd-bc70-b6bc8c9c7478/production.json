      { x: rightX,  y: sideY,   w: sideW,   h: sideH },\n                hiddenLeft:  { x: leftX - sideW - videoGap, y: sideY, w: sideW, h: sideH },\n                hiddenRight: { x: rightX + sideW + videoGap, y: sideY, w: sideW, h: sideH },\n                cardHeight:  totalH,\n                arrowGap:    arrowGap,\n                scratchGap:  scratchGap\n            };\n        }\n\n        function getSlotName(offset, total) {\n            if (offset === 0) return 'center';\n            if (offset === -1) return 'left';\n            if (offset === 1) return 'right';\n            return 'hidden-slot';\n        }\n\n        function positionSlots() {\n            if (!currentData || !currentData.videos.length) return;\n            var card = document.querySelector('.carousel-card');\n            var track = document.querySelector('.carousel-track');\n            if (!track || !card) return;\n            var trackW = track.offsetWidth;\n            var positions = getSlotPositions(trackW);\n            var videos = currentData.videos;\n            var total = videos.length;\n\n            // Set card height from content\n            card.style.height = positions.cardHeight + 'px';\n\n            // Position nav-area proportionally below center video\n            var arrowTop = positions.center.y + positions.center.h + positions.arrowGap;\n            var navArea = document.querySelector('.nav-area');\n            if (navArea) {\n                navArea.style.top = arrowTop + 'px';\n            }\n            // Position scratch link proportionally below center video\n            var scratchLink = document.querySelector('.scratch-link');\n            if (scratchLink) {\n                var scratchTop = positions.center.y + positions.center.h + positions.scratchGap;\n                scratchLink.style.top = scratchTop + 'px';\n                scratchLink.style.fontSize = Math.round(trackW * R_FONT_SCRATCH) + 'px';\n            }\n\n            // Title font-size is