          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"minWidth\":500}'>\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * A single video item representing a design set\n */\ninterface VideoItem {\n  designSetID: string;\n  url: string;\n}\n\n/**\n * Font configuration\n */\ninterface FontConfig {\n  id: string;\n  family: string;\n  style?: string;\n  weight?: number;\n  url: string;\n}\n\n/**\n * Localized UI strings\n */\ninterface LangStrings {\n  /** CTA button text, defaults to \"Start now\" */\n  ctaText?: string;\n  /** Title text above the carousel */\n  title?: string;\n  /** \"Start from scratch\" link text */\n  scratchText?: string;\n}\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n  videos: VideoItem[];\n  fonts?: FontConfig[];\n  /** Localized UI strings */\n  lang?: LangStrings;\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'new_gallery_clicked': { designSetID: string } | {};\n  'size-requested': {\n    width?: number | null;\n    height?: number | null;\n    minWidth?: number | null;\n    maxWidth?: number | null;\n    minHeight?: number | null;\n    maxHeight?: number | null;\n    required?: boolean;\n  };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n    <style>\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: fit-content;            \n        }\n\n        #app-root {\n            width: 100%;\n            display: flex;\n            flex-direction: column;\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\n        }\n\n        /* Title above the carousel card */\n        .gallery-title {\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\n            font-weight: 500;\n            font-style: var(--fontStyle_main, normal);\n            font-size: 18px;\n            line-height: 130%;\n            color: var(--3-Text-H-3-1-1-primary-text, #222);\n            font-feature-settings: 'liga' off, 'clig' off;\n            padding: 0 6px;\n            margin: 0 0 clamp(6px, 1.47vw, 12px) 0;\n            flex-shrink: 0;\n        }\n\n        /* Main carousel card - height defined by content */\n        .carousel-card {\n            background: #EFE7DA;\n            border-radius: 10px;\n            position: relative;\n            overflow: hidden;\n        }\n\n        /* Video slots container */\n        .carousel-track {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n        }\n\n        /* Each video slot */\n        .video-slot {\n            position: absolute;\n            overflow: hidden;\n            cursor: pointer;\n            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);\n            will-change: transform, opacity, width, height, left, top;\n            background: #fff;\n        }\n\n        .video-slot video {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n            transform: scale(1.02);\n        }\n\n        .video-slot.center {\n            z-index: 3;\n        }\n\n        .video-slot.left,\n        .video-slot.right {\n            z-index: 2;\n            opacity: 0.4;\n        }\n\n        .video-slot.hidden-slot {\n            opacity: 0;\n            pointer-events: none;\n            z-index: 0;\n        }\n\n        /* Hover overlay on center video */\n        .video-overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(0, 0, 0, 0.15);\n            opacity: 0;\n            transition: opacity 0.3s ease;\n            pointer-events: none;\n        }\n\n        .video-slot.center .video-overlay {\n            opacity: 1;\n            pointer-events: auto;\n        }\n\n        /* CTA Button - bottom-right corner, scales with video size\n           Figma ref: button 100.43×34 in 445.05×249.15 video\n           width: 22.57%, height: 13.65%, right: 3.64%, bottom: 6.48% */\n        .cta-btn {\n            position: absolute;\n            bottom: 6.48%;\n            right: 3.64%;\n            width: 22.57%;\n            height: 13.65%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\n            font-weight: var(--fontWeight_main, 500);\n            font-style: var(--fontStyle_main, normal);\n            font-size: 15px; /* dynamically set by JS */\n            line-height: 125%;\n            color: var(--DARK, #232323);\n            font-feature-settings: 'liga' off, 'clig' off;\n            background: #FFFFFF;\n            border: none;\n            border-radius: 2px;\n            padding: 0;\n            cursor: pointer;\n            white-space: nowrap;\n            box-shadow: 0px 0px 4px 0px rgba(0, 0, 0, 0.25);\n            transition: transform 0.15s ease, box-shadow 0.2s ease;\n        }\n\n        .cta-btn:hover {\n            transform: scale(1.04);\n            box-shadow: 0px 0px 8px 0px rgba(0, 0, 0, 0.3);\n        }\n\n        .cta-btn:active {\n            transform: scale(0.97);\n        }\n\n        /* Bottom navigation area - positioned dynamically below center video */\n        .nav-area {\n            position: absolute;\n            left: 0;\n            right: 0;\n            display: flex;\n            align-items: flex-start;\n            justify-content: center;\n        }\n\n        /* Arrow navigation - simple arrow icons */\n        .nav-arrows {\n            display: flex;\n            align-items: center;\n            gap: clamp(14px, 2.93vw, 28px);\n        }\n\n        .nav-arrow {\n            background: none;\n            border: none;\n            padding: 4px;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            opacity: 0.7;\n            transition: opacity 0.2s ease;\n        }\n\n        .nav-arrow:hover {\n            opacity: 1;\n        }\n\n        .nav-arrow svg {\n            width: clamp(12px, 2.2vw, 20px);\n            height: clamp(9px, 1.61vw, 15px);\n        }\n\n        /* \"or start from scratch\" link - positioned dynamically alongside arrows */\n        .scratch-link {\n            position: absolute;\n            right: clamp(12px, 2.93vw, 28px);\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\n            font-weight: var(--fontWeight_main, 400);\n            font-size: 14px; /* dynamically set by JS */\n            line-height: 1.3;\n            color: #000000;\n            text-decoration: underline;\n            cursor: pointer;\n            background: none;\n            border: none;\n            padding: 0;\n        }\n\n        .scratch-link:hover {\n            opacity: 0.7;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function() {\n        var currentData = null;\n        var activeIndex = 0;\n        var hoverTimeout = null;\n        var loadedFontUrls = [];\n        var listenersAttached = false;\n\n        function loadFonts(fonts) {\n            if (!fonts || !fonts.length) return;\n            fonts.forEach(function(font) {\n                var root = document.documentElement;\n                root.style.setProperty('--font_' + font.id, font.family + ', sans-serif');\n                if (font.weight !== undefined) {\n                    root.style.setProperty('--fontWeight_' + font.id, font.weight);\n                }\n                if (font.style) {\n                    root.style.setProperty('--fontStyle_' + font.id, font.style);\n                }\n                if (font.url && loadedFontUrls.indexOf(font.url) === -1) {\n                    loadedFontUrls.push(font.url);\n                    var link = document.createElement('link');\n                    link.rel = 'stylesheet';\n                    link.href = font.url;\n                    document.head.appendChild(link);\n                }\n            });\n        }\n\n        // ---------------------------------------------------------------\n        // All spacing is proportional to card width so the component\n        // keeps the same visual ratio at any screen size.\n        // Reference Figma frame: 682 × 367 px\n        // ---------------------------------------------------------------\n        var REF_W = 682;\n        var R_CENTER_TOP    = 53    / REF_W; // 0.0777 – top padding to center video\n        var R_VIDEO_GAP     = 33.28 / REF_W; // 0.0488 – gap between side & center video\n        var R_ARROW_GAP     = 20    / REF_W; // 0.0293 – arrows below center video\n        var R_SCRATCH_GAP   = 30    / REF_W; // 0.0440 – scratch link below center video\n        var R_ARROW_ROW_H   = 24    / REF_W; // 0.0352 – arrow row height\n        var R_CARD_BOT_PAD  = 20    / REF_W; // 0.0293 – bottom padding\n\n        // Font-size ratios (relative to card width, ref 682px)\n        var R_FONT_TITLE    = 18    / REF_W; // 0.0264 – title