    "consume_variant": [
      {
        "name": "Version 10",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"minWidth\":500}'>\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * A single video item representing a design set\n */\ninterface VideoItem {\n  designSetID: string;\n  /** Video URL - supports Vimeo URLs (vimeo.com/123456789) or direct video URLs (.mp4) */\n  url: string;\n  /** Title to display when this video is active */\n  title: string;\n}\n\n/**\n * Font configuration\n */\ninterface FontConfig {\n  id: string;\n  family: string;\n  style?: string;\n  weight?: number;\n  url: string;\n}\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n  videos: VideoItem[];\n  fonts?: FontConfig[];\n  /** Auto-rotation interval in milliseconds (default: 10000) */\n  autoRotateInterval?: number;\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'new_gallery_clicked': { designSetID: string } | {};\n  'size-requested': {\n    width?: number | null;\n    height?: number | null;\n    minWidth?: number | null;\n    maxWidth?: number | null;\n    minHeight?: number | null;\n    maxHeight?: number | null;\n    required?: boolean;\n  };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n    <style>\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: fit-content;            \n        }\n\n        #app-root {\n            width: 100%;\n            display: flex;\n            flex-direction: column;\n            font-family: var(--font_main);\n        }\n\n        /* Main carousel card - height defined by content */\n        .carousel-card {\n            background: #FFF;\n            border-radius: 10px;\n            position: relative;\n            overflow: hidden;\n        }\n\n        /* Video slots container */\n        .carousel-track {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n        }\n\n        /* Each video slot */\n        .video-slot {\n            position: absolute;\n            overflow: hidden;\n            cursor: pointer;\n            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);\n            will-change: transform, opacity, width, height, left, top;\n            background: #fff;\n        }\n\n        .video-slot video,\n        .video-slot iframe {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n            transform: scale(1.02);\n            border: 1px solid rgba(0, 0, 0, 0.08);\n            transition: box-shadow 0.5s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        /* Center video/iframe: 6px border-radius */\n        .video-slot.center video,\n        .video-slot.center iframe {\n            border-radius: 6px;\n        }\n\n        /* Side videos/iframes: 4px border-radius */\n        .video-slot.left video,\n        .video-slot.left iframe,\n        .video-slot.right video,\n        .video-slot.right iframe,\n        .video-slot.hidden-slot video,\n        .video-slot.hidden-slot iframe {\n            border-radius: 4px;\n        }\n\n        /* Border effect: white border with gap - only on slot with .has-border class */\n        .video-slot.has-border video,\n        .video-slot.has-border iframe {\n            box-shadow: 0 0 0 4px #FFF, 0 0 0 6px #fff;\n        }\n\n        .video-slot.center {\n            z-index: 3;\n        }\n\n        .video-slot.left,\n        .video-slot.right {\n            z-index: 2;\n            opacity: 0.4;\n            cursor: pointer;\n        }\n\n        .video-slot.hidden-slot {\n            opacity: 0;\n            pointer-events: none;\n            z-index: 0;\n        }\n\n        /* Bottom navigation area - fixed at bottom */\n        .nav-area {\n            position: absolute;\n            bottom: 23px;\n            left: 0;\n            right: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        /* Dot navigation */\n        .nav-dots {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n        }\n\n        .nav-dot {\n            width: 10px;\n            height: 10px;\n            border-radius: 50%;\n            border: 1.5px solid #D9D9D9;\n            background: transparent;\n            padding: 0;\n            cursor: pointer;\n            transition: background 0.2s ease, border-color 0.2s ease;\n        }\n\n        .nav-dot:hover {\n            border-color: #999;\n        }\n\n        .nav-dot.active {\n            background: #3D3D3D;\n            border-color: #3D3D3D;\n        }\n\n        /* Dynamic title above videos (inside carousel card) */\n        .video-title {\n            position: absolute;\n            top: 16px;\n            color: var(--DARK, #232323);\n            text-align: center;\n            leading-trim: both;\n            text-edge: cap;\n            font-family: var(--font_main, \"TT Norms Pro\"), sans-serif;\n            font-size: 30px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 120%; /* 36px */\n            letter-spacing: -0.44px;\n            text-transform: capitalize;\n            z-index: 10;\n            /* Width and position set dynamically by JS to match center video */\n        }\n\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function() {\n        // =================================================================\n        // STATE\n        // =================================================================\n        var currentData = null;\n        var activeIndex = 0;\n        var hoverTimeout = null;\n        var loadedFontUrls = [];\n        var listenersAttached = false;\n        var autoRotateTimer = null;\n        var isHovering = false;\n\n        // =================================================================\n        // CONFIGURATION\n        // =================================================================\n        var SIDE_VIDEO_VISIBLE = 0.30;  // 30% of side video visible\n        var MIN_VIDEO_GAP = 10;         // Minimum gap between center and side videos\n        var FIRST_HOVER_DELAY = 1000;   // 1 second delay on first hover\n        var CONTINUE_DELAY = 2000;      // 2 second delay for continuation\n        var BOTTOM_NAV_HEIGHT = 55;     // 23px bottom + 32px arrow height\n\n        // Reference Figma frame: 682 × 367 px\n        var REF_W = 682;\n        var R_CENTER_TOP = 53 / REF_W;  // Top padding to center video\n\n        // =================================================================\n        // VIDEO URL HELPERS\n        // =================================================================\n\n        // Check if URL is a Vimeo URL and extract video ID\n        function parseVimeoUrl(url) {\n            if (!url) return null;\n\n            // Match various Vimeo URL formats:\n            // https://vimeo.com/123456789\n            // https://vimeo.com/123456789/abc123def (private link with hash)\n            // https://player.vimeo.com/video/123456789\n            // https://vimeo.com/channels/channelname/123456789\n            // https://vimeo.com/groups/groupname/videos/123456789\n            var patterns = [\n                /vimeo\\.com\\/(\\d+)(?:\\/([a-zA-Z0-9]+))?/,\n                /player\\.vimeo\\.com\\/video\\/(\\d+)/,\n                /vimeo\\.com\\/channels\\/[\\w-]+\\/(\\d+)/,\n                /vimeo\\.com\\/groups\\/[\\w-]+\\/videos\\/(\\d+)/\n            ];\n\n            for (var i = 0; i < patterns.length; i++) {\n                var match = url.match(patterns[i]);\n                if (match) {\n                    return {\n                        id: match[1],\n                        hash: match[2] || null // Private video hash if present\n                    };\n                }\n            }\n            return null;\n        }\n\n        // Convert URL to embeddable format\n        function getEmbedUrl(url) {\n            var vimeo = parseVimeoUrl(url);\n            if (vimeo) {\n                // Build Vimeo player embed URL with autoplay, muted, loop, no controls\n                var embedUrl = 'https://player.vimeo.com/video/' + vimeo.id +\n                    '?autoplay=1&muted=1&loop=1&background=1&quality=auto';\n                if (vimeo.hash) {\n                    embedUrl += '&h=' + vimeo.hash;\n                }\n                return { type: 'vimeo', url: embedUrl };\n            }\n            // Default: treat as direct video URL\n            return { type: 'video', url: url };\n        }\n\n        // =================================================================\n        // FONT LOADING\n        // =================================================================\n        function loadFonts(fonts) {\n            if (!fonts || !fonts.length) return;\n            fonts.forEach(function(font) {\n                var root = document.documentElement;\n                // Set font-family CSS variable\n                root.style.setProperty('--font_' + font.id, font.family + ', sans-serif');\n                // Set font-weight CSS variable (default to 400 if not provided)\n                root.style.setProperty('--fontWeight_' + font.id, font.weight !== undefined ? font.weight : 400);\n                // Set font-style CSS variable (default to 'normal' if not provided)\n                root.style.setProperty('--fontStyle_' + font.id, font.style || 'normal');\n                // Load font stylesheet if URL provided\n                if (font.url && loadedFontUrls.indexOf(font.url) === -1) {\n                    loadedFontUrls.push(font.url);\n                    var link = document.createElement('link');\n                    link.rel = 'stylesheet';\n                    link.href = font.url;\n                    document.head.appendChild(link);\n                }\n            });\n        }\n\n        // =================================================================\n        // AUTO-ROTATION\n        // =================================================================\n        function startAutoRotation() {\n            stopAutoRotation();\n            if (!currentData || currentData.videos.length <= 1) return;\n            var interval = currentData.autoRotateInterval || 10000;\n            autoRotateTimer = setInterval(function() {\n                if (!isHovering) {\n                    navigateTo(activeIndex + 1);\n                }\n            }, interval);\n        }\n\n        function stopAutoRotation() {\n            if (autoRotateTimer) {\n                clearInterval(autoRotateTimer);\n                autoRotateTimer = null;\n            }\n        }\n\n        // =================================================================\n        // LAYOUT CALCULATIONS\n        // =================================================================\n        function getSlotPositions(trackW) {\n            var centerTop = Math.round(trackW * R_CENTER_TOP);\n\n            // Center video: ~65.3% of card width, ratio 1.786:1\n            var centerW = Math.round(trackW * 0.652);\n            var centerH = Math.round(centerW / 1.786);\n            var centerX = Math.round((trackW - centerW) / 2);\n            var centerY = centerTop;\n\n            // Side videos: ~86% height of center, same aspect ratio\n            var sideH = Math.round(centerH * 0.863);\n            var sideW = Math.round(sideH * 1.786);\n            var sideY = Math.round(centerY + (centerH - sideH) / 2);\n\n            // Position side videos to show 30% visible\n            var visibleWidth = Math.round(sideW * SIDE_VIDEO_VISIBLE);\n            var leftX = -(sideW - visibleWidth);\n            var rightX = trackW - visibleWidth;\n\n            // Ensure minimum gap from center video\n            var leftGap = centerX - (leftX + sideW);\n            if (leftGap < MIN_VIDEO_GAP) {\n                leftX = centerX - sideW - MIN_VIDEO_GAP;\n            }\n            var rightGap = rightX - (centerX + centerW);\n            if (rightGap < MIN_VIDEO_GAP) {\n                rightX = centerX + centerW + MIN_VIDEO_GAP;\n            }\n\n            // Card height\n            var totalH = centerY + centerH + BOTTOM_NAV_HEIGHT;\n\n            return {\n                center: { x: centerX, y: centerY, w: centerW, h: centerH },\n                left: { x: leftX, y: sideY, w: sideW, h: sideH },\n                right: { x: rightX, y: sideY, w: sideW, h: sideH },\n                hiddenLeft: { x: leftX - sideW - 20, y: sideY, w: sideW, h: sideH },\n                hiddenRight: { x: rightX + sideW + 20, y: sideY, w: sideW, h: sideH },\n                cardHeight: totalH\n            };\n        }\n\n        function getSlotName(offset, total) {\n            if (offset === 0) return 'center';\n            if (offset === -1) return 'left';\n            if (offset === 1) return 'right';\n            return 'hidden-slot';\n        }\n\n        // Update which video has the border (immediately on navigation)\n        function updateBorderClass() {\n            var slots = document.querySelectorAll('.video-slot');\n            slots.forEach(function(slot) {\n                var idx = parseInt(slot.getAttribute('data-index'), 10);\n                if (idx === activeIndex) {\n                    slot.classList.add('has-border');\n                } else {\n                    slot.classList.remove('has-border');\n                }\n            });\n        }\n\n        // Update active dot indicator\n        function updateActiveDot() {\n            var dots = document.querySelectorAll('.nav-dot');\n            dots.forEach(function(dot) {\n                var idx = parseInt(dot.getAttribute('data-index'), 10);\n                if (idx === activeIndex) {\n                    dot.classList.add('active');\n                } else {\n                    dot.classList.remove('active');\n                }\n            });\n        }\n\n        // Update the title based on active video\n        function updateTitle() {\n            if (!currentData || !currentData.videos.length) return;\n            var titleEl = document.querySelector('.video-title');\n            if (titleEl) {\n                var video = currentData.videos[activeIndex];\n                titleEl.textContent = video.title || '';\n            }\n        }\n\n        // Position the title to match center video width\n        function positionTitle() {\n            var titleEl = document.querySelector('.video-title');\n            var track = document.querySelector('.carousel-track');\n            if (!titleEl || !track) return;\n\n            var trackW = track.offsetWidth;\n            var positions = getSlotPositions(trackW);\n            var center = positions.center;\n\n            titleEl.style.left = center.x + 'px';\n            titleEl.style.width = center.w + 'px';\n        }\n\n        function positionSlots() {\n            if (!currentData || !currentData.videos.length) return;\n            var card = document.querySelector('.carousel-card');\n            var track = document.querySelector('.carousel-track');\n            if (!track || !card) return;\n            var trackW = track.offsetWidth;\n            var positions = getSlotPositions(trackW);\n            var videos = currentData.videos;\n            var total = videos.length;\n\n            // Set card height from content\n            card.style.height = positions.cardHeight + 'px';\n\n            var slots = track.querySelectorAll('.video-slot');\n            slots.forEach(function(slot) {\n                var idx = parseInt(slot.getAttribute('data-index'), 10);\n                var diff = idx - activeIndex;\n\n                // Wrap around for circular navigation\n                if (total > 1) {\n                    if (diff > Math.floor(total / 2)) diff -= total;\n                    if (diff < -Math.floor(total / 2)) diff += total;\n                }\n\n                var slotName = getSlotName(diff, total);\n                var pos;\n                switch(slotName) {\n                    case 'center':    pos = positions.center; break;\n                    case 'left':      pos = positions.left; break;\n                    case 'right':     pos = positions.right; break;\n                    default:\n                        pos = diff < 0 ? positions.hiddenLeft : positions.hiddenRight;\n                        break;\n                }\n\n                // Update classes (preserve has-border class)\n                var hasBorder = slot.classList.contains('has-border');\n                slot.className = 'video-slot';\n                slot.classList.add(slotName);\n                if (hasBorder) slot.classList.add('has-border');\n\n                slot.style.left = pos.x + 'px';\n                slot.style.top = pos.y + 'px';\n                slot.style.width = pos.w + 'px';\n                slot.style.height = pos.h + 'px';\n\n                // Handle video/iframe playback and opacity\n                var video = slot.querySelector('video');\n                var iframe = slot.querySelector('iframe');\n                var mediaType = slot.getAttribute('data-type');\n\n                if (slotName === 'center') {\n                    if (video) {\n                        video.style.opacity = '1';\n                        if (video.paused) {\n                            video.play().catch(function(){});\n                        }\n                    }\n                    if (iframe) {\n                        iframe.style.opacity = '1';\n                    }\n                    slot.classList.add('playing');\n                } else {\n                    if (video) {\n                        video.style.opacity = '0.4';\n                        if (!video.paused) {\n                            video.pause();\n                            video.currentTime = 0;\n                        }\n                    }\n                    if (iframe) {\n                        iframe.style.opacity = '0.4';\n                    }\n                    slot.classList.remove('playing');\n                }\n            });\n        }\n\n        function navigateTo(index) {\n            if (!currentData) return;\n            var total = currentData.videos.length;\n            if (total === 0) return;\n\n            // Pause current center video (only for native video elements, iframes handle their own playback)\n            var currentSlot = document.querySelector('.video-slot.center');\n            if (currentSlot) {\n                var currentVideo = currentSlot.querySelector('video');\n                if (currentVideo && !currentVideo.paused) {\n                    currentVideo.pause();\n                    currentVideo.currentTime = 0;\n                }\n                currentSlot.classList.remove('playing');\n            }\n\n            activeIndex = ((index % total) + total) % total;\n\n            // Update border, active dot, and title immediately (before position animation)\n            updateBorderClass();\n            updateActiveDot();\n            updateTitle();\n\n            positionSlots();\n        }\n\n        function render(data) {\n            currentData = data;\n            var videos = data.videos || [];\n\n            if (videos.length > 0 && activeIndex >= videos.length) {\n                activeIndex = 0;\n            }\n\n            loadFonts(data.fonts);\n\n            var root = document.getElementById('app-root');\n\n            // Get initial title from active video\n            var initialTitle = videos.length > 0 ? (videos[activeIndex].title || '') : '';\n\n            // Carousel card\n            var cardHTML = '<div class=\"carousel-card\">';\n\n            // Dynamic title inside carousel card\n            cardHTML += '<div class=\"video-title\">' + initialTitle + '</div>';\n\n            // Track with video slots\n            cardHTML += '<div class=\"carousel-track\">';\n            videos.forEach(function(v, i) {\n                var embed = getEmbedUrl(v.url);\n                var mediaHTML;\n\n                if (embed.type === 'vimeo') {\n                    // Use iframe for Vimeo\n                    mediaHTML = '<iframe src=\"' + embed.url + '\" ' +\n                        'frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture\" ' +\n                        'allowfullscreen></iframe>';\n                } else {\n                    // Use video element for direct URLs\n                    mediaHTML = '<video muted loop playsinline autoplay preload=\"auto\">' +\n                        '<source src=\"' + embed.url + '\" type=\"video/mp4\">' +\n                    '</video>';\n                }\n\n                cardHTML += '<div class=\"video-slot\" data-index=\"' + i + '\" data-design-id=\"' + v.designSetID + '\" data-type=\"' + embed.type + '\">' +\n                    mediaHTML +\n                '</div>';\n            });\n\n            // Navigation area with dots (inside carousel-track)\n            cardHTML += '<div class=\"nav-area\">';\n            if (videos.length > 1) {\n                cardHTML += '<div class=\"nav-dots\">';\n                videos.forEach(function(v, i) {\n                    var activeClass = i === activeIndex ? ' active' : '';\n                    cardHTML += '<button class=\"nav-dot' + activeClass + '\" data-index=\"' + i + '\"></button>';\n                });\n                cardHTML += '</div>';\n            }\n            cardHTML += '</div>'; // close nav-area\n            cardHTML += '</div>'; // close carousel-track\n\n            cardHTML += '</div>'; // close carousel-card\n\n            root.innerHTML = cardHTML;\n\n            // Set initial border on first video\n            updateBorderClass();\n\n            // Position slots and compute card height\n            positionSlots();\n\n            // Position title to match center video width\n            positionTitle();\n\n            // Request host to resize to fit content\n            var totalHeight = root.scrollHeight;\n            window.myop_cta_handler('size-requested', { height: totalHeight });\n\n            // Start auto-rotation\n            startAutoRotation();\n\n            // Attach event listeners only once (root persists across renders)\n            if (!listenersAttached) {\n                attachListeners(root, videos);\n                listenersAttached = true;\n            }\n        }\n\n        function attachListeners(root, videos) {\n            var total = videos.length;\n\n            // Hover on side slots -> navigate after delay\n            // Hover on any slot -> pause auto-rotation\n            root.addEventListener('mouseenter', function(e) {\n                var slot = e.target.closest('.video-slot');\n                if (!slot) return;\n\n                isHovering = true;\n\n                if (slot.classList.contains('left')) {\n                    clearTimeout(hoverTimeout);\n                    hoverTimeout = setTimeout(function() {\n                        navigateTo(activeIndex - 1);\n                    }, FIRST_HOVER_DELAY);\n                } else if (slot.classList.contains('right')) {\n                    clearTimeout(hoverTimeout);\n                    hoverTimeout = setTimeout(function() {\n                        navigateTo(activeIndex + 1);\n                    }, FIRST_HOVER_DELAY);\n                }\n            }, true);\n\n            root.addEventListener('mouseleave', function(e) {\n                var slot = e.target.closest('.video-slot');\n                if (!slot) return;\n                clearTimeout(hoverTimeout);\n                isHovering = false;\n            }, true);\n\n            // Click handlers\n            root.addEventListener('click', function(e) {\n                // Dot click\n                var dot = e.target.closest('.nav-dot');\n                if (dot) {\n                    var idx = parseInt(dot.getAttribute('data-index'), 10);\n                    navigateTo(idx);\n                    return;\n                }\n\n                // Click on side slot -> navigate\n                var clickedSlot = e.target.closest('.video-slot');\n                if (clickedSlot && !clickedSlot.classList.contains('center')) {\n                    var idx = parseInt(clickedSlot.getAttribute('data-index'), 10);\n                    navigateTo(idx);\n                }\n            });\n\n            // Resize handler — recompute layout and request new height\n            var resizeTimer;\n            window.addEventListener('resize', function() {\n                clearTimeout(resizeTimer);\n                resizeTimer = setTimeout(function() {\n                    positionSlots();\n                    positionTitle();\n                    var root = document.getElementById('app-root');\n                    if (root) {\n                        window.myop_cta_handler('size-requested', { height: root.scrollHeight });\n                    }\n                }, 50);\n            });\n        }\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentData;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            videos: [\n                {\n                    designSetID: \"ds-001\",\n                    url: \"https://vimeo.com/1175956705/b9462bc23e\",\n                    title: \"Animated, video, and multi-image covers\"\n                },\n                {\n                    designSetID: \"ds-002\",\n                    url: \"https://vimeo.com/1175956281/dea48f5821\",\n                    title: \"Style your gallery down to the last button\"\n                },\n                {\n                    designSetID: \"ds-003\",\n                    url: \"https://vimeo.com/1175954741/ed95d442dd\",\n                    title: \"Redesigned gallery flow\"\n                },\n                {\n                    designSetID: \"ds-004\",\n                    url: \"https://vimeo.com/1175955251/37de810fc5\",\n                    title: \"A new Shop experience\"\n                },\n                {\n                    designSetID: \"ds-005\",\n                    url: \"https://vimeo.com/1175956991/3ff709e579\",\n                    title: \"Next-gen album Designer\"\n                }\n            ],\n            fonts: [\n                {\n                    id: \"main\",\n                    family: \"TT Norms Pro\",\n                    weight: 400,\n                    url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n                }\n            ],\n            autoRotateInterval: 10000\n        });\n    </script>\n</body>\n</html>"
        },
        "id": "8d711cc5-c7ce-48b4-8aa4-f73b2d900c41"
      }
