      {
        "id": "27818cd6-f3bc-4cec-88b5-42dfdb6ae867",
        "name": "Default Version",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Variant Environment Status</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap\" rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        ::-webkit-scrollbar {\n            width: 12px;\n            height: 12px;\n        }\n\n        ::-webkit-scrollbar-track {\n            background: transparent;\n        }\n\n        ::-webkit-scrollbar-thumb {\n            background: rgba(0, 0, 0, 0.2);\n            border-radius: 6px;\n            border: 3px solid transparent;\n            background-clip: padding-box;\n        }\n\n\n        * {\n            scrollbar-width: thin;\n            scrollbar-color: rgba(0, 0, 0, 0.2) transparent;\n        }\n\n        body {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            background: transparent;\n            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 13px;\n            color: #18181b;\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n        }\n\n        .container {\n            width: 100%;\n            height: 100%;\n            padding: 24px;\n            overflow-y: auto;\n            overflow-x: hidden;\n        }\n\n        .header {\n            margin-bottom: 24px;\n        }\n\n        .header h1 {\n            color: #0A090A;\n            font-family: \"DM Sans\";\n            font-size: 24px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 32px;\n            margin-bottom: 4px;\n        }\n\n        .header p {\n            color: var(--grey-90, #3E3D3E);\n            font-family: \"DM Sans\";\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 24px;\n        }\n\n        .variants-list {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n            margin-bottom: 24px;\n        }\n\n        .variant-card {\n            display: flex;\n            padding: 10px 16px 8px 16px;\n            justify-content: space-between;\n            align-items: center;\n            align-self: stretch;\n            border-radius: 4px;\n            border: 1px solid var(--grey-20, #D3D1D5);\n            background: var(--white, #FFF);\n        }\n\n\n        .variant-info {\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: flex-start;\n            gap: 4px;\n            align-self: stretch;\n        }\n\n        .variant-name {\n            color: var(--black, #0A090A);\n            font-family: \"DM Sans\";\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 600;\n            line-height: 18px;\n        }\n\n        .variant-meta {\n            color: var(--black, #0A090A);\n            font-family: \"DM Sans\";\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 18px;\n        }\n\n        .environments {\n            display: flex;\n            gap: 8px;\n            flex-wrap: wrap;\n            align-items: center;\n            justify-content: flex-end;\n        }\n\n        .env-badge {\n            display: flex;\n            height: 24px;\n            padding: 2px 8px;\n            justify-content: center;\n            align-items: center;\n            gap: 4px;\n            border-radius: 8px;\n            border: 1px solid var(--grey-20, #D3D1D5);\n            background: var(--white, #FFF);\n            font-size: 13px;\n            font-weight: 500;\n            color: #18181b;\n            white-space: nowrap;\n        }\n\n\n        .not-implemented {\n            font-size: 14px;\n            color: #71717a;\n            font-style: italic;\n            font-weight: 400;\n        }\n\n        .footer {\n            display: flex;\n            justify-content: flex-end;\n            margin-top: 24px;\n        }\n\n        .btn-close {\n            display: flex;\n            height: 34px;\n            padding: 4px 16px;\n            justify-content: center;\n            align-items: center;\n            gap: 8px;\n            border-radius: 6px;\n            border: 1px solid var(--grey-20, #D3D1D5);\n            background: var(--white, #FFF);\n            font-size: 13px;\n            font-weight: 400;\n            color: #18181b;\n            font-family: 'DM Sans', sans-serif;\n        }\n\n\n        .btn-close:active {\n            transform: scale(0.98);\n        }\n\n        /* Loader */\n        #loader-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            min-height: 200px;\n            gap: 12px;\n        }\n\n        .loader-spinner {\n            width: 32px;\n            height: 32px;\n            border: 3px solid #E8E1EF;\n            border-top-color: #9157F7;\n            border-radius: 50%;\n            animation: spin 0.8s linear infinite;\n        }\n\n        @keyframes spin {\n            to { transform: rotate(360deg); }\n        }\n\n        .loader-text {\n            font-size: 13px;\n            color: #71717a;\n        }\n\n        /* App Root - hidden by default */\n        #app-root {\n            opacity: 0;\n            transition: opacity 0.3s ease;\n            display: none;\n        }\n\n        #app-root.visible {\n            opacity: 1;\n            display: block;\n        }\n    </style>\n</head>\n<body>\n<div class=\"container\" id=\"container\">\n    <!-- Loader -->\n    <div id=\"loader-container\">\n        <div class=\"loader-spinner\"></div>\n        <div class=\"loader-text\">Loading...</div>\n    </div>\n\n    <!-- App Root -->\n    <div id=\"app-root\">\n        <div class=\"header\">\n            <h1>Variant Environment Status</h1>\n            <p>See where each variant is implemented.</p>\n        </div>\n\n        <div class=\"variants-list\" id=\"variants-list\">\n            <!-- Variants will be rendered here -->\n        </div>\n\n        <div class=\"footer\">\n            <button class=\"btn-close\" id=\"btn-close\">Close</button>\n        </div>\n    </div>\n</div>\n\n<script>\n    (function() {\n        // ==========================================\n        // PRIVATE SCOPE\n        // ==========================================\n\n        // Private state\n        let variantsState = [];\n        let isInitialized = false;\n\n        // DOM References\n        const loaderContainer = document.getElementById('loader-container');\n        const appRoot = document.getElementById('app-root');\n\n        // ==========================================\n        // Private Functions\n        // ==========================================\n\n        function hideLoader() {\n            if (loaderContainer) {\n                loaderContainer.style.display = 'none';\n            }\n            if (appRoot) {\n                appRoot.classList.add('visible');\n            }\n        }\n\n        function render() {\n            const listContainer = document.getElementById('variants-list');\n            if (!listContainer) return;\n\n            if (!variantsState || variantsState.length === 0) {\n                listContainer.innerHTML = '<p style=\"color: #71717a; text-align: center; padding: 40px;\">No variants to display</p>';\n                return;\n            }\n\n            listContainer.innerHTML = variantsState.map(variant => `\n                <div class=\"variant-card\" data-id=\"${variant.id}\">\n                    <div class=\"variant-info\">\n                        <div class=\"variant-name\">${escapeHtml(variant.name)}</div>\n                        <div class=\"variant-meta\">Last modified on ${escapeHtml(variant.lastModified)} by ${escapeHtml(variant.modifiedBy)}</div>\n                    </div>\n                    <div class=\"environments\">\n                        ${variant.environments && variant.environments.length > 0\n                            ? variant.environments.map(env => `<span class=\"env-badge\">${escapeHtml(env)}</span>`).join('')\n                            : '<span class=\"not-implemented\">Not implemented</span>'\n                        }\n                    </div>\n                </div>\n            `).join('');\n        }\n\n        function handleClose() {\n            window.myop_cta_handler('close', {});\n        }\n\n        function escapeHtml(text) {\n            const div = document.createElement('div');\n            div.textContent = text;\n            return div.innerHTML;\n        }\n\n        function attachEventListeners() {\n            const closeBtn = document.getElementById('btn-close');\n            if (closeBtn) {\n                closeBtn.addEventListener('click', handleClose);\n            }\n        }\n\n        // ==========================================\n        // PUBLIC API - Only 2 global functions\n        // ==========================================\n\n        /**\n         * Initialize component with data OR receive updates from host\n         * @param {Object} data - Configuration object\n         * @param {Array} data.variants - Array of variant objects\n         * @param {string} data.action - Optional action type ('setVariants', 'updateVariant', 'addVariant', 'removeVariant')\n         * @param {any} data.payload - Optional payload for the action\n         */\n        window.myop_init_interface = function(data) {\n            if (arguments.length > 0) {\n                console.log('Component: myop_init_interface() called with:', data);\n\n                // Handle initialization data\n                if (data.variants !== undefined) {\n                    variantsState = data.variants;\n                }\n\n                // Handle action-based updates\n                if (data.action) {\n                    switch (data.action) {\n                        case 'setVariants':\n                            if (data.payload && Array.isArray(data.payload)) {\n                                variantsState = data.payload;\n                            }\n                            break;\n\n                        case 'updateVariant':\n                            if (data.payload && data.payload.id) {\n                                const index = variantsState.findIndex(v => v.id === data.payload.id);\n                                if (index !== -1) {\n                                    variantsState[index] = { ...variantsState[index], ...data.payload };\n                                }\n                            }\n                            break;\n\n                        case 'addVariant':\n                            if (data.payload) {\n                                variantsState.push(data.payload);\n                            }\n                            break;\n\n                        case 'removeVariant':\n                            if (data.payload && data.payload.id) {\n                                variantsState = variantsState.filter(v => v.id !== data.payload.id);\n                            }\n                            break;\n\n                        default:\n                            console.warn('Component: Unknown action:', data.action);\n                    }\n                }\n\n                // Attach event listeners only once\n                if (!isInitialized) {\n                    attachEventListeners();\n                    isInitialized = true;\n                }\n\n                render();\n                hideLoader();\n                return data;\n            }\n\n            // Getter: Return current state\n            return { variants: variantsState };\n        };\n\n        /**\n         * Handle user actions and communicate back to the host application\n         * @param {string} action_id - The action identifier\n         * @param {object} payload - The action payload data\n         */\n        window.myop_cta_handler = function(action_id, payload) {\n            console.log('Component: myop_cta_handler called with:', action_id, payload);\n            // This function will be overwritten by the host application\n        };\n\n        // ==========================================\n        // INITIALIZATION\n        // ==========================================\n\n        console.log('Variant Status component loaded and ready for initialization');\n\n    })(); // End IIFE\n</script>\n\n<!-- Mock data for preview and development -->\n<script id=\"myop_preview\">\n    setTimeout(() => {\n        window.myop_init_interface({\n            variants: [\n                {\n                    id: '1',\n                    name: 'Variant name',\n                    lastModified: 'Oct 18, 2025',\n                    modifiedBy: 'J.Doe',\n                    environments: ['Dev', 'QA', 'Custom', 'E. Prod', 'Prod']\n                },\n                {\n                    id: '2',\n                    name: 'Variant name',\n                    lastModified: 'Oct 18, 2025',\n                    modifiedBy: 'J.Doe',\n                    environments: ['Dev', 'Prod']\n                },\n                {\n                    id: '3',\n                    name: 'Variant name',\n                    lastModified: 'Oct 18, 2025',\n                    modifiedBy: 'J.Doe',\n                    environments: ['Prod']\n                },\n                {\n                    id: '4',\n                    name: 'Variant name',\n                    lastModified: 'Oct 18, 2025',\n                    modifiedBy: 'J.Doe',\n                    environments: []\n                }\n            ]\n        });\n    }, 500);\n</script>\n</body>\n</html>"
        }
      }
    ]
  }
