{
  "version": "0.2.10",
  "item": {
    "name": "Referral Dashboard",
    "id": "134c6254-38d1-4ec4-ba66-ec28b6f46272",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "a68dc808-cb11-4f4f-bc64-64fa846e1497",
        "name": "Version 16",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"auto\",\"minWidth\":280}'>\n\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Font definition for dynamic font loading\n     */\n    interface FontDefinition {\n        /** Unique identifier for the font, used in CSS variable name (e.g., \"main\" -> --font_main) */\n        id: string;\n        /** Font family name */\n        family: string;\n        /** Font style (optional, e.g., \"normal\", \"italic\") */\n        style?: string;\n        /** Font weight (optional, e.g., 400, 500, 700) */\n        weight?: number;\n        /** URL to the font CSS file */\n        url: string;\n    }\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n        /** Array of font definitions for dynamic font loading */\n        fonts: FontDefinition[];\n        /** Whether the user has any referrals (determines which state to show) */\n        hasReferrals: boolean;\n        /** Text shown in empty state for incentive (e.g., \"Get 1 free month\") */\n        incentiveText: string;\n        /** Subtitle text shown in empty state (e.g., \"Invite your friend to Pic-time...\") */\n        subtitleText: string;\n        /** Button text for empty state (e.g., \"Invite friends\") */\n        emptyButtonText: string;\n        /** Total earnings amount displayed in active state (e.g., \"$850\") */\n        earningsAmount: string;\n        /** Label for earnings (e.g., \"total earnings\") */\n        earningsLabel: string;\n        /** Number of people who have upgraded through referrals (null to hide) */\n        upgradedCount: number | null;\n        /** Label for upgraded count (e.g., \"upgraded\") */\n        upgradedLabel: string;\n        /** Number of pending referrals (null to hide) */\n        pendingCount: number | null;\n        /** Label for pending count (e.g., \"pending\") */\n        pendingLabel: string;\n        /** Button text for referral state when hasReferrals is true (e.g., \"Invite more friends\") */\n        referralButtonText: string;\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n        /** Triggered when user clicks the invite button */\n        'invite_navigation_clicked': void;\n        /** Standard layout action - request container resize */\n        'size-requested': {\n            width?: number | null;\n            height?: number | null;\n            minWidth?: number | null;\n            maxWidth?: number | null;\n            minHeight?: number | null;\n            maxHeight?: number | null;\n            required?: boolean;\n        };\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <!-- Preload default font for preview -->\n    <link rel=\"stylesheet\" href=\"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\">\n\n    <style>\n        :root {\n            /* Default fallback fonts - will be overridden by JS */\n            --font_main: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            --font_main_style: normal;\n            --font_main_weight: 400;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: auto;\n            overflow: visible;\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            background: transparent;\n        }\n\n        #app-root {\n            width: 100%;\n            height: auto;\n        }\n\n        .referral-container {\n            background: #FFFFFF;\n            border: 1px solid #DDDDD1;\n            border-radius: 8px;\n            width: 100%;\n            position: relative;\n            overflow: hidden;\n        }\n\n        /* Empty State Elements */\n        .empty-state {\n            display: none;\n        }\n\n        .referral-container.state-empty .empty-state {\n            display: flex;\n            flex-direction: column;\n            align-items: flex-start;\n            gap: 16px;\n            padding: 24px 29px;\n        }\n\n        .header-row {\n            display: flex;\n            flex-direction: row;\n            align-items: center;\n            gap: 12px;\n            width: 100%;\n        }\n\n        .header-row .gift-icon {\n            width: 24px;\n            height: 24px;\n            flex-shrink: 0;\n        }\n\n        .header-text {\n            color: #222;\n            font-feature-settings: 'liga' off, 'clig' off;\n            font-family: var(--font_main);\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 130%;\n        }\n\n        .empty-state .header-text {\n            margin-bottom: -8px;\n        }\n\n        .empty-state .subtitle-text {\n            color: #222;\n            font-kerning: none;\n            font-feature-settings: 'liga' off, 'calt' off;\n            font-family: var(--font_main);\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 400;\n            margin-bottom: 8px;\n            line-height: normal;\n            text-align: left;\n            width: 272px;\n            max-width: 100%;\n        }\n\n        .cta-button {\n            background: #AF5903;\n            color: #FFFFFF;\n            font-family: var(--font_main);\n            font-size: 16px;\n            font-weight: 400;\n            letter-spacing: 0.14px;\n            padding: 5px 12px;\n            line-height: 22px;\n            border-radius: 2px;\n            border: none;\n            cursor: pointer;\n            transition: background 0.2s;\n            white-space: nowrap;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 8px;\n        }\n\n        .cta-button .btn-icon {\n            width: 16px;\n            height: 16px;\n            flex-shrink: 0;\n        }\n\n        .cta-button:hover {\n            background: #9A4E03;\n        }\n\n        .cta-button:active {\n            background: #854402;\n        }\n\n        /* Active State Elements */\n        .active-state {\n            display: none;\n        }\n\n        .referral-container.state-active .active-state {\n            display: flex;\n            flex-direction: column;\n            align-items: flex-start;\n            gap: 16px;\n            padding: 24px 29px;\n        }\n\n        .active-state .header-text {\n            margin-bottom: -8px;\n        }\n\n        .active-state .stats-text {\n            color: #222;\n            font-kerning: none;\n            font-feature-settings: 'liga' off, 'calt' off;\n            font-family: var(--font_main);\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: normal;\n            text-align: left;\n            margin-bottom: 8px;\n        }\n\n        /* Mobile responsive - smaller container */\n        @media (max-width: 320px) {\n            .referral-container.state-empty .empty-state,\n            .referral-container.state-active .active-state {\n                padding: 20px;\n                gap: 12px;\n            }\n\n            .header-row .gift-icon {\n                width: 20px;\n                height: 20px;\n            }\n\n            .header-row .header-text {\n                font-size: 16px;\n            }\n\n            .empty-state .subtitle-text,\n            .active-state .stats-text {\n                font-size: 14px;\n                width: 100%;\n            }\n\n            .cta-button {\n                font-size: 13px;\n                padding: 4px 10px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\">\n        <div class=\"referral-container state-empty\" id=\"referralContainer\">\n            <!-- Empty State -->\n            <div class=\"empty-state\">\n                <div class=\"header-text\" id=\"subtitleText\">Invite friends. Earn rewards.</div>\n                <div class=\"subtitle-text\" id=\"incentiveText\">Get 1 free month for every referral</div>\n                <button class=\"cta-button\" id=\"emptyCtaBtn\"><svg class=\"btn-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M8 5V14.3333\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M2.33337 3C2.33337 1.896 3.18004 1 4.22271 1C7.01737 1 8.00004 5 8.00004 5H4.22271C3.18004 5 2.33337 4.104 2.33337 3Z\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M11.7773 5H8C8 5 8.98267 1 11.7773 1C12.82 1 13.6667 1.896 13.6667 3C13.6667 4.104 12.82 5 11.7773 5Z\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M15 5H1\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M13.6667 5V11.6667C13.6667 13.14 12.4734 14.3333 11 14.3333H5.00004C3.52671 14.3333 2.33337 13.14 2.33337 11.6667V5\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg><span>Invite friends</span></button>\n            </div>\n\n            <!-- Active State -->\n            <div class=\"active-state\">\n                <div class=\"header-text\" id=\"earningsHeader\">$850 total earnings</div>\n                <div class=\"stats-text\" id=\"statsText\">54 upgraded, 12 pending</div>\n                <button class=\"cta-button\" id=\"activeCtaBtn\"><svg class=\"btn-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M8 5V14.3333\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M2.33337 3C2.33337 1.896 3.18004 1 4.22271 1C7.01737 1 8.00004 5 8.00004 5H4.22271C3.18004 5 2.33337 4.104 2.33337 3Z\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M11.7773 5H8C8 5 8.98267 1 11.7773 1C12.82 1 13.6667 1.896 13.6667 3C13.6667 4.104 12.82 5 11.7773 5Z\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M15 5H1\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M13.6667 5V11.6667C13.6667 13.14 12.4734 14.3333 11 14.3333H5.00004C3.52671 14.3333 2.33337 13.14 2.33337 11.6667V5\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg><span>Invite more friends</span></button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        // Private state\n        var currentState = null;\n        var loadedFontUrls = {};\n\n        // Cache DOM references\n        var container = document.getElementById('referralContainer');\n        var subtitleTextEl = document.getElementById('subtitleText');\n        var incentiveTextEl = document.getElementById('incentiveText');\n        var emptyCtaBtn = document.getElementById('emptyCtaBtn');\n        var earningsHeader = document.getElementById('earningsHeader');\n        var statsText = document.getElementById('statsText');\n        var activeCtaBtn = document.getElementById('activeCtaBtn');\n\n        // Load fonts and set CSS variables\n        function loadFonts(fonts) {\n            if (!fonts || !Array.isArray(fonts)) return;\n\n            var root = document.documentElement;\n\n            fonts.forEach(function(font) {\n                if (!font.id || !font.family) return;\n\n                // Set CSS variables for this font\n                var varPrefix = '--font_' + font.id;\n                root.style.setProperty(varPrefix, \"'\" + font.family + \"', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif\");\n\n                // Set style variable if provided\n                if (font.style) {\n                    root.style.setProperty(varPrefix + '_style', font.style);\n                }\n\n                // Set weight variable if provided\n                if (font.weight) {\n                    root.style.setProperty(varPrefix + '_weight', font.weight.toString());\n                }\n\n                // Load font CSS file if not already loaded\n                if (font.url && !loadedFontUrls[font.url]) {\n                    var link = document.createElement('link');\n                    link.rel = 'stylesheet';\n                    link.href = font.url;\n                    document.head.appendChild(link);\n                    loadedFontUrls[font.url] = true;\n                }\n            });\n        }\n\n        // Request iframe size from host based on content\n        function requestSize() {\n            // Use requestAnimationFrame to ensure DOM has rendered\n            requestAnimationFrame(function() {\n                var contentHeight = container.offsetHeight;\n                window.myop_cta_handler('size-requested', {\n                    width: null, // Let host determine width (100%)\n                    height: contentHeight,\n                    minWidth: 280,\n                    required: false\n                });\n            });\n        }\n\n        // Build stats text from data\n        function buildStatsText(data) {\n            var parts = [];\n            if (data.upgradedCount != null) {\n                parts.push(data.upgradedCount + ' ' + data.upgradedLabel);\n            }\n            if (data.pendingCount != null) {\n                parts.push(data.pendingCount + ' ' + data.pendingLabel);\n            }\n            return parts.join(', ');\n        }\n\n        // Render function\n        function render(data) {\n            currentState = data;\n\n            // Load fonts first\n            loadFonts(data.fonts);\n\n            if (data.hasReferrals) {\n                container.className = 'referral-container state-active';\n\n                // Build header: \"$850 total earnings\" (use non-breaking space to prevent wrapping)\n                earningsHeader.innerHTML = data.earningsAmount + '&nbsp;' + data.earningsLabel;\n\n                // Build stats: \"54 upgraded, 12 pending\"\n                statsText.innerHTML = buildStatsText(data);\n\n                activeCtaBtn.innerHTML = '<svg class=\"btn-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M8 5V14.3333\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M2.33337 3C2.33337 1.896 3.18004 1 4.22271 1C7.01737 1 8.00004 5 8.00004 5H4.22271C3.18004 5 2.33337 4.104 2.33337 3Z\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M11.7773 5H8C8 5 8.98267 1 11.7773 1C12.82 1 13.6667 1.896 13.6667 3C13.6667 4.104 12.82 5 11.7773 5Z\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M15 5H1\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M13.6667 5V11.6667C13.6667 13.14 12.4734 14.3333 11 14.3333H5.00004C3.52671 14.3333 2.33337 13.14 2.33337 11.6667V5\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg><span>' + data.referralButtonText + '</span>';\n            } else {\n                container.className = 'referral-container state-empty';\n                subtitleTextEl.innerHTML = data.subtitleText;\n                incentiveTextEl.innerHTML = data.incentiveText;\n                emptyCtaBtn.innerHTML = '<svg class=\"btn-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M8 5V14.3333\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M2.33337 3C2.33337 1.896 3.18004 1 4.22271 1C7.01737 1 8.00004 5 8.00004 5H4.22271C3.18004 5 2.33337 4.104 2.33337 3Z\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M11.7773 5H8C8 5 8.98267 1 11.7773 1C12.82 1 13.6667 1.896 13.6667 3C13.6667 4.104 12.82 5 11.7773 5Z\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M15 5H1\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M13.6667 5V11.6667C13.6667 13.14 12.4734 14.3333 11 14.3333H5.00004C3.52671 14.3333 2.33337 13.14 2.33337 11.6667V5\" stroke=\"white\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg><span>' + data.emptyButtonText + '</span>';\n            }\n\n            // Request size after render\n            requestSize();\n        }\n\n        // Event handlers using delegation\n        emptyCtaBtn.addEventListener('click', function() {\n            window.myop_cta_handler('invite_navigation_clicked');\n        });\n\n        activeCtaBtn.addEventListener('click', function() {\n            window.myop_cta_handler('invite_navigation_clicked');\n        });\n\n        // Public API - defined at top level (CRITICAL for Myop)\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState; // Getter mode\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n            console.log('CTA Handler called:', action_id, payload);\n        };\n    })();\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            fonts: [\n                {\n                    id: 'main',\n                    family: 'TT Norms Pro',\n                    style: 'normal',\n                    weight: 400,\n                    url: 'https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css'\n                }\n            ],\n            hasReferrals: false,\n            subtitleText: 'Invite friends. Earn rewards.',\n            incentiveText: 'Get 1 free month for every referral',\n            emptyButtonText: 'Invite friends',\n            earningsAmount: '$850',\n            earningsLabel: 'total earnings',\n            upgradedCount: 54,\n            upgradedLabel: 'upgraded',\n            pendingCount: 12,\n            pendingLabel: 'pending',\n            referralButtonText: 'Invite more friends'\n        });\n    </script>\n</body>\n</html>\n"
        }
      }
    ]
  }
}