{
  "version": "0.2.10",
  "item": {
    "name": "PHDash_insights",
    "id": "d6b80b09-1520-4d55-b766-1d86204faaf1",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "4975c999-39de-46b5-8132-9197e214afb3",
        "name": "V0",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Insights Dashboard</title>\n  \n  <style>\n    /* --- 1. RESET & BASE --- */\n    body {\n      background-color: #f3f4f6;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      min-height: 100vh;\n      padding: 1rem;\n      margin: 0;\n      /* Using a standard, system-safe font stack */\n      font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n      box-sizing: border-box;\n    }\n    *, *:before, *:after {\n      box-sizing: inherit;\n    }\n\n    /* --- 2. WIDGET LAYOUT --- */\n    #dashboard-widget {\n      background-color: #ffffff;\n      border-radius: 1rem; /* rounded-2xl */\n      box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1); /* shadow-md */\n      width: 100%;\n      max-width: 64rem; /* max-w-4xl */\n      overflow: hidden;\n      display: none; /* Initially hidden until init is called */\n    }\n\n    .widget-header {\n      padding-left: 1.5rem;\n      padding-right: 1.5rem;\n      height: 3.5rem; /* h-14 */\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n    }\n\n    .widget-separator {\n      margin-left: 1.5rem;\n      margin-right: 1.5rem;\n      border-top: 1px solid #E1E1E1;\n    }\n\n    .widget-content {\n      padding: 1rem;\n    }\n\n    #stats-grid {\n      display: grid;\n      grid-template-columns: repeat(4, 1fr); /* Default: 4 columns */\n      gap: 1rem;\n      transition: opacity 0.3s ease-in-out;\n    }\n\n    /* --- 3. HEADER COMPONENTS --- */\n    #timeframe-container {\n      position: relative;\n    }\n    \n    #timeframe-button {\n      display: flex;\n      align-items: center;\n      gap: 0.5rem;\n      font-weight: 500;\n      color: #1f2937;\n      cursor: pointer;\n      font-size: 0.875rem;\n      background: none;\n      border: none;\n      padding: 0;\n    }\n\n    #chevron-icon {\n      width: 1rem;\n      height: 1rem;\n      color: #4b5563;\n      transition: transform 0.2s ease-in-out;\n    }\n    #chevron-icon.rotate-180 {\n      transform: rotate(180deg);\n    }\n\n    #timeframe-menu {\n      position: absolute;\n      top: 100%;\n      margin-top: 0.5rem;\n      width: 15rem;\n      background-color: #ffffff;\n      border-radius: 0.5rem;\n      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);\n      border: 1px solid #e5e7eb;\n      z-index: 10;\n      display: none; /* 'hidden' class toggles this */\n    }\n    #timeframe-menu.hidden {\n      display: none;\n    }\n\n    #timeframe-menu a {\n      display: block;\n      padding: 0.5rem 1rem;\n      font-size: 0.875rem;\n      color: #374151;\n      text-decoration: none;\n    }\n    #timeframe-menu a:hover {\n      background-color: #f3f4f6;\n    }\n\n    .menu-divider {\n      border-top: 1px solid #e5e7eb;\n      margin-top: 0.25rem;\n      margin-bottom: 0.25rem;\n    }\n\n    #menu-dots {\n      display: flex;\n      flex-direction: column;\n      gap: 0.25rem;\n      cursor: pointer;\n      padding: 0.5rem;\n    }\n    .menu-dot {\n      width: 0.25rem;\n      height: 0.25rem;\n      background-color: #374151;\n      border-radius: 9999px;\n    }\n\n    /* --- 4. STATS GRID COMPONENTS --- */\n    .stat-container {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      padding: 1rem;\n      position: relative;\n    }\n    \n    .stat-badge {\n      position: absolute;\n      top: -0.5rem;\n      background-color: #d9f99d; /* bg-lime-200 */\n      color: #65a30d; /* text-lime-800 */\n      font-size: 0.75rem;\n      font-weight: 500;\n      padding: 0.25rem 0.75rem;\n      border-radius: 9999px;\n    }\n    \n    .stat-value {\n      font-size: 1.875rem;\n      line-height: 2.25rem;\n      font-weight: 300;\n      color: #1f2937;\n      margin-top: 0.625rem;\n      min-height: 36px;\n    }\n    \n    .stat-description {\n      margin-top: 0.5rem;\n      font-size: 0.875rem;\n      color: #4b5563;\n      line-height: 1.25;\n    }\n    .stat-description span {\n      font-weight: 500;\n      color: #111827;\n    }\n\n    /* --- 5. STATS EMPTY STATES --- */\n    .stat-empty-text {\n      font-size: 0.875rem;\n      color: #4b5563;\n      margin-bottom: 0.75rem;\n    }\n    .stat-value-empty {\n      font-size: 1.875rem;\n      font-weight: 300;\n      color: #9ca3af;\n      margin-top: 0.625rem;\n    }\n    \n    .build-shop-button {\n      background-color: #e0e7ff; /* bg-indigo-100 */\n      color: #3730a3; /* text-indigo-800 */\n      font-weight: 500;\n      padding: 0.5rem 1.25rem;\n      border-radius: 9999px;\n      border: none;\n      cursor: pointer;\n      transition: background-color 0.3s ease;\n    }\n    .build-shop-button:hover {\n      background-color: #c7d2fe;\n    }\n\n    .no-activity-container {\n      grid-column: 1 / -1; /* Span all columns */\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      padding: 1rem;\n      height: 8rem;\n      color: #6b7280;\n    }\n\n    /* --- 6. TOOLTIP (from original) --- */\n    .tooltip-container {\n      position: relative;\n      display: inline-block;\n      cursor: pointer;\n    }\n    .tooltip-text {\n      visibility: hidden;\n      background-color: #333;\n      color: #fff;\n      text-align: center;\n      border-radius: 6px;\n      padding: 8px 12px;\n      position: absolute;\n      z-index: 1;\n      bottom: 140%;\n      left: 50%;\n      transform: translateX(-50%);\n      opacity: 0;\n      transition: opacity 0.3s;\n      box-shadow: 0 2px 8px rgba(0,0,0,0.2);\n      white-space: nowrap;\n      font-size: 12px;\n    }\n    .tooltip-text::after {\n      content: \"\";\n      position: absolute;\n      top: 100%;\n      left: 50%;\n      margin-left: -5px;\n      border-width: 5px;\n      border-style: solid;\n      border-color: #333 transparent transparent transparent;\n    }\n    .tooltip-container:hover .tooltip-text {\n      visibility: visible;\n      opacity: 1;\n    }\n    \n    /* --- 7. RESPONSIVE MEDIA QUERIES --- */\n    @media (max-width: 768px) { /* md breakpoint */\n      #stats-grid {\n        grid-template-columns: repeat(2, 1fr);\n      }\n    }\n    @media (max-width: 640px) { /* sm breakpoint */\n      .widget-header, .widget-separator {\n        padding-left: 1rem;\n        padding-right: 1rem;\n      }\n      .widget-content {\n        padding: 0.5rem;\n      }\n      #stats-grid {\n        grid-template-columns: 1fr;\n      }\n      .stat-container {\n        /* Add borders for stacked mobile view */\n        border-bottom: 1px solid #E1E1E1;\n      }\n      .stat-container:last-child {\n        border-bottom: none;\n      }\n    }\n\n  </style>\n</head>\n<body class=\"bg-gray-100\">\n\n  <!-- Main Card Container -->\n  <div id=\"dashboard-widget\">\n    <!-- Card Header -->\n    <div class=\"widget-header\">\n      <div class=\"relative\" id=\"timeframe-container\">\n        <!-- Custom Dropdown Button -->\n        <button id=\"timeframe-button\">\n          <span id=\"timeframe-text\"></span>\n          <svg id=\"chevron-icon\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"2\" stroke=\"currentColor\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19.5 8.25l-7.5 7.5-7.5-7.5\" />\n          </svg>\n        </button>\n        <!-- Custom Dropdown Menu -->\n        <div id=\"timeframe-menu\" class=\"hidden\">\n          <a href=\"#\" data-value=\"thisWeek\">This Week</a>\n          <a href=\"#\" data-value=\"thisMonth\">This Month</a>\n          <a href=\"#\" data-value=\"thisQuarter\">This Quarter</a>\n          <a href=\"#\" data-value=\"thisYear\">This Year</a>\n          <a href=\"#\" data-value=\"lastYear\">Last Year</a>\n          <!-- \"Custom Range\" has been removed -->\n        </div>\n      </div>\n      <div id=\"menu-dots\">\n        <div class=\"menu-dot\"></div>\n        <div class=\"menu-dot\"></div>\n        <div class=\"menu-dot\"></div>\n      </div>\n    </div>\n\n    <!-- Separator -->\n    <div class=\"widget-separator\"></div>\n\n    <!-- Card Content - Stats Grid -->\n    <div class=\"widget-content\">\n      <div id=\"stats-grid\">\n        <!-- Insights will be rendered here by JS -->\n      </div>\n    </div>\n  </div>\n\n  <script>\n    /**\n     * ========================================================================\n     * GLOBAL CTA HANDLER (PUBLIC INTERFACE)\n     * ========================================================================\n     * This function is called whenever the widget needs to communicate\n     * an action or event back to the parent application.\n     */\n    window.myop_cta_handler = (action_id, payload) => {\n      console.log('MYOP CTA Handler -- Action:', action_id, '-- Payload:', payload);\n      // The parent application would listen to this and react,\n      // e.g., by fetching new data and calling myop_init_interface again.\n    };\n\n    /**\n     * ========================================================================\n     * GLOBAL INIT FUNCTION (PUBLIC INTERFACE)\n     * ========================================================================\n     * This function receives the full configuration object and renders\n     * the entire widget. It is the single entry point for data.\n     */\n    window.myop_init_interface = (config) => {\n      console.log(\"myop_init_interface called with config:\", config);\n      const widget = document.getElementById('dashboard-widget');\n      const timeframeText = document.getElementById('timeframe-text');\n      const timeframeMenu = document.getElementById('timeframe-menu');\n\n      if (!config) {\n        console.error(\"myop_init_interface: No config provided.\");\n        return;\n      }\n      \n      // Show the widget\n      widget.style.display = 'block';\n\n      // Set the initial timeframe text\n      const timeframeLabel = timeframeMenu.querySelector(`[data-value=\"${config.defaultTimeframe}\"]`)?.textContent || 'Insights';\n      \n      if (config.defaultTimeframe === 'custom' && config.customRangeLabel) {\n          timeframeText.textContent = config.customRangeLabel;\n      } else {\n          timeframeText.textContent = `Insights for ${timeframeLabel.toLowerCase()}`;\n      }\n\n      // Render the main widget content\n      renderWidgetData(config);\n    };\n\n    /**\n     * ========================================================================\n     * INTERNAL WIDGET LOGIC\n     * ========================================================================\n     */\n    document.addEventListener('DOMContentLoaded', () => {\n\n      // --- 1. LANGUAGE STRINGS ---\n      // These are kept internally to populate the UI\n      const lang = {\n        \"dashboardInsightsGalleryDelivered\": \"Gallery delivered\\nwith {photos} photos\",\n        \"dashboardInsightsGalleryViews\": \"Total gallery views\\nby {users} users\",\n        \"dashboardInsightsItemsDownloaded\": \"Items downloaded\\nfrom {galleries} galleries\",\n        \"dashboardInsightsDownloadsEmptyState\": \"No photos\\ndownloads yet\",\n        \"dashboardInsightsDownloadsEmptyStatePast\": \"No downloads in this period\",\n        \"dashboardInsightsRevenue\": \"Revenue from\\n{galleries} galleries\",\n        \"dashboardInsightsRevenueEmptyState\": \"Enjoy a passive\\nincome!\",\n        \"dashboardInsightsRevenueEmptyStateButton\": \"Build shop\",\n        \"dashboardInsightsRevenueEmptyStatePast\": \"No revenue in this period\",\n        \"dashboardInsightsNoActivity\": \"No activity during this time period\",\n      };\n\n      // --- 2. UI ELEMENTS ---\n      const widget = document.getElementById('dashboard-widget');\n      const timeframeButton = document.getElementById('timeframe-button');\n      const timeframeMenu = document.getElementById('timeframe-menu');\n      const chevronIcon = document.getElementById('chevron-icon');\n      const statsGrid = document.getElementById('stats-grid');\n      const menuDots = document.getElementById('menu-dots');\n      \n      // --- 3. INTERNAL HELPER FUNCTIONS ---\n\n      /**\n       * Renders a single insight card, including empty states.\n       */\n      const renderInsight = (container, insightData, isPastPeriod) => {\n        const getMainCount = (data) => {\n          switch (data.type) {\n            case 'galleryViews': return data.views;\n            case 'galleryDelivered': return data.galleries;\n            case 'downloads': return data.items;\n            case 'revenue': return data.revenue;\n            default: return 0;\n          }\n        };\n        const count = getMainCount(insightData);\n        let content = '';\n\n        if (insightData.showEmptyState || count === 0) {\n          switch (insightData.type) {\n            case 'downloads':\n              content = `<p class=\"stat-empty-text\">${(isPastPeriod ? lang.dashboardInsightsDownloadsEmptyStatePast : lang.dashboardInsightsDownloadsEmptyState).replace('\\n', '<br>')}</p>`;\n              break;\n            case 'revenue':\n              if (insightData.shopExists) {\n                content = `<p class=\"stat-empty-text\">${isPastPeriod ? lang.dashboardInsightsRevenueEmptyStatePast : 'No revenue yet'}</p>`;\n              } else {\n                content = `<p class=\"stat-empty-text\">${lang.dashboardInsightsRevenueEmptyState.replace('\\n', '<br>')}</p><button data-action=\"build-shop\" class=\"build-shop-button\">${lang.dashboardInsightsRevenueEmptyStateButton}</button>`;\n              }\n              break;\n            default:\n              // Default empty state for 'galleryViews' and 'galleryDelivered'\n              content = `<p class=\"stat-value-empty\">0</p><p class=\"stat-description\">&nbsp;</p>`;\n              break;\n          }\n        } else {\n          // Standard state with data\n          const badge = insightData.showBadge ? `<div class=\"stat-badge\">${insightData.badgeContent}</div>` : '';\n          const value = `<p class=\"stat-value\"></p>`; // Value populated below\n          let description = '';\n          switch (insightData.type) {\n            case 'galleryViews':\n              description = lang.dashboardInsightsGalleryViews.replace('{users}', `<span>${insightData.users.toLocaleString('en-US')}</span>`);\n              break;\n            case 'galleryDelivered':\n              description = lang.dashboardInsightsGalleryDelivered.replace('{photos}', `<span>${insightData.photos.toLocaleString('en-US')}</span>`);\n              break;\n            case 'downloads':\n              description = lang.dashboardInsightsItemsDownloaded.replace('{galleries}', `<span>${insightData.galleries.toLocaleString('en-US')}</span>`);\n              break;\n            case 'revenue':\n              description = lang.dashboardInsightsRevenue.replace('{galleries}', `<span>${insightData.galleries.toLocaleString('en-US')}</span>`);\n              break;\n          }\n          content = `${badge}${value}<p class=\"stat-description\">${description.replace('\\n', '<br>')}</p>`;\n        }\n        \n        container.innerHTML = content;\n        \n        // Now populate the value to handle currency\n        const valueElement = container.querySelector('.stat-value');\n        if (valueElement && !(insightData.showEmptyState || count === 0)) {\n          let formattedValue = '';\n          if (insightData.currencySymbol && insightData.currencyCode) {\n            // Add tooltip for currency\n            formattedValue += `<span class=\"tooltip-container\">${insightData.currencySymbol}<span class=\"tooltip-text\">${insightData.currencyCode}</span></span>`;\n          }\n          formattedValue += count.toLocaleString('en-US');\n          valueElement.innerHTML = formattedValue;\n        }\n      };\n      \n      /**\n       * Main internal rendering function.\n       * Takes the config object and populates the entire widget.\n       */\n      window.renderWidgetData = (config) => {\n        if (!config || !config.insights) {\n            console.error(\"renderWidgetData: Invalid config or missing insights.\");\n            return;\n        }\n        \n        menuDots.style.display = config.showMenu ? 'flex' : 'none';\n        \n        statsGrid.style.opacity = 0;\n        \n        setTimeout(() => {\n          const hasDelivered = config.insights.some(insight => insight.type === 'galleryDelivered' && insight.galleries > 0);\n          \n          if (!hasDelivered) {\n            // Special \"No Activity\" state\n            statsGrid.innerHTML = `<div class=\"no-activity-container\"><p>${lang.dashboardInsightsNoActivity}</p></div>`;\n          } else {\n            statsGrid.innerHTML = ''; // Clear the grid\n            \n            config.insights.forEach(insightData => {\n              const insightContainer = document.createElement('div');\n              insightContainer.className = `stat-container`;\n              statsGrid.appendChild(insightContainer);\n              renderInsight(insightContainer, insightData, config.isPast);\n            });\n\n            // Add border separators (CSS only handles mobile)\n            const containers = statsGrid.querySelectorAll('.stat-container');\n            const gridCols = window.getComputedStyle(statsGrid).gridTemplateColumns.split(' ').length;\n            \n            for (let i = 0; i < containers.length; i++) {\n                // Remove old borders\n                containers[i].style.borderLeft = 'none';\n                containers[i].style.borderBottom = 'none';\n\n                // Add vertical borders\n                if (gridCols > 1 && (i % gridCols !== 0)) {\n                    containers[i].style.borderLeft = '1px solid #E1E1E1';\n                }\n                \n                // Add horizontal borders for 2-col layout\n                if (gridCols === 2 && i < containers.length - 2) {\n                     containers[i].style.borderBottom = '1px solid #E1E1E1';\n                }\n            }\n          }\n          statsGrid.style.opacity = 1;\n        }, 300); // Short delay for fade-in effect\n      };\n\n\n      // --- 4. EVENT LISTENERS ---\n\n      // Toggle timeframe dropdown\n      timeframeButton.addEventListener('click', (e) => {\n        e.stopPropagation();\n        timeframeMenu.classList.toggle('hidden');\n        chevronIcon.classList.toggle('rotate-180');\n      });\n\n      // Close dropdown when clicking outside\n      window.addEventListener('click', () => {\n        if (!timeframeMenu.classList.contains('hidden')) {\n          timeframeMenu.classList.add('hidden');\n          chevronIcon.classList.remove('rotate-180');\n        }\n      });\n\n      // Handle timeframe selection\n      timeframeMenu.addEventListener('click', (e) => {\n        e.preventDefault();\n        const target = e.target;\n        if (target.tagName === 'A' && target.dataset.value) {\n          const timeframe = target.dataset.value;\n          \n          // Call the global CTA handler.\n          // The widget will NOT update itself.\n          // The parent app must call myop_init_interface with new data.\n          window.myop_cta_handler('timeframeChanged', { selectedTimeframe: timeframe });\n          \n          // We can, however, optimistically close the menu\n          timeframeMenu.classList.add('hidden');\n          chevronIcon.classList.remove('rotate-180');\n        }\n      });\n\n      // Handle \"Build Shop\" button click\n      statsGrid.addEventListener('click', (e) => {\n        if (e.target && e.target.dataset.action === 'build-shop') {\n          window.myop_cta_handler('buildShopClicked', { message: 'User clicked the build shop button' });\n        }\n      });\n      \n      // Handle 3-dot menu click\n      menuDots.addEventListener('click', () => {\n        window.myop_cta_handler('menuClicked', {});\n      });\n\n      // Watch for resizes to re-apply borders correctly\n      // (Simple debouncer to avoid firing on every pixel change)\n      let resizeTimer;\n      window.addEventListener('resize', () => {\n          clearTimeout(resizeTimer);\n          resizeTimer = setTimeout(() => {\n              // Re-run the border logic from renderWidgetData\n              const containers = statsGrid.querySelectorAll('.stat-container');\n              if (containers.length === 0) return;\n              \n              const gridCols = window.getComputedStyle(statsGrid).gridTemplateColumns.split(' ').length;\n            \n              for (let i = 0; i < containers.length; i++) {\n                  containers[i].style.borderLeft = 'none';\n                  containers[i].style.borderBottom = 'none';\n                  if (gridCols > 1 && (i % gridCols !== 0)) {\n                      containers[i].style.borderLeft = '1px solid #E1E1E1';\n                  }\n                  if (gridCols === 2 && i < containers.length - 2) {\n                       containers[i].style.borderBottom = '1px solid #E1E1E1';\n                  }\n              }\n          }, 100);\n      });\n\n      // NOTE: NO initial render.\n      // The widget is now \"dumb\" and will wait for\n      // window.myop_init_interface() to be called.\n      \n      // --- DEMO ---\n      // To test the widget, you can manually call this from the console:\n      \n      window.myop_init_interface({\n        showWidget: true,\n        showMenu: true,\n        isPast: false,\n        defaultTimeframe: 'thisYear',\n        insights: [\n          { type: 'galleryViews', views: 6542, users: 3084, showBadge: false, badgeContent: '102 this week!' },\n          { type: 'galleryDelivered', galleries: 41, photos: 9425, showBadge: false, badgeContent: '' },\n          { type: 'downloads', items: 10005, galleries: 35, showBadge: true, badgeContent: '10K Downloads!' },\n        ]\n      });\n      \n\n    });\n    \n  </script>\n\n</body>\n</html>"
        }
      }
    ]
  }
}