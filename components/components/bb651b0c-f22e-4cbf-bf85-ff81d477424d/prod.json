-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                            '</defs>' +\n                        '</svg>' +\n                    '</div>' +\n                    '<h1 class=\"request-title\">' + escapeHtml(r.title || ('Implementation request for ' + (r.componentName || 'Component'))) + '</h1>' +\n                    '<div class=\"request-fields\">';\n\n            // Contact details\n            html += '<div class=\"request-field\">' +\n                '<div class=\"request-field__label\">' + escapeHtml(r.contactLabel) + '</div>' +\n                '<div class=\"request-field__value\">' + escapeHtml(r.contactValue) + '</div>' +\n            '</div>';\n\n            // Deadline\n            html += '<div class=\"request-field\">' +\n                '<div class=\"request-field__label\">' + escapeHtml(r.deadlineLabel) + '</div>' +\n                '<div class=\"request-field__value\">' + escapeHtml(r.deadlineValue) + '</div>' +\n            '</div>';\n\n            // Description\n            html += '<div class=\"request-field request-field--description\">' +\n                '<div class=\"request-field__label\">' + escapeHtml(r.descriptionLabel) + '</div>' +\n                '<div class=\"request-field__value\">' + escapeHtml(r.descriptionValue) + '</div>' +\n            '</div>';\n\n            html += '</div>'; // close .request-fields\n\n            html += '</div>'; // close .request-panel__content\n\n            // Footer with CTA Button\n            html += '<div class=\"request-panel__footer\">' +\n                '<div class=\"request-cta\">' +\n                    '<button class=\"request-cta__button\" data-action=\"edit-clicked\">' + escapeHtml(data.ctaButton.label) + '</button>' +\n                '</div>' +\n            '</div>';\n\n            html += '</div>'; // close .request-panel\n            return html;\n        }\n\n        function escapeHtml(str) {\n            if (!str) return '';\n            return String(str)\n                .replace(/&/g, '&amp;')\n                .replace(/</g, '&lt;')\n                .replace(/>/g, '&gt;')\n                .replace(/\"/g, '&quot;');\n        }\n\n        function render(data) {\n            var container = document.getElementById('app-root');\n            container.innerHTML =\n                buildTopBar(data) +\n                '<div class=\"main-content\">' +\n                    buildPreviewPanel(data) +\n                    buildRequestPanel(data) +\n                '</div>';\n\n            // Attach event listeners\n            var ctaBtn = container.querySelector('[data-action=\"edit-clicked\"]');\n            if (ctaBtn) {\n                ctaBtn.addEventListener('click', function() {\n                    window.myop_cta_handler('edit-clicked');\n                });\n            }\n\n            // Toggle panel collapse/expand (desktop)\n            var toggleBtn = container.querySelector('.copy-icon-btn');\n            var requestPanel = container.querySelector('.request-panel');\n            if (toggleBtn && requestPanel) {\n                toggleBtn.addEventListener('click', function() {\n                    requestPanel.classList.toggle('collapsed');\n                });\n\n                // Fixed-position tooltip (escapes overflow:hidden clipping)\n                var tooltip = toggleBtn.querySelector('.tooltip');\n                var tooltipDelay;\n                if (tooltip) {\n                    toggleBtn.addEventListener('mouseenter', function() {\n                        tooltipDelay = setTimeout(function() {\n                            var rect = toggleBtn.getBoundingClientRect();\n                            tooltip.style.left = (rect.left + rect.width / 2) + 'px';\n                            tooltip.style.top = (rect.bottom + 6) + 'px';\n                            tooltip.style.transform = 'translateX(-50%)';\n                            tooltip.style.opacity = '1';\n                        }, 1000);\n                    });\n                    toggleBtn.addEventListener('mouseleave', function() {\n                        clearTimeout(tooltipDelay);\n                        tooltip.style.opacity = '0';\n                    });\n                }\n            }\n\n            // Mobile toggle button to open/close panel\n            var mobileToggleBtn = container.querySelector('.mobile-toggle-btn');\n            var mobileOverlay = container.querySelector('.mobile-overlay');\n            if (mobileToggleBtn && requestPanel && mobileOverlay) {\n                mobileToggleBtn.addEventListener('click', function() {\n                    requestPanel.classList.toggle('mobile-open');\n                    mobileOverlay.classList.toggle('active');\n                });\n            }\n\n            // Desktop: drag on header to scroll content\n            var headerFixed = container.querySelector('.request-panel__header-fixed');\n            var panelContent = container.querySelector('.request-panel__content');\n            if (headerFixed && panelContent) {\n                var dragging = false;\n                var lastY = 0;\n                headerFixed.style.cursor = 'grab';\n                headerFixed.addEventListener('mousedown', function(e) {\n                    dragging = true;\n                    lastY = e.clientY;\n                    headerFixed.style.cursor = 'grabbing';\n                    document.body.style.userSelect = 'none';\n                    e.preventDefault();\n                    e.stopPropagation();\n                });\n                document.addEventListener('mousemove', function(e) {\n                    if (!dragging) return;\n                    var delta = lastY - e.clientY;\n                    panelContent.scrollTop += delta;\n                    lastY = e.clientY;\n                });\n                document.addEventListener('mouseup', function() {\n                    if (!dragging) return;\n                    dragging = false;\n                    headerFixed.style.cursor = 'grab';\n                    document.body.style.userSelect = '';\n                });\n                headerFixed.addEventListener('wheel', function(e) {\n                    panelContent.scrollTop += e.deltaY;\n                    e.preventDefault();\n                }, { passive: false });\n            }\n\n            // Mobile: drag header to close panel + tap header to close\n            var isMobile = window.matchMedia('(max-width: 768px)').matches;\n            if (isMobile && headerFixed && requestPanel && mobileOverlay) {\n                var startY = 0;\n                var currentTranslateY = 0;\n                var isDraggingPanel = false;\n                var didDrag = false;\n\n                function closeMobilePanel() {\n                    requestPanel.style.transition = 'transform 0.3s ease';\n                    requestPanel.style.transform = 'translateY(100%)';\n                    mobileOverlay.style.transition = 'opacity 0.3s ease';\n                    mobileOverlay.classList.remove('active');\n                    setTimeout(function() {\n                        requestPanel.classList.remove('mobile-open');\n                        requestPanel.style.transition = '';\n                        requestPanel.style.transform = '';\n                    }, 300);\n                }\n\n                function snapBack() {\n                    requestPanel.style.transition = 'transform 0.25s ease';\n                    requestPanel.style.transform = 'translateY(0)';\n                    mobileOverlay.style.opacity = '';\n                    setTimeout(function() {\n                        requestPanel.style.transition = '';\n                    }, 250);\n                }\n\n                // Pointer events work for both mouse and touch, more reliable in iframes\n                headerFixed.addEventListener('pointerdown', function(e) {\n                    isDraggingPanel = true;\n                    didDrag = false;\n                    startY = e.clientY;\n                    currentTranslateY = 0;\n                    requestPanel.style.transition = 'none';\n                    headerFixed.setPointerCapture(e.pointerId);\n                    e.preventDefault();\n                });\n\n                headerFixed.addEventListener('pointermove', function(e) {\n                    if (!isDraggingPanel) return;\n                    var deltaY = e.clientY - startY;\n                    if (Math.abs(deltaY) > 3) didDrag = true;\n                    currentTranslateY = Math.max(0, deltaY);\n                    requestPanel.style.transform = 'translateY(' + currentTranslateY + 'px)';\n                    var panelHeight = requestPanel.offsetHeight;\n                    var opacity = 1 - (currentTranslateY / panelHeight);\n                    mobileOverlay.style.opacity = Math.max(0, opacity);\n                    e.preventDefault();\n                });\n\n                headerFixed.addEventListener('pointerup', function(e) {\n                    if (!isDraggingPanel) return;\n                    isDraggingPanel = false;\n                    var panelHeight = requestPanel.offsetHeight;\n                    if (currentTranslateY > panelHeight * 0.25) {\n                        closeMobilePanel();\n                    } else {\n                        snapBack();\n                    }\n                });\n\n                headerFixed.addEventListener('pointercancel', function() {\n                    if (!isDraggingPanel) return;\n                    isDraggingPanel = false;\n                    snapBack();\n                });\n\n                // Tap anywhere on header to close (if not a drag)\n                headerFixed.addEventListener('click', function() {\n                    if (!didDrag) {\n                        closeMobilePanel();\n                    }\n                });\n\n                // Also add touch-action CSS to prevent browser scroll interference\n                headerFixed.style.touchAction = 'none';\n            }\n\n            // Mobile overlay tap to close\n            if (mobileOverlay && requestPanel) {\n                mobileOverlay.addEventListener('click', function() {\n                    requestPanel.classList.remove('mobile-open');\n                    mobileOverlay.classList.remove('active');\n                });\n            }\n\n        }\n\n        // Track last known mobile state to avoid unnecessary re-renders\n        var wasMobile = window.matchMedia('(max-width: 768px)').matches;\n\n        // Re-render when the breakpoint is crossed\n        var mq = window.matchMedia('(max-width: 768px)');\n        function onBreakpointChange(e) {\n            var isMobileNow = e.matches;\n            if (isMobileNow !== wasMobile && currentState) {\n                wasMobile = isMobileNow;\n                render(currentState);\n            }\n        }\n        // Use addEventListener for modern browsers, addListener as fallback\n        if (mq.addEventListener) {\n            mq.addEventListener('change', onBreakpointChange);\n        } else if (mq.addListener) {\n            mq.addListener(onBreakpointChange);\n        }\n\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            currentState = data;\n            wasMobile = window.matchMedia('(max-width: 768px)').matches;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            topBar: {\n                message: \"A Myop component was shared with you\",\n                subtitle: \"You've been invited to implement this component - open in Myop to get started.\"\n            },\n            request: {\n                componentName: \"Product Data Table\",\n                title: \"\",\n                contactLabel: \"Contact details\",\n                contactValue: \"Daphna@pendalogic.com\",\n                descriptionLabel: \"Description\",\n                descriptionValue: \"We need to redesign and rebuild the product data table. The focus should be on creating an improved user experience, especially for mobile devices. Please change the table to use our brand colors and typography, as specified in the attached style guide and links. Make sure the new design follows the conventions outlined in the attached style documents.\",\n                deadlineLabel: \"Deadline\",\n                deadlineValue: \"N/A\"\n            },\n            preview: {\n                placeholder: true,\n                label: \"Component preview\"\n            },\n            ctaButton: {\n                label: \"Edit in Myop\"\n            }\n        });\n    </script>\n</body>\n</html>\n"
        },
