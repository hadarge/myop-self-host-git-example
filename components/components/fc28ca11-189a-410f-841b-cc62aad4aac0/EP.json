        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"auto\"}'>\r\n\r\n    <script type=\"myop/types\">\r\n// =============================================================================\r\n// MYOP COMPONENT TYPE DEFINITIONS\r\n// =============================================================================\r\n\r\n/**\r\n * Font definition for dynamic font loading\r\n */\r\ninterface MyopFont {\r\n  id: string;\r\n  family: string;\r\n  style?: string;\r\n  weight?: number;\r\n  url: string;\r\n}\r\n\r\n/**\r\n * Lang strings passed under the \"lang\" key\r\n * title supports the {daysLeft} placeholder, e.g. \"{daysLeft} days left\"\r\n */\r\ninterface MyopLang {\r\n  title: string; // supports {daysLeft} placeholder\r\n  body: string;\r\n  buttonText: string;\r\n}\r\n\r\n/**\r\n * Data passed to myop_init_interface(data)\r\n */\r\ninterface MyopInitData {\r\n  trialEndDate: string; // ISO 8601 date string, e.g. \"2026-04-08\"\r\n  lang: MyopLang;\r\n  fonts: MyopFont[];\r\n}\r\n\r\n/**\r\n * Actions and payloads for myop_cta_handler(action, payload)\r\n */\r\ninterface MyopCtaPayloads {\r\n  'open_popup': { dashPopupId: string };\r\n}\r\n\r\n// =============================================================================\r\n// DO NOT EDIT BELOW - Standard Myop type declarations\r\n// =============================================================================\r\n\r\ndeclare function myop_init_interface(): MyopInitData;\r\ndeclare function myop_init_interface(data: MyopInitData): void;\r\n\r\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\r\n  action: K,\r\n  payload: MyopCtaPayloads[K]\r\n): void;\r\n    </script>\r\n\r\n    <style>\r\n        * { box-sizing: border-box; margin: 0; padding: 0; }\r\n        html, body { width: 100%; margin: 0; padding: 0; }\r\n\r\n        #app-root {\r\n            width: 100%;\r\n            background-color: #f5eaff;\r\n            padding: 20px 24px 24px;\r\n            font-family: var(--font_main, sans-serif);\r\n            border-radius: 8px;\r\n        }\r\n\r\n        .banner-title {\r\n            font-size: 22px;\r\n            font-weight: var(--font_main_weight, 700);\r\n            font-style: var(--font_main_style, normal);\r\n            color: #54033C;\r\n            margin-bottom: 4px;\r\n            line-height: 1.2;\r\n        }\r\n\r\n        .banner-body {\r\n            font-size: 13px;\r\n            font-weight: var(--font_main_weight, 400);\r\n            font-style: var(--font_main_style, normal);\r\n            color: #7B2D5E;\r\n            margin-bottom: 18px;\r\n            line-height: 1.4;\r\n        }\r\n\r\n        .banner-btn {\r\n            display: inline-block;\r\n            padding: 8px 16px;\r\n            background: transparent;\r\n            border: 1.5px solid #54033C;\r\n            border-radius: 4px;\r\n            color: #54033C;\r\n            font-size: 13px;\r\n            font-weight: var(--font_main_weight, 500);\r\n            font-style: var(--font_main_style, normal);\r\n            cursor: pointer;\r\n            font-family: var(--font_main, sans-serif);\r\n            transition: background 0.15s, color 0.15s;\r\n        }\r\n\r\n        .banner-btn:hover {\r\n            background: #54033C;\r\n            color: #fff;\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div id=\"app-root\">\r\n        <div class=\"banner-title\" id=\"banner-title\"></div>\r\n        <div class=\"banner-body\" id=\"banner-body\"></div>\r\n        <button class=\"banner-btn\" id=\"banner-btn\"></button>\r\n    </div>\r\n\r\n    <script>\r\n    (function() {\r\n        var currentState = null;\r\n        var loadedFontUrls = {};\r\n\r\n        var titleEl = document.getElementById('banner-title');\r\n        var bodyEl  = document.getElementById('banner-body');\r\n        var btnEl   = document.getElementById('banner-btn');\r\n        var root    = document.documentElement;\r\n\r\n        btnEl.addEventListener('click', function() {\r\n            window.myop_cta_handler('open_popup', { dashPopupId: 'p2promopopup' });\r\n        });\r\n\r\n        function applyFonts(fonts) {\r\n            if (!fonts || !fonts.length) return;\r\n            fonts.forEach(function(font) {\r\n                // Load font stylesheet if not already loaded\r\n                if (font.url && !loadedFontUrls[font.url]) {\r\n                    var link = document.createElement('link');\r\n                    link.rel = 'stylesheet';\r\n                    link.href = font.url;\r\n                    document.head.appendChild(link);\r\n                    loadedFontUrls[font.url] = true;\r\n                }\r\n                // Set CSS variables using the font id\r\n                var varPrefix = '--font_' + font.id;\r\n                root.style.setProperty(varPrefix, font.family);\r\n                if (font.style) {\r\n                    root.style.setProperty(varPrefix + '_style', font.style);\r\n                }\r\n                if (font.weight) {\r\n                    root.style.setProperty(varPrefix + '_weight', String(font.weight));\r\n                }\r\n            });\r\n        }\r\n\r\n        function calcDaysLeft(isoDate) {\r\n            if (!isoDate) return 0;\r\n            var target = new Date(isoDate);\r\n            var now = new Date();\r\n            // Strip time component for accurate whole-day diff\r\n            target.setHours(0, 0, 0, 0);\r\n            now.setHours(0, 0, 0, 0);\r\n            var diff = Math.ceil((target - now) / (1000 * 60 * 60 * 24));\r\n            return Math.max(diff, 0);\r\n        }\r\n\r\n        window.myop_init_interface = function(data) {\r\n            if (!data) return currentState;\r\n            currentState = data;\r\n            applyFonts(data.fonts);\r\n            var daysLeft = calcDaysLeft(data.trialEndDate);\r\n            var title = (data.lang.title || '').replace('{daysLeft}', daysLeft);\r\n            titleEl.textContent = title;\r\n            bodyEl.textContent  = data.lang.body;\r\n            btnEl.textContent   = data.lang.buttonText;\r\n        };\r\n\r\n        window.myop_cta_handler = function(action_id, payload) {\r\n            // Overridden by host application\r\n        };\r\n    })();\r\n    </script>\r\n\r\n    <script id=\"myop_preview\">\r\n        window.myop_init_interface({\"trialEndDate\":\"2026-04-08\",\"lang\":{\"title\":\"{daysLeft} days left\",\"body\":\"to enjoy unlimited Pic-Time 2.0 designs\",\"buttonText\":\"Learn more\"},\"fonts\":[{\"id\":\"main\",\"family\":\"TT Norms Pro\",\"style\":\"normal\",\"weight\":400,\"url\":\"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"}]});\r\n    </script>\r\n</body>\r\n</html>\r\n"
        }
