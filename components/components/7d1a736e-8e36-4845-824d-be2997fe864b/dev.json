ition: absolute; overflow: hidden; background: transparent; }\n        .media-slot img, .media-slot video { width: 100%; height: 100%; object-fit: cover; display: block; }\n        .media-slot-0 { left: 60.67%; top: 20.31%; width: 11.33%; height: 64.20%; }\n        .is-mobile .banner-text { top: 5%; left: 11.4%; right: 11.4%; bottom: 55%; align-items: center; text-align: center; gap: 24px; }\n        .is-mobile .media-slot-0 { left: 54.15%; top: 51.83%; width: 38.55%; height: 31.36%; }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n    <script>\n    (function() {\n        var currentState = null, root = document.getElementById('app-root');\n        var fontConfig = { desktop: { title: { max: 42, min: 32, maxLines: 2, lineHeight: 1.15 }, description: { max: 24, min: 16, maxLines: 2, lineHeight: 1.35 } }, mobile: { title: { max: 36, min: 24, maxLines: 1, lineHeight: 1.15 }, description: { max: 16, min: 14, maxLines: 2, lineHeight: 1.35 } } };\n        function fitTextInContainer(container, titleEl, descEl, cfg) {\n            if (!titleEl && !descEl) return;\n            var tCfg=cfg.title, dCfg=cfg.description, tSize=tCfg.max, dSize=dCfg.max, cH=container.offsetHeight;\n            if (titleEl) { titleEl.style.fontSize=tSize+'px'; titleEl.style.lineHeight=String(tCfg.lineHeight); }\n            if (descEl) { descEl.style.fontSize=dSize+'px'; descEl.style.lineHeight=String(dCfg.lineHeight); }\n            if (titleEl) { var mH=Math.ceil(tSize*tCfg.lineHeight*tCfg.maxLines)+2; while(titleEl.scrollHeight>mH&&tSize>tCfg.min){tSize--;titleEl.style.fontSize=tSize+'px';mH=Math.ceil(tSize*tCfg.lineHeight*tCfg.maxLines)+2;} }\n            if (descEl) { var mH2=Math.ceil(dSize*dCfg.lineHeight*dCfg.maxLines)+2; while(descEl.scrollHeight>mH2&&dSize>dCfg.min){dSize--;descEl.style.fontSize=dSize+'px';mH2=Math.ceil(dSize*dCfg.lineHeight*dCfg.maxLines)+2;} }\n            var i=30; while(i-->0&&container.scrollHeight>cH+2){var ts=titleEl&&tSize>tCfg.min,ds=descEl&&dSize>dCfg.min;if(!ts&&!ds)break;if(ts){tSize--;titleEl.style.fontSize=tSize+'px';}if(ds){dSize--;descEl.style.fontSize=dSize+'px';}}\n        }\n        function applyLayout(mob) { root.classList.toggle('is-mobile',!!mob); var cfg=mob?fontConfig.mobile:fontConfig.desktop; var c=root.querySelector('.banner-text'),t=root.querySelector('.banner-title'),d=root.querySelector('.banner-description'); if(c) fitTextInContainer(c,t,d,cfg); }\n        function escapeHtml(s) { if(!s)return''; return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;'); }\n        function renderMedia(item,i) { if(!item||!item.url)return''; var t=item.type||'image'; if(t==='video')return'<div class=\"media-slot media-slot-'+i+'\"><video src=\"'+escapeHtml(item.url)+'\" muted loop autoplay playsinline></video></div>'; return'<div class=\"media-slot media-slot-'+i+'\"><img src=\"'+escapeHtml(item.url)+'\" alt=\"\" loading=\"lazy\" /></div>'; }\n        function render(data) {\n            var texts=data.texts||{}, imgs=data.backgroundImages||{}, mob=!!data.isMobile;\n            var bg=(mob?(imgs.mobile||imgs.desktop):imgs.desktop)||'', h='';\n            if(bg) h+='<img class=\"banner-bg\" src=\"'+escapeHtml(bg)+'\" alt=\"\" />';\n            h+='<div class=\"banner-text\">'; if(texts.title) h+='<div class=\"banner-title\">'+escapeHtml(texts.title)+'</div>'; if(texts.description) h+='<div class=\"banner-description\">'+escapeHtml(texts.description)+'</div>'; h+='</div>';\n            var m=data.media||[]; if(m.length>0) h+=renderMedia(m[0],0);\n            root.innerHTML=h; root.onclick=function(){window.myop_cta_handler('banner-clicked',{linkMode:data.linkMode,linkProps:data.linkProps});}; applyLayout(mob);\n        }\n        window.myop_init_interface=function(d){if(!d)return currentState;currentState=d;render(d);};\n        window.myop_cta_handler=function(){};\n    })();\n    </script>\n    <script id=\"myop_preview\">\n        window.myop_init_interface(