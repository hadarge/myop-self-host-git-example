    "id": "8c78c06a-b8c0-4457-bb7d-c02136da3daf",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "name": "Version 11",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <title>Save Gallery As Template</title>\n\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Language strings for the component\n     */\n    interface LangStrings {\n        modalTitle: string;\n        templateNameLabel: string;\n        templateNamePlaceholder: string;\n        infoText: string;\n        successInfoText: string;\n        learnMoreText: string;\n        saveButtonText: string;\n        templateSavedText: string;\n        validationRequired: string;\n    }\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n        saveCompleted: boolean;\n        knowledgeBaseUrl: string;\n        lang: LangStrings;\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n        'save-template': { templateName: string };\n        'size-requested': {\n            width?: number | null;\n            height?: number | null;\n            minWidth?: number | null;\n            maxWidth?: number | null;\n            minHeight?: number | null;\n            maxHeight?: number | null;\n            required?: boolean;\n        };\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        html, body {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            margin: 0;\n            padding: 0;\n            font-family: 'Gotham Narrow SSm', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;\n            background-color: white;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .modal {\n            background: white;\n            width: 100%;\n        }\n\n        .modal-content {\n            padding: 40px;\n        }\n\n        .modal-title {\n            font-size: 16px;\n            letter-spacing: 1.5px;\n            text-transform: uppercase;\n            color: #444;\n            font-weight: 400;\n            margin-bottom: 30px;\n            text-align: left;\n        }\n\n        .template-name-section {\n            margin-bottom: 20px;\n        }\n\n        .field-label {\n            font-size: 11px;\n            letter-spacing: 0.2px;\n            text-transform: uppercase;\n            color: #bcbcbc;\n            margin-bottom: 8px;\n            display: block;\n        }\n\n        .text-input {\n            width: 100%;\n            padding: 11px 15px;\n            border: 1px solid #868686;\n            background: white;\n            font-size: 13px;\n            letter-spacing: 0.6px;\n            color: #444;\n        }\n\n        .text-input::placeholder {\n            color: #bcbcbc;\n        }\n\n        .text-input:focus {\n            outline: none;\n            border-color: #444;\n        }\n\n        .text-input.error {\n            border-color: #FF232B;\n        }\n\n        .validation-error {\n            font-size: 13px;\n            letter-spacing: 0.2px;\n            color: #FF232B;\n            margin-top: 5px;\n            height: 20px;\n            opacity: 0;\n        }\n\n        .validation-error.active {\n            opacity: 1;\n        }\n\n        .info-section {\n            margin-top: 40px;\n        }\n\n        .info-text {\n            font-size: 13px;\n            letter-spacing: 0.2px;\n            color: #868686;\n            line-height: 1.5;\n            margin-bottom: 8px;\n        }\n\n        .learn-more-link {\n            font-size: 13px;\n            letter-spacing: 0.2px;\n            color: #868686;\n            text-decoration: underline;\n            cursor: pointer;\n            display: inline-block;\n        }\n\n        .learn-more-link:hover {\n            color: #444;\n        }\n\n        .save-button {\n            width: 100%;\n            height: 40px;\n            background: #ececec;\n            border: none;\n            cursor: pointer;\n            margin-top: 30px;\n            font-size: 12px;\n            letter-spacing: 1px;\n            text-transform: uppercase;\n            color: #1c1c1c;\n            font-weight: 500;\n            transition: background-color 0.2s;\n        }\n\n        .save-button:hover:not(:disabled) {\n            background: #e0e0e0;\n        }\n\n        .save-button:disabled {\n            opacity: 0.6;\n            cursor: not-allowed;\n        }\n\n        .success-state {\n            display: none;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: 60px 40px;\n        }\n\n        .success-state.active {\n            display: flex;\n        }\n\n        .checkmark-container {\n            width: 48px;\n            height: 48px;\n            position: relative;\n            margin-bottom: 30px;\n        }\n\n        .circle {\n            width: 48px;\n            height: 48px;\n            border: 2px solid #444;\n            border-radius: 50%;\n            position: relative;\n        }\n\n        .circle.loading {\n            border-top-color: transparent;\n            animation: spin 1s linear infinite;\n        }\n\n        @keyframes spin {\n            0% { transform: rotate(0deg); }\n            100% { transform: rotate(360deg); }\n        }\n\n        .checkmark {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 20px;\n            height: 20px;\n            opacity: 0;\n            transition: opacity 0.3s;\n        }\n\n        .checkmark.visible {\n            opacity: 1;\n        }\n\n        .checkmark-path {\n            stroke: #444;\n            stroke-width: 2;\n            stroke-linecap: round;\n            stroke-linejoin: round;\n            fill: none;\n        }\n\n        .success-text {\n            font-size: 16px;\n            letter-spacing: 1.5px;\n            text-transform: uppercase;\n            color: #444;\n            font-weight: 400;\n        }\n\n        .success-info {\n            margin-top: 30px;\n            text-align: center;\n        }\n\n        .form-state {\n            display: block;\n        }\n\n        .form-state.hidden {\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\">\n        <div class=\"modal\">\n            <div class=\"form-state\" id=\"formState\">\n                <div class=\"modal-content\">\n                    <h1 class=\"modal-title\" id=\"modalTitle\">Save Gallery As Template</h1>\n\n                    <div class=\"template-name-section\">\n                        <label class=\"field-label\" id=\"templateNameLabel\">Template name</label>\n                        <input\n                            type=\"text\"\n                            class=\"text-input\"\n                            id=\"templateNameInput\"\n                            placeholder=\"Write here...\"\n                            maxlength=\"60\"\n                        >\n                        <div class=\"validation-error\" id=\"validationError\"></div>\n                    </div>\n\n                    <div class=\"info-section\">\n                        <p class=\"info-text\" id=\"infoText\">You can edit it later in Settings / Preferences</p>\n                        <a class=\"learn-more-link\" id=\"learnMoreLink\" href=\"#\" target=\"_blank\">Learn more</a>\n                    </div>\n\n                    <button class=\"save-button\" id=\"saveButton\">Save</button>\n                </div>\n            </div>\n\n            <div class=\"success-state\" id=\"successState\">\n                <div class=\"checkmark-container\">\n                    <div class=\"circle\" id=\"loadingCircle\">\n                        <svg class=\"checkmark\" id=\"checkmark\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\">\n                            <path class=\"checkmark-path\" d=\"M4 10 L8 14 L16 6\"/>\n                        </svg>\n                    </div>\n                </div>\n                <p class=\"success-text\" id=\"successText\">Template saved</p>\n                <div class=\"info-section success-info\">\n                    <p class=\"info-text\" id=\"successInfoText\">You can use it when creating new galleries and edit it anytime in Settings > Preferences</p>\n                    <a class=\"learn-more-link\" id=\"successLearnMoreLink\" href=\"#\" target=\"_blank\">Learn more</a>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        // Private state\n        var currentState = null;\n        var lang = {};\n\n        // DOM elements cache\n        var elements = {};\n\n        function cacheElements() {\n            elements.templateNameInput = document.getElementById('templateNameInput');\n            elements.saveButton = document.getElementById('saveButton');\n            elements.formState = document.getElementById('formState');\n            elements.successState = document.getElementById('successState');\n            elements.loadingCircle = document.getElementById('loadingCircle');\n            elements.checkmark = document.getElementById('checkmark');\n            elements.modalTitle = document.getElementById('modalTitle');\n            elements.templateNameLabel = document.getElementById('templateNameLabel');\n            elements.infoText = document.getElementById('infoText');\n            elements.learnMoreLink = document.getElementById('learnMoreLink');\n            elements.successText = document.getElementById('successText');\n            elements.validationError = document.getElementById('validationError');\n            elements.successInfoText = document.getElementById('successInfoText');\n            elements.successLearnMoreLink = document.getElementById('successLearnMoreLink');\n        }\n\n        function applyLang(langData) {\n            lang = langData;\n            if (lang.modalTitle) elements.modalTitle.textContent = lang.modalTitle;\n            if (lang.templateNameLabel) elements.templateNameLabel.textContent = lang.templateNameLabel;\n            if (lang.templateNamePlaceholder) elements.templateNameInput.placeholder = lang.templateNamePlaceholder;\n            if (lang.infoText) {\n                elements.infoText.textContent = lang.infoText;\n            }\n            if (lang.successInfoText) {\n                elements.successInfoText.textContent = lang.successInfoText;\n            }\n            if (lang.learnMoreText) {\n                elements.learnMoreLink.textContent = lang.learnMoreText;\n                elements.successLearnMoreLink.textContent = lang.learnMoreText;\n            }\n            if (lang.saveButtonText) elements.saveButton.textContent = lang.saveButtonText;\n            if (lang.templateSavedText) elements.successText.textContent = lang.templateSavedText;\n            if (lang.validationRequired) elements.validationError.textContent = lang.validationRequired;\n        }\n\n        function clearValidationError() {\n            elements.templateNameInput.classList.remove('error');\n            elements.validationError.classList.remove('active');\n        }\n\n        function showValidationError() {\n            elements.templateNameInput.classList.add('error');\n            elements.validationError.classList.add('active');\n        }\n\n        function handleSave() {\n            var templateName = elements.templateNameInput.value.trim();\n\n            // Validate input\n            if (templateName === '') {\n                showValidationError();\n                elements.templateNameInput.focus();\n                return;\n            }\n\n            // Disable the save button\n            elements.saveButton.disabled = true;\n\n            // Switch to success state with loading\n            elements.formState.classList.add('hidden');\n            elements.successState.classList.add('active');\n            elements.loadingCircle.classList.add('loading');\n\n            // Send CTA with template name\n            window.myop_cta_handler('save-template', { templateName: templateName });\n        }\n\n        function showSaveCompleted() {\n            // Stop spinner\n            elements.loadingCircle.classList.remove('loading');\n            // Show checkmark\n            elements.checkmark.classList.add('visible');\n        }\n\n        function attachEventListeners() {\n            elements.saveButton.addEventListener('click', handleSave);\n            elements.templateNameInput.addEventListener('keypress', function(e) {\n                if (e.key === 'Enter') {\n                    handleSave();\n                }\n            });\n            elements.templateNameInput.addEventListener('input', function() {\n                if (elements.templateNameInput.value.trim() !== '') {\n                    clearValidationError();\n                }\n            });\n        }\n\n        function render(data) {\n            currentState = data;\n\n            // Apply language strings\n            if (data.lang) {\n                applyLang(data.lang);\n            }\n\n            // Set knowledge base URL\n            if (data.knowledgeBaseUrl) {\n                elements.learnMoreLink.href = data.knowledgeBaseUrl;\n                elements.successLearnMoreLink.href = data.knowledgeBaseUrl;\n            }\n\n            // Check if save was completed\n            if (data.saveCompleted) {\n                elements.formState.classList.add('hidden');\n                elements.successState.classList.add('active');\n                showSaveCompleted();\n            }\n        }\n\n        // Initialize DOM cache and event listeners\n        cacheElements();\n        attachEventListeners();\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n            console.log('CTA:', action_id, payload);\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            saveCompleted: false,\n            knowledgeBaseUrl: \"https://help.pic-time.com/en/articles/7834761-how-do-i-create-and-use-gallery-templates\",\n            lang: {\n                modalTitle: \"Save Gallery As Template\",\n                templateNameLabel: \"Template name\",\n                templateNamePlaceholder: \"Write here...\",\n                infoText: \"You can edit it later in Settings / Preferences\",\n                successInfoText: \"You can use it when creating new galleries and edit it anytime in Settings > Preferences\",\n                learnMoreText: \"Learn more\",\n                saveButtonText: \"Save\",\n                templateSavedText: \"Template saved\",\n                validationRequired: \"Required\"\n            }\n        });\n    </script>\n</body>\n</html>\n"
        },
        "id": "b7518181-9f18-488e-b5b6-dcb403655966"
      }
    ]
  }
}