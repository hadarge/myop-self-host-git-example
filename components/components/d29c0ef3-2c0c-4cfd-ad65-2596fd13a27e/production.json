          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Image Preview</title>\n    <style>\n        /* --- Reset & Base Styles --- */\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n\n        html, body {\n            height: 100%;\n            width: 100%;\n            background-color: transparent;\n        }\n\n        body {\n            font-family: \"TT_Norms_Pro\", sans-serif;\n            background-color: transparent;\n            margin: 0;\n            padding: 0;\n            overflow: hidden;\n            /* Defined Variables */\n            --x3-texth-3-1-1-primary-text: #222222;\n            --x3-texth-3-5-1-inverted-color-text: #FFFFFF;\n        }\n\n        /* --- Components --- */\n\n        /* Main Card */\n        #imageContainer {\n            background-color: transparent;\n            overflow: visible;\n            position: absolute;\n            top: 0;\n            left: 50%;\n            transform: translateX(-50%);\n            display: inline-flex;\n            flex-direction: column;\n            visibility: hidden; /* Hidden until image loads */\n        }\n\n        #imageContainer.loaded {\n            visibility: visible;\n        }\n\n        /* Footer */\n        footer {\n            padding: 16px 16px 16px 24px;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            background-color: #ffffff;\n            box-sizing: border-box;\n        }\n\n        .footer-left {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            min-width: 0; /* Allow shrinking */\n            flex: 1;\n            overflow: hidden;\n        }\n\n        .footer-right {\n            display: flex;\n            align-items: center;\n            flex-shrink: 0; /* Never shrink - keep button visible */\n            margin-left: 12px;\n        }\n\n        /* Typography */\n        #photoName {\n            color: var(--3-Text-H-3-1-1-primary-text, #222);\n            font-family: \"TT Norms Pro\", sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 125%;\n            overflow: hidden;\n            text-overflow: ellipsis;\n            white-space: nowrap;\n            min-width: 0; /* Allow text to shrink */\n        }\n\n        /* Buttons */\n        button {\n            background: none;\n            border: none;\n            cursor: pointer;\n            padding: 0;\n        }\n\n        #copyBtn {\n            color: #9ca3af; /* text-gray-400 */\n            position: relative;\n            display: flex;\n            align-items: center;\n        }\n        #copyBtn:hover {\n            color: #1f2937; /* text-gray-800 */\n        }\n\n        #downloadBtn {\n            display: flex;\n            padding: 6px 12px;\n            justify-content: center;\n            align-items: center;\n            gap: 8px;\n            border-radius: 2px;\n            background: var(--Primary-Main, #222);\n            color: var(--Primary-Contrast, #FFF);\n            font-family: \"TT Norms Pro\", sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 125%;\n            transition: opacity 0.2s;\n        }\n        #downloadBtn:hover {\n            opacity: 0.85;\n        }\n        #downloadBtn:active {\n            opacity: 0.7;\n        }\n\n        #closeBtn {\n            color: #6b7280;\n            display: flex;\n            align-items: center;\n        }\n        #closeBtn:hover {\n            color: #1f2937;\n        }\n\n        /* Tooltip */\n        #copyMessage {\n            position: absolute;\n            top: -2rem;\n            left: 50%;\n            transform: translateX(-50%);\n            background-color: #000;\n            color: #fff;\n            font-size: 0.75rem;\n            padding: 0.25rem 0.5rem;\n            border-radius: 0.25rem;\n            white-space: nowrap;\n            pointer-events: none;\n        }\n        .hidden {\n            display: none !important;\n        }\n\n        /* Main Media Area */\n        main {\n            position: relative;\n            background-color: transparent;\n            overflow: hidden;\n            display: block;\n        }\n\n        #mainImage {\n            height: calc(100vh - 56px);\n            width: auto;\n            display: block;\n        }\n\n        #videoPlayer {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            object-fit: contain;\n        }\n\n        /* Video Controls Styling (Webkit) */\n        video::-webkit-media-controls-panel {\n            background-color: rgba(0, 0, 0, 0.5);\n        }\n\n        /* Play Button Overlay */\n        #playButtonOverlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            cursor: pointer;\n            z-index: 10;\n        }\n\n        .play-circle {\n            width: 5rem; /* 20 */\n            height: 5rem;\n            border-radius: 9999px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            border: 2px solid white;\n        }\n\n        /* SVG Icons */\n        .icon-sm { width: 1rem; height: 1rem; }\n        .icon-md { width: 1.25rem; height: 1.25rem; } /* 20px */\n        .icon-lg { width: 3rem; height: 3rem; color: white; margin-left: 0.25rem; }\n    </style>\n</head>\n<body>\n\n    <!-- Main Card Container -->\n    <div id=\"imageContainer\">\n\n        <!-- Media Display Area -->\n        <main>\n            <!-- Image Thumbnail / Poster -->\n            <img id=\"mainImage\" src=\"\" alt=\"Media Preview\" />\n\n            <!-- Video Player -->\n            <video id=\"videoPlayer\" class=\"hidden\" controls playsinline></video>\n\n            <!-- Play Button Overlay for Videos -->\n            <div id=\"playButtonOverlay\" class=\"hidden\">\n                <div class=\"play-circle\">\n                    <svg class=\"icon-lg\" fill=\"currentColor\" viewBox=\"0 0 20 20\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z\"></path></svg>\n                </div>\n            </div>\n        </main>\n\n        <!-- Footer Section -->\n        <footer>\n            <div class=\"footer-left\">\n                <span id=\"photoName\" title=\"\">8343410980</span>\n                <button id=\"copyBtn\" type=\"button\" aria-label=\"Copy name\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n                        <path d=\"M5 2H9.73333C11.2268 2 11.9735 2 12.544 2.29065C13.0457 2.54631 13.4537 2.95426 13.7094 3.45603C14 4.02646 14 4.77319 14 6.26667V11M4.13333 14H9.53333C10.2801 14 10.6534 14 10.9387 13.8547C11.1895 13.7268 11.3935 13.5229 11.5213 13.272C11.6667 12.9868 11.6667 12.6134 11.6667 11.8667V6.46667C11.6667 5.71993 11.6667 5.34656 11.5213 5.06135C11.3935 4.81046 11.1895 4.60649 10.9387 4.47866C10.6534 4.33333 10.2801 4.33333 9.53333 4.33333H4.13333C3.3866 4.33333 3.01323 4.33333 2.72801 4.47866C2.47713 4.60649 2.27316 4.81046 2.14532 5.06135C2 5.34656 2 5.71993 2 6.46667V11.8667C2 12.6134 2 12.9868 2.14532 13.272C2.27316 13.5229 2.47713 13.7268 2.72801 13.8547C3.01323 14 3.3866 14 4.13333 14Z\" stroke=\"#222222\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                    </svg>\n                    <span id=\"copyMessage\" class=\"hidden\">Copied!</span>\n                </button>\n            </div>\n            <div class=\"footer-right\">\n                <!-- Download Button -->\n                <button id=\"downloadBtn\" type=\"button\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n                        <g clip-path=\"url(#clip0_723_10469)\">\n                            <path d=\"M14.6025 13.6494C15.0164 13.6497 15.3523 13.9856 15.3525 14.3994C15.3525 14.8134 15.0165 15.1491 14.6025 15.1494H1.40234C0.98813 15.1494 0.652344 14.8136 0.652344 14.3994C0.652553 13.9854 0.988259 13.6494 1.40234 13.6494H14.6025ZM8.00195 0.650391C8.41608 0.650498 8.75195 0.986244 8.75195 1.40039V9.78906L11.4717 7.06934C11.7646 6.77677 12.2394 6.77663 12.5322 7.06934C12.825 7.36213 12.8248 7.83697 12.5322 8.12988L8.53223 12.1299C8.39162 12.2705 8.20079 12.3496 8.00195 12.3496C7.80304 12.3496 7.61233 12.2705 7.47168 12.1299L3.47168 8.12988C3.17888 7.83698 3.17882 7.3622 3.47168 7.06934C3.76457 6.77677 4.23942 6.77663 4.53223 7.06934L7.25195 9.78906V1.40039C7.25195 0.986177 7.58774 0.650391 8.00195 0.650391Z\" fill=\"white\"/>\n                        </g>\n                        <defs>\n                            <clipPath id=\"clip0_723_10469\">\n                                <rect width=\"16\" height=\"16\" fill=\"white\"/>\n                            </clipPath>\n                        </defs>\n                    </svg>\n                    <span id=\"downloadBtnText\">Download</span>\n                </button>\n            </div>\n        </footer>\n\n    </div>\n\n    <script>\n        /**\n         * 2. myop_cta_handler\n         * Receives all CTA calls (action_id, payload).\n         * Logs actions to console instead of alerts.\n         */\n        window.myop_cta_handler = function(action_id, payload) {\n            const serverUpdate = {\n                action: action_id,\n                payload: payload\n            };\n            console.log(`SERVER UPDATE: ${JSON.stringify(serverUpdate, null, 2)}`);\n        };\n\n        /**\n         * 1. myop_init_interface\n         * Receives full config object (DTO only).\n         * Initializes interface, loads fonts, and populates data.\n         */\n        window.myop_init_interface = function(config) {\n            if (!config) {\n                console.error(\"Configuration object is missing for myop_init_interface.\");\n                return;\n            }\n\n            // 1. Load External Fonts/CSS if provided\n            if (config.fonts && Array.isArray(config.fonts)) {\n                config.fonts.forEach(fontUrl => {\n                    const link = document.createElement('link');\n                    link.rel = 'stylesheet';\n                    link.href = fontUrl;\n                    document.head.appendChild(link);\n                });\n            }\n\n            // 2. Initialize Logic\n            const downloadBtnText = document.getElementById('downloadBtnText');\n            const mainImage = document.getElementById('mainImage');\n            const photoName = document.getElementById('photoName');\n            const playButtonOverlay = document.getElementById('playButtonOverlay');\n            const videoPlayer = document.getElementById('videoPlayer');\n            const imageContainer = document.getElementById('imageContainer');\n\n            let currentPhotoId = null;\n            let currentMediaType = 'photo';\n            let videoUrl = null;\n\n            // Extract Data from Config\n            if (config.media) {\n                currentPhotoId = config.media.id || null;\n                if (config.media.media) {\n                    const name = config.media.media.name || '';\n                    photoName.innerText = name;\n                    photoName.title = name; // Show full name on hover\n                    currentMediaType = config.media.media.type || 'photo';\n                }\n            }\n\n            if (config.imageUrl) {\n                mainImage.src = config.imageUrl;\n            }\n\n            // Set container and footer width to match image width after load\n            const footer = document.querySelector('footer');\n            function setWidths() {\n                const imgWidth = mainImage.clientWidth || mainImage.offsetWidth;\n                if (imgWidth > 0) {\n                    imageContainer.style.width = imgWidth + 'px';\n                    footer.style.width = imgWidth + 'px';\n                    // Show everything together once image is loaded and sized\n                    imageContainer.classList.add('loaded');\n                }\n            }\n            mainImage.onload = setWidths;\n            // Also try on window load as backup\n            window.addEventListener('load', setWidths);\n            // Check if image is already cached and loaded\n            if (mainImage.complete && mainImage.naturalWidth > 0) {\n                setWidths();\n            }\n\n            if (config.videoUrl) {\n                videoUrl = config.videoUrl;\n            }\n\n            if (config.lang && config.lang.downloadButton) {\n                downloadBtnText.innerText = config.lang.downloadButton;\n            }\n\n            // 3. Setup Media Logic\n            if (currentMediaType === 'video' && videoUrl) {\n                playButtonOverlay.classList.remove('hidden');\n                mainImage.classList.remove('hidden');\n                videoPlayer.classList.add('hidden');\n                // Note: Without HLS.js external library, we rely on native browser support.\n                // Modern browsers like Safari support HLS natively.\n                // Others will only play if format is supported (e.g. mp4).\n                videoPlayer.src = videoUrl;\n            } else {\n                playButtonOverlay.classList.add('hidden');\n                videoPlayer.classList.add('hidden');\n                mainImage.classList.remove('hidden');\n            }\n\n            // 4. Attach Event Listeners (using closures to capture current config state)\n\n            // Click Handlers\n            document.getElementById('downloadBtn').onclick = () => {\n                window.myop_cta_handler('photo_download', { photo_id: currentPhotoId });\n            };\n\n            document.getElementById('copyBtn').onclick = () => {\n                window.myop_cta_handler('photo_copy', { photo_id: currentPhotoId });\n                const textToCopy = photoName.innerText;\n                const textArea = document.createElement('textarea');\n                textArea.value = textToCopy;\n                document.body.appendChild(textArea);\n                textArea.select();\n                try {\n                    document.execCommand('copy');\n                    const copyMessage = document.getElementById('copyMessage');\n                    copyMessage.classList.remove('hidden');\n                    setTimeout(() => { copyMessage.classList.add('hidden'); }, 2000);\n                } catch (err) {\n                    console.error('Failed to copy text: ', err);\n                }\n                document.body.removeChild(textArea);\n            };\n\n            playButtonOverlay.onclick = () => {\n                if (currentMediaType === 'video') {\n                    window.myop_cta_handler('video_play', { photo_id: currentPhotoId });\n                    playButtonOverlay.classList.add('hidden');\n                    videoPlayer.classList.remove('hidden');\n                    videoPlayer.play().catch(e => console.error(\"Video play failed (format might not be supported natively):\", e));\n                }\n            };\n\n            videoPlayer.onpause = () => {\n                if (!videoPlayer.ended && !videoPlayer.seeking) {\n                    window.myop_cta_handler('video_pause', { photo_id: currentPhotoId });\n                }\n            };\n\n            videoPlayer.onended = () => {\n                videoPlayer.classList.add('hidden');\n                playButtonOverlay.classList.remove('hidden');\n                // Reload src to reset\n                videoPlayer.load();\n            };\n\n            document.getElementById('closeBtn').onclick = (event) => {\n                event.stopPropagation();\n                window.myop_cta_handler('close', { photo_id: currentPhotoId });\n            };\n\n            // Global Click listener for background close (attached to body for simplicity, checked against container)\n            document.body.onclick = (event) => {\n                if (!imageContainer.contains(event.target)) {\n                    window.myop_cta_handler('close', { photo_id: currentPhotoId });\n                }\n            };\n\n            // Prevent clicks inside container from bubbling to body and closing\n            imageContainer.onclick = (event) => {\n                event.stopPropagation();\n            };\n        };\n\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            // External Fonts passed via Config\n            fonts: [\n                \"https://pictimecloudaf-pub-g3csanfebyefg3dm.a02.azurefd.net/pictures/scripts/platform2/resources/stores/4/environments/ep/r1323/assets_css/index.css\"\n            ],\n            lang: {\n                downloadButton: \"Download\",\n            },\n            media: {\n                id: 8343410980,\n                media: { name: \"Sydney_Wedding_Photographer_Ana_Jack_Previews_Collection_Best_Moments_2024-8.jpg\", type: \"photo\"}\n            },\n            // Portrait image to test narrow container with long filename\n            imageUrl: 'https://images.unsplash.com/photo-1583939003579-730e3918a45a?q=80&w=687&auto=format&fit=crop'\n        });\n    </script>\n</body>\n</html>"
        }
