{
  "version": "0.2.10",
  "item": {
    "name": "PHDash_criticalalerts",
    "id": "95aa8dcb-bded-4f50-a557-20099924fb74",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "3e21bcc2-2fc9-4c9a-a9ef-436f4f1807f8",
        "name": "V0",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Critical Alerts</title>\n    \n    <!-- Added Google Font \"Inter\" as per font exception -->\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap\" rel=\"stylesheet\">\n    \n    <!-- \n      REMOVED: External stylesheet link to 'index.css' to meet dependency requirements.\n    -->\n    \n    <style>\n        /* --- Base & Font Styles --- */\n        :root {\n            --card-bg: #fdfdff;\n            --body-bg: #f3f4f6;\n            --text-primary: #111827;\n            --text-secondary: #6b7280;\n            --border-color: #e5e7eb;\n        }\n\n        body {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            /* UPDATED: Added \"Inter\" as primary font */\n            font-family: \"Inter\", \"TT_Norms_Pro\", sans-serif;\n            background-color: var(--body-bg);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            min-height: 100vh;\n        }\n\n        /* --- Main Card --- */\n        .alert-card-widget {\n            width: 370px;\n            background-color: var(--card-bg);\n            border-radius: 0.75rem; /* 12px */\n            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);\n            transition: opacity 0.4s ease-out, transform 0.4s ease-out;\n            position: relative;\n        }\n\n        .alert-card-widget.hidden-widget {\n            opacity: 0;\n            transform: scale(0.95);\n            pointer-events: none;\n        }\n\n        /* --- Card Header --- */\n        .card-header {\n            display: flex;\n            align-items: center;\n            padding: 1.5rem; /* 24px */\n            cursor: pointer;\n            user-select: none;\n        }\n\n        .header-icon-container {\n            width: 33px;\n            height: 34px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            flex-shrink: 0;\n            margin-right: 1rem; /* 16px */\n        }\n\n        .header-title {\n            color: #C75151;\n            /* UPDATED: Added \"Inter\" as primary font */\n            font-family: \"Inter\", \"TT Norms Pro\", sans-serif;\n            font-size: 18px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: normal;\n        }\n\n        .chevron-icon {\n            margin-left: auto;\n            color: var(--text-secondary);\n            transition: transform 0.3s ease-in-out;\n        }\n\n        .chevron-icon.rotate-180 {\n            transform: rotate(180deg);\n        }\n\n        /* --- Alerts Container & Items --- */\n        .alerts-container {\n            padding-bottom: 0.5rem; /* 8px */\n        }\n        \n        .alert-item {\n            padding: 1.5rem; /* 24px */\n            transition: opacity 0.3s ease-out, transform 0.3s ease-out;\n        }\n        \n        .alert-item.removing {\n            opacity: 0;\n            transform: scale(0.95);\n        }\n\n        .alert-item-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-start;\n        }\n\n        .alert-item-title {\n            font-weight: 500;\n            font-size: 1rem; /* 16px */\n            color: var(--text-primary);\n        }\n        \n        .alert-item-icons {\n            display: flex;\n            align-items: center;\n        }\n\n        /* UPDATED: Converted .icon-wrapper from div to button for accessibility */\n        .icon-wrapper {\n            position: relative;\n            cursor: pointer;\n            /* Added reset styles for button */\n            background: none;\n            border: none;\n            padding: 0;\n            display: flex; /* To center the SVG */\n            align-items: center;\n            justify-content: center;\n        }\n        \n        /* --- Improved Tooltip --- */\n        .tooltip-text {\n            visibility: hidden;\n            opacity: 0;\n            width: auto;\n            white-space: nowrap;\n            background-color: #333;\n            color: #fff;\n            text-align: center;\n            border-radius: 6px;\n            padding: 8px 12px;\n            position: absolute;\n            z-index: 1;\n            bottom: 140%;\n            left: 50%;\n            transform: translateX(-50%);\n            box-shadow: 0 2px 8px rgba(0,0,0,0.2);\n            transition: opacity 0.3s;\n            font-size: 12px;\n        }\n        \n        .tooltip-text::after {\n            content: \"\";\n            position: absolute;\n            top: 100%;\n            left: 50%;\n            margin-left: -5px;\n            border-width: 5px;\n            border-style: solid;\n            border-color: #333 transparent transparent transparent;\n        }\n        \n        .icon-wrapper:hover .tooltip-text,\n        .icon-wrapper:focus .tooltip-text {\n            visibility: visible;\n            opacity: 1;\n        }\n\n        .resolve-icon {\n            width: 0.85rem; /* 14px */\n            height: 0.85rem; /* 14px */\n            color: var(--text-primary); /* Black */\n        }\n\n        .alert-item-description {\n            margin-top: 0.5rem; /* 8px */\n            font-size: 1rem; /* 16px */\n            color: var(--text-primary);\n            width: 265px;\n        }\n\n        .alert-item-time {\n            margin-top: 1.25rem; /* 20px */\n            font-size: 0.75rem; /* 12px */\n            color: var(--text-secondary);\n        }\n\n        .alert-item-action {\n            margin-top: 1rem; /* 16px */\n            font-weight: 500;\n            font-size: 1rem; /* 16px */\n            color: var(--text-primary);\n            text-decoration-line: underline;\n            background: none;\n            border: none;\n            padding: 0;\n            cursor: pointer;\n        }\n\n        .separator {\n            margin: 0.5rem 1.5rem; /* 8px 24px */\n            height: 1px;\n            background-color: var(--border-color);\n        }\n\n    </style>\n</head>\n<body>\n\n    <!-- Main Alert Card -->\n    <div id=\"ca-widget-card\" class=\"alert-card-widget\">\n        <!-- Card Header -->\n        <div id=\"ca-widget-header\" class=\"card-header\">\n            <div class=\"header-icon-container\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"33\" height=\"34\" viewBox=\"0 0 33 34\" fill=\"none\">\n                    <circle cx=\"16.5\" cy=\"17.1172\" r=\"16.5\" fill=\"#C75151\"/>\n                    <rect x=\"14.5195\" y=\"7.21875\" width=\"3.96\" height=\"14.52\" fill=\"white\"/>\n                    <circle cx=\"16.4995\" cy=\"26.355\" r=\"1.98\" fill=\"white\"/>\n                </svg>\n            </div>\n            <div id=\"ca-widget-title\" class=\"header-title\"></div>\n            <svg id=\"ca-widget-chevron\" class=\"chevron-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                <path d=\"M6 9L12 15L18 9\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n        </div>\n\n        <!-- Alerts will be dynamically inserted here -->\n        <div id=\"ca-widget-alerts-container\" class=\"alerts-container\"></div>\n        \n    </div>\n\n    <script>\n        (function() {\n            // --- IIFE-scoped variables ---\n            let alertsData = [];\n            let lang = {};\n            let isExpanded = true;\n            let timeUpdaterInterval = null;\n\n            // --- DOM Elements ---\n            const alertCard = document.getElementById('ca-widget-card');\n            const cardHeader = document.getElementById('ca-widget-header');\n            const alertsContainer = document.getElementById('ca-widget-alerts-container');\n            const chevronIcon = document.getElementById('ca-widget-chevron');\n            const alertTitle = document.getElementById('ca-widget-title');\n\n            if (!alertCard) return;\n\n            // --- Utility Functions ---\n\n            const timeAgo = (isoTimestamp) => {\n                const now = new Date();\n                const past = new Date(isoTimestamp);\n                const seconds = Math.floor((now - past) / 1000);\n\n                if (seconds < 60) return lang.dashboardCriticalAlertNow || \"Now\";\n                \n                const minutes = Math.floor(seconds / 60);\n                if (minutes < 60) return (lang.dashboardCriticalAlertElapsedTime || \"{time} ago\").replace(\"{time}\", `${minutes} min`);\n\n                const hours = Math.floor(minutes / 60);\n                if (hours < 24) return (lang.dashboardCriticalAlertElapsedTime || \"{time} ago\").replace(\"{time}\", `${hours} hours`);\n                \n                const days = Math.floor(hours / 24);\n                return (lang.dashboardCriticalAlertElapsedTime || \"{time} ago\").replace(\"{time}\", `${days} days`);\n            };\n\n            const updateAlertCount = () => {\n                const count = alertsData.length;\n                if (count === 1) {\n                    alertTitle.textContent = lang.dashboardCriticalAlertWidgetTitleSingular || \"1 Critical alert\";\n                } else {\n                    alertTitle.textContent = (lang.dashboardCriticalAlertWidgetTitle || \"{count} Critical alerts\").replace(\"{count}\", count);\n                }\n            };\n            \n            /**\n             * FIXED: Re-written to use a DocumentFragment for better rendering performance.\n             * This builds all DOM nodes in memory and appends them only once,\n             * avoiding multiple \"layout reflows\".\n             */\n            const renderAlerts = () => {\n                const fragment = document.createDocumentFragment();\n                \n                alertsData.forEach((alert, index) => {\n                    const actionButtonHTML = alert.cta ? `<button class=\"alert-item-action\">${alert.cta}</button>` : '';\n                    const tooltipText = lang.dashboardCriticalAlertTooltipText || \"Mark as resolved\";\n\n                    const alertElement = document.createElement('div');\n                    alertElement.className = 'alert-item';\n                    alertElement.dataset.id = alert.id;\n\n                    alertElement.innerHTML = `\n                        <div class=\"alert-item-header\">\n                            <div class=\"alert-item-title\">${alert.type}</div>\n                            <div class=\"alert-item-icons\">\n                                <!-- FIXED: Changed from <div> to <button> for accessibility -->\n                                <button class=\"icon-wrapper\" aria-label=\"${tooltipText}\">\n                                    <svg class=\"resolve-icon\" viewBox=\"0 0 20 20\" fill=\"currentColor\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\" /></svg>\n                                    <span class=\"tooltip-text\">${tooltipText}</span>\n                                </button>\n                            </div>\n                        </div>\n                        <p class=\"alert-item-description\">${alert.description}</p>\n                        <div class=\"alert-item-time\" data-timestamp=\"${alert.timestamp}\">${timeAgo(alert.timestamp)}</div>\n                        ${actionButtonHTML}\n                    `;\n                    \n                    fragment.appendChild(alertElement);\n                    \n                    if (index < alertsData.length - 1) {\n                        const separator = document.createElement('div');\n                        separator.className = 'separator';\n                        fragment.appendChild(separator);\n                    }\n                });\n\n                // Update the DOM exactly once\n                alertsContainer.innerHTML = ''; \n                alertsContainer.appendChild(fragment);\n                \n                updateAlertCount();\n            };\n\n            const toggleExpand = () => {\n                isExpanded = !isExpanded;\n                chevronIcon.classList.toggle('rotate-180', isExpanded);\n                alertsContainer.style.display = isExpanded ? 'block' : 'none';\n            };\n\n            const updateAllTimestamps = () => {\n                alertsContainer.querySelectorAll('.alert-item-time').forEach(el => el.textContent = timeAgo(el.dataset.timestamp));\n            };\n\n            // --- Main Widget Logic ---\n\n            function runWidget(config) {\n                const { alerts, lang: newLang, showWidget = true } = config;\n\n                // Handle visibility first\n                if (!showWidget || !alerts || alerts.length === 0) {\n                    alertCard.classList.add('hidden-widget');\n                    if (timeUpdaterInterval) clearInterval(timeUpdaterInterval);\n                    timeUpdaterInterval = null;\n                    return;\n                }\n\n                // If we are here, it means showWidget is true and there are alerts\n                alertCard.classList.remove('hidden-widget');\n                \n                alertsData = alerts;\n                lang = newLang || lang;\n                renderAlerts();\n                \n                if (timeUpdaterInterval) clearInterval(timeUpdaterInterval);\n                \n                // FIXED: Update interval to 1 minute (60000ms) for better performance.\n                timeUpdaterInterval = setInterval(updateAllTimestamps, 60000);\n            }\n\n            // --- Event Listeners ---\n\n            cardHeader.addEventListener('click', toggleExpand);\n\n            alertsContainer.addEventListener('click', (e) => {\n                const target = e.target;\n                const alertItem = target.closest('.alert-item');\n                if (!alertItem) return;\n\n                const alertId = Number(alertItem.dataset.id);\n\n                // FIXED: Changed selector to the accessible button wrapper\n                if (target.closest('.icon-wrapper')) {\n                    e.stopPropagation();\n                    \n                    // FIXED: Call the global CTA handler instead of console.log\n                    if (typeof window.myop_cta_handler === 'function') {\n                        window.myop_cta_handler('alert_resolve', { CriticalAlertID: alertId });\n                    } else {\n                        console.warn('myop_cta_handler not found. Action:', 'alert_resolve', { CriticalAlertID: alertId });\n                    }\n                    \n                    alertItem.classList.add('removing');\n                    setTimeout(() => {\n                        alertsData = alertsData.filter(a => a.id !== alertId);\n                        // Re-run the widget logic to update the count and hide if empty\n                        runWidget({ alerts: alertsData, lang: lang, showWidget: true });\n                    }, 300);\n\n                } else if (target.closest('.alert-item-action')) {\n                    e.stopPropagation();\n                    \n                    // FIXED: Call the global CTA handler instead of console.log\n                    if (typeof window.myop_cta_handler === 'function') {\n                        window.myop_cta_handler('alert_action_click', { CriticalAlertID: alertId });\n                    } else {\n                        console.warn('myop_cta_handler not found. Action:', 'alert_action_click', { CriticalAlertID: alertId });\n                    }\n                }\n            });\n\n            // --- Public API ---\n            \n            /**\n             * FIXED: Renamed function to myop_init_interface as requested.\n             * This is the main entry point for initializing the widget.\n             * @param {object} config - The configuration object.\n             * @param {Array} config.alerts - Array of alert objects.\n             * @param {object} config.lang - Language strings object.\n             * @param {boolean} [config.showWidget=true] - Whether to show the widget.\n             */\n            window.myop_init_interface = function(config) {\n                runWidget(config);\n                console.log(\"✅ Critical Alerts widget initialized/updated.\");\n            };\n\n            \n            /**\n             * FIXED: Added placeholder for documentation.\n             * The host application should define this function.\n             * @param {string} action_id - The ID of the action (e.g., 'alert_resolve').\n             * @param {object} payload - The data associated with the action.\n             */\n            if (typeof window.myop_cta_handler === 'undefined') {\n                console.info(\"Info: window.myop_cta_handler is not defined. Widget actions will be logged to the console.\");\n                // You can optionally define a default logger here\n                // window.myop_cta_handler = (action_id, payload) => {\n                //    console.log('myop_cta_handler default log:', action_id, payload);\n                // }\n            }\n\n            // --- INITIALIZATION ---\n            \n            // FIXED: Removed default config and initial run.\n            // The widget will now start as hidden until myop_init_interface is called.\n            runWidget({ alerts: [], showWidget: false });\n            \n        })();\nfunction myop_cta_handler(action_id,payload){\n   console.log(\"myop_cta_handler\", action_id, payload);\n}\n\n        window.myop_init_interface({\n    showWidget: true,\n    alerts: [\n        { \"id\": 1, \"type\": \"Order Error\", \"description\": \"David & Jennifer: Order #4245981 — Some photos need your attention.\", \"cta\": \"Fix it\", \"timestamp\": new Date(Date.now() - 5 * 1000).toISOString() },\n        { \"id\": 2, \"type\": \"Payment Failed\", \"description\": \"Update your billing details to avoid any interruption to your plan\", \"cta\": \"Update Billing\", \"timestamp\": new Date(Date.now() - 2 * 60 * 60 * 1000).toISOString() }\n    ],\n    lang: {\n        \"dashboardCriticalAlertWidgetTitle\": \"{count} Critical alerts\",\n        \"dashboardCriticalAlertWidgetTitleSingular\": \"1 Critical alert\",\n        \"dashboardCriticalAlertNow\": \"Now\",\n        \"dashboardCriticalAlertElapsedTime\": \"{time} ago\",\n        \"dashboardCriticalAlertTooltipText\": \"Mark as resolved\"\n    }\n});\n    </script>\n\n</body>\n</html>"
        }
      }
    ]
  }
}