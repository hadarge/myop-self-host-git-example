  "version": "0.2.10",
  "item": {
    "name": "PHDash_criticalalerts",
    "id": "95aa8dcb-bded-4f50-a557-20099924fb74",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "134b7e5c-62e4-438e-b3f4-93abe045034e",
        "name": "Version 11",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Critical Alerts</title>\n\n    <style>\n        /* --- Base & Font Styles --- */\n        :root {\n            --card-bg: transparent;\n            --body-bg: transparent;\n            --text-primary: #111827;\n            --text-secondary: #6b7280;\n            --border-color: #e5e7eb;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            background-color: var(--body-bg);\n        }\n\n        body {\n            box-sizing: border-box;\n            font-family: \"TT_Norms_Pro\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\";\n        }\n\n        /* --- Main Card --- */\n        .alert-card-widget {\n            width: 370px;\n            background-color: var(--card-bg);\n            border-radius: 0.75rem;\n            /* 12px */\n            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);\n            transition: opacity 0.4s ease-out, transform 0.4s ease-out;\n            position: relative;\n        }\n\n        .alert-card-widget.hidden-widget {\n            display: none;\n        }\n\n        /* --- Card Header --- */\n        .card-header {\n            display: flex;\n            align-items: center;\n            padding: 1.5rem;\n            /* 24px */\n            cursor: pointer;\n            user-select: none;\n        }\n\n        .header-icon-container {\n            width: 33px;\n            height: 34px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            flex-shrink: 0;\n            margin-right: 1rem;\n            /* 16px */\n        }\n\n        .header-title {\n            color: #C75151;\n            font-family: \"TT Norms Pro\", sans-serif;\n            font-size: 18px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: normal;\n        }\n\n        .chevron-icon {\n            margin-left: auto;\n            color: var(--text-secondary);\n            transition: transform 0.3s ease-in-out;\n        }\n\n        .chevron-icon.rotate-180 {\n            transform: rotate(180deg);\n        }\n\n        /* --- Alerts Container & Items --- */\n        .alerts-container {\n            padding-bottom: 0.5rem;\n            /* 8px */\n        }\n\n        .alert-item {\n            padding: 1.5rem;\n            /* 24px */\n            transition: opacity 0.3s ease-out, transform 0.3s ease-out;\n        }\n\n        .alert-item.removing {\n            opacity: 0;\n            transform: scale(0.95);\n        }\n\n        .alert-item-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-start;\n        }\n\n        .alert-item-title {\n            font-weight: 500;\n            font-size: 1rem;\n            /* 16px */\n            color: var(--text-primary);\n        }\n\n        .alert-item-icons {\n            display: flex;\n            align-items: center;\n        }\n\n        .icon-wrapper {\n            position: relative;\n            cursor: pointer;\n            background: none;\n            border: none;\n            padding: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        /* --- Improved Tooltip --- */\n        .tooltip-text {\n            visibility: hidden;\n            opacity: 0;\n            width: auto;\n            white-space: nowrap;\n            background-color: #333;\n            color: #fff;\n            text-align: center;\n            border-radius: 6px;\n            padding: 8px 12px;\n            position: absolute;\n            z-index: 1;\n            bottom: 140%;\n            left: 50%;\n            transform: translateX(-50%);\n            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);\n            transition: opacity 0.3s;\n            font-size: 12px;\n        }\n\n        .tooltip-text::after {\n            content: \"\";\n            position: absolute;\n            top: 100%;\n            left: 50%;\n            margin-left: -5px;\n            border-width: 5px;\n            border-style: solid;\n            border-color: #333 transparent transparent transparent;\n        }\n\n        .icon-wrapper:hover .tooltip-text,\n        .icon-wrapper:focus .tooltip-text {\n            visibility: visible;\n            opacity: 1;\n        }\n\n        .resolve-icon {\n            width: 0.85rem;\n            /* 14px */\n            height: 0.85rem;\n            /* 14px */\n            color: var(--text-primary);\n            /* Black */\n        }\n\n        .alert-item-description {\n            margin-top: 0.5rem;\n            /* 8px */\n            font-size: 1rem;\n            /* 16px */\n            color: var(--text-primary);\n            width: 265px;\n        }\n\n        .alert-item-time {\n            margin-top: 1.25rem;\n            /* 20px */\n            font-size: 0.75rem;\n            /* 12px */\n            color: var(--text-secondary);\n        }\n\n        .alert-item-action {\n            margin-top: 1rem;\n            /* 16px */\n            font-weight: 500;\n            font-size: 1rem;\n            /* 16px */\n            color: var(--text-primary);\n            text-decoration-line: underline;\n            background: none;\n            border: none;\n            padding: 0;\n            cursor: pointer;\n            /* Explicitly set font for buttons as requested */\n            font-family: \"TT_Norms_Pro\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n        }\n\n        .separator {\n            margin: 0.5rem 1.5rem;\n            /* 8px 24px */\n            height: 1px;\n            background-color: var(--border-color);\n        }\n    </style>\n</head>\n\n<body>\n\n    <div id=\"ca-widget-card\" class=\"alert-card-widget\">\n        <div id=\"ca-widget-header\" class=\"card-header\">\n            <div class=\"header-icon-container\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"33\" height=\"34\" viewBox=\"0 0 33 34\" fill=\"none\">\n                    <circle cx=\"16.5\" cy=\"17.1172\" r=\"16.5\" fill=\"#C75151\" />\n                    <rect x=\"14.5195\" y=\"7.21875\" width=\"3.96\" height=\"14.52\" fill=\"white\" />\n                    <circle cx=\"16.4995\" cy=\"26.355\" r=\"1.98\" fill=\"white\" />\n                </svg>\n            </div>\n            <div id=\"ca-widget-title\" class=\"header-title\"></div>\n            <svg id=\"ca-widget-chevron\" class=\"chevron-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\"\n                xmlns=\"http://www.w3.org/2000/svg\">\n                <path d=\"M6 9L12 15L18 9\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"\n                    stroke-linejoin=\"round\" />\n            </svg>\n        </div>\n\n        <div id=\"ca-widget-alerts-container\" class=\"alerts-container\"></div>\n    </div>\n\n    <script>\n        // --- Global Public Methods ---\n\n        /**\n         * 1. myop_init_interface\n         * Receives the full config object to initialize the widget.\n         */\n        window.myop_init_interface = function(config) {\n            // Dispatch a custom event so the internal widget logic can pick it up\n            const event = new CustomEvent('myop_widget_init', { detail: config });\n            window.dispatchEvent(event);\n        };\n\n        /**\n         * 2. myop_cta_handler\n         * Receives action calls (action_id, payload).\n         * Logs the action to the console.\n         */\n        window.myop_cta_handler = function(action_id, payload) {\n            console.log('LOG: Action:', action_id, 'Payload:', JSON.stringify(payload));\n        };\n\n        // --- Internal Widget Logic (Scoped) ---\n        (function() {\n            // Internal state\n            let alertsData = [];\n            let lang = {};\n            let isExpanded = false; // Default to false (collapsed)\n            let timeUpdaterInterval = null;\n\n            // DOM Elements\n            const alertCard = document.getElementById('ca-widget-card');\n            const cardHeader = document.getElementById('ca-widget-header');\n            const alertsContainer = document.getElementById('ca-widget-alerts-container');\n            const chevronIcon = document.getElementById('ca-widget-chevron');\n            const alertTitle = document.getElementById('ca-widget-title');\n\n            if (!alertCard) return;\n\n            // --- Helper Functions ---\n\n            const timeAgo = (isoTimestamp) => {\n                const now = new Date();\n                const past = new Date(isoTimestamp);\n                const seconds = Math.floor((now - past) / 1000);\n\n                if (seconds < 60) return lang.dashboardCriticalAlertNow || \"Now\";\n\n                const minutes = Math.floor(seconds / 60);\n                if (minutes < 60) return (lang.dashboardCriticalAlertElapsedTime || \"{time} ago\").replace(\"{time}\", `${minutes} min`);\n\n                const hours = Math.floor(minutes / 60);\n                if (hours < 24) return (lang.dashboardCriticalAlertElapsedTime || \"{time} ago\").replace(\"{time}\", `${hours} hours`);\n\n                const days = Math.floor(hours / 24);\n                return (lang.dashboardCriticalAlertElapsedTime || \"{time} ago\").replace(\"{time}\", `${days} days`);\n            };\n\n            const updateAlertCount = () => {\n                const count = alertsData.length;\n                if (count === 1) {\n                    alertTitle.textContent = lang.dashboardCriticalAlertWidgetTitleSingular || \"1 Critical alert\";\n                } else {\n                    alertTitle.textContent = (lang.dashboardCriticalAlertWidgetTitle || \"{count} Critical alerts\").replace(\"{count}\", count);\n                }\n            };\n\n            const renderAlerts = () => {\n                const fragment = document.createDocumentFragment();\n\n                alertsData.forEach((alert, index) => {\n                    const actionButtonHTML = alert.cta ? `<button class=\"alert-item-action\">${alert.cta}</button>` : '';\n                    const tooltipText = lang.dashboardCriticalAlertTooltipText || \"Mark as resolved\";\n\n                    const alertElement = document.createElement('div');\n                    alertElement.className = 'alert-item';\n                    alertElement.dataset.id = alert.id;\n\n                    alertElement.innerHTML = `\n                        <div class=\"alert-item-header\">\n                            <div class=\"alert-item-title\">${alert.type}</div>\n                            <div class=\"alert-item-icons\">\n                                <button class=\"icon-wrapper\" aria-label=\"${tooltipText}\">\n                                    <svg class=\"resolve-icon\" viewBox=\"0 0 20 20\" fill=\"currentColor\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\" /></svg>\n                                    <span class=\"tooltip-text\">${tooltipText}</span>\n                                </button>\n                            </div>\n                        </div>\n                        <p class=\"alert-item-description\">${alert.description}</p>\n                        <div class=\"alert-item-time\" data-timestamp=\"${alert.timestamp}\">${timeAgo(alert.timestamp)}</div>\n                        ${actionButtonHTML}\n                    `;\n\n                    fragment.appendChild(alertElement);\n\n                    if (index < alertsData.length - 1) {\n                        const separator = document.createElement('div');\n                        separator.className = 'separator';\n                        fragment.appendChild(separator);\n                    }\n                });\n\n                alertsContainer.innerHTML = '';\n                alertsContainer.appendChild(fragment);\n\n                updateAlertCount();\n            };\n\n            const toggleExpand = () => {\n                isExpanded = !isExpanded;\n                chevronIcon.classList.toggle('rotate-180', !isExpanded);\n                alertsContainer.style.display = isExpanded ? 'block' : 'none';\n            };\n\n            const updateAllTimestamps = () => {\n                alertsContainer.querySelectorAll('.alert-item-time').forEach(el => el.textContent = timeAgo(el.dataset.timestamp));\n            };\n\n            // --- Main Logic ---\n\n            function runWidget(config) {\n                const { alerts, lang: newLang, showWidget = true } = config;\n\n                if (!showWidget || !alerts || alerts.length === 0) {\n                    alertCard.classList.add('hidden-widget');\n                    if (timeUpdaterInterval) clearInterval(timeUpdaterInterval);\n                    timeUpdaterInterval = null;\n                    // Notify parent iframe that height should be 0\n                    requestAnimationFrame(() => {\n                        window.myop_cta_handler('size-requested', { height: 0 });\n                    });\n                    return;\n                }\n\n                alertCard.classList.remove('hidden-widget');\n\n                alertsData = alerts;\n                lang = newLang || lang;\n                renderAlerts();\n\n                // Reset view state to default (collapsed/false) or maintain current?\n                // The prompt requested \"Collapsed Mode is the default\" for presentation.\n                // We will respect the `isExpanded` variable which defaults to false.\n                chevronIcon.classList.toggle('rotate-180', !isExpanded);\n                alertsContainer.style.display = isExpanded ? 'block' : 'none';\n\n                if (timeUpdaterInterval) clearInterval(timeUpdaterInterval);\n                timeUpdaterInterval = setInterval(updateAllTimestamps, 60000);\n\n                // Notify parent iframe of content height\n                requestAnimationFrame(() => {\n                    const height = document.body.scrollHeight;\n                    window.myop_cta_handler('size-requested', { height: height });\n                });\n            }\n\n            // --- Event Listeners ---\n\n            // Listen for the initialization event triggered by the public API\n            window.addEventListener('myop_widget_init', (e) => {\n                runWidget(e.detail);\n            });\n\n            cardHeader.addEventListener('click', toggleExpand);\n\n            alertsContainer.addEventListener('click', (e) => {\n                const target = e.target;\n                const alertItem = target.closest('.alert-item');\n                if (!alertItem) return;\n\n                const alertId = Number(alertItem.dataset.id);\n\n                if (target.closest('.icon-wrapper')) {\n                    e.stopPropagation();\n\n                    // Call public handler\n                    window.myop_cta_handler('alert_resolve', { CriticalAlertID: alertId });\n\n                    alertItem.classList.add('removing');\n                    setTimeout(() => {\n                        alertsData = alertsData.filter(a => a.id !== alertId);\n                        runWidget({ alerts: alertsData, lang: lang, showWidget: true });\n                    }, 300);\n\n                } else if (target.closest('.alert-item-action')) {\n                    e.stopPropagation();\n\n                    // Call public handler\n                    window.myop_cta_handler('alert_action_click', { CriticalAlertID: alertId });\n                }\n            });\n\n            // Initial state: Hidden until init is called\n            runWidget({ alerts: [], showWidget: false });\n\n        })();\n\n        // --- DEMO / TEST ---\n        // Simulating the host application calling init\n        window.onload = function() {\n            if(typeof window.myop_init_interface === 'function') {\n                window.myop_init_interface({\n                    showWidget: true,\n                    alerts: [\n                        { \"id\": 1, \"type\": \"Order Error\", \"description\": \"David & Jennifer: Order #4245981 — Some photos need your attention.\", \"cta\": \"Fix it\", \"timestamp\": new Date(Date.now() - 5 * 1000).toISOString() },\n                        { \"id\": 2, \"type\": \"Payment Failed\", \"description\": \"Update your billing details to avoid any interruption to your plan\", \"cta\": \"Update Billing\", \"timestamp\": new Date(Date.now() - 2 * 60 * 60 * 1000).toISOString() }\n                    ],\n                    lang: {\n                        \"dashboardCriticalAlertWidgetTitle\": \"{count} Critical alerts\",\n                        \"dashboardCriticalAlertWidgetTitleSingular\": \"1 Critical alert\",\n                        \"dashboardCriticalAlertNow\": \"Now\",\n                        \"dashboardCriticalAlertElapsedTime\": \"{time} ago\",\n                        \"dashboardCriticalAlertTooltipText\": \"Mark as resolved\"\n                    }\n                });\n            }\n        };\n    </script>\n\n</body>\n\n</html>"
        }
      }
    ]
  }
}