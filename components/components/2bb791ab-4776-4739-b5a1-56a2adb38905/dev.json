{
  "version": "0.2.10",
  "item": {
    "name": "Shop Tab - Popup",
    "id": "2bb791ab-4776-4739-b5a1-56a2adb38905",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "650b0a96-4f5d-41a6-b6ac-c67631cfa0f6",
        "name": "fixes - popup, captions",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Shop Tab Popup - Price List Wizard</title>\n\n    <style>\n        /* * ===================================================================\n         * 1. BASE & STYLE GUIDE RULES\n         * =================================================================== */\n\n        :root {\n            /* Colors - From Design System */\n            --color-white: #FFFFFF;\n            --color-text-primary: #222222;\n            --color-text-secondary: #6B6B6B;\n            --color-text-disabled: #AEAEAE;\n            --color-border: #ddddd1;\n            --color-hover-bg: #f5f5f5;\n            --color-button-primary: #222222;\n            --color-button-primary-hover: #333333;\n        }\n\n        /* Global Reset */\n        *,\n        *::before,\n        *::after {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n\n        html {\n            font-size: 16px;\n            overflow-x: hidden;\n        }\n\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", \"Gotham Narrow SSm\", \"Gotham Narrow SSm A\", \"Gotham Narrow SSm B\", \"TT_Norms_Pro\", sans-serif;\n            background-color: transparent;\n            color: var(--color-text-primary);\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n            line-height: 1.5;\n            overflow-x: hidden;\n            max-width: 100vw;\n        }\n\n        #app-container {\n            width: 100%;\n            max-width: 100vw;\n            box-sizing: border-box;\n            overflow-x: hidden;\n        }\n\n        *:focus,\n        *:focus-visible {\n            outline: 1px solid var(--color-text-primary);\n            outline-offset: 1px;\n        }\n\n        /* * ===================================================================\n         * 2. POPUP LAYOUT - Modal Dialog\n         * =================================================================== */\n\n        .popup-wrapper {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            width: 100%;\n            min-height: 100vh;\n            padding: 24px;\n        }\n\n        .popup-dialog {\n            position: relative;\n            display: flex;\n            flex-direction: column;\n            gap: 24px;\n            align-items: center;\n            justify-content: center;\n            max-width: 600px;\n            width: 100%;\n            padding: 32px;\n            background: var(--color-white);\n            border-radius: 8px;\n            overflow: hidden;\n        }\n\n        /* * ===================================================================\n         * 3. CLOSE BUTTON\n         * =================================================================== */\n\n        .popup-close-btn {\n            position: absolute;\n            top: 16px;\n            right: 16px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            width: 32px;\n            height: 32px;\n            padding: 8px;\n            background: rgba(239, 239, 239, 0);\n            border: none;\n            border-radius: 81px;\n            cursor: pointer;\n            z-index: 1;\n        }\n\n        .popup-close-btn:hover {\n            background: var(--color-hover-bg);\n        }\n\n        .popup-close-btn svg {\n            width: 16px;\n            height: 16px;\n            flex-shrink: 0;\n        }\n\n        /* * ===================================================================\n         * 4. TEXT SECTION (Title + Subtitle)\n         * =================================================================== */\n\n        .popup-text-section {\n            display: flex;\n            flex-direction: column;\n            align-items: flex-start;\n            gap: 12px;\n            width: 100%;\n        }\n\n        .popup-title-row {\n            display: flex;\n            align-items: center;\n            width: 100%;\n        }\n\n        .popup-title {\n            color: var(--color-text-primary);\n            font-feature-settings: 'liga' off, 'clig' off;\n            font-family: \"TT Norms Pro\", -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 24px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 133%;\n        }\n\n        .popup-subtitle-row {\n            display: flex;\n            flex-direction: column;\n            align-items: flex-start;\n            width: 100%;\n        }\n\n        .popup-subtitle {\n            color: var(--color-text-secondary);\n            font-feature-settings: 'liga' off, 'clig' off;\n            font-family: \"TT Norms Pro\", -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 125%;\n        }\n\n        /* * ===================================================================\n         * 5. VIDEO + ACTIONS SECTION\n         * =================================================================== */\n\n        .popup-body-section {\n            display: flex;\n            flex-direction: column;\n            align-items: flex-start;\n            gap: 24px;\n            width: 100%;\n        }\n\n        /* Video Thumbnail */\n        .popup-video-container {\n            position: relative;\n            width: 100%;\n            overflow: visible;\n        }\n\n        .popup-video-thumbnail {\n            position: relative;\n            width: 100%;\n            aspect-ratio: 16 / 9;\n            border-radius: 8px;\n            overflow: hidden;\n            cursor: pointer;\n        }\n\n        .popup-video-thumbnail img {\n            display: block;\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            border-radius: 8px;\n        }\n\n        .popup-video-overlay {\n            position: absolute;\n            inset: 0;\n            background: rgba(0, 0, 0, 0.05);\n            border-radius: 8px;\n            pointer-events: none;\n        }\n\n        .popup-video-play-btn {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 48px;\n            height: 48px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            pointer-events: none;\n        }\n\n        .popup-video-play-btn svg {\n            width: 48px;\n            height: 48px;\n        }\n\n        .popup-video-thumbnail:hover .popup-video-overlay {\n            background: rgba(0, 0, 0, 0.12);\n        }\n\n        /* Inline Video Player (replaces thumbnail on play) */\n        .popup-video-player {\n            position: relative;\n            width: 100%;\n            aspect-ratio: 16 / 9;\n            background: transparent;\n        }\n\n        .popup-video-player iframe {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            border: 0;\n        }\n\n        /* * ===================================================================\n         * 6. ACTIONS ROW (Horizontal, Right-aligned)\n         * =================================================================== */\n\n        .popup-actions {\n            display: flex;\n            align-items: center;\n            justify-content: flex-end;\n            gap: 24px;\n            width: 100%;\n        }\n\n        .link-dismiss {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 8px;\n            padding: 8px 16px;\n            border: none;\n            border-radius: 2px;\n            background: none;\n            color: var(--color-text-secondary);\n            font-feature-settings: 'liga' off, 'clig' off;\n            font-family: \"TT Norms Pro\", -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 125%;\n            text-decoration-line: underline;\n            text-decoration-style: solid;\n            text-decoration-skip-ink: none;\n            text-decoration-thickness: auto;\n            text-underline-offset: auto;\n            text-underline-position: from-font;\n            cursor: pointer;\n        }\n\n        .link-dismiss:hover {\n            background: #F6F6F3;\n            color: var(--color-text-primary);\n        }\n\n        .link-dismiss:focus,\n        .link-dismiss:focus-visible {\n            outline: 1px solid var(--color-text-primary);\n            outline-offset: 2px;\n        }\n\n        .btn-primary {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            min-height: 44px;\n            min-width: 150px;\n            padding: 6px 24px;\n            background-color: var(--color-button-primary);\n            border: none;\n            overflow: hidden;\n            color: var(--color-white);\n            font-feature-settings: 'liga' off, 'clig' off;\n            font-family: \"TT Norms Pro\", -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 125%;\n            text-align: center;\n            cursor: pointer;\n        }\n\n        .btn-primary:hover {\n            background-color: #655A47;\n        }\n\n        .btn-primary:focus,\n        .btn-primary:focus-visible {\n            outline: 1px solid var(--color-text-primary);\n            outline-offset: 2px;\n        }\n\n        /* * ===================================================================\n         * 7. RESPONSIVE\n         * =================================================================== */\n\n        @media screen and (max-width: 648px) {\n            .popup-wrapper {\n                padding: 16px;\n            }\n\n            .popup-dialog {\n                padding: 24px;\n            }\n\n            .popup-title {\n                font-size: 20px;\n            }\n\n            .popup-actions {\n                flex-wrap: wrap;\n            }\n        }\n    </style>\n</head>\n\n<body>\n\n    <!-- Main application container -->\n    <div id=\"app-container\">\n        <!-- Content is dynamically injected here -->\n    </div>\n\n    <script>\n        // ===================================================================\n        // GLOBAL CONFIG & DEFAULTS\n        // ===================================================================\n        let globalConfig = {\n            state: {},\n            lang: {},\n            data: {},\n            html: {}\n        };\n\n        const defaultLang = {\n            popupTitle: \"Build a shop that sells more\",\n            popupSubtitle: \"We've created a Wizard that helps you select the right products, prices and labs based on real sales data, so you can maximize your shop revenue.\",\n            getStarted: \"Get started\",\n            dontShowAgain: \"Don't show again\"\n        };\n\n        const defaultPageData = {\n            state: {\n                accountId: \"acc_123\",\n                galleryId: \"gal_456\"\n            },\n            lang: defaultLang,\n            data: {\n                videoThumbnailUrl: \"\",\n                videoUrl: \"\"\n            },\n            fonts: [],\n            html: {}\n        };\n\n        // ===================================================================\n        // 1. PUBLIC METHODS\n        // ===================================================================\n\n        /**\n         * Initializes the interface.\n         * @param {object} config - Full configuration object.\n         */\n        window.myop_init_interface = (config) => {\n            try {\n                globalConfig.state = { ...defaultPageData.state, ...config.state };\n                globalConfig.lang = { ...defaultPageData.lang, ...config.lang };\n                globalConfig.data = { ...defaultPageData.data, ...config.data };\n                globalConfig.html = { ...defaultPageData.html, ...config.html };\n\n                // Load Fonts\n                const fontsToLoad = config.fonts || defaultPageData.fonts;\n                if (fontsToLoad && Array.isArray(fontsToLoad)) {\n                    fontsToLoad.forEach(url => {\n                        if (!document.querySelector(`link[href=\"${url}\"]`)) {\n                            const link = document.createElement('link');\n                            link.rel = 'stylesheet';\n                            link.href = url;\n                            document.head.appendChild(link);\n                        }\n                    });\n                }\n\n                renderApp();\n\n                // Auto-generate thumbnail from video at 2s if no thumbnail provided\n                autoGenerateThumbnail();\n\n                console.log('INTERFACE_INIT: Configuration processed.', globalConfig);\n\n            } catch (e) {\n                console.error('Failed to initialize interface:', e, config);\n            }\n        };\n\n        /**\n         * Handles all calls to action.\n         * @param {string} action_id - The identifier for the action.\n         * @param {object} payload - Data associated with the action.\n         */\n        window.myop_cta_handler = (action_id, payload) => {\n            const output = {\n                action: action_id,\n                payload: payload,\n                timestamp: new Date().toISOString()\n            };\n\n            console.log('CTA_HANDLER:', JSON.stringify(output, null, 2));\n\n            // Dispatch event for external listeners if needed\n            try {\n                const event = new CustomEvent('myop-cta', {\n                    detail: output,\n                    bubbles: true,\n                    composed: true\n                });\n                document.body.dispatchEvent(event);\n            } catch (e) {\n                console.error(\"Failed to dispatch event\", e);\n            }\n        };\n\n        // ===================================================================\n        // 2. CORE RENDER LOGIC\n        // ===================================================================\n\n        /**\n         * Notifies the parent window of the iframe content height.\n         */\n        function notifyParentOfHeight() {\n            try {\n                const body = document.body;\n                const html = document.documentElement;\n                const height = Math.max(\n                    body.scrollHeight,\n                    body.offsetHeight,\n                    html.clientHeight,\n                    html.scrollHeight,\n                    html.offsetHeight\n                );\n\n                if (window.parent && window.parent !== window) {\n                    window.parent.postMessage({\n                        type: 'shop-tab-popup-resize',\n                        height: height\n                    }, '*');\n                }\n            } catch (e) {\n                console.warn('Could not notify parent of height:', e);\n            }\n        }\n\n        function renderApp() {\n            try {\n                const { state, lang, data, html } = globalConfig;\n                if (!state || !lang) return;\n\n                const appContainer = document.getElementById('app-container');\n                appContainer.innerHTML = '';\n\n                // Clean up listeners\n                document.body.removeEventListener('click', handleGlobalClick);\n\n                // Render popup\n                appContainer.innerHTML = getPopupHTML(state, lang, data);\n\n                // Attach listeners\n                document.body.addEventListener('click', handleGlobalClick);\n\n                // Notify parent iframe of content height after render\n                requestAnimationFrame(() => {\n                    notifyParentOfHeight();\n                });\n            } catch (renderError) {\n                console.error(\"RENDER_ERROR:\", renderError);\n                const appContainer = document.getElementById('app-container');\n                if (appContainer && !appContainer.innerHTML) {\n                    appContainer.innerHTML = \"<div style='text-align:center;padding:48px;'><p>Error rendering interface. Please refresh.</p></div>\";\n                }\n            }\n        }\n\n        // ===================================================================\n        // 3. POPUP HTML\n        // ===================================================================\n\n        function getPopupHTML(state, lang, data) {\n            const videoThumbnail = data.videoThumbnailUrl\n                ? `<img src=\"${escapeHTML(data.videoThumbnailUrl)}\" alt=\"Price List Wizard video\">`\n                : `<div style=\"width:100%;height:100%;background:#e5e5e5;border-radius:8px;\"></div>`;\n\n            return `\n                <div class=\"popup-wrapper\">\n                    <div class=\"popup-dialog\">\n                        <!-- Close Button -->\n                        <button class=\"popup-close-btn\" data-action=\"closePopup\" type=\"button\" aria-label=\"Close\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n                                <path d=\"M14.1464 1.1463C14.3417 0.951169 14.6582 0.951082 14.8535 1.1463C15.0487 1.34152 15.0486 1.65806 14.8535 1.85333L8.70697 7.99982L14.8535 14.1463C15.0487 14.3415 15.0486 14.6581 14.8535 14.8533C14.6582 15.0485 14.3416 15.0485 14.1464 14.8533L7.99994 8.70685L1.85345 14.8533C1.65819 15.0486 1.34169 15.0486 1.14642 14.8533C0.951161 14.6581 0.951161 14.3416 1.14642 14.1463L7.29291 7.99982L1.14642 1.85333C0.951163 1.65807 0.951164 1.34156 1.14642 1.1463C1.34169 0.951163 1.65823 0.951083 1.85345 1.1463L7.99994 7.29279L14.1464 1.1463Z\" fill=\"#222222\"/>\n                            </svg>\n                        </button>\n\n                        <!-- Text Section: Title + Subtitle -->\n                        <div class=\"popup-text-section\">\n                            <div class=\"popup-title-row\">\n                                <h1 class=\"popup-title\">${escapeHTML(lang.popupTitle)}</h1>\n                            </div>\n                            <div class=\"popup-subtitle-row\">\n                                <p class=\"popup-subtitle\">${escapeHTML(lang.popupSubtitle)}</p>\n                            </div>\n                        </div>\n\n                        <!-- Body: Video + Actions -->\n                        <div class=\"popup-body-section\">\n                            <!-- Video Thumbnail -->\n                            <div class=\"popup-video-container\">\n                                <div class=\"popup-video-thumbnail\" data-action=\"playVideo\" role=\"button\" tabindex=\"0\" aria-label=\"Play video\">\n                                    ${videoThumbnail}\n                                    <div class=\"popup-video-overlay\"></div>\n                                    <div class=\"popup-video-play-btn\">\n                                        <svg width=\"48\" height=\"48\" viewBox=\"0 0 48 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                            <circle cx=\"24\" cy=\"24\" r=\"23\" fill=\"rgba(0,0,0,0.4)\" stroke=\"white\" stroke-width=\"2\"/>\n                                            <path d=\"M20 16L32 24L20 32V16Z\" fill=\"white\"/>\n                                        </svg>\n                                    </div>\n                                </div>\n                            </div>\n\n                            <!-- Actions Row -->\n                            <div class=\"popup-actions\">\n                                <button class=\"link-dismiss\" data-action=\"dontShowAgain\" type=\"button\">\n                                    ${escapeHTML(lang.dontShowAgain)}\n                                </button>\n                                <button class=\"btn-primary\" data-action=\"getStarted\" type=\"button\">\n                                    ${escapeHTML(lang.getStarted)}\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            `;\n        }\n\n        // ===================================================================\n        // 4. EVENT HANDLERS\n        // ===================================================================\n\n        function handleGlobalClick(event) {\n            const target = event.target.closest('[data-action]');\n            if (!target) return;\n\n            const action = target.dataset.action;\n            const { state } = globalConfig;\n\n            switch (action) {\n                case 'getStarted':\n                    window.myop_cta_handler('getStarted', {\n                        accountId: state.accountId,\n                        galleryId: state.galleryId\n                    });\n                    break;\n\n                case 'dontShowAgain':\n                    window.myop_cta_handler('dontShowAgain', {\n                        accountId: state.accountId,\n                        galleryId: state.galleryId\n                    });\n                    break;\n\n                case 'closePopup':\n                    window.myop_cta_handler('closePopup', {\n                        accountId: state.accountId,\n                        galleryId: state.galleryId\n                    });\n                    break;\n\n                case 'playVideo':\n                    playVideoInline(target);\n                    window.myop_cta_handler('playVideo', {\n                        videoUrl: globalConfig.data.videoUrl || ''\n                    });\n                    break;\n            }\n        }\n\n        // ===================================================================\n        // 5. INLINE VIDEO PLAYER\n        // ===================================================================\n\n        /**\n         * Replaces the video thumbnail with an inline Vimeo iframe player.\n         * Extracts the Vimeo video ID from the configured videoUrl and embeds\n         * the player with autoplay. User can use Vimeo's native fullscreen button.\n         */\n        function playVideoInline(thumbnailEl) {\n            const videoUrl = globalConfig.data.videoUrl || '';\n            if (!videoUrl) return;\n\n            // Extract Vimeo video ID from various URL formats\n            const vimeoId = extractVimeoId(videoUrl);\n            if (!vimeoId) return;\n\n            const container = thumbnailEl.closest('.popup-video-container');\n            if (!container) return;\n\n            // Build embed URL with autoplay and allowing fullscreen via player controls\n            const embedUrl = `https://player.vimeo.com/video/${vimeoId}?autoplay=1&title=0&byline=0&portrait=0`;\n\n            // Replace thumbnail with inline player\n            container.innerHTML = `\n                <div class=\"popup-video-player\">\n                    <iframe\n                        src=\"${embedUrl}\"\n                        allow=\"autoplay; fullscreen; picture-in-picture\"\n                        allowfullscreen\n                        title=\"Price List Wizard video\"\n                    ></iframe>\n                </div>\n            `;\n\n            // Notify parent of height change after embed\n            requestAnimationFrame(() => {\n                notifyParentOfHeight();\n            });\n        }\n\n        /**\n         * Extracts a Vimeo video ID from various URL formats:\n         * - https://vimeo.com/123456789\n         * - https://player.vimeo.com/video/123456789\n         * - https://vimeo.com/channels/xxx/123456789\n         * - https://vimeo.com/groups/xxx/videos/123456789\n         */\n        function extractVimeoId(url) {\n            if (!url) return null;\n            // If it's already just a numeric ID\n            if (/^\\d+$/.test(url.trim())) return url.trim();\n\n            const match = url.match(/(?:vimeo\\.com\\/(?:video\\/|channels\\/\\w+\\/|groups\\/\\w+\\/videos\\/)?|player\\.vimeo\\.com\\/video\\/)(\\d+)/);\n            return match ? match[1] : null;\n        }\n\n        /**\n         * Generates a thumbnail from a direct video URL by capturing the frame at 2 seconds.\n         * Creates a hidden <video> element, seeks to the target time, and draws to a canvas.\n         * @param {string} videoUrl - Direct URL to a video file (mp4, webm, etc.)\n         * @returns {Promise<string>} - Data URL of the captured frame (JPEG)\n         */\n        function generateVideoThumbnail(videoUrl) {\n            return new Promise((resolve, reject) => {\n                const video = document.createElement('video');\n                video.crossOrigin = 'anonymous';\n                video.muted = true;\n                video.preload = 'metadata';\n                video.playsInline = true;\n                video.style.display = 'none';\n                document.body.appendChild(video);\n\n                const cleanup = () => {\n                    video.removeAttribute('src');\n                    video.load();\n                    video.remove();\n                };\n\n                video.addEventListener('loadedmetadata', () => {\n                    // Seek to 2 seconds, or end of video if shorter\n                    video.currentTime = Math.min(2, video.duration);\n                });\n\n                video.addEventListener('seeked', () => {\n                    try {\n                        const canvas = document.createElement('canvas');\n                        canvas.width = video.videoWidth;\n                        canvas.height = video.videoHeight;\n                        const ctx = canvas.getContext('2d');\n                        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);\n                        const dataUrl = canvas.toDataURL('image/jpeg', 0.85);\n                        cleanup();\n                        resolve(dataUrl);\n                    } catch (e) {\n                        cleanup();\n                        reject(e);\n                    }\n                });\n\n                video.addEventListener('error', () => {\n                    cleanup();\n                    reject(new Error('Failed to load video for thumbnail generation'));\n                });\n\n                video.src = videoUrl;\n            });\n        }\n\n        /**\n         * Auto-generates a thumbnail if videoThumbnailUrl is not provided.\n         * For Vimeo URLs, fetches thumbnail via oEmbed API.\n         * For direct video URLs, captures the frame at 2 seconds.\n         */\n        async function autoGenerateThumbnail() {\n            const { data } = globalConfig;\n            if (data.videoThumbnailUrl || !data.videoUrl) return;\n\n            const vimeoId = extractVimeoId(data.videoUrl);\n            if (vimeoId) {\n                // Use Vimeo oEmbed API to get thumbnail\n                try {\n                    const resp = await fetch(`https://vimeo.com/api/oembed.json?url=https://vimeo.com/${vimeoId}&width=625`);\n                    if (resp.ok) {\n                        const json = await resp.json();\n                        if (json.thumbnail_url) {\n                            data.videoThumbnailUrl = json.thumbnail_url;\n                            renderApp();\n                            return;\n                        }\n                    }\n                } catch (e) {\n                    console.warn('Could not fetch Vimeo thumbnail:', e);\n                }\n            } else {\n                // Direct video URL — capture 2-second frame\n                try {\n                    const thumbnailDataUrl = await generateVideoThumbnail(data.videoUrl);\n                    data.videoThumbnailUrl = thumbnailDataUrl;\n                    renderApp();\n                } catch (e) {\n                    console.warn('Could not generate video thumbnail:', e);\n                }\n            }\n        }\n\n        // ===================================================================\n        // 6. UTILITIES\n        // ===================================================================\n\n        function escapeHTML(str) {\n            if (!str) return '';\n            const div = document.createElement('div');\n            div.appendChild(document.createTextNode(str));\n            return div.innerHTML;\n        }\n\n        // ===================================================================\n        // 7. INITIALIZATION\n        // ===================================================================\n\n        document.addEventListener('DOMContentLoaded', () => {\n            console.log('Application Loaded. Waiting for window.myop_init_interface(config) call.');\n\n            // Initial render with mock data\n            window.myop_init_interface({\n                state: {\n                    accountId: \"acc_123\",\n                    galleryId: \"gal_456\"\n                },\n                lang: {},\n                data: {\n                    videoThumbnailUrl: \"\",\n                    videoUrl: \"\"\n                },\n                html: {}\n            });\n\n            // Listen for window resize to update iframe height\n            window.addEventListener('resize', () => {\n                notifyParentOfHeight();\n            });\n        });\n\n    </script>\n</body>\n\n</html>"
        }
      }
    ]
  }
}