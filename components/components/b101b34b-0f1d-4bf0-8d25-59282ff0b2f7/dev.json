        "name": "Version 3",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    interface MyopInitData {\n        mode: 'start' | 'video-slot';\n    }\n\n    interface MyopCtaPayloads {\n        'navigate_back': void;\n        'navigate_session_mode': { mode: string };\n        'session_close': void;\n    }\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n    <style>\n        * { box-sizing: border-box; margin: 0; padding: 0; }\n        html, body { width: 100%; height: 100%; overflow: hidden; margin: 0; padding: 0; }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .screen {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            gap: 24px;\n            padding: 40px;\n            text-align: center;\n            position: relative;\n        }\n\n        .btn--back {\n            position: absolute;\n            top: 16px;\n            left: 16px;\n            padding: 8px 18px;\n            font-size: 14px;\n            font-weight: 600;\n            font-family: sans-serif;\n            border: none;\n            border-radius: 6px;\n            cursor: pointer;\n            background-color: rgba(0,0,0,0.15);\n            color: #ffffff;\n            transition: opacity 0.15s ease;\n        }\n\n        .btn--back:hover {\n            opacity: 0.75;\n        }\n\n        .screen--video-slot .btn--back {\n            background-color: rgba(0,0,0,0.12);\n            color: #1a1a1a;\n        }\n\n        .screen--start {\n            background-color: #7c3aed;\n        }\n\n        .screen--video-slot {\n            background-color: #facc15;\n        }\n\n        .screen__text {\n            font-family: sans-serif;\n            font-size: 20px;\n            font-weight: 600;\n            line-height: 1.4;\n        }\n\n        .screen--start .screen__text {\n            color: #ffffff;\n        }\n\n        .screen--video-slot .screen__text {\n            color: #1a1a1a;\n        }\n\n        .btn {\n            padding: 12px 32px;\n            font-size: 16px;\n            font-weight: 600;\n            font-family: sans-serif;\n            border: none;\n            border-radius: 8px;\n            cursor: pointer;\n            transition: opacity 0.15s ease;\n        }\n\n        .btn:hover {\n            opacity: 0.85;\n        }\n\n        .btn--next {\n            background-color: #ffffff;\n            color: #7c3aed;\n        }\n\n        .btn--done {\n            background-color: #1a1a1a;\n            color: #facc15;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function () {\n        var currentState = { mode: 'start' };\n\n        var screens = {\n            'start': function () {\n                return '<div class=\"screen screen--start\">' +\n                    '<button class=\"btn btn--back\" id=\"btn-back\">Back</button>' +\n                    '<p class=\"screen__text\">Click this to see whats next</p>' +\n                    '<button class=\"btn btn--next\" id=\"btn-next\">Next</button>' +\n                    '</div>';\n            },\n            'video-slot': function () {\n                return '<div class=\"screen screen--video-slot\">' +\n                    '<button class=\"btn btn--back\" id=\"btn-back\">Back</button>' +\n                    '<p class=\"screen__text\">This is it</p>' +\n                    '<button class=\"btn btn--done\" id=\"btn-done\">Done</button>' +\n                    '</div>';\n            }\n        };\n\n        function attachListeners(mode) {\n            document.getElementById('btn-back').addEventListener('click', function () {\n                window.myop_cta_handler('navigate_back', undefined);\n            });\n            if (mode === 'start') {\n                document.getElementById('btn-next').addEventListener('click', function () {\n                    window.myop_cta_handler('navigate_session_mode', { mode: 'video-slot' });\n                    render({ mode: 'video-slot' });\n                });\n            } else if (mode === 'video-slot') {\n                document.getElementById('btn-done').addEventListener('click', function () {\n                    window.myop_cta_handler('session_close', undefined);\n                });\n            }\n        }\n\n        function render(data) {\n            currentState = data;\n            var screenFn = screens[data.mode] || screens['start'];\n            document.getElementById('app-root').innerHTML = screenFn();\n            attachListeners(data.mode);\n        }\n\n        window.myop_init_interface = function (data) {\n            if (!data) return currentState;\n            render(data);\n        };\n\n        window.myop_cta_handler = function (action_id, payload) {\n            // Overridden by host application\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({ mode: 'start' });\n    </script>\n</body>\n</html>\n"
        },
        "id": "494c48a9-f57d-4841-8d17-3dff05f2b107"
      }
    ]
