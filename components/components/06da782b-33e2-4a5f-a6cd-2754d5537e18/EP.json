        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta name=\"myop:size\" content='{\"width\":250,\"height\":\"100%\",\"minWidth\":200,\"maxWidth\":300}'>\r\n    <script type=\"myop/types\">\r\n    /**\r\n     * Data structure passed to myop_init_interface(data)\r\n     */\r\n    interface MyopInitData {\r\n        activeItem: 'vendors' | 'terms' | 'profile' | 'past_invited';\r\n        menuItems?: Array<{\r\n            id: string;\r\n            label: string;\r\n            enabled: boolean;\r\n        }>;\r\n    }\r\n\r\n    /**\r\n     * Actions and payloads for myop_cta_handler(action, payload)\r\n     */\r\n    interface MyopCtaPayloads {\r\n        'navigate': { target: 'vendors' | 'terms' | 'profile' | 'past_invited' };\r\n        'navigate_back': void;\r\n    }\r\n\r\n    declare function myop_init_interface(): MyopInitData;\r\n    declare function myop_init_interface(data: MyopInitData): void;\r\n\r\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\r\n        action: K,\r\n        payload: MyopCtaPayloads[K]\r\n    ): void;\r\n    </script>\r\n    <style>\r\n        * {\r\n            box-sizing: border-box;\r\n            margin: 0;\r\n            padding: 0;\r\n        }\r\n\r\n        html, body {\r\n            margin: 0;\r\n            padding: 0;\r\n            width: 100%;\r\n            height: 100%;\r\n            overflow: hidden;\r\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\r\n            color: #333;\r\n            background: #fff;\r\n        }\r\n\r\n        #app-root {\r\n            width: 100%;\r\n            height: 100%;\r\n            display: flex;\r\n            flex-direction: column;\r\n            padding: 24px 0;\r\n        }\r\n\r\n        .back-btn {\r\n            padding: 0 24px;\r\n            margin-bottom: 12px;\r\n            font-size: 12px;\r\n            color: #666;\r\n            cursor: pointer;\r\n            letter-spacing: 0.5px;\r\n            text-transform: uppercase;\r\n            font-weight: 500;\r\n        }\r\n\r\n        .back-btn:hover {\r\n            color: #333;\r\n        }\r\n\r\n        .section-title {\r\n            padding: 0 24px;\r\n            margin-bottom: 24px;\r\n            font-size: 20px;\r\n            font-weight: 600;\r\n            letter-spacing: 1px;\r\n            text-transform: uppercase;\r\n            cursor: pointer;\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 6px;\r\n        }\r\n\r\n        .section-title .chevron {\r\n            font-size: 10px;\r\n            color: #666;\r\n        }\r\n\r\n        .menu-items {\r\n            display: flex;\r\n            flex-direction: column;\r\n        }\r\n\r\n        .menu-item {\r\n            padding: 10px 24px;\r\n            font-size: 14px;\r\n            color: #999;\r\n            cursor: pointer;\r\n            transition: color 0.15s ease;\r\n        }\r\n\r\n        .menu-item:hover {\r\n            color: #333;\r\n        }\r\n\r\n        .menu-item.active {\r\n            color: #333;\r\n            font-weight: 500;\r\n        }\r\n\r\n        .menu-item.disabled {\r\n            color: #ccc;\r\n            cursor: default;\r\n            pointer-events: none;\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div id=\"app-root\">\r\n        <div class=\"back-btn\" id=\"back-btn\">&lsaquo; BACK</div>\r\n        <div class=\"section-title\" id=\"section-title\">\r\n            VENDORS <span class=\"chevron\">&#8964;</span>\r\n        </div>\r\n        <div class=\"menu-items\" id=\"menu-items\"></div>\r\n    </div>\r\n\r\n    <script>\r\n    (function() {\r\n        var currentState = {\r\n            activeItem: 'profile',\r\n            menuItems: [\r\n                { id: 'vendors', label: 'Vendors', enabled: true },\r\n                { id: 'terms', label: 'Vendor terms', enabled: true },\r\n                { id: 'profile', label: 'Profile', enabled: true },\r\n                { id: 'past_invited', label: 'Past invited', enabled: true }\r\n            ]\r\n        };\r\n\r\n        var menuContainer = document.getElementById('menu-items');\r\n        var backBtn = document.getElementById('back-btn');\r\n\r\n        function render(data) {\r\n            currentState = Object.assign({}, currentState, data);\r\n            var items = currentState.menuItems || [\r\n                { id: 'vendors', label: 'Vendors', enabled: true },\r\n                { id: 'terms', label: 'Vendor terms', enabled: true },\r\n                { id: 'profile', label: 'Profile', enabled: true },\r\n                { id: 'past_invited', label: 'Past invited', enabled: true }\r\n            ];\r\n\r\n            var html = items.map(function(item) {\r\n                var classes = ['menu-item'];\r\n                if (item.id === currentState.activeItem) classes.push('active');\r\n                if (!item.enabled) classes.push('disabled');\r\n                return '<div class=\"' + classes.join(' ') + '\" data-target=\"' + item.id + '\">' + item.label + '</div>';\r\n            }).join('');\r\n\r\n            menuContainer.innerHTML = html;\r\n        }\r\n\r\n        // Event delegation for menu items\r\n        menuContainer.addEventListener('click', function(e) {\r\n            var target = e.target.closest('.menu-item');\r\n            if (!target || target.classList.contains('disabled')) return;\r\n            var itemTarget = target.getAttribute('data-target');\r\n            if (itemTarget) {\r\n                window.myop_cta_handler('navigate', { target: itemTarget });\r\n            }\r\n        });\r\n\r\n        // Back button\r\n        backBtn.addEventListener('click', function() {\r\n            window.myop_cta_handler('navigate_back');\r\n        });\r\n\r\n        // Public API\r\n        window.myop_init_interface = function(data) {\r\n            if (!data) return currentState;\r\n            render(data);\r\n        };\r\n\r\n        window.myop_cta_handler = function(action_id, payload) {\r\n            // Will be overridden by host application\r\n        };\r\n    })();\r\n    </script>\r\n\r\n    <script id=\"myop_preview\">\r\n        window.myop_init_interface({\r\n            activeItem: 'profile'\r\n        });\r\n    </script>\r\n</body>\r\n</html>"
        }
