{
  "version": "0.2.10",
  "item": {
    "name": "Vendors empty state w integrations",
    "id": "f2825cf1-c8b5-4b8b-a7ce-09d0f5c85025",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "name": "Version 9",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n  <title>Vendor Network</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    html, body {\n      width: 100%;\n      height: 100%;\n      overflow: hidden;\n      margin: 0;\n      padding: 0;\n    }\n\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;\n      -webkit-font-smoothing: antialiased;\n      -moz-osx-font-smoothing: grayscale;\n      background-color: #f9fafb;\n    }\n\n    .action-card {\n      cursor: pointer;\n    }\n\n    /* Support for dynamic content injected via JS */\n    .learn-more {\n        color: #2563eb; /* text-blue-600 */\n        margin-left: 0.25rem;\n        cursor: pointer;\n    }\n    .learn-more:hover {\n        text-decoration: underline;\n    }\n    \n    /* Ensure icons injected via JS fit the container */\n    .icon-content svg, .icon-content img {\n        width: 100%;\n        height: 100%;\n        object-fit: contain;\n    }\n  </style>\n</head>\n<body>\n  <main class=\"w-full h-full overflow-y-auto bg-white\" style=\"display: flex; flex-direction: column; min-height: 0;\">\n    <!-- Header -->\n    <div class=\"border-b border-gray-200 px-12 py-6 flex justify-between items-start bg-white\">\n      <div>\n        <h1 id=\"ui-title\" class=\"text-2xl mb-2 text-gray-900\">\n          The Vendor Network: Build connections and boost business\n        </h1>\n        <p id=\"ui-description\" class=\"text-gray-600 text-sm\">\n          Loading...\n        </p>\n      </div>\n      <button id=\"help-btn\" class=\"flex items-center gap-2 text-sm text-gray-700 hover:text-gray-900 transition-colors\">\n        <!-- HelpCircle Icon -->\n        <svg class=\"w-4 h-4\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n          <path d=\"M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3\"/>\n          <line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"/>\n        </svg>\n        <span id=\"help-text\">Help</span>\n      </button>\n    </div>\n\n    <!-- Main Content -->\n    <div class=\"px-12 py-8 flex-1\" style=\"min-height: 0; overflow-y: auto;\">\n      \n      <!-- Section 1 -->\n      <section class=\"mb-10\">\n        <h2 class=\"text-lg mb-4 text-gray-900\">Let others collect contacts for you</h2>\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n          \n          <!-- Card 1: Share Link -->\n          <button id=\"action-share_link\" class=\"action-card hidden w-full text-left border border-gray-200 rounded p-6 hover:border-gray-300 transition-colors bg-white\">\n            <div class=\"flex items-start gap-4\">\n              <div class=\"icon-content w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0 text-gray-700 p-2\">\n                <!-- Link2 Icon -->\n                <svg class=\"w-5 h-5\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                  <path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"/>\n                  <path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"/>\n                </svg>\n              </div>\n              <div>\n                <h3 class=\"card-title text-base mb-1 text-gray-900\">Share registration link</h3>\n                <p class=\"card-desc text-sm text-gray-600\">\n                  Allow clients and vendors to add their contacts for you\n                </p>\n              </div>\n            </div>\n          </button>\n\n          <!-- Card 2: Wedding Workflows -->\n          <button id=\"action-import_from_ww_clicked\" class=\"action-card hidden w-full text-left border border-gray-200 rounded p-6 hover:border-gray-300 transition-colors bg-white\">\n            <div class=\"flex items-start gap-4\">\n              <div class=\"icon-content w-10 h-10 rounded-full bg-[#f5f5f5] flex items-center justify-center flex-shrink-0 p-2\">\n                <!-- Default Placeholder (W text) -->\n                <span class=\"text-[#d4af7a] text-lg font-serif\">W</span>\n              </div>\n              <div>\n                <h3 class=\"card-title text-base mb-1 text-gray-900\">Wedding Workflows</h3>\n                <p class=\"card-desc text-sm text-gray-600\">\n                  Automatically collect vendor details\n                </p>\n              </div>\n            </div>\n          </button>\n\n        </div>\n      </section>\n\n      <!-- Section 2 -->\n      <section class=\"mb-10\">\n        <h2 class=\"text-lg mb-4 text-gray-900\">Do it yourself</h2>\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n          \n          <!-- Card 3: Invite New -->\n          <button id=\"action-invite_new_clicked\" class=\"action-card hidden w-full text-left border border-gray-200 rounded p-6 hover:border-gray-300 transition-colors bg-white\">\n            <div class=\"flex items-start gap-4\">\n              <div class=\"icon-content w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0 text-gray-700 p-2\">\n                <!-- Mail Icon -->\n                <svg class=\"w-5 h-5\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                  <rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"/>\n                  <path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"/>\n                </svg>\n              </div>\n              <div>\n                <h3 class=\"card-title text-base mb-1 text-gray-900\">Invite new vendor</h3>\n                <p class=\"card-desc text-sm text-gray-600\">\n                  Enter a vendor's details and share curated photos\n                </p>\n              </div>\n            </div>\n          </button>\n\n          <!-- Card 4: Invite Existing -->\n          <button id=\"action-invite_existing_clicked\" class=\"action-card hidden w-full text-left border border-gray-200 rounded p-6 hover:border-gray-300 transition-colors bg-white\">\n            <div class=\"flex items-start gap-4\">\n              <div class=\"icon-content w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0 text-gray-700 p-2\">\n                <!-- Plus Icon -->\n                <svg class=\"w-5 h-5\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                  <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/>\n                  <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/>\n                </svg>\n              </div>\n              <div>\n                <h3 class=\"card-title text-base mb-1 text-gray-900\">Invite existing vendors</h3>\n                <p class=\"card-desc text-sm text-gray-600\">\n                  Select vendors you've added or worked with before\n                </p>\n              </div>\n            </div>\n          </button>\n\n        </div>\n      </section>\n\n      <!-- Video Sections -->\n      <div id=\"video-container\" class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n        <!-- Videos will be injected here via JS -->\n      </div>\n    </div>\n  </main>\n\n  <script>\n        /**\n         * Vendor Network Interface\n         */\n        \n        // Action Handler\n        window.myop_cta_handler = function(action_id, payload = {}) {\n            const logEntry = {\n                action: action_id,\n                data: payload,\n                time: new Date().toLocaleTimeString()\n            };\n            console.log(`%c[Action] ${action_id}`, 'color: #3b82f6; font-weight: bold;', payload);\n            window.dispatchEvent(new CustomEvent('myop_action', { detail: logEntry }));\n        };\n\n        // Initialization Logic\n        window.myop_init_interface = function(config) {\n            if (!config) return;\n            \n            // 1. Header Mapping\n            const header = config.header || {};\n            if (header.title) document.getElementById('ui-title').innerText = header.title;\n            if (header.description) document.getElementById('ui-description').innerText = header.description;\n            if (header.helpText) document.getElementById('help-text').innerText = header.helpText;\n\n            // 2. Action Cards Mapping\n            const cards = config.actionCards || [];\n            const betaFlags = config.betaFlags || {};\n\n            cards.forEach(cardData => {\n                // Find element matching the actionId\n                const elId = `action-${cardData.actionId}`;\n                const cardEl = document.getElementById(elId);\n\n                if (cardEl) {\n                    // Special handling for Wedding Workflows - check vendor_integration beta flag\n                    if (cardData.actionId === 'import_from_ww_clicked' && betaFlags.vendor_integration === false) {\n                        // Hide the card completely\n                        cardEl.classList.add('hidden');\n                        return;\n                    }\n\n                    // Show card\n                    cardEl.classList.remove('hidden');\n\n                    // Check if included in current plan (default to true if undefined)\n                    const isIncluded = cardData.includedInCurrentPlan !== false;\n\n                    if (!isIncluded) {\n                        // Apply disabled styles\n                        cardEl.classList.add('opacity-60', 'cursor-not-allowed', 'bg-gray-50');\n                        cardEl.classList.remove('hover:border-gray-300', 'cursor-pointer', 'bg-white');\n                        // Disable button interaction\n                        cardEl.disabled = true;\n                        // No click handler attached\n                        return;\n                    }\n                    \n                    // Set Click Handler (only if included)\n                    cardEl.onclick = function(e) {\n                         // Check if learn-more was clicked (target or parent)\n                         if (e.target.closest('.learn-more')) {\n                             e.stopPropagation();\n                             // Specific handling for Wedding Workflows Learn More\n                             if (cardData.actionId === 'import_from_ww_clicked') {\n                                 window.open(\"https://help.pic-time.com/en/articles/12689343-how-do-i-invite-vendors-from-wedding-workflows\", \"_blank\");\n                                 return;\n                             }\n                             myop_cta_handler('WW learn more clicked', { context: cardData.actionId });\n                             return;\n                         }\n                         myop_cta_handler(cardData.actionId);\n                    };\n\n                    // Set Title & Desc\n                    const titleEl = cardEl.querySelector('.card-title');\n                    const descEl = cardEl.querySelector('.card-desc');\n                    if (titleEl) titleEl.innerText = cardData.title;\n                    if (descEl) descEl.innerHTML = cardData.description; // innerHTML for <span> tags\n\n                    // Set Icon\n                    const iconContainer = cardEl.querySelector('.icon-content');\n                    if (iconContainer) {\n                        // Special Case: Import from WW Logo override\n                        if (cardData.actionId === 'import_from_ww_clicked' && config.wwLogoUrl) {\n                            iconContainer.innerHTML = `<img src=\"${config.wwLogoUrl}\" class=\"w-full h-full object-contain\" alt=\"Icon\">`;\n                        } else if (cardData.iconContent) {\n                            iconContainer.innerHTML = cardData.iconContent;\n                        }\n                    }\n                }\n            });\n\n            // 3. Videos\n            const videos = config.videoCards || config.vendorsIntroVideos || [];\n            const videoContainer = document.getElementById('video-container');\n            \n            if (videoContainer) {\n                videoContainer.innerHTML = ''; // Clear existing\n                \n                videos.forEach(video => {\n                    if (video.src) {\n                        // Create Container for individual video section\n                        const wrapper = document.createElement('div');\n                        \n                        // Add Title (Updated style for new design)\n                        if (video.title) {\n                            const title = document.createElement('h2');\n                            title.className = \"text-lg mb-4 text-gray-900\";\n                            title.innerText = video.title;\n                            wrapper.appendChild(title);\n                        }\n\n                        // Add Video Aspect Ratio Box (Updated classes for new design)\n                        const ratioBox = document.createElement('div');\n                        ratioBox.className = \"relative aspect-video bg-gray-100 rounded overflow-hidden\";\n                        \n                        const iframe = document.createElement('iframe');\n                        iframe.className = \"absolute inset-0 w-full h-full\";\n                        if (video.className) iframe.classList.add(video.className);\n                        \n                        iframe.src = video.src;\n                        iframe.frameBorder = \"0\";\n                        iframe.allow = \"autoplay; fullscreen; picture-in-picture; clipboard-write\";\n                        iframe.loading = \"lazy\";\n                        iframe.title = video.title || \"Video\";\n                        \n                        ratioBox.appendChild(iframe);\n                        wrapper.appendChild(ratioBox);\n                        \n                        videoContainer.appendChild(wrapper);\n                    }\n                });\n            }\n            \n            // 4. Help Button\n            const helpBtn = document.getElementById('help-btn');\n            if (helpBtn) {\n                helpBtn.onclick = () => {\n                    const fallbackUrl = \"https://help.pic-time.com/en/articles/9523692-how-do-i-add-vendors-to-my-gallery\";\n                    const url = config.vendorsKBLink || fallbackUrl;\n                    window.open(url, \"_blank\");\n                };\n            }\n            \n            myop_cta_handler('interface_ready', { timestamp: new Date().toISOString() });\n        };\n\n        // Initialize with the provided data\n        window.addEventListener('load', () => {\n            myop_init_interface({\n              \"_myopName\": \"Vendors empty state with vendors\",\n              \"lang\": {},\n              \"betaFlags\": {\n                \"vendor_integration\": true\n              },\n              \"header\": {\n                \"title\": \"The Vendor Network: Build Connections and Boost Business\",\n                \"description\": \"Share curated galleries, collect contact details, and make impactful connections with other professionals\",\n                \"helpText\": \"Help\"\n              },\n              \"actionCards\": [\n                {\n                  \"title\": \"Invite new vendor\",\n                  \"description\": \"Enter a vendor's details and share curated photos\",\n                  \"actionId\": \"invite_new_clicked\",\n                  \"includedInCurrentPlan\": true,\n                  \"iconContent\": \"<svg class=\\\"card-icon\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\"><path d=\\\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM20 8v6M23 11h-6\\\" stroke=\\\"#6b6b6b\\\" stroke-width=\\\"1.5\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"/></svg>\"\n                },\n                {\n                  \"title\": \"Invite existing vendors\",\n                  \"description\": \"Select vendors you've added or worked with before\",\n                  \"actionId\": \"invite_existing_clicked\",\n                  \"includedInCurrentPlan\": true,\n                  \"iconContent\": \"<svg class=\\\"card-icon\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\"><path d=\\\"M12 5v14M5 12h14\\\" stroke=\\\"#6b6b6b\\\" stroke-width=\\\"1.5\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"/></svg>\"\n                },\n                {\n                  \"title\": \"Share registration link\",\n                  \"description\": \"Let clients and vendors add contacts for you\",\n                  \"actionId\": \"share_link\",\n                  \"includedInCurrentPlan\": true,\n                  \"iconContent\": \"<svg class=\\\"card-icon\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\"><path d=\\\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\\\" stroke=\\\"#6b6b6b\\\" stroke-width=\\\"1.5\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"/></svg>\"\n                },\n                {\n                  \"title\": \"Import from Wedding Workflows\",\n                  \"description\": \"Automatically collect vendor details <span class=\\\"learn-more\\\">Learn More</span>\",\n                  \"actionId\": \"import_from_ww_clicked\",\n                  \"includedInCurrentPlan\": true,\n                  \"iconContent\": \"<svg xmlns=\\\"http://www.w3.org/2000/svg\\\" width=\\\"31\\\" height=\\\"22\\\" viewBox=\\\"0 0 31 22\\\" fill=\\\"none\\\"><path d=\\\"M30.9988 8.37365V8.55481C30.3143 8.58581 30.065 9.34144 29.7751 9.84964L25.727 19.9852L25.6322 20.0272C25.5143 20.0144 25.3793 20.043 25.2669 20.0217C24.9368 19.9579 24.2498 18.8691 24.0723 18.5469C22.8395 16.3116 22.0158 13.6229 20.8596 11.3244C20.8194 11.2454 20.7854 11.1633 20.7155 11.105L17.7039 20.015L16.845 20.0107C16.2194 19.4107 15.789 18.6351 15.4152 17.8606C15.152 17.3153 14.5398 16.0618 14.4024 15.5348C14.3793 15.4466 14.3568 15.3676 14.3872 15.2764L15.1635 13.3499C15.8912 14.9955 16.5617 16.6813 17.338 18.305C17.3647 18.3615 17.49 18.7305 17.5909 18.6284L20.9216 8.41134L21.1903 8.37305L25.7514 18.6892L29.1514 9.65147C29.2772 9.08976 29.2547 8.62715 28.5732 8.55603V8.37487H31L30.9988 8.37365Z\\\" fill=\\\"#967240\\\"/><path d=\\\"M3.3932 2.85352V3.09485C2.42542 3.10762 2.74579 4.04014 2.96706 4.6444C3.96281 7.36172 5.56646 10.0559 6.59807 12.7836L6.82117 13.1672L10.2868 2.86081L10.4838 2.86203L13.6218 10.011L12.8564 11.8328L12.7683 11.7702C11.8303 9.87966 11.119 7.86324 10.1981 5.9678C10.1355 5.83893 10.0801 5.6523 9.94518 5.58422L7.02238 14.4018C6.92998 14.5538 6.22178 14.538 6.06251 14.4711C5.82542 14.3715 5.14944 13.2657 4.99807 12.9873C3.50019 10.2347 2.547 6.92586 1.13788 4.1064C0.995635 3.8213 0.702018 3.26993 0.402929 3.14227C0.236972 3.07175 -0.177618 3.11917 0.0849961 2.85352H3.39138H3.3932Z\\\" fill=\\\"#967240\\\"/><path d=\\\"M19.2901 0.122189L10.7338 21.4778L10.1284 21.3562L18.6846 0L19.2901 0.122189Z\\\" fill=\\\"#967240\\\"/></svg>\"\n                }\n              ],\n              \"videoCards\": [\n                {\n                  \"id\": \"1\",\n                  \"title\": \"How it works\",\n                  \"src\": \"https://player.vimeo.com/video/985695931?h=fcc95795a7&badge=0&autopause=0&player_id=0&app_id=58479\",\n                  \"className\": \"vendors_empty-novendors_video0\"\n                },\n                {\n                  \"id\": \"2\",\n                  \"title\": \"How to share photos with vendors\",\n                  \"src\": \"https://player.vimeo.com/video/981654429?h=831c3b398f&badge=0&autopause=0&player_id=0&app_id=58479\",\n                  \"className\": \"vendors_empty-novendors_video1\"\n                }\n              ],\n              \"vendorsIntroVideos\": [\n                {\n                  \"id\": \"1\",\n                  \"title\": \"Vendors Intro\",\n                  \"src\": \"https://player.vimeo.com/video/985695931?h=fcc95795a7&badge=0&autopause=0&player_id=0&app_id=58479\"\n                },\n                {\n                  \"id\": \"2\",\n                  \"title\": \"Vendors Tutorial\",\n                  \"src\": \"https://player.vimeo.com/video/981654429?h=831c3b398f&badge=0&autopause=0&player_id=0&app_id=58479\"\n                }\n              ],\n              \"vendorsKBLink\": \"https://help.pic-time.com/en/articles/9523692-how-do-i-add-vendors-to-my-gallery\",\n              \"wwLogoUrl\": null\n            });\n        });\n\n        window.addEventListener('keydown', (e) => {\n            if ((e.key === 'Enter' || e.key === ' ') && e.target.classList.contains('action-card')) {\n                e.preventDefault();\n                e.target.click();\n            }\n        });\n    </script>\n</body>\n</html>"
        },
        "id": "7d3888c9-d0da-448e-aa81-e6512166e4cc"
      }
