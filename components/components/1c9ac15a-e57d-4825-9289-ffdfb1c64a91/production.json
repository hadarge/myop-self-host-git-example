{
  "version": "0.2.10",
  "item": {
    "name": "Ph invite - vendor exposure",
    "id": "1c9ac15a-e57d-4825-9289-ffdfb1c64a91",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "name": "Version 3 - photo fix",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Vendor Network</title>\r\n\r\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap\" rel=\"stylesheet\">\r\n\r\n    <style>\r\n        /* 1. CSS Variables */\r\n        :root {\r\n            --font-main: 'Gotham Narrow SSm', 'Montserrat', sans-serif;\r\n            --font-btn: 'Gotham XNarr SSm', 'Montserrat', sans-serif;\r\n            --color-text: #444444;\r\n            --color-bg-overlay: #d0d0d0;\r\n            --color-btn-bg: #ececec;\r\n            --color-btn-hover: #e0e0e0;\r\n            --color-focus-ring: #444444;\r\n            /* Added for accessibility */\r\n            --spacing-card: 40px;\r\n        }\r\n\r\n        /* Reset & Base */\r\n        * {\r\n            margin: 0;\r\n            padding: 0;\r\n            box-sizing: border-box;\r\n        }\r\n\r\n        body,\r\n        html {\r\n            width: 100%;\r\n            height: 100%;\r\n            font-family: var(--font-main);\r\n            background-color: white;\r\n            color: var(--color-text);\r\n        }\r\n\r\n        /* Button Reset (Refactor: New helper for semantic buttons) */\r\n        button {\r\n            border: none;\r\n            background: none;\r\n            font-family: inherit;\r\n            padding: 0;\r\n            cursor: pointer;\r\n            color: inherit;\r\n        }\r\n\r\n        /* Accessibility: Visible Focus Styles */\r\n        button:focus-visible,\r\n        input:focus-visible {\r\n            outline: 2px solid var(--color-focus-ring);\r\n            outline-offset: 2px;\r\n        }\r\n\r\n        /* Layout */\r\n        .container {\r\n            position: relative;\r\n            width: 100%;\r\n            min-height: 100vh;\r\n            display: flex;\r\n            justify-content: center;\r\n            align-items: center;\r\n            overflow-x: hidden;\r\n            padding: 20px;\r\n        }\r\n\r\n        .overlay {\r\n            position: absolute;\r\n            inset: 0;\r\n            background: var(--color-bg-overlay);\r\n            opacity: 0.9;\r\n            z-index: 0;\r\n        }\r\n\r\n        /* Close Button */\r\n        .close-button-wrapper {\r\n            position: absolute;\r\n            top: 20px;\r\n            right: 20px;\r\n            z-index: 20;\r\n            width: 40px;\r\n            height: 40px;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            transition: transform 0.2s;\r\n            border-radius: 50%;\r\n            /* Helps with focus ring shape */\r\n        }\r\n\r\n        .close-button-wrapper:hover {\r\n            transform: scale(1.1);\r\n        }\r\n\r\n        .close-svg svg {\r\n            width: 16px;\r\n            height: 16px;\r\n            display: block;\r\n            stroke: var(--color-text);\r\n            stroke-width: 1.5;\r\n        }\r\n\r\n        /* Card Component */\r\n        .card {\r\n            position: relative;\r\n            background: white;\r\n            width: 100%;\r\n            max-width: 840px;\r\n            min-height: 400px;\r\n            z-index: 10;\r\n            display: flex;\r\n            flex-direction: column-reverse;\r\n            /* Mobile default */\r\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);\r\n            border-radius: 4px;\r\n            overflow: hidden;\r\n        }\r\n\r\n        @media (min-width: 768px) {\r\n            .card {\r\n                flex-direction: row;\r\n                align-items: stretch;\r\n            }\r\n        }\r\n\r\n        /* Card Content (Left) */\r\n        .card-content {\r\n            flex: 1;\r\n            padding: var(--spacing-card);\r\n            display: flex;\r\n            flex-direction: column;\r\n            justify-content: center;\r\n        }\r\n\r\n        /* Card Image (Right) */\r\n        .card-image {\r\n            flex: 1;\r\n            position: relative;\r\n            min-height: 200px;\r\n            background-color: transparent;\r\n        }\r\n\r\n        .card-image img {\r\n            width: 100%;\r\n            height: 100%;\r\n            object-fit: contain;\r\n            object-position: center;\r\n            display: block;\r\n        }\r\n\r\n        /* Typography */\r\n        .pre-header {\r\n            font-size: 13px;\r\n            line-height: 1.2;\r\n            margin-bottom: 4px;\r\n        }\r\n\r\n        .title {\r\n            font-size: 18px;\r\n            font-weight: 500;\r\n            letter-spacing: 0.5px;\r\n            line-height: 1.2;\r\n            margin-top: 8px;\r\n            margin-bottom: 30px;\r\n        }\r\n\r\n        .content-list {\r\n            font-size: 13px;\r\n            letter-spacing: 0.2px;\r\n            line-height: 1.5;\r\n            margin-bottom: 40px;\r\n            max-width: 340px;\r\n        }\r\n\r\n        .content-list ul {\r\n            list-style-type: disc;\r\n            padding-left: 20px;\r\n        }\r\n\r\n        .content-list li {\r\n            margin-bottom: 12px;\r\n        }\r\n\r\n        /* Buttons */\r\n        .button-group {\r\n            display: flex;\r\n            gap: 16px;\r\n            flex-wrap: wrap;\r\n        }\r\n\r\n        .button {\r\n            height: 40px;\r\n            width: 160px;\r\n            background: var(--color-btn-bg);\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            transition: background 0.2s;\r\n            user-select: none;\r\n            border-radius: 2px;\r\n            /* Slight rounding for focus ring */\r\n        }\r\n\r\n        .button:hover {\r\n            background: var(--color-btn-hover);\r\n        }\r\n\r\n        .button-text {\r\n            font-family: var(--font-btn);\r\n            font-size: 12px;\r\n            text-transform: uppercase;\r\n            letter-spacing: 1px;\r\n            white-space: nowrap;\r\n            pointer-events: none;\r\n        }\r\n\r\n        /* Checkbox Styling */\r\n        .checkbox-container {\r\n            margin-top: 20px;\r\n            display: flex;\r\n            align-items: center;\r\n        }\r\n\r\n        .checkbox-container input[type=\"checkbox\"] {\r\n            margin-right: 8px;\r\n            width: 14px;\r\n            height: 14px;\r\n            cursor: pointer;\r\n            accent-color: var(--color-text);\r\n        }\r\n\r\n        .checkbox-container label {\r\n            font-size: 12px;\r\n            cursor: pointer;\r\n            user-select: none;\r\n            opacity: 0.9;\r\n        }\r\n\r\n        /* Mobile Adjustments */\r\n        @media (max-width: 767px) {\r\n            .card-image {\r\n                min-height: 200px;\r\n                max-height: 250px;\r\n            }\r\n\r\n            .card-content {\r\n                padding: 30px 20px;\r\n                text-align: center;\r\n            }\r\n\r\n            .content-list {\r\n                margin: 0 auto 30px auto;\r\n                text-align: left;\r\n                display: inline-block;\r\n            }\r\n\r\n            .button-group {\r\n                justify-content: center;\r\n            }\r\n\r\n            .checkbox-container {\r\n                justify-content: center;\r\n            }\r\n        }\r\n    </style>\r\n</head>\r\n\r\n<body>\r\n\r\n    <div class=\"container\">\r\n        <div class=\"overlay\"></div>\r\n\r\n        <!-- Close Button (Refactor: changed div to button for a11y) -->\r\n        <button class=\"close-button-wrapper\" id=\"btn-close\" type=\"button\" aria-label=\"Close\" onclick=\"myop_cta_handler('close_modal', null)\">\r\n      <div class=\"close-svg\">\r\n        <svg viewBox=\"0 0 16 16\" fill=\"none\" stroke-linecap=\"square\">\r\n          <path d=\"M1 1L15 15M1 15L15 1\" />\r\n        </svg>\r\n      </div>\r\n    </button>\r\n\r\n        <div class=\"card\">\r\n            <!-- Content Section -->\r\n            <div class=\"card-content\">\r\n                <p class=\"pre-header\" id=\"txt-preheader\">Sharing with vendors?</p>\r\n                <h2 class=\"title\" id=\"txt-title\">Invite them to the Vendor Network</h2>\r\n\r\n                <div class=\"content-list\">\r\n                    <ul id=\"list-features\">\r\n                        <!-- Features populated by JS -->\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"button-group\">\r\n                    <!-- Refactor: changed div to button -->\r\n                    <button class=\"button\" id=\"btn-primary\" type=\"button\" onclick=\"myop_cta_handler('share_vendors_clicked', { target: 'vendor_tab', action: 'redirect' })\">\r\n            <span class=\"button-text\" id=\"txt-btn-primary\">Invite Vendors</span>\r\n          </button>\r\n\r\n                    <button class=\"button\" id=\"btn-secondary\" type=\"button\" onclick=\"myop_cta_handler('share_others_clicked', { type: 'secondary' })\">\r\n            <span class=\"button-text\" id=\"txt-btn-secondary\">Invite Others</span>\r\n          </button>\r\n                </div>\r\n\r\n                <!-- Checkbox -->\r\n                <div class=\"checkbox-container\">\r\n                    <input type=\"checkbox\" id=\"chk-no-show\" onchange=\"myop_cta_handler('do_not_show_again_clicked', { checked: this.checked })\">\r\n                    <label for=\"chk-no-show\">Do not show this again</label>\r\n                </div>\r\n\r\n            </div>\r\n\r\n            <!-- Image Section -->\r\n            <div class=\"card-image\">\r\n                <img id=\"img-main\"\r\n             src=\"data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7\"\r\n             onerror=\"this.src='https://placehold.co/438x339/fafafa/e0e0e0?text=Vendor+Image'\"\r\n             alt=\"Vendor Network Interface\">\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <script>\r\n        /**\r\n     * 1. myop_init_interface\r\n     * Initializes the UI with configuration data.\r\n     */\r\n    window.myop_init_interface = function(config) {\r\n      if (!config) return console.warn('myop_init_interface: No config provided');\r\n\r\n      console.log('myop_init_interface payload:', config);\r\n\r\n      if (config.galleryId) {\r\n        console.log(`Loading cover photo associated with Gallery ID: ${config.galleryId}`);\r\n      }\r\n\r\n      // Helper for safely setting text\r\n      const setText = (id, text) => {\r\n        const el = document.getElementById(id);\r\n        if (el && text) el.textContent = text;\r\n      };\r\n\r\n      setText('txt-preheader', config.preHeader);\r\n      setText('txt-title', config.title);\r\n      setText('txt-btn-primary', config.buttons?.primary);\r\n      setText('txt-btn-secondary', config.buttons?.secondary);\r\n\r\n      // Update Features List\r\n      if (Array.isArray(config.features)) {\r\n        const listEl = document.getElementById('list-features');\r\n        if (listEl) {\r\n          listEl.innerHTML = config.features.map(f => `\r\n            <li>\r\n              <strong>${f.title}</strong>\r\n              <div style=\"margin-top:2px;\">${f.desc}</div>\r\n            </li>\r\n          `).join('');\r\n        }\r\n      }\r\n\r\n      // Update Image\r\n      if (config.imageSrc) {\r\n        const imgEl = document.getElementById('img-main');\r\n        if (imgEl) imgEl.src = config.imageSrc;\r\n      }\r\n    };\r\n\r\n    /**\r\n     * 2. myop_cta_handler\r\n     * Central handler for all CTA interactions.\r\n     */\r\n    window.myop_cta_handler = function(action_id, payload) {\r\n      console.log('CTA Action:', action_id, 'Payload:', payload);\r\n\r\n      // Business Logic Mapping\r\n      switch (action_id) {\r\n        case 'close_modal':\r\n          console.log('Action: Close Modal');\r\n          alert('Action: Close Modal triggered');\r\n          break;\r\n        case 'share_vendors_clicked':\r\n          console.log('Action: Invite Vendors Clicked');\r\n          alert('Action: Invite Vendors triggered');\r\n          break;\r\n        case 'share_others_clicked':\r\n          console.log('Action: Invite Others Clicked');\r\n          alert('Action: Invite Others triggered');\r\n          break;\r\n        case 'do_not_show_again_clicked':\r\n          console.log('Action: Do not show again toggled', payload);\r\n          // Alert just to confirm it works in preview\r\n          if(payload.checked) {\r\n            alert('Action: Do not show again CHECKED');\r\n          }\r\n          break;\r\n        default:\r\n          break;\r\n      }\r\n    };\r\n\r\n    // Initialization Simulation\r\n    document.addEventListener('DOMContentLoaded', () => {\r\n      const defaultConfig = {\r\n        galleryId: \"102938\",\r\n        preHeader: \"Sharing with vendors?\",\r\n        title: \"Invite them to the Vendor Network\",\r\n        features: [\r\n          { \r\n            title: \"Boost exposure\", \r\n            desc: \"Guarantee social credits and stronger vendor connections.\" \r\n          },\r\n          { \r\n            title: \"Save time\", \r\n            desc: \"Share auto-curated sets or hand-picked photos in just a few clicks.\" \r\n          },\r\n          { \r\n            title: \"Stay in control\", \r\n            desc: \"Define exactly how each vendor can use your photos.\" \r\n          }\r\n        ],\r\n        buttons: {\r\n          primary: \"Invite Vendors\",\r\n          secondary: \"Invite Others\"\r\n        },\r\n        imageSrc: \"https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=800\"\r\n      };\r\n\r\n      // Simulate external call\r\n      window.myop_init_interface(defaultConfig);\r\n    });\r\n    </script>\r\n</body>\r\n\r\n</html>"
        },
        "id": "4da901dc-3e14-4725-b771-0f362720607c"
      }
    ]
  }
}