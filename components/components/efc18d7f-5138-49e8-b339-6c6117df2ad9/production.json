{
  "version": "0.2.10",
  "item": {
    "name": "WWW landing test 1",
    "id": "efc18d7f-5138-49e8-b339-6c6117df2ad9",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "e8dd7753-9e13-43e5-86c4-f185b51f448c",
        "name": "Version 1",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <title>Photographer Portfolio</title>\n\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    interface SocialHandle {\n        ig?: string;\n        facebook?: string;\n        x?: string;\n        www?: string;\n    }\n\n    interface MyopInitData {\n        brandName: string;\n        accountName: string;\n        country: string;\n        serviceEmail: string;\n        socialHandle: SocialHandle;\n        brandLeadingMedia: string[];\n        leadingMedia_ByPhotographyCategory: Record<string, string[]>;\n        accountDarkLogo?: string;\n        accountBrightLogo?: string;\n        aboutText?: string;\n        myPhotographyPrinciples?: string;\n    }\n\n    interface MyopCtaPayloads {\n        'contact-clicked': { email: string };\n        'gallery-image-clicked': { imageUrl: string; index: number };\n        'category-selected': { category: string };\n        'social-link-clicked': { platform: string; url: string };\n        'size-requested': {\n            width?: number | null;\n            height?: number | null;\n            minWidth?: number | null;\n            maxWidth?: number | null;\n            minHeight?: number | null;\n            maxHeight?: number | null;\n            required?: boolean;\n        };\n    }\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n\n    <style>\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n\n        html, body {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            font-family: 'Montserrat', sans-serif;\n            background: #0a0a0a;\n            color: #fff;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            overflow-y: auto;\n            overflow-x: hidden;\n            scroll-behavior: smooth;\n        }\n\n        /* Navigation */\n        .nav {\n            position: fixed;\n            top: 0;\n            left: 0;\n            right: 0;\n            z-index: 100;\n            padding: 20px 40px;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            background: linear-gradient(to bottom, rgba(10,10,10,0.9) 0%, transparent 100%);\n            transition: background 0.3s ease;\n        }\n\n        .nav.scrolled {\n            background: rgba(10,10,10,0.95);\n            backdrop-filter: blur(10px);\n        }\n\n        .nav-logo img {\n            height: 50px;\n            width: auto;\n            filter: brightness(1.1);\n        }\n\n        .nav-links {\n            display: flex;\n            gap: 40px;\n            list-style: none;\n        }\n\n        .nav-links a {\n            color: #fff;\n            text-decoration: none;\n            font-size: 12px;\n            font-weight: 500;\n            letter-spacing: 2px;\n            text-transform: uppercase;\n            opacity: 0.8;\n            transition: opacity 0.3s ease;\n        }\n\n        .nav-links a:hover {\n            opacity: 1;\n        }\n\n        /* Hero Section */\n        .hero {\n            position: relative;\n            height: 100vh;\n            min-height: 600px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            overflow: hidden;\n        }\n\n        .hero-slideshow {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n        }\n\n        .hero-slide {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            opacity: 0;\n            transition: opacity 1.5s ease-in-out;\n            background-size: cover;\n            background-position: center;\n        }\n\n        .hero-slide.active {\n            opacity: 1;\n        }\n\n        .hero-overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(to bottom,\n                rgba(0,0,0,0.3) 0%,\n                rgba(0,0,0,0.1) 40%,\n                rgba(0,0,0,0.1) 60%,\n                rgba(0,0,0,0.7) 100%);\n        }\n\n        .hero-content {\n            position: relative;\n            z-index: 2;\n            text-align: center;\n            padding: 20px;\n        }\n\n        .hero-title {\n            font-family: 'Cormorant Garamond', serif;\n            font-size: clamp(48px, 10vw, 120px);\n            font-weight: 300;\n            letter-spacing: 8px;\n            text-transform: uppercase;\n            margin-bottom: 20px;\n            line-height: 1;\n        }\n\n        .hero-subtitle {\n            font-size: 13px;\n            font-weight: 400;\n            letter-spacing: 6px;\n            text-transform: uppercase;\n            opacity: 0.9;\n        }\n\n        .scroll-indicator {\n            position: absolute;\n            bottom: 40px;\n            left: 50%;\n            transform: translateX(-50%);\n            z-index: 2;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 10px;\n            cursor: pointer;\n            opacity: 0.7;\n            transition: opacity 0.3s ease;\n        }\n\n        .scroll-indicator:hover {\n            opacity: 1;\n        }\n\n        .scroll-indicator span {\n            font-size: 10px;\n            letter-spacing: 3px;\n            text-transform: uppercase;\n        }\n\n        .scroll-line {\n            width: 1px;\n            height: 60px;\n            background: linear-gradient(to bottom, #fff, transparent);\n            animation: scrollPulse 2s ease-in-out infinite;\n        }\n\n        @keyframes scrollPulse {\n            0%, 100% { opacity: 0.3; transform: scaleY(0.5); }\n            50% { opacity: 1; transform: scaleY(1); }\n        }\n\n        /* Section Styling */\n        section {\n            padding: 120px 40px;\n        }\n\n        .section-title {\n            font-family: 'Cormorant Garamond', serif;\n            font-size: clamp(36px, 5vw, 56px);\n            font-weight: 300;\n            text-align: center;\n            margin-bottom: 20px;\n            letter-spacing: 4px;\n        }\n\n        .section-subtitle {\n            text-align: center;\n            font-size: 12px;\n            letter-spacing: 4px;\n            text-transform: uppercase;\n            opacity: 0.6;\n            margin-bottom: 60px;\n        }\n\n        /* About Section */\n        .about {\n            background: #111;\n        }\n\n        .about-content {\n            max-width: 900px;\n            margin: 0 auto;\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 80px;\n            align-items: start;\n        }\n\n        .about-text {\n            font-family: 'Cormorant Garamond', serif;\n            font-size: 20px;\n            line-height: 1.9;\n            font-weight: 300;\n            color: rgba(255,255,255,0.85);\n            font-style: italic;\n        }\n\n        .about-principles h3 {\n            font-family: 'Cormorant Garamond', serif;\n            font-size: 24px;\n            font-weight: 400;\n            margin-bottom: 25px;\n            letter-spacing: 2px;\n        }\n\n        .about-principles p {\n            font-size: 14px;\n            line-height: 2;\n            color: rgba(255,255,255,0.7);\n            font-weight: 300;\n        }\n\n        /* Gallery Section */\n        .gallery {\n            background: #0a0a0a;\n        }\n\n        .gallery-categories {\n            display: flex;\n            justify-content: center;\n            gap: 40px;\n            margin-bottom: 50px;\n            flex-wrap: wrap;\n        }\n\n        .category-btn {\n            background: none;\n            border: none;\n            color: #fff;\n            font-size: 12px;\n            font-weight: 500;\n            letter-spacing: 3px;\n            text-transform: uppercase;\n            cursor: pointer;\n            opacity: 0.5;\n            transition: all 0.3s ease;\n            padding: 10px 0;\n            border-bottom: 1px solid transparent;\n        }\n\n        .category-btn:hover,\n        .category-btn.active {\n            opacity: 1;\n            border-bottom-color: #fff;\n        }\n\n        .gallery-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n            gap: 15px;\n            max-width: 1400px;\n            margin: 0 auto;\n        }\n\n        .gallery-item {\n            position: relative;\n            aspect-ratio: 3/4;\n            overflow: hidden;\n            cursor: pointer;\n        }\n\n        .gallery-item:nth-child(3n+1) {\n            aspect-ratio: 4/3;\n        }\n\n        .gallery-item:nth-child(5n+2) {\n            aspect-ratio: 1;\n        }\n\n        .gallery-item img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            transition: transform 0.8s ease;\n        }\n\n        .gallery-item:hover img {\n            transform: scale(1.05);\n        }\n\n        .gallery-item::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(0,0,0,0);\n            transition: background 0.3s ease;\n        }\n\n        .gallery-item:hover::after {\n            background: rgba(0,0,0,0.2);\n        }\n\n        /* Contact Section */\n        .contact {\n            background: #111;\n            text-align: center;\n        }\n\n        .contact-content {\n            max-width: 600px;\n            margin: 0 auto;\n        }\n\n        .contact-email {\n            font-family: 'Cormorant Garamond', serif;\n            font-size: clamp(24px, 4vw, 36px);\n            color: #fff;\n            text-decoration: none;\n            display: inline-block;\n            margin-bottom: 50px;\n            transition: opacity 0.3s ease;\n            font-weight: 300;\n            letter-spacing: 2px;\n        }\n\n        .contact-email:hover {\n            opacity: 0.7;\n        }\n\n        .social-links {\n            display: flex;\n            justify-content: center;\n            gap: 30px;\n        }\n\n        .social-link {\n            width: 50px;\n            height: 50px;\n            border: 1px solid rgba(255,255,255,0.3);\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: #fff;\n            text-decoration: none;\n            transition: all 0.3s ease;\n        }\n\n        .social-link:hover {\n            background: #fff;\n            color: #0a0a0a;\n            border-color: #fff;\n        }\n\n        .social-link svg {\n            width: 20px;\n            height: 20px;\n            fill: currentColor;\n        }\n\n        /* Footer */\n        .footer {\n            padding: 40px;\n            text-align: center;\n            background: #0a0a0a;\n            border-top: 1px solid rgba(255,255,255,0.1);\n        }\n\n        .footer-logo img {\n            height: 40px;\n            margin-bottom: 20px;\n            opacity: 0.8;\n        }\n\n        .footer-text {\n            font-size: 11px;\n            letter-spacing: 2px;\n            opacity: 0.5;\n            text-transform: uppercase;\n        }\n\n        /* Lightbox */\n        .lightbox {\n            display: none;\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(0,0,0,0.95);\n            z-index: 1000;\n            align-items: center;\n            justify-content: center;\n            cursor: pointer;\n        }\n\n        .lightbox.active {\n            display: flex;\n        }\n\n        .lightbox img {\n            max-width: 90%;\n            max-height: 90%;\n            object-fit: contain;\n        }\n\n        .lightbox-close {\n            position: absolute;\n            top: 30px;\n            right: 30px;\n            width: 40px;\n            height: 40px;\n            background: none;\n            border: none;\n            color: #fff;\n            font-size: 30px;\n            cursor: pointer;\n            opacity: 0.7;\n            transition: opacity 0.3s ease;\n        }\n\n        .lightbox-close:hover {\n            opacity: 1;\n        }\n\n        .lightbox-nav {\n            position: absolute;\n            top: 50%;\n            transform: translateY(-50%);\n            background: none;\n            border: none;\n            color: #fff;\n            font-size: 40px;\n            cursor: pointer;\n            opacity: 0.7;\n            transition: opacity 0.3s ease;\n            padding: 20px;\n        }\n\n        .lightbox-nav:hover {\n            opacity: 1;\n        }\n\n        .lightbox-prev {\n            left: 20px;\n        }\n\n        .lightbox-next {\n            right: 20px;\n        }\n\n        /* Responsive */\n        @media (max-width: 768px) {\n            .nav {\n                padding: 15px 20px;\n            }\n\n            .nav-links {\n                display: none;\n            }\n\n            section {\n                padding: 80px 20px;\n            }\n\n            .about-content {\n                grid-template-columns: 1fr;\n                gap: 40px;\n            }\n\n            .gallery-grid {\n                grid-template-columns: repeat(2, 1fr);\n                gap: 8px;\n            }\n\n            .gallery-item,\n            .gallery-item:nth-child(3n+1),\n            .gallery-item:nth-child(5n+2) {\n                aspect-ratio: 1;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\">\n        <!-- Content will be rendered here -->\n    </div>\n\n    <div class=\"lightbox\" id=\"lightbox\">\n        <button class=\"lightbox-close\">&times;</button>\n        <button class=\"lightbox-nav lightbox-prev\">&#8249;</button>\n        <button class=\"lightbox-nav lightbox-next\">&#8250;</button>\n        <img src=\"\" alt=\"Gallery Image\">\n    </div>\n\n    <script>\n    (function() {\n        let currentState = null;\n        let currentCategory = 'all';\n        let currentSlide = 0;\n        let slideInterval = null;\n        let lightboxImages = [];\n        let lightboxIndex = 0;\n\n        function escapeHtml(text) {\n            if (!text) return '';\n            const div = document.createElement('div');\n            div.textContent = text;\n            return div.innerHTML;\n        }\n\n        function buildHeroSlides(images) {\n            return images.slice(0, 5).map((img, i) => `\n                <div class=\"hero-slide ${i === 0 ? 'active' : ''}\" style=\"background-image: url('${img}')\"></div>\n            `).join('');\n        }\n\n        function buildSocialLinks(social) {\n            const links = [];\n            if (social.ig) {\n                links.push(`<a href=\"${social.ig}\" target=\"_blank\" rel=\"noopener\" class=\"social-link\" data-platform=\"instagram\">\n                    <svg viewBox=\"0 0 24 24\"><path d=\"M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z\"/></svg>\n                </a>`);\n            }\n            if (social.facebook) {\n                links.push(`<a href=\"${social.facebook}\" target=\"_blank\" rel=\"noopener\" class=\"social-link\" data-platform=\"facebook\">\n                    <svg viewBox=\"0 0 24 24\"><path d=\"M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z\"/></svg>\n                </a>`);\n            }\n            if (social.x) {\n                links.push(`<a href=\"${social.x}\" target=\"_blank\" rel=\"noopener\" class=\"social-link\" data-platform=\"x\">\n                    <svg viewBox=\"0 0 24 24\"><path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/></svg>\n                </a>`);\n            }\n            if (social.www) {\n                links.push(`<a href=\"${social.www}\" target=\"_blank\" rel=\"noopener\" class=\"social-link\" data-platform=\"website\">\n                    <svg viewBox=\"0 0 24 24\"><path d=\"M12 0c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm1 16.057v-3.057h2.994c-.059 1.143-.212 2.24-.456 3.279-.823-.12-1.674-.188-2.538-.222zm1.957 2.162c-.499 1.33-1.159 2.497-1.957 3.456v-3.62c.666.028 1.319.081 1.957.164zm-1.957-7.219v-3.015c.868-.034 1.721-.103 2.548-.224.238 1.027.389 2.111.446 3.239h-2.994zm0-5.014v-3.661c.806.969 1.471 2.15 1.971 3.496-.642.084-1.3.137-1.971.165zm2.703-3.267c1.237.496 2.354 1.228 3.29 2.146-.642.234-1.311.442-2.019.607-.344-.992-.775-1.91-1.271-2.753zm-7.241 13.56c-.244-1.039-.398-2.136-.456-3.279h2.994v3.057c-.865.034-1.714.102-2.538.222zm2.538 1.776v3.62c-.798-.959-1.458-2.126-1.957-3.456.638-.083 1.291-.136 1.957-.164zm-2.994-7.055c.057-1.128.207-2.212.446-3.239.827.121 1.68.19 2.548.224v3.015h-2.994zm1.024-5.179c.5-1.346 1.165-2.527 1.97-3.496v3.661c-.671-.028-1.329-.081-1.97-.165zm-2.005-.35c-.708-.165-1.377-.373-2.018-.607.937-.918 2.053-1.65 3.29-2.146-.496.844-.927 1.762-1.272 2.753zm-.549 1.918c-.264 1.151-.434 2.36-.492 3.611h-3.933c.165-1.658.739-3.197 1.617-4.518.88.361 1.816.67 2.808.907zm.009 9.262c-.988.236-1.92.542-2.797.9-.89-1.328-1.471-2.879-1.637-4.551h3.934c.058 1.265.231 2.488.5 3.651zm.553 1.917c.342.976.768 1.881 1.257 2.712-1.223-.49-2.326-1.211-3.256-2.115.636-.229 1.299-.435 1.999-.597zm9.924 0c.7.163 1.362.367 1.999.597-.931.903-2.034 1.625-3.257 2.116.489-.832.915-1.737 1.258-2.713zm.553-1.917c.27-1.163.442-2.386.501-3.651h3.934c-.167 1.672-.748 3.223-1.638 4.551-.877-.358-1.81-.664-2.797-.9zm.501-5.651c-.058-1.251-.229-2.46-.492-3.611.992-.237 1.929-.546 2.809-.907.877 1.321 1.451 2.86 1.616 4.518h-3.933z\"/></svg>\n                </a>`);\n            }\n            return links.join('');\n        }\n\n        function buildGalleryImages(data, category) {\n            let images = [];\n            if (category === 'all') {\n                images = data.brandLeadingMedia || [];\n            } else if (data.leadingMedia_ByPhotographyCategory && data.leadingMedia_ByPhotographyCategory[category]) {\n                images = data.leadingMedia_ByPhotographyCategory[category];\n            }\n\n            lightboxImages = images;\n\n            return images.map((img, i) => `\n                <div class=\"gallery-item\" data-index=\"${i}\">\n                    <img src=\"${img}\" alt=\"Gallery Image ${i + 1}\" loading=\"lazy\">\n                </div>\n            `).join('');\n        }\n\n        function buildCategoryButtons(data) {\n            const categories = Object.keys(data.leadingMedia_ByPhotographyCategory || {});\n            let buttons = `<button class=\"category-btn active\" data-category=\"all\">All Work</button>`;\n            categories.forEach(cat => {\n                buttons += `<button class=\"category-btn\" data-category=\"${escapeHtml(cat)}\">${escapeHtml(cat)}</button>`;\n            });\n            return buttons;\n        }\n\n        function render(data) {\n            const container = document.getElementById('app-root');\n            const brandName = data.brandName || 'Photography';\n            const nameParts = brandName.split(' ');\n\n            container.innerHTML = `\n                <nav class=\"nav\" id=\"nav\">\n                    <div class=\"nav-logo\">\n                        <img src=\"${data.accountBrightLogo || ''}\" alt=\"${escapeHtml(brandName)}\">\n                    </div>\n                    <ul class=\"nav-links\">\n                        <li><a href=\"#home\">Home</a></li>\n                        <li><a href=\"#about\">About</a></li>\n                        <li><a href=\"#gallery\">Portfolio</a></li>\n                        <li><a href=\"#contact\">Contact</a></li>\n                    </ul>\n                </nav>\n\n                <section class=\"hero\" id=\"home\">\n                    <div class=\"hero-slideshow\">\n                        ${buildHeroSlides(data.brandLeadingMedia || [])}\n                    </div>\n                    <div class=\"hero-overlay\"></div>\n                    <div class=\"hero-content\">\n                        <h1 class=\"hero-title\">${escapeHtml(brandName)}</h1>\n                        <p class=\"hero-subtitle\">Wedding & Portrait Photography</p>\n                    </div>\n                    <div class=\"scroll-indicator\">\n                        <span>Scroll</span>\n                        <div class=\"scroll-line\"></div>\n                    </div>\n                </section>\n\n                <section class=\"about\" id=\"about\">\n                    <h2 class=\"section-title\">The Story</h2>\n                    <p class=\"section-subtitle\">Behind the lens</p>\n                    <div class=\"about-content\">\n                        <div class=\"about-text\">\n                            \"${escapeHtml(data.aboutText || '')}\"\n                        </div>\n                        <div class=\"about-principles\">\n                            <h3>My Approach</h3>\n                            <p>${escapeHtml(data.myPhotographyPrinciples || '')}</p>\n                        </div>\n                    </div>\n                </section>\n\n                <section class=\"gallery\" id=\"gallery\">\n                    <h2 class=\"section-title\">Portfolio</h2>\n                    <p class=\"section-subtitle\">Selected works</p>\n                    <div class=\"gallery-categories\">\n                        ${buildCategoryButtons(data)}\n                    </div>\n                    <div class=\"gallery-grid\" id=\"gallery-grid\">\n                        ${buildGalleryImages(data, 'all')}\n                    </div>\n                </section>\n\n                <section class=\"contact\" id=\"contact\">\n                    <h2 class=\"section-title\">Get in Touch</h2>\n                    <p class=\"section-subtitle\">Let's create something beautiful</p>\n                    <div class=\"contact-content\">\n                        <a href=\"mailto:${data.serviceEmail}\" class=\"contact-email\">${escapeHtml(data.serviceEmail)}</a>\n                        <div class=\"social-links\">\n                            ${buildSocialLinks(data.socialHandle || {})}\n                        </div>\n                    </div>\n                </section>\n\n                <footer class=\"footer\">\n                    <div class=\"footer-logo\">\n                        <img src=\"${data.accountBrightLogo || ''}\" alt=\"${escapeHtml(brandName)}\">\n                    </div>\n                    <p class=\"footer-text\">&copy; ${new Date().getFullYear()} ${escapeHtml(brandName)}. All rights reserved.</p>\n                </footer>\n            `;\n\n            attachEventListeners(data);\n            startSlideshow();\n        }\n\n        function attachEventListeners(data) {\n            // Navigation scroll effect\n            const nav = document.getElementById('nav');\n            const appRoot = document.getElementById('app-root');\n            appRoot.addEventListener('scroll', () => {\n                if (appRoot.scrollTop > 100) {\n                    nav.classList.add('scrolled');\n                } else {\n                    nav.classList.remove('scrolled');\n                }\n            });\n\n            // Smooth scroll for nav links\n            document.querySelectorAll('.nav-links a, .scroll-indicator').forEach(link => {\n                link.addEventListener('click', (e) => {\n                    e.preventDefault();\n                    const targetId = link.getAttribute('href') || '#about';\n                    const target = document.querySelector(targetId);\n                    if (target) {\n                        target.scrollIntoView({ behavior: 'smooth' });\n                    }\n                });\n            });\n\n            // Category buttons\n            document.querySelectorAll('.category-btn').forEach(btn => {\n                btn.addEventListener('click', () => {\n                    document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));\n                    btn.classList.add('active');\n                    currentCategory = btn.dataset.category;\n                    document.getElementById('gallery-grid').innerHTML = buildGalleryImages(data, currentCategory);\n                    attachGalleryListeners();\n                    window.myop_cta_handler('category-selected', { category: currentCategory });\n                });\n            });\n\n            // Gallery items\n            attachGalleryListeners();\n\n            // Lightbox\n            const lightbox = document.getElementById('lightbox');\n            lightbox.querySelector('.lightbox-close').addEventListener('click', closeLightbox);\n            lightbox.addEventListener('click', (e) => {\n                if (e.target === lightbox) closeLightbox();\n            });\n            lightbox.querySelector('.lightbox-prev').addEventListener('click', (e) => {\n                e.stopPropagation();\n                navigateLightbox(-1);\n            });\n            lightbox.querySelector('.lightbox-next').addEventListener('click', (e) => {\n                e.stopPropagation();\n                navigateLightbox(1);\n            });\n\n            // Social links\n            document.querySelectorAll('.social-link').forEach(link => {\n                link.addEventListener('click', (e) => {\n                    const platform = link.dataset.platform;\n                    const url = link.href;\n                    window.myop_cta_handler('social-link-clicked', { platform, url });\n                });\n            });\n\n            // Contact email\n            const emailLink = document.querySelector('.contact-email');\n            if (emailLink) {\n                emailLink.addEventListener('click', () => {\n                    window.myop_cta_handler('contact-clicked', { email: data.serviceEmail });\n                });\n            }\n        }\n\n        function attachGalleryListeners() {\n            document.querySelectorAll('.gallery-item').forEach(item => {\n                item.addEventListener('click', () => {\n                    const index = parseInt(item.dataset.index);\n                    openLightbox(index);\n                });\n            });\n        }\n\n        function openLightbox(index) {\n            lightboxIndex = index;\n            const lightbox = document.getElementById('lightbox');\n            lightbox.querySelector('img').src = lightboxImages[index];\n            lightbox.classList.add('active');\n            window.myop_cta_handler('gallery-image-clicked', { imageUrl: lightboxImages[index], index });\n        }\n\n        function closeLightbox() {\n            document.getElementById('lightbox').classList.remove('active');\n        }\n\n        function navigateLightbox(direction) {\n            lightboxIndex += direction;\n            if (lightboxIndex < 0) lightboxIndex = lightboxImages.length - 1;\n            if (lightboxIndex >= lightboxImages.length) lightboxIndex = 0;\n            document.getElementById('lightbox').querySelector('img').src = lightboxImages[lightboxIndex];\n        }\n\n        function startSlideshow() {\n            if (slideInterval) clearInterval(slideInterval);\n            const slides = document.querySelectorAll('.hero-slide');\n            if (slides.length <= 1) return;\n\n            slideInterval = setInterval(() => {\n                slides[currentSlide].classList.remove('active');\n                currentSlide = (currentSlide + 1) % slides.length;\n                slides[currentSlide].classList.add('active');\n            }, 5000);\n        }\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            currentState = data;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action, payload) {\n            // Will be overridden by host application\n            console.log('CTA:', action, payload);\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            \"__type\": \"Pictime.Interfaces.webMyLPWWWDTO\",\n            \"brandName\": \"nirav patel\",\n            \"accountName\": \"nirav patel\",\n            \"country\": \"United States\",\n            \"serviceEmail\": \"nikusp@gmail.com\",\n            \"socialHandle\": {\n                \"ig\": \"https://www.instagram.com/niravpatelweddings/\",\n                \"facebook\": \"https://www.facebook.com/Nirav-Photography-114491138574349/\",\n                \"x\": \"https://twitter.com/nikusp\",\n                \"www\": \"http://niravpatelphotography.com/\"\n            },\n            \"brandLeadingMedia\": [\n                \"https://pictime7eus1public-pub-hdf3hecqdpaqeuev.a02.azurefd.net/pictures/48/783/48783218/ordinte9y629glwa5m/smallres/11354225253.jpg\",\n                \"https://pictime7eus1public-pub-hdf3hecqdpaqeuev.a02.azurefd.net/pictures/48/783/48783218/ordinte9y629glwa5m/smallres/11354225375.jpg\",\n                \"https://pictime7eus1public-pub-hdf3hecqdpaqeuev.a02.azurefd.net/p