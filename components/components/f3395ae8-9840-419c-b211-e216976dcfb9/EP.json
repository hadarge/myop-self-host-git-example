{
  "version": "0.2.10",
  "item": {
    "name": "DesignTab_premiumbanner",
    "id": "f3395ae8-9840-419c-b211-e216976dcfb9",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "b239da43-2e9a-4654-bdef-8d250b8c3018",
        "name": "Version 7",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Font definition for the component\n */\ninterface MyopFont {\n  id: string;\n  family: string;\n  style?: string;\n  weight?: number;\n  url: string;\n}\n\n/**\n * Localization strings for the component\n */\ninterface MyopLang {\n  proLabel: string;   // e.g. \"You're using Pro features.\"\n  message: string;    // e.g. \"Upgrade to publish your gallery with full access\"\n  ctaText: string;    // e.g. \"Level up\"\n}\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n  lang: MyopLang;\n  backgroundColor?: string;\n  fonts?: MyopFont[];\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'banner_click': void;\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n\n    <style>\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            font-family: var(--font_main), sans-serif;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background-color: var(--bg-color, #f3e8ff);\n            color: #54033C;\n            padding: 0 24px;\n            opacity: 1 !important;\n            visibility: visible !important;\n        }\n\n        .banner-content {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            cursor: pointer;\n            user-select: none;\n        }\n\n        .banner-content:hover .cta-link {\n            text-decoration: underline;\n        }\n\n        .icon {\n            width: 16px;\n            height: 14px;\n            flex-shrink: 0;\n            margin-bottom: 3px;\n        }\n\n        .message {\n            font-size: 16px;\n            line-height: 1.4;\n            font-weight: var(--font_main_weight, 400);\n            font-style: var(--font_main_style, normal);\n        }\n\n        .message-bold {\n            font-family: var(--font_bold, var(--font_main)), sans-serif;\n            font-weight: var(--font_bold_weight, var(--font_main_weight, 500));\n            font-style: var(--font_bold_style, var(--font_main_style, normal));\n        }\n\n        .cta-link {\n            font-family: var(--font_bold, var(--font_main)), sans-serif;\n            font-weight: var(--font_bold_weight, var(--font_main_weight, 500));\n            font-style: var(--font_bold_style, var(--font_main_style, normal));\n            margin-left: 4px;\n            text-decoration: underline;\n            color: inherit;\n            display: inline-flex;\n            align-items: center;\n            gap: 4px;\n        }\n\n        .arrow {\n            display: inline-flex;\n            width: 16px;\n            height: 16px;\n            flex-shrink: 0;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function() {\n        let currentState = null;\n\n        function loadFonts(fonts) {\n            if (!fonts || !fonts.length) return;\n            const root = document.documentElement;\n            fonts.forEach(function(font) {\n                // Load font stylesheet\n                if (font.url && !document.querySelector('link[href=\"' + font.url + '\"]')) {\n                    var link = document.createElement('link');\n                    link.rel = 'stylesheet';\n                    link.href = font.url;\n                    document.head.appendChild(link);\n                }\n                // Set CSS variables: --font_{id}, --font_{id}_weight, --font_{id}_style\n                var varName = '--font_' + font.id;\n                root.style.setProperty(varName, font.family);\n                if (font.weight !== undefined) {\n                    root.style.setProperty(varName + '_weight', font.weight);\n                }\n                if (font.style !== undefined) {\n                    root.style.setProperty(varName + '_style', font.style);\n                }\n            });\n        }\n\n        function render(data) {\n            if (!data || !data.lang) return;\n            currentState = data;\n\n            const root = document.getElementById('app-root');\n\n            // Load fonts and set CSS variables\n            loadFonts(data.fonts);\n\n            // Set CSS variables for colors\n            root.style.setProperty('--bg-color', data.backgroundColor || '#f3e8ff');\n\n            // Crown SVG icon\n            const crownSvg = `<svg class=\"icon\" xmlns=\"http://www.w3.org/2000/svg\" width=\"15\" height=\"13\" viewBox=\"0 0 15 13\" fill=\"none\">\n                <path d=\"M7.06689 0.755554C7.25796 0.41532 7.74692 0.415321 7.93799 0.755554L9.69092 3.87665C10.0947 4.5955 11.0035 4.8537 11.7251 4.45477L13.7612 3.3288C14.1415 3.11858 14.5907 3.45992 14.4897 3.88251L12.5327 12.0739C12.4789 12.2989 12.2778 12.4577 12.0464 12.4577H2.9585C2.72713 12.4577 2.52595 12.2989 2.47217 12.0739L0.515137 3.88251C0.414186 3.45992 0.863417 3.11858 1.24365 3.3288L3.27979 4.45477C4.00135 4.85369 4.9102 4.5955 5.31396 3.87665L7.06689 0.755554Z\" fill=\"#F8ECFF\" stroke=\"#54033C\"/>\n            </svg>`;\n\n            // Arrow SVG icon\n            const arrowSvg = `<svg class=\"arrow\" xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n                <path d=\"M4.98865 4.29913L12.6004 4.29903M12.6004 4.29903V11.8025M12.6004 4.29903L4.20039 12.699\" stroke=\"#54033C\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>`;\n\n            root.innerHTML = `\n                <div class=\"banner-content\" id=\"banner\">\n                    ${crownSvg}\n                    <div class=\"message\">\n                        <span class=\"message-bold\">${escapeHtml(data.lang.proLabel)}</span> ${escapeHtml(data.lang.message)}\n                        <span class=\"cta-link\">${escapeHtml(data.lang.ctaText)} ${arrowSvg}</span>\n                    </div>\n                </div>\n            `;\n\n            // Attach click handler\n            const banner = document.getElementById('banner');\n            banner.addEventListener('click', handleBannerClick);\n        }\n\n        function handleBannerClick() {\n            window.myop_cta_handler('banner_click');\n        }\n\n        function escapeHtml(text) {\n            const div = document.createElement('div');\n            div.textContent = text;\n            return div.innerHTML;\n        }\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action, payload) {\n            // Will be overridden by host application\n            console.log('CTA:', action, payload);\n        };\n    })();\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            lang: {\n                proLabel: \"You're using Pro features.\",\n                message: \"Upgrade to publish your gallery with full access\",\n                ctaText: \"Level up\"\n            },\n            backgroundColor: \"#f3e8ff\",\nfonts: [\n                        {\n                            id: \"main\",\n                            family: \"tt_norms_pro\",\n                            style: \"normal\",\n                            weight: 400,\n                            url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n                        },\n                        {\n                            id: \"bold\",\n                            family: \"tt_norms_pro\",\n                            style: \"normal\",\n                            weight: 500,\n                            url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n                        }\n            ]\n        });\n    </script>\n</body>\n</html>\n"
        }
      }
    ]
  }
}