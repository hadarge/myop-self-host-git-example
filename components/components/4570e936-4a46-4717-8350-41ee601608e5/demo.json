        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n  <meta name=\"myop:size\" content='{\"width\":456,\"height\":461}'>\n  <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;600&display=swap\" rel=\"stylesheet\">\n\n  <script type=\"myop/types\">\n  interface MyopInitData {\n    prefillEmail?: string;\n  }\n\n  interface MyopCtaPayloads {\n    'email-signin-clicked': void;\n    'google-signin-clicked': void;\n    'signin-clicked': void;\n  }\n\n  declare function myop_init_interface(): MyopInitData;\n  declare function myop_init_interface(data: MyopInitData): void;\n\n  declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n    action: K,\n    payload: MyopCtaPayloads[K]\n  ): void;\n  </script>\n\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    html, body { width: 100%; height: 100%; margin: 0; padding: 0; font-family: 'DM Sans', sans-serif; background: transparent; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }\n\n    #app-root {\n      display: inline-flex;\n      width: fit-content;\n    }\n\n    .card {\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n      align-items: center;\n      padding: 48px 40px;\n      gap: 20px;\n      width: 376px;\n      background: #FFFFFF;\n      border-radius: 16px;\n      position: relative;\n    }\n\n\n    /* Title row */\n    .title-row {\n      display: flex;\n      flex-direction: row;\n      justify-content: center;\n      align-items: center;\n      padding: 0px 0px 8px;\n      gap: 10px;\n      width: 296px;\n      align-self: stretch;\n    }\n\n    .title {\n      font-weight: 300;\n      font-size: 28px;\n      line-height: 24px;\n      color: #0A090A;\n      flex-grow: 1;\n    }\n\n    /* Social button (Google) */\n    .btn-social {\n      display: flex;\n      flex-direction: row;\n      justify-content: center;\n      align-items: center;\n      padding: 12px 16px;\n      gap: 8px;\n      width: 296px;\n      height: 48px;\n      background: #FFFFFF;\n      border: 1px solid #D3D1D5;\n      border-radius: 6px;\n      cursor: pointer;\n      align-self: stretch;\n      font-family: 'DM Sans', sans-serif;\n      font-weight: 400;\n      font-size: 16px;\n      line-height: 24px;\n      color: #0A090A;\n      transition: background 0.15s;\n    }\n\n\n    /* Google icon SVG */\n    .google-icon {\n      width: 20px;\n      height: 20px;\n      flex-shrink: 0;\n    }\n\n    /* Divider */\n    .divider {\n      display: flex;\n      flex-direction: row;\n      justify-content: center;\n      align-items: center;\n      padding: 0;\n      gap: 12px;\n      width: 296px;\n      align-self: stretch;\n    }\n\n    .divider-line {\n      flex-grow: 1;\n      height: 0;\n      border-top: 1px solid #B6B5B7;\n    }\n\n    .divider-text {\n      font-weight: 400;\n      font-size: 16px;\n      line-height: 24px;\n      color: #B6B5B7;\n    }\n\n    /* Email button */\n    .btn-email {\n      display: flex;\n      flex-direction: row;\n      justify-content: center;\n      align-items: center;\n      padding: 12px 16px;\n      gap: 8px;\n      width: 296px;\n      height: 48px;\n      background: #FFFFFF;\n      border: 1px solid #D3D1D5;\n      border-radius: 6px;\n      cursor: pointer;\n      align-self: stretch;\n      font-family: 'DM Sans', sans-serif;\n      font-weight: 400;\n      font-size: 16px;\n      line-height: 24px;\n      color: #0A090A;\n      transition: background 0.15s;\n    }\n\n\n    /* Primary CTA */\n    .btn-primary {\n      display: flex;\n      flex-direction: row;\n      justify-content: center;\n      align-items: center;\n      padding: 4px 16px;\n      gap: 8px;\n      width: 296px;\n      height: 40px;\n      background: linear-gradient(50.35deg, #6751FF 8.73%, #AE5C9A 41.91%, #FF6827 80.07%);\n      border-radius: 6px;\n      border: none;\n      cursor: pointer;\n      align-self: stretch;\n      font-family: 'DM Sans', sans-serif;\n      font-weight: 600;\n      font-size: 16px;\n      line-height: 24px;\n      color: #FFFFFF;\n      transition: opacity 0.15s;\n    }\n\n    .btn-primary:hover { opacity: 0.9; }\n\n    .terms-link {\n      color: inherit;\n      text-decoration: underline;\n    }\n    .terms-link:hover {\n      color: #6C18FF;\n      text-decoration: underline;\n    }\n\n    .terms-text {\n      color: #3E3D3E;\n      font-family: 'DM Sans', sans-serif;\n      font-size: 11px;\n      font-style: normal;\n      font-weight: 400;\n      line-height: 16px;\n      letter-spacing: -0.11px;\n      text-align: center;\n      align-self: stretch;\n    }\n  </style>\n</head>\n<body>\n  <div id=\"app-root\">\n    <div class=\"card\">\n      <div class=\"title-row\">\n        <span class=\"title\">Sign in</span>\n      </div>\n\n      <button class=\"btn-social\" id=\"btn-google\">\n        <!-- Google \"G\" logo -->\n        <svg class=\"google-icon\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M19.6 10.227c0-.709-.064-1.39-.182-2.045H10v3.868h5.382a4.6 4.6 0 01-1.996 3.018v2.51h3.232c1.891-1.742 2.982-4.305 2.982-7.35z\" fill=\"#4285F4\"/>\n          <path d=\"M10 20c2.7 0 4.964-.895 6.618-2.423l-3.232-2.509c-.895.6-2.04.954-3.386.954-2.605 0-4.81-1.76-5.596-4.123H1.064v2.59A9.996 9.996 0 0010 20z\" fill=\"#34A853\"/>\n          <path d=\"M4.404 11.9A6.01 6.01 0 014.09 10c0-.663.114-1.305.314-1.9V5.51H1.064A9.996 9.996 0 000 10c0 1.614.386 3.14 1.064 4.49l3.34-2.59z\" fill=\"#FBBC05\"/>\n          <path d=\"M10 3.977c1.468 0 2.786.505 3.822 1.496l2.868-2.868C14.959.99 12.695 0 10 0A9.996 9.996 0 001.064 5.51l3.34 2.59C5.19 5.736 7.395 3.977 10 3.977z\" fill=\"#EB4335\"/>\n        </svg>\n        Sign in with Google\n      </button>\n\n      <div class=\"divider\">\n        <div class=\"divider-line\"></div>\n        <span class=\"divider-text\">or</span>\n        <div class=\"divider-line\"></div>\n      </div>\n\n      <button class=\"btn-email\" id=\"btn-email\">\n        Sign in with Email and Password\n      </button>\n\n      <p class=\"terms-text\">By continuing, you agree to the <a class=\"terms-link\" href=\"https://www.myop.dev/terms\" target=\"_blank\">Terms of Service</a><br>and <a class=\"terms-link\" href=\"https://www.myop.dev/privacy.html\" target=\"_blank\">Privacy Policy</a>.</p>\n\n    </div>\n  </div>\n\n  <script>\n  (function() {\n    function attachListeners() {\n      document.getElementById('btn-google').addEventListener('click', function() {\n        window.myop_cta_handler('google-signin-clicked', undefined);\n      });\n      document.getElementById('btn-email').addEventListener('click', function() {\n        window.myop_cta_handler('email-signin-clicked', undefined);\n      });\n      document.getElementById('btn-signin').addEventListener('click', function() {\n        window.myop_cta_handler('signin-clicked', undefined);\n      });\n    }\n\n    attachListeners();\n\n    window.myop_init_interface = function(data) {\n      if (!data) return {};\n      // No dynamic data needed for this component\n    };\n\n    window.myop_cta_handler = function(action_id, payload) {};\n  })();\n  </script>\n\n  <script id=\"myop_preview\">\n    window.myop_init_interface({});\n  </script>\n</body>\n</html>\n"
        }
