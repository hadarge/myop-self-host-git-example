          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n  <meta name=\"myop:size\" content='{\"width\":456,\"height\":461}'>\n\n  <script type=\"myop/types\">\n  interface MyopInitData {\n    prefillEmail?: string;\n  }\n\n  interface MyopCtaPayloads {\n    'email-signin-clicked': void;\n    'google-signin-clicked': void;\n  }\n\n  declare function myop_init_interface(): MyopInitData;\n  declare function myop_init_interface(data: MyopInitData): void;\n\n  declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n    action: K,\n    payload: MyopCtaPayloads[K]\n  ): void;\n  </script>\n\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    html, body { width: 100%; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background: transparent; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }\n\n    #app-root {\n      display: inline-flex;\n      width: fit-content;\n    }\n\n    .card {\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n      align-items: center;\n      padding: 48px 40px;\n      gap: 20px;\n      width: 376px;\n      background: #FFFFFF;\n      border-radius: 16px;\n      position: relative;\n    }\n\n    /* Title row */\n    .title-row {\n      display: flex;\n      flex-direction: row;\n      justify-content: center;\n      align-items: center;\n      padding: 0px 0px 8px;\n      gap: 10px;\n      width: 296px;\n      align-self: stretch;\n      margin-bottom: 10px;\n    }\n\n    .title {\n      font-weight: 300;\n      font-size: 28px;\n      line-height: 24px;\n      color: #0A090A;\n      flex-grow: 1;\n    }\n\n    /* Social button (Google) */\n    .btn-social {\n      display: flex;\n      flex-direction: row;\n      justify-content: center;\n      align-items: center;\n      padding: 12px 16px;\n      gap: 8px;\n      width: 296px;\n      height: 48px;\n      background: #FFFFFF;\n      border: 1px solid #D3D1D5;\n      border-radius: 6px;\n      cursor: pointer;\n      align-self: stretch;\n      font-family: inherit;\n      font-weight: 400;\n      font-size: 16px;\n      line-height: 24px;\n      color: #0A090A;\n      transition: background 0.15s;\n    }\n\n    /* Google icon SVG */\n    .google-icon {\n      width: 20px;\n      height: 20px;\n      flex-shrink: 0;\n    }\n\n    /* Divider */\n    .divider {\n      display: flex;\n      flex-direction: row;\n      justify-content: center;\n      align-items: center;\n      padding: 0;\n      gap: 12px;\n      width: 296px;\n      align-self: stretch;\n    }\n\n    .divider-line {\n      flex-grow: 1;\n      height: 0;\n      border-top: 1px solid #B6B5B7;\n    }\n\n    .divider-text {\n      font-weight: 400;\n      font-size: 16px;\n      line-height: 24px;\n      color: #B6B5B7;\n    }\n\n    /* Email button */\n    .btn-email {\n      display: flex;\n      flex-direction: row;\n      justify-content: center;\n      align-items: center;\n      padding: 12px 16px;\n      gap: 8px;\n      width: 296px;\n      height: 48px;\n      background: #FFFFFF;\n      border: 1px solid #D3D1D5;\n      border-radius: 6px;\n      cursor: pointer;\n      align-self: stretch;\n      font-family: inherit;\n      font-weight: 400;\n      font-size: 16px;\n      line-height: 24px;\n      color: #0A090A;\n      transition: background 0.15s;\n    }\n\n    /* Primary CTA */\n    .btn-primary {\n      display: flex;\n      flex-direction: row;\n      justify-content: center;\n      align-items: center;\n      padding: 4px 16px;\n      gap: 8px;\n      width: 296px;\n      height: 40px;\n      background: linear-gradient(50.35deg, #6751FF 8.73%, #AE5C9A 41.91%, #FF6827 80.07%);\n      border-radius: 6px;\n      border: none;\n      cursor: pointer;\n      align-self: stretch;\n      font-family: inherit;\n      font-weight: 600;\n      font-size: 16px;\n      line-height: 24px;\n      color: #FFFFFF;\n      transition: opacity 0.15s;\n    }\n\n    .btn-primary:hover { opacity: 0.9; }\n\n    .terms-link {\n      color: inherit;\n      text-decoration: underline;\n    }\n    .terms-link:hover {\n      color: #6C18FF;\n      text-decoration: underline;\n    }\n\n    .terms-text {\n      color: #3E3D3E;\n      font-size: 11px;\n      font-style: normal;\n      font-weight: 400;\n      line-height: 16px;\n      letter-spacing: -0.11px;\n      text-align: center;\n      align-self: stretch;\n    }\n  </style>\n</head>\n<body>\n  <div id=\"app-root\"></div>\n\n  <script>\n  (function() {\n    var currentState = {};\n\n    function render(data) {\n      var root = document.getElementById('app-root');\n      root.innerHTML =\n        '<div class=\"card\">' +\n          '<div class=\"title-row\">' +\n            '<svg width=\"189\" height=\"33\" viewBox=\"0 0 189 33\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" style=\"width:138px;height:auto;\">' +\n              '<path d=\"M16.9398 8.41758C16.9398 13.0665 13.1477 16.8352 8.4699 16.8352C3.79211 16.8352 0 13.0665 0 8.41758C0 3.76868 3.79211 0 8.4699 0C13.1477 0 16.9398 3.76868 16.9398 8.41758Z\" fill=\"url(#paint0_linear_5698_25334)\"/>' +\n              '<path d=\"M20.3511 1.87194V15.0122C20.3511 15.8434 21.027 16.5045 21.8531 16.5969C24.7085 16.9162 28.2093 18.3469 32.1128 23.5011C37.3636 30.4344 48.3558 32.9263 54.0526 32.8517C54.8218 32.8416 55.3983 32.1932 55.3983 31.4239V19.2927C55.4261 18.6361 55.5415 17.6912 55.9602 17.3345C56.3515 17.0011 56.9937 16.8791 57.4591 16.8353H69.9433C70.7744 16.8353 71.4482 16.1615 71.4482 15.3303V2.04087C71.4482 1.20971 70.7744 0.535929 69.9433 0.535929H56.5525C55.7213 0.535929 55.0475 1.20972 55.0475 2.04087V14.1474C55.0014 14.8128 54.8777 15.5087 54.5751 15.7681C54.1256 16.1536 53.4665 16.163 53.109 16.1334C49.6274 15.4894 47.7553 14.5184 40.9043 7.67843C34.5004 1.28484 26.0718 0.482151 21.8548 0.381434C21.0239 0.361588 20.3511 1.04078 20.3511 1.87194Z\" fill=\"url(#paint1_linear_5698_25334)\"/