n          '<button class=\"btn-email\" id=\"btn-email\">' +\n            'Sign in with Email and Password' +\n          '</button>' +\n          '<p class=\"terms-text\">By continuing, you agree to the <a class=\"terms-link\" href=\"https://www.myop.dev/terms\" target=\"_blank\">Terms of Service</a><br>and <a class=\"terms-link\" href=\"https://www.myop.dev/privacy.html\" target=\"_blank\">Privacy Policy</a>.</p>' +\n        '</div>';\n\n      // Attach event listeners via delegation\n      root.addEventListener('click', function(e) {\n        var target = e.target.closest('button');\n        if (!target) return;\n        if (target.id === 'btn-google') {\n          window.myop_cta_handler('google-signin-clicked', undefined);\n        } else if (target.id === 'btn-email') {\n          window.myop_cta_handler('email-signin-clicked', undefined);\n          window.open('https://dashboard.myop.dev/', '_blank');\n        }\n      });\n    }\n\n    window.myop_init_interface = function(data) {\n      if (!data) return currentState;\n      currentState = data;\n      render(data);\n    };\n\n    window.myop_cta_handler = function(action_id, payload) {\n      console.log('[myop_cta]', action_id, payload);\n    };\n  })();\n  </script>\n\n  <script id=\"myop_preview\">\n    window.myop_init_interface({});\n  </script>\n</body>\n</html>\n"
