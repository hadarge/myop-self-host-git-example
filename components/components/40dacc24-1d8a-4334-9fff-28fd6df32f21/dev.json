{
  "version": "0.2.10",
  "item": {
    "name": "UserIntro_designtab1",
    "id": "40dacc24-1d8a-4334-9fff-28fd6df32f21",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "cda50d54-56a2-42df-ba9d-2696fc53ae6e",
        "name": "Version 3",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n  <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n  <script type=\"myop/types\">\n  // =============================================================================\n  // MYOP COMPONENT TYPE DEFINITIONS\n  // =============================================================================\n\n  interface SequenceItem {\n    /** Video time in milliseconds to trigger this item */\n    time: number;\n    /** Optional title shown as an overlay at this moment. Also places a marker on the timeline. */\n    title?: string;\n    /** Optional CTA action_id — silently fires myop_cta_handler at the given time. No visible button. */\n    cta?: string;\n    /** Payload forwarded to myop_cta_handler — only used when cta is set */\n    ctaPayload?: Record<string, unknown>;\n  }\n\n  interface MyopInitData {\n    /** URL of the video to play */\n    videoUrl: string;\n    /** Timed sequence of titles / CTAs */\n    sequence: SequenceItem[];\n  }\n\n  interface MyopCtaPayloads {\n    [key: string]: Record<string, unknown>;\n  }\n\n  declare function myop_init_interface(): MyopInitData;\n  declare function myop_init_interface(data: MyopInitData): void;\n  declare function myop_cta_handler(action: string, payload: Record<string, unknown>): void;\n  </script>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    html, body {\n      width: 100%; height: 100%;\n      overflow: hidden;\n      background: #000;\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    }\n    #app-root {\n      width: 100%; height: 100%;\n      display: flex; flex-direction: column;\n      position: relative; background: #000;\n    }\n\n    /* ── Video ── */\n    #video-wrapper {\n      position: relative; width: 100%; height: 100%;\n      flex: 1 1 auto; min-height: 0;\n    }\n    #main-video {\n      width: 100%; height: 100%;\n      object-fit: contain; display: block; cursor: pointer;\n    }\n\n    /* ── Title overlay — bottom-center, above controls ── */\n    #title-overlay {\n      position: absolute;\n      bottom: 52px; left: 0; right: 0;\n      display: flex; justify-content: center;\n      pointer-events: none;\n      z-index: 15;\n      padding: 0 16px;\n    }\n    #title-text {\n      display: inline-block;\n      color: #fff;\n      font-size: 15px;\n      font-weight: 600;\n      letter-spacing: 0.01em;\n      text-align: center;\n      text-shadow: 0 1px 8px rgba(0,0,0,0.9);\n      background: rgba(0,0,0,0.45);\n      border-radius: 8px;\n      padding: 6px 14px;\n      max-width: 80%;\n      line-height: 1.4;\n      opacity: 0;\n      transform: translateY(6px);\n      transition: opacity 0.3s ease, transform 0.3s ease;\n    }\n    #title-text.visible {\n      opacity: 1;\n      transform: translateY(0);\n    }\n\n    /* ── Controls bar ── */\n    #controls {\n      position: absolute; bottom: 0; left: 0; right: 0;\n      padding: 8px 14px 10px;\n      background: linear-gradient(transparent, rgba(0,0,0,0.8));\n      display: flex; flex-direction: column; gap: 6px;\n      z-index: 20; pointer-events: none;\n    }\n    #controls > *, #controls button, #progress-track { pointer-events: auto; }\n\n    #progress-track {\n      position: relative; width: 100%; height: 4px;\n      background: rgba(255,255,255,0.25); border-radius: 2px; cursor: pointer;\n    }\n    #progress-fill {\n      height: 100%; background: #fff; border-radius: 2px;\n      width: 0%; pointer-events: none;\n    }\n    /* Only items WITH a title get a marker */\n    .seq-marker {\n      position: absolute; top: 50%;\n      transform: translate(-50%, -50%);\n      width: 11px; height: 11px; border-radius: 50%;\n      background: #facc15;\n      border: 2px solid #fff;\n      box-shadow: 0 0 0 1px rgba(0,0,0,0.5);\n      pointer-events: none;\n    }\n    .seq-marker.fired { background: #4ade80; }\n\n    #controls-row {\n      display: flex; align-items: center; gap: 10px;\n    }\n    .ctrl-btn {\n      background: none; border: none; cursor: pointer; color: #fff;\n      padding: 2px; display: flex; align-items: center; justify-content: center;\n      opacity: 0.9; flex-shrink: 0; transition: opacity 0.15s;\n    }\n    .ctrl-btn:hover { opacity: 1; }\n\n    #time-display {\n      color: rgba(255,255,255,0.85); font-size: 12px;\n      font-variant-numeric: tabular-nums; white-space: nowrap; flex: 1;\n    }\n\n    /* ── Unmute badge ── */\n    #unmute-btn {\n      display: flex; align-items: center; gap: 6px;\n      background: rgba(0,0,0,0.55);\n      border: 1.5px solid rgba(255,255,255,0.35); border-radius: 20px;\n      padding: 5px 12px 5px 8px;\n      color: #fff; font-size: 12px; font-weight: 600; letter-spacing: 0.02em;\n      cursor: pointer; transition: background 0.15s, border-color 0.15s; flex-shrink: 0;\n    }\n    #unmute-btn:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.7); }\n    #unmute-btn.hidden { display: none; }\n\n    /* ── Empty state ── */\n    #empty-state {\n      display: none; flex-direction: column; align-items: center;\n      justify-content: center; height: 100%; gap: 12px;\n      color: rgba(255,255,255,0.5); font-size: 14px;\n    }\n    #app-root.empty #video-wrapper { display: none; }\n    #app-root.empty #controls      { display: none; }\n    #app-root.empty #empty-state   { display: flex; }\n  </style>\n</head>\n<body>\n<div id=\"app-root\">\n  <div id=\"video-wrapper\">\n    <video id=\"main-video\" playsinline preload=\"auto\" muted></video>\n\n    <!-- Title overlay — top of video, only shown when item has title -->\n    <div id=\"title-overlay\">\n      <div id=\"title-text\"></div>\n    </div>\n\n  </div>\n\n  <div id=\"controls\">\n    <div id=\"progress-track\">\n      <div id=\"progress-fill\"></div>\n      <!-- markers injected here only for items with title -->\n    </div>\n    <div id=\"controls-row\">\n      <button id=\"play-btn\" class=\"ctrl-btn\" aria-label=\"Play / Pause\"></button>\n      <span id=\"time-display\">0:00 / 0:00</span>\n      <button id=\"unmute-btn\" aria-label=\"Unmute\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"white\">\n          <path d=\"M11 5L6 9H2v6h4l5 4V5z\"/>\n          <line x1=\"23\" y1=\"9\" x2=\"17\" y2=\"15\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n          <line x1=\"17\" y1=\"9\" x2=\"23\" y2=\"15\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        </svg>\n        Tap to unmute\n      </button>\n    </div>\n  </div>\n\n  <div id=\"empty-state\">\n    <svg width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\">\n      <rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"/>\n      <path d=\"M10 9l5 3-5 3V9z\" fill=\"currentColor\" stroke=\"none\"/>\n    </svg>\n    <span>No video configured</span>\n  </div>\n</div>\n\n<script>\n(function () {\n  const root          = document.getElementById('app-root');\n  const video         = document.getElementById('main-video');\n  const titleText     = document.getElementById('title-text');\n  const progressTrack = document.getElementById('progress-track');\n  const progressFill  = document.getElementById('progress-fill');\n  const playBtn       = document.getElementById('play-btn');\n  const timeDisplay   = document.getElementById('time-display');\n  const unmuteBtn     = document.getElementById('unmute-btn');\n\n  let currentState = { videoUrl: '', sequence: [] };\n  let firedSet     = new Set();\n\n  const ICON_PLAY  = `<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"white\"><path d=\"M5 3l14 9-14 9V3z\"/></svg>`;\n  const ICON_PAUSE = `<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"white\"><rect x=\"6\" y=\"4\" width=\"4\" height=\"16\"/><rect x=\"14\" y=\"4\" width=\"4\" height=\"16\"/></svg>`;\n\n  function formatTime(sec) {\n    const m = Math.floor(sec / 60);\n    const s = Math.floor(sec % 60).toString().padStart(2, '0');\n    return `${m}:${s}`;\n  }\n\n  function syncUnmuteBtn() {\n    if (video.muted) unmuteBtn.classList.remove('hidden');\n    else             unmuteBtn.classList.add('hidden');\n  }\n\n  // ── Title ─────────────────────────────────────────────────────────────────\n  function showTitle(text) {\n    titleText.textContent = text;\n    titleText.classList.add('visible');\n  }\n  function hideTitle() {\n    titleText.classList.remove('visible');\n  }\n\n  // ── Timeline markers — only for items that have a title ───────────────────\n  function buildMarkers(sequence, duration) {\n    progressTrack.querySelectorAll('.seq-marker').forEach(el => el.remove());\n    if (!duration) return;\n    sequence.forEach((item, i) => {\n      if (!item.title) return;                        // no title → no marker\n      const pct = Math.min((item.time / 1000) / duration, 1) * 100;\n      const dot = document.createElement('div');\n      dot.className   = 'seq-marker';\n      dot.style.left  = pct + '%';\n      dot.dataset.idx = i;\n      progressTrack.appendChild(dot);\n    });\n  }\n\n  function updateMarkers() {\n    progressTrack.querySelectorAll('.seq-marker').forEach(el => {\n      const i = parseInt(el.dataset.idx, 10);\n      el.classList.toggle('fired', firedSet.has(i));\n    });\n  }\n\n  // ── Autoplay (muted) ──────────────────────────────────────────────────────\n  function autoplay() {\n    video.muted = true;\n    syncUnmuteBtn();\n    const p = video.play();\n    if (p && p.catch) p.catch(err => console.warn('[myop-video] autoplay rejected:', err));\n  }\n\n  // ── Render ────────────────────────────────────────────────────────────────\n  function render(data) {\n    currentState = data;\n    firedSet.clear();\n    hideTitle();\n\n    if (!data.videoUrl) {\n      root.classList.add('empty');\n      return;\n    }\n    root.classList.remove('empty');\n\n    const newSrc    = data.videoUrl;\n    const currentSrc = video.getAttribute('src') || '';\n    if (currentSrc !== newSrc) {\n      video.setAttribute('src', newSrc);\n      video.load();\n      progressFill.style.width   = '0%';\n      timeDisplay.textContent    = '0:00 / 0:00';\n    }\n    playBtn.innerHTML = ICON_PLAY;\n    autoplay();\n  }\n\n  // ── Video events ──────────────────────────────────────────────────────────\n  video.addEventListener('canplay', function () {\n    if (video.paused) autoplay();\n  });\n\n  video.addEventListener('loadedmetadata', function () {\n    buildMarkers(currentState.sequence || [], video.duration);\n    timeDisplay.textContent = `0:00 / ${formatTime(video.duration)}`;\n  });\n\n  video.addEventListener('timeupdate', function () {\n    const currentMs = video.currentTime * 1000;\n    const dur       = video.duration || 0;\n\n    if (dur > 0) progressFill.style.width = (video.currentTime / dur * 100) + '%';\n    timeDisplay.textContent = `${formatTime(video.currentTime)} / ${formatTime(dur)}`;\n\n    (currentState.sequence || []).forEach((item, i) => {\n      if (firedSet.has(i) || currentMs < item.time) return;\n      firedSet.add(i);\n      updateMarkers();\n\n      // Title: show if non-empty string, hide if empty string, ignore if undefined\n      if (item.title === '') hideTitle();\n      else if (item.title)   showTitle(item.title);\n\n      // CTA: fire handler silently — no visible button\n      if (item.cta) window.myop_cta_handler(item.cta, item.ctaPayload || {});\n    });\n  });\n\n  video.addEventListener('play',  () => { playBtn.innerHTML = ICON_PAUSE; });\n  video.addEventListener('pause', () => { playBtn.innerHTML = ICON_PLAY;  });\n  video.addEventListener('ended', () => { playBtn.innerHTML = ICON_PLAY;  });\n  video.addEventListener('volumechange', syncUnmuteBtn);\n  video.addEventListener('error', function () {\n    console.error('[myop-video] error:', video.error && video.error.message, 'src:', video.getAttribute('src'));\n  });\n\n  // ── Unmute ────────────────────────────────────────────────────────────────\n  unmuteBtn.addEventListener('click', (e) => {\n    e.stopPropagation();\n    video.muted  = false;\n    video.volume = 1;\n    syncUnmuteBtn();\n  });\n\n  // ── Play / Pause ──────────────────────────────────────────────────────────\n  function togglePlay() {\n    if (!video.getAttribute('src')) return;\n    if (video.paused || video.ended) {\n      const p = video.play();\n      if (p && p.catch) p.catch(err => console.warn('[myop-video] play rejected:', err));\n    } else {\n      video.pause();\n    }\n  }\n  playBtn.addEventListener('click', (e) => { e.stopPropagation(); togglePlay(); });\n  video.addEventListener('click',   (e) => { e.stopPropagation(); togglePlay(); });\n\n  // ── Seek ──────────────────────────────────────────────────────────────────\n  progressTrack.addEventListener('click', function (e) {\n    const rect  = progressTrack.getBoundingClientRect();\n    const ratio = (e.clientX - rect.left) / rect.width;\n    if (!video.duration) return;\n    video.currentTime = ratio * video.duration;\n    firedSet = new Set(\n      (currentState.sequence || []).reduce((acc, item, i) => {\n        if ((item.time / 1000) < video.currentTime) acc.push(i);\n        return acc;\n      }, [])\n    );\n    updateMarkers();\n  });\n\n  // ── Init ──────────────────────────────────────────────────────────────────\n  playBtn.innerHTML = ICON_PLAY;\n  syncUnmuteBtn();\n\n  window.myop_init_interface = function (data) {\n    if (!data) return currentState;\n    render(data);\n  };\n\n  if (typeof window.myop_cta_handler !== 'function') {\n    window.myop_cta_handler = function (action_id, payload) {};\n  }\n})();\n</script>\n\n<script id=\"myop_preview\">\n  window.myop_init_interface({\n    videoUrl: \"./uploads/userintrodesigntab_test.mp4\",\n    sequence: [\n      { time: 2000, title: \"Welcome!\", cta: \"showIt\", ctaPayload: { target: \"show1\" } },\n      { time: 5000, title: \"Check this out\" },\n      { time: 9000, cta: \"Sign Up Now\", ctaPayload: { target: \"cta_final\" } }\n    ]\n  });\n</script>\n</body>\n</html>\n"
        }
      }
    ]
  }
}