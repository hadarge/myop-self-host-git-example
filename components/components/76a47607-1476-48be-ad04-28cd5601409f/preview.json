      {
        "name": "Version 17",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,400&display=swap\" rel=\"stylesheet\">\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n    /** The component name shown in the title */\n    componentName: string;\n    /** Optional pre-filled description */\n    description?: string;\n    /** Icon URL or gradient placeholder */\n    iconUrl?: string;\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n    /** User closed the modal */\n    'modal-closed': void;\n    /** User submitted the form */\n    'submit-clicked': { description: string };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n    action: K,\n    payload: MyopCtaPayloads[K]\n): void;\n    </script>\n    <style>\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n        }\n\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;\n            background: transparent;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            max-width: 680px;\n            padding: 12px 24px 20px;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .modal {\n            border-radius: 12px;\n            border: none;\n            background: var(--White, #FFF);\n            box-shadow: none;\n            width: 100%;\n            position: relative;\n            padding: 0;\n            display: flex;\n            flex-direction: column;\n        }\n\n\n        .modal-header {\n            display: flex;\n            flex-direction: column;\n            gap: 12px;\n            margin-bottom: 20px;\n        }\n\n        .modal-icon {\n            width: 72px;\n            height: 73px;\n            flex-shrink: 0;\n        }\n\n        .modal-icon svg {\n            width: 72px;\n            height: 73px;\n            display: block;\n        }\n\n        .modal-icon img {\n            width: 82px;\n            height: 82px;\n            object-fit: cover;\n            border-radius: 12px;\n        }\n\n        .modal-title {\n            font-family: \"DM Sans\", -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            font-size: 24px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 32px;\n            color: #3E3D3E;\n            margin: 0;\n        }\n\n        .modal-subtitle {\n            font-family: \"DM Sans\", -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 24px;\n            color: var(--Grey-90, #3E3D3E);\n            margin: 0;\n            margin-top: -16px;\n        }\n\n        .form-group {\n            display: flex;\n            flex-direction: column;\n            gap: 8px;\n            margin-bottom: 20px;\n        }\n\n        .form-label {\n            font-family: \"DM Sans\", -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            font-size: 11px;\n            font-style: normal;\n            font-weight: 600;\n            line-height: 14px;\n            letter-spacing: 1px;\n            text-transform: uppercase;\n            color: #6A696A;\n        }\n\n        /* Rich Text Area Container */\n        .rich-textarea-container {\n            position: relative;\n            width: 100%;\n            border: 1px solid #e5e4e4;\n            border-radius: 8px;\n            padding: 8px;\n            display: flex;\n            flex-direction: column;\n            min-height: 80px;\n            background: #ffffff;\n            transition: border-color 0.15s ease;\n        }\n\n        .rich-textarea-container:focus-within {\n            border-color: #D3D1D5;\n        }\n\n        /* Contenteditable Area */\n        .rich-editable {\n            position: relative;\n            border: none;\n            outline: none;\n            resize: none;\n            font-family: \"DM Sans\", -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            font-size: 14px;\n            font-weight: 300;\n            line-height: 18px;\n            color: #3E3D3E;\n            width: 100%;\n            min-height: 60px;\n            max-height: 150px;\n            flex: 1;\n            overflow-y: auto;\n            overflow-x: hidden;\n            white-space: pre-wrap;\n            word-wrap: break-word;\n            overflow-wrap: break-word;\n            scrollbar-width: thin;\n            scrollbar-color: rgba(0,0,0,0.15) transparent;\n        }\n\n        .rich-editable::-webkit-scrollbar {\n            width: 4px;\n        }\n\n        .rich-editable::-webkit-scrollbar-thumb {\n            background: rgba(0,0,0,0.15);\n            border-radius: 4px;\n        }\n\n        .rich-editable.placeholder::before {\n            content: attr(data-placeholder);\n            position: absolute;\n            top: 0;\n            left: 0;\n            color: #9ca3af;\n            opacity: 0.8;\n            pointer-events: none;\n            font-style: italic;\n            font-weight: 400;\n        }\n\n        /* Hidden Color Picker - must remain interactive for native dialog */\n        .hidden-color-picker {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 1px;\n            height: 1px;\n            padding: 0;\n            margin: 0;\n            border: none;\n            opacity: 0.01;\n            overflow: hidden;\n            clip: rect(0, 0, 0, 0);\n            z-index: -1;\n        }\n\n        /* Inline Color Swatches */\n        .color-swatch-token {\n            display: inline-block;\n            width: 12px;\n            height: 12px;\n            border-radius: 50%;\n            border: 1px solid rgba(0,0,0,0.1);\n            vertical-align: middle;\n            margin-right: 3px;\n            cursor: pointer;\n            user-select: none;\n            transition: transform 0.15s ease, box-shadow 0.15s ease;\n        }\n\n        .color-swatch-token:hover {\n            transform: scale(1.2);\n            box-shadow: 0 0 0 2px rgba(0,0,0,0.1);\n        }\n\n        /* Inline Color Keywords */\n        @keyframes gradient-shift {\n            0% { background-position: 0% 50%; }\n            50% { background-position: 100% 50%; }\n            100% { background-position: 0% 50%; }\n        }\n\n        .color-keyword-token {\n            background: linear-gradient(135deg, #ff6b6b, #feca57, #48dbfb, #ff9ff3, #54a0ff);\n            background-size: 300% 300%;\n            -webkit-background-clip: text;\n            background-clip: text;\n            -webkit-text-fill-color: transparent;\n            animation: gradient-shift 3s ease infinite;\n            border-bottom: 1px dashed rgba(139, 92, 246, 0.5);\n            padding-bottom: 1px;\n            cursor: pointer;\n            font-weight: 500;\n        }\n\n        .color-keyword-token:hover {\n            animation-duration: 0.5s;\n        }\n\n        /* Link Styling */\n        .rich-editable a {\n            color: #6C18FF;\n            text-decoration: underline;\n            cursor: pointer;\n        }\n\n        .rich-editable a:hover {\n            color: #5513CC;\n        }\n\n        @media (max-width: 768px) {\n            .rich-textarea-container {\n                min-height: 160px;\n            }\n        }\n\n        .modal-footer {\n            display: flex;\n            justify-content: flex-end;\n        }\n\n        .submit-btn {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 6px;\n            height: 34px;\n            padding: 0 16px;\n            border-radius: 6px;\n            border: none;\n            background: #3E3D3E;\n            color: #FFF;\n            font-family: 'DM Sans', sans-serif;\n            font-size: 13px;\n            font-weight: 400;\n            white-space: nowrap;\n            cursor: pointer;\n            transition: all 0.15s ease;\n        }\n\n        .submit-btn:hover {\n            background: #9747FF;\n            border-radius: 6px;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function() {\n        var currentData = null;\n        var initialDescription = '';\n\n        function render(data) {\n            var container = document.getElementById('app-root');\n            var description = data.description || '';\n\n            var defaultIconSVG =\n                '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"100\" height=\"101\" viewBox=\"0 0 100 101\" fill=\"none\">' +\n                    '<path d=\"M1.66431 42.5898C1.66431 35.9624 7.03689 30.5898 13.6643 30.5898H65.0943C71.7218 30.5898 77.0944 35.9624 77.0944 42.5898V88.554C77.0944 95.1814 71.7218 100.554 65.0944 100.554H13.6643C7.03691 100.554 1.66431 95.1814 1.66431 88.554V42.5898Z\" fill=\"url(#paint0_linear_4037_16976)\" fill-opacity=\"0.4\"/>' +\n                    '<path d=\"M1.66431 42.5898C1.66431 35.9624 7.03689 30.5898 13.6643 30.5898H65.0943C71.7218 30.5898 77.0944 35.9624 77.0944 42.5898V50.2923C77.0944 56.9198 71.7218 62.2923 65.0944 62.2923H13.6643C7.03691 62.2923 1.66431 56.9197 1.66431 50.2923V42.5898Z\" fill=\"url(#paint1_linear_4037_16976)\" fill-opacity=\"0.4\"/>' +\n                    '<path d=\"M27.6643 30.6855C27.6643 24.6104 32.5892 19.6855 38.6643 19.6855C44.7394 19.6855 49.6643 24.6104 49.6643 30.6855\" stroke=\"url(#paint2_linear_4037_16976)\" stroke-width=\"3\"/>' +\n                    '<path d=\"M11.9397 34.3145C11.9397 27.687 17.3123 22.3145 23.9397 22.3145H75.3697C81.9971 22.3145 87.3698 27.687 87.3698 34.3145V80.2786C87.3698 86.906 81.9972 92.2786 75.3698 92.2786H23.9397C17.3123 92.2786 11.9397 86.906 11.9397 80.2786V34.3145Z\" fill=\"url(#paint3_linear_4037_16976)\" fill-opacity=\"0.4\"/>' +\n                    '<path d=\"M11.9397 34.3144C11.9397 27.687 17.3123 22.3145 23.9397 22.3145H75.3697C81.9971 22.3145 87.3698 27.687 87.3698 34.3145V42.017C87.3698 48.6444 81.9972 54.0169 75.3698 54.0169H23.9397C17.3123 54.0169 11.9397 48.6444 11.9397 42.0169V34.3144Z\" fill=\"url(#paint4_linear_4037_16976)\" fill-opacity=\"0.4\"/>' +\n                    '<path d=\"M23 24.4043C23 17.7769 28.3726 12.4043 35 12.4043H86.43C93.0574 12.4043 98.4301 17.7769 98.4301 24.4043V70.3684C98.4301 76.9958 93.0575 82.3684 86.4301 82.3684H35C28.3726 82.3684 23 76.9958 23 70.3684V24.4043Z\" fill=\"url(#paint5_linear_4037_16976)\"/>' +\n                    '<path d=\"M23 24.4043C23 17.7769 28.3726 12.4043 35 12.4043H86.43C93.0574 12.4043 98.4301 17.7769 98.4301 24.4043V32.1068C98.4301 38.7342 93.0575 44.1068 86.4301 44.1068H35C28.3726 44.1068 23 38.7342 23 32.1068V24.4043Z\" fill=\"url(#paint6_linear_4037_16976)\"/>' +\n                    '<path d=\"M49 12.5C49 6.42487 53.9249 1.5 60 1.5C66.0751 1.5 71 6.42487 71 12.5\" stroke=\"url(#paint7_linear_4037_16976)\" stroke-width=\"3\"/>' +\n                    '<defs>' +\n                        '<linearGradient id=\"paint0_linear_4037_16976\" x1=\"90.5611\" y1=\"30.5899\" x2=\"19.7418\" y2=\"109.433\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                        '<linearGradient id=\"paint1_linear_4037_16976\" x1=\"90.5611\" y1=\"30.5899\" x2=\"68.0223\" y2=\"85.9664\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                        '<linearGradient id=\"paint2_linear_4037_16976\" x1=\"37.6972\" y1=\"30.6855\" x2=\"38.9867\" y2=\"19.8601\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                        '<linearGradient id=\"paint3_linear_4037_16976\" x1=\"100.836\" y1=\"22.3145\" x2=\"30.0172\" y2=\"101.158\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                        '<linearGradient id=\"paint4_linear_4037_16976\" x1=\"100.836\" y1=\"22.3145\" x2=\"78.2977\" y2=\"77.691\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                        '<linearGradient id=\"paint5_linear_4037_16976\" x1=\"111.897\" y1=\"12.4043\" x2=\"41.0775\" y2=\"91.2477\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                        '<linearGradient id=\"paint6_linear_4037_16976\" x1=\"111.897\" y1=\"12.4043\" x2=\"89.358\" y2=\"67.7808\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                        '<linearGradient id=\"paint7_linear_4037_16976\" x1=\"59.0329\" y1=\"12.5\" x2=\"60.3224\" y2=\"1.67454\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                    '</defs>' +\n                '</svg>';\n\n            var iconHTML = data.iconUrl\n                ? '<img src=\"' + escapeHTML(data.iconUrl) + '\" alt=\"Component icon\" />'\n                : defaultIconSVG;\n\n            container.innerHTML =\n                '<div class=\"modal\">' +\n                    '<div class=\"modal-header\">' +\n                        '<div class=\"modal-icon\">' + iconHTML + '</div>' +\n                        '<h2 class=\"modal-title\">Submit ' + escapeHTML(data.componentName) + ' implementation</h2>' +\n                        '<p class=\"modal-subtitle\">Add details so the requester can review your implementation.</p>' +\n                    '</div>' +\n                    '<div class=\"form-group\">' +\n                        '<label class=\"form-label\" for=\"description-input\">Implementation details</label>' +\n                        '<div class=\"rich-textarea-container\">' +\n                            '<div class=\"rich-editable' + (description ? '' : ' placeholder') + '\" id=\"description-input\" contenteditable=\"true\" data-placeholder=\"Add details about your implementation…\"></div>' +\n                            '<input type=\"color\" class=\"hidden-color-picker\" />' +\n                        '</div>' +\n                    '</div>' +\n                    '<div class=\"modal-footer\">' +\n                        '<button class=\"submit-btn\" data-action=\"submit\">Submit</button>' +\n                    '</div>' +\n                '</div>';\n\n            // Set initial description BEFORE attachListeners so placeholder state is correct\n            if (description) {\n                var editable = document.getElementById('description-input');\n                if (editable) {\n                    editable.innerHTML = '';\n                    editable.textContent = description;\n                    renderColors(editable);\n                }\n            }\n\n            initialDescription = description;\n            attachListeners();\n        }\n\n        var isRendering = false;\n        var activeColorTarget = null;\n        var COLOR_REGEX = /(#[0-9a-fA-F]{3,8}\\b|rgba?\\s*\\(\\s*\\d+\\s*,\\s*\\d+\\s*,\\s*\\d+\\s*(?:,\\s*[\\d.]+\\s*)?\\))/gi;\n        var LINK_REGEX = /(https?:\\/\\/[^\\s<]+[^\\s<.,;:!?()[\\]{}'\\\"]+)/gi;\n\n        function getPlainText(el) {\n            var text = '';\n            el.childNodes.forEach(function(node) {\n                if (node.nodeType === 3) {\n                    text += node.textContent;\n                } else if (node.nodeName === 'BR') {\n                    text += '\\n';\n                } else if (node.classList && node.classList.contains('color-swatch-token')) {\n                    // skip swatches\n                } else if (node.classList && node.classList.contains('color-keyword-token')) {\n                    text += node.textContent;\n                } else if (node.nodeName === 'A') {\n                    text += node.getAttribute('href') || node.textContent;\n                } else {\n                    text += getPlainText(node);\n                }\n            });\n            return text;\n        }\n\n        function getCaretOffset(el) {\n            var sel = window.getSelection();\n            if (!sel.rangeCount) return 0;\n            var range = sel.getRangeAt(0);\n            var preRange = range.cloneRange();\n            preRange.selectNodeContents(el);\n            preRange.setEnd(range.startContainer, range.startOffset);\n            // count text offset skipping swatch nodes\n            var offset = 0;\n            var walker = document.createTreeWalker(el, NodeFilter.SHOW_ALL, null, false);\n            var node;\n            while ((node = walker.nextNode())) {\n                if (preRange.comparePoint(node, 0) > 0) break;\n                if (node.nodeType === 3) {\n                    if (node === range.startContainer) {\n                        offset += range.startOffset;\n                        break;\n                    }\n                    // check parent is not swatch\n                    var p = node.parentNode;\n                    if (p && p.classList && p.classList.contains('color-swatch-token')) continue;\n                    offset += node.textContent.length;\n                } else if (node.nodeName === 'BR') {\n                    offset += 1;\n                }\n            }\n            return offset;\n        }\n\n        function setCaretOffset(el, targetOffset) {\n            var walker = document.createTreeWalker(el, NodeFilter.SHOW_ALL, null, false);\n            var offset = 0;\n            var node;\n            while ((node = walker.nextNode())) {\n                if (node.nodeType === 3) {\n                    var p = node.parentNode;\n                    if (p && p.classList && p.classList.contains('color-swatch-token')) continue;\n                    if (offset + node.textContent.length >= targetOffset) {\n                        var sel = window.getSelection();\n                        var range = document.createRange();\n                        range.setStart(node, targetOffset - offset);\n                        range.collapse(true);\n                        sel.removeAllRanges();\n                        sel.addRange(range);\n                        return;\n                    }\n                    offset += node.textContent.length;\n                } else if (node.nodeName === 'BR') {\n                    if (offset + 1 > targetOffset) {\n                        var sel = window.getSelection();\n                        var range = document.createRange();\n                        range.setStartBefore(node);\n                        range.collapse(true);\n                        sel.removeAllRanges();\n                        sel.addRange(range);\n                        return;\n                    }\n                    offset += 1;\n                }\n            }\n            // fallback: set caret at end\n            var sel = window.getSelection();\n            var range = document.createRange();\n            range.selectNodeContents(el);\n            range.collapse(false);\n            sel.removeAllRanges();\n            sel.addRange(range);\n        }\n\n        function renderColors(editable) {\n            if (isRendering) return;\n            isRendering = true;\n\n            var caretPos = getCaretOffset(editable);\n            var plainText = getPlainText(editable);\n            var escaped = escapeHTML(plainText).replace(/\\n/g, '<br>');\n\n            var rendered = escaped.replace(COLOR_REGEX, function(match) {\n                return '<span class=\"color-swatch-token\" style=\"background:' + match + '\" contenteditable=\"false\" data-color=\"' + match + '\"></span><span class=\"color-keyword-token\" data-color=\"' + match + '\">' + match + '</span>';\n            });\n\n            // Apply link regex after colors\n            rendered = rendered.replace(LINK_REGEX, function(match) {\n                return '<a href=\"' + match + '\" target=\"_blank\" rel=\"noopener noreferrer\">' + match + '</a>';\n            });\n\n            editable.innerHTML = rendered;\n            setCaretOffset(editable, caretPos);\n\n            isRendering = false;\n        }\n\n        function updatePlaceholder(editable) {\n            var plainText = getPlainText(editable).trim();\n            if (plainText.length === 0) {\n                editable.classList.add('placeholder');\n            } else {\n                editable.classList.remove('placeholder');\n            }\n        }\n\n        function checkDirty(editable) {\n            var currentText = getPlainText(editable);\n            var isDirty = currentText !== initialDescription;\n            window.myop_cta_handler('form-dirty', { isDirty: isDirty });\n        }\n\n        function attachListeners() {\n            var submitBtn = document.querySelector('[data-action=\"submit\"]');\n            if (submitBtn) {\n                submitBtn.addEventListener('click', function() {\n                    var editable = document.getElementById('description-input');\n                    var value = editable ? getPlainText(editable) : '';\n                    window.myop_cta_handler('submit-clicked', { description: value });\n                });\n            }\n\n\n            var editable = document.getElementById('description-input');\n            var colorPicker = document.querySelector('.hidden-color-picker');\n\n            if (editable) {\n                editable.addEventListener('keydown', function(e) {\n                    if (e.key === 'Enter') {\n                        e.preventDefault();\n                        var sel = window.getSelection();\n                        if (!sel.rangeCount) return;\n                        var range = sel.getRangeAt(0);\n                        range.deleteContents();\n                        var br = document.createElement('br');\n                        range.insertNode(br);\n                        // Move caret after the <br>\n                        range.setStartAfter(br);\n                        range.collapse(true);\n                        sel.removeAllRanges();\n                        sel.addRange(range);\n                        // Trigger rendering\n                        renderColors(editable);\n                        updatePlaceholder(editable);\n                        checkDirty(editable);\n                    }\n                });\n\n                editable.addEventListener('input', function() {\n                    renderColors(editable);\n                    updatePlaceholder(editable);\n                    checkDirty(editable);\n                });\n\n                editable.addEventListener('click', function(e) {\n                    var target = e.target;\n                    if (target.classList && (target.classList.contains('color-swatch-token') || target.classList.contains('color-keyword-token'))) {\n                        e.preventDefault();\n                        e.stopPropagation();\n                        var colorVal = target.getAttribute('data-color');\n                        if (colorVal && colorPicker) {\n                            activeColorTarget = colorVal;\n                            var hex = colorToHex(colorVal);\n                            colorPicker.value = hex;\n                            // Position picker near the clicked swatch for context\n                            var rect = target.getBoundingClientRect();\n                            var containerRect = editable.closest('.rich-textarea-container').getBoundingClientRect();\n                            colorPicker.style.position = 'absolute';\n                            colorPicker.style.left = (rect.left - containerRect.left) + 'px';\n                            colorPicker.style.top = (rect.bottom - containerRect.top + 4) + 'px';\n                            colorPicker.