{
  "version": "0.2.10",
  "item": {
    "name": "Confirmation payment popup",
    "id": "4465f5f1-567e-4d96-aa48-d6e56b852f44",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "name": "Version 4",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!doctype html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}' />\n    <title>Success - Price List Ready</title>\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Font configuration object\n */\ninterface FontConfig {\n  /** Font identifier used for CSS variable naming (e.g., \"main\" -> --font_main) */\n  id: string;\n  /** Font family name */\n  family: string;\n  /** Font style (optional) */\n  style?: string;\n  /** Font weight (optional) */\n  weight?: number;\n  /** URL to font CSS file (optional) */\n  url?: string;\n}\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n  /** Array of font configurations */\n  fonts?: FontConfig[];\n  /** Dynamic data for template substitution */\n  data?: {\n    gallery_name?: string;\n  };\n  /** Localization strings */\n  lang?: {\n    kicker?: string;\n    title?: string;\n    subtitle?: string;\n    button?: string;\n    button_success?: string;\n  };\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'done_clicked': Record<string, never>;\n  'size-requested': {\n    width?: number | null;\n    height?: number | null;\n    minWidth?: number | null;\n    maxWidth?: number | null;\n    minHeight?: number | null;\n    maxHeight?: number | null;\n    required?: boolean;\n  };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n    <style>\n        :root {\n            --bg: #ffffff;\n            --text: #444444;\n            --muted: #6b6b6b;\n            --btn: #222;\n\n            /* Font variables - set via JS from fonts array */\n            --font_main: system-ui, -apple-system, sans-serif;\n            --font_main_style: normal;\n            --font_main_weight: 400;\n\n            /* Button Variables */\n            --1-Button-H-1-1-1-primary-button: #222;\n            --3-Text-H-3-5-1-inverted-color-text: #FFF;\n        }\n\n        * {\n            box-sizing: border-box;\n        }\n\n        html,\n        body {\n            width: 100%;\n            height: 100%;\n            margin: 0;\n            padding: 0;\n            overflow: hidden;\n        }\n\n        body {\n            background: var(--bg);\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            color: var(--text);\n        }\n\n        /* Stage */\n        .stage {\n            position: relative;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        /* Confetti layer */\n        .confetti-layer {\n            position: absolute;\n            inset: 0;\n            pointer-events: none;\n            z-index: 0;\n        }\n\n        .confetti {\n            position: absolute;\n            display: block;\n            background: var(--c, #3aa);\n            width: var(--w, 10px);\n            height: var(--h, 10px);\n            border-radius: var(--br, 2px);\n            transform: translate(-50%, -50%) rotate(var(--r, 0deg));\n            opacity: 1;\n        }\n\n        /* Content */\n        .content {\n            position: relative;\n            z-index: 1;\n            text-align: center;\n            width: min(860px, 92vw);\n            transform: translateY(-38px);\n        }\n\n        .kicker {\n            color: #000;\n            text-align: center;\n            font-family: var(--font_main);\n            font-size: 32px;\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            line-height: 150%;\n            /* 48px */\n            margin: 0 0 24px;\n        }\n\n        .title {\n            color: #000;\n            text-align: center;\n            font-family: var(--font_main);\n            font-size: 50px;\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            line-height: 150%;\n            /* 75px */\n            margin: 0 0 18px;\n        }\n\n        .subtitle {\n            color: #000;\n            text-align: center;\n            font-family: var(--font_main);\n            font-size: 24px;\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            line-height: 150%;\n            /* 36px */\n            width: 434px;\n            max-width: 100%;\n            margin: 0 auto 26px;\n        }\n\n        .btn {\n            appearance: none;\n            border: 0;\n            display: inline-flex;\n            min-width: 248px;\n            min-height: 56px;\n            padding: 6px 48px;\n            justify-content: center;\n            align-items: center;\n            gap: 4px;\n            background: var(--1-Button-H-1-1-1-primary-button, #222);\n\n            color: var(--3-Text-H-3-5-1-inverted-color-text, #FFF);\n            text-align: center;\n            font-feature-settings: 'liga' off, 'clig' off;\n            font-family: var(--font_main);\n            font-size: 16px;\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            line-height: 125%;\n            /* 20px */\n\n            border-radius: 2px;\n            cursor: pointer;\n            box-shadow: 0 1px 0 rgba(0, 0, 0, 0.25);\n            transition: all 0.2s ease;\n        }\n\n        .btn:focus {\n            outline: 2px solid rgba(0, 0, 0, 0.25);\n            outline-offset: 3px;\n        }\n\n        .btn:active {\n            transform: translateY(1px);\n        }\n\n        /* Small responsiveness */\n        @media (max-width:520px) {\n            .kicker {\n                margin-bottom: 36px;\n            }\n\n            .title {\n                font-size: 32px;\n            }\n\n            .subtitle {\n                font-size: 13px;\n            }\n\n            .content {\n                transform: translateY(-18px);\n            }\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"stage\">\n        <div class=\"confetti-layer\" id=\"confettiLayer\" aria-hidden=\"true\"></div>\n\n        <main class=\"content\" role=\"main\" aria-label=\"Success message\">\n            <p class=\"kicker\" id=\"ui-kicker\"></p>\n\n            <h1 class=\"title\" id=\"ui-title\"></h1>\n\n            <p class=\"subtitle\" id=\"ui-subtitle\"></p>\n\n            <!-- Added data-success-text to store localized success message -->\n            <button class=\"btn\" type=\"button\" id=\"doneBtn\" data-success-text=\"Saved!\"></button>\n        </main>\n    </div>\n\n    <script>\n        /**\n     * 1. Global CTA Handler\n     * Receives action_id and payload. Logs to console.\n     */\n    window.myop_cta_handler = function(action_id, payload) {\n      console.log(`[CTA Handler] Action: ${action_id}`, payload);\n    };\n\n    /**\n     * 2. Global Init Interface\n     * Receives config object (DTO) and populates the UI.\n     */\n    window.myop_init_interface = function(config) {\n      // Set Fonts via CSS Variables from fonts array\n      const root = document.documentElement;\n      if (config.fonts && Array.isArray(config.fonts)) {\n        config.fonts.forEach(font => {\n          if (font.id && font.family) {\n            // Load font CSS if url provided\n            if (font.url) {\n              const linkId = `font-${font.id}`;\n              if (!document.getElementById(linkId)) {\n                const link = document.createElement('link');\n                link.id = linkId;\n                link.rel = 'stylesheet';\n                link.href = font.url;\n                document.head.appendChild(link);\n              }\n            }\n            // Set CSS variables using font id (e.g., --font_main)\n            root.style.setProperty(`--font_${font.id}`, `\"${font.family}\", system-ui, sans-serif`);\n            if (font.style) {\n              root.style.setProperty(`--font_${font.id}_style`, font.style);\n            }\n            if (font.weight) {\n              root.style.setProperty(`--font_${font.id}_weight`, font.weight);\n            }\n          }\n        });\n      }\n\n      // Set Text Content from Lang Object\n      const lang = config.lang || {};\n      const data = config.data || {};\n\n      if (lang.kicker) {\n        document.getElementById('ui-kicker').textContent = lang.kicker;\n      }\n      if (lang.title) {\n        document.getElementById('ui-title').textContent = lang.title;\n      }\n      if (lang.subtitle) {\n        let subtitleHTML = lang.subtitle;\n        // Handle dynamic gallery name replacement from data object\n        if (data.gallery_name) {\n          subtitleHTML = subtitleHTML.replace('{gallery_name}', data.gallery_name);\n        }\n        // InnerHTML used to support <br/> tag in subtitle\n        document.getElementById('ui-subtitle').innerHTML = subtitleHTML;\n      }\n      if (lang.button) {\n        const btn = document.getElementById('doneBtn');\n        btn.textContent = lang.button;\n        \n        // Update localized success message if provided\n        if (lang.button_success) {\n          btn.dataset.successText = lang.button_success;\n        }\n      }\n\n      // Initialize visual elements (Confetti)\n      initConfetti();\n    };\n\n    /**\n     * Internal: Confetti Logic\n     */\n    function initConfetti() {\n       // Clear previous confetti if any (supports re-init)\n       const layer = document.getElementById(\"confettiLayer\");\n       layer.innerHTML = '';\n\n       const confettiData = [\n        // top + upper area\n        { x: 56, y: 18, w: 18, h: 14, r: -25, c: \"#37B5CC\", br: 4 },\n        { x: 14, y: 32, w: 18, h: 12, r: -18, c: \"#FFE07A\", br: 3 },\n        { x: 7,  y: 40, w: 16, h: 14, r: 12,  c: \"#7FE9D6\", br: 4 },\n        { x: 86, y: 40, w: 18, h: 12, r: 18,  c: \"#FFE07A\", br: 3 },\n        { x: 94, y: 33, w: 18, h: 8,  r: 32,  c: \"#37B5CC\", br: 8 },\n        // left mid\n        { x: 11, y: 55, w: 7,  h: 7,  r: 0,   c: \"#37B5CC\", br: 50 },\n        { x: 21, y: 57, w: 18, h: 16, r: -32, c: \"#2F47C6\", br: 5 },\n        { x: 15, y: 60, w: 12, h: 6,  r: 22,  c: \"#E63B4A\", br: 2 },\n        { x: 25, y: 64, w: 2,  h: 18, r: -58, c: \"#F3C14B\", br: 2 },\n        { x: 19, y: 73, w: 18, h: 14, r: -18, c: \"#3E8F7E\", br: 3 },\n        // right mid\n        { x: 82, y: 62, w: 14, h: 6,  r: -12, c: \"#E63B4A\", br: 2 },\n        { x: 89, y: 60, w: 6,  h: 6,  r: 0,   c: \"#37B5CC\", br: 50 },\n        { x: 86, y: 68, w: 14, h: 10, r: -30, c: \"#2F47C6\", br: 2 },\n        { x: 92, y: 73, w: 2,  h: 18, r: 58,  c: \"#37B5CC\", br: 2 },\n        { x: 80, y: 74, w: 12, h: 18, r: 18,  c: \"#E63B4A\", br: 2 },\n        { x: 88, y: 77, w: 14, h: 10, r: 22,  c: \"#2F47C6\", br: 2 },\n        { x: 84, y: 82, w: 12, h: 12, r: 0,   c: \"#3E8F7E\", br: 50 },\n        // bottom-left scatter\n        { x: 12, y: 86, w: 12, h: 12, r: 0,   c: \"#3E8F7E\", br: 50 },\n        { x: 18, y: 90, w: 10, h: 14, r: 18,  c: \"#F09A2D\", br: 2 },\n        { x: 22, y: 94, w: 2,  h: 18, r: 66,  c: \"#F09A2D\", br: 2 },\n        { x: 26, y: 92, w: 16, h: 10, r: -18, c: \"#F09A2D\", br: 2 },\n        { x: 8,  y: 96, w: 10, h: 14, r: -22, c: \"#E63B4A\", br: 2 },\n        // bottom-mid scatter\n        { x: 58, y: 90, w: 18, h: 12, r: 18,  c: \"#37B5CC\", br: 3 },\n        { x: 64, y: 96, w: 10, h: 14, r: 12,  c: \"#37B5CC\", br: 2 },\n        { x: 68, y: 94, w: 12, h: 8,  r: -22, c: \"#2F47C6\", br: 2 },\n        { x: 72, y: 96, w: 12, h: 6,  r: 22,  c: \"#7FE9D6\", br: 3 },\n        // bottom-right cluster\n        { x: 86, y: 92, w: 18, h: 12, r: 10,  c: \"#FFE07A\", br: 3 },\n        { x: 90, y: 95, w: 2,  h: 18, r: 70,  c: \"#37B5CC\", br: 2 },\n        { x: 94, y: 92, w: 14, h: 6,  r: -12, c: \"#3E8F7E\", br: 2 },\n        { x: 96, y: 96, w: 16, h: 10, r: 18,  c: \"#F09A2D\", br: 2 },\n        { x: 92, y: 98, w: 10, h: 14, r: 22,  c: \"#2F47C6\", br: 2 }\n      ];\n\n      confettiData.forEach((p) => {\n        const el = document.createElement(\"span\");\n        el.className = \"confetti\";\n        el.style.left = p.x + \"%\";\n        el.style.top  = p.y + \"%\";\n        el.style.setProperty(\"--w\", p.w + \"px\");\n        el.style.setProperty(\"--h\", p.h + \"px\");\n        el.style.setProperty(\"--r\", p.r + \"deg\");\n        el.style.setProperty(\"--c\", p.c);\n        el.style.setProperty(\"--br\", (p.br === 50 ? \"999px\" : p.br + \"px\"));\n        layer.appendChild(el);\n      });\n    }\n\n    /**\n     * Event Listeners\n     */\n    const btn = document.getElementById(\"doneBtn\");\n    btn.addEventListener(\"click\", () => {\n      // Close the component\n      if (window.myop_cta_handler) {\n        window.myop_cta_handler('done_clicked', {});\n      }\n    });\n\n    /**\n     * Mock Initialization\n     * This mimics the app calling the init method with data.\n     */\n    const mockConfig = {\n      fonts: [\n        {\n          id: \"main\",\n          family: \"TT Norms Pro\",\n          style: \"normal\",\n          weight: 400,\n          url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n        }\n      ],\n      // Dynamic Data\n      data: {\n        gallery_name: \"Jessica & Ben\"\n      },\n      // Localization Strings\n      lang: {\n        kicker: \"Congratulations!\",\n        title: \"You're all set!\",\n        subtitle: \"Now is the time to deliver your story with all your new features.\",\n        button: \"Done\",\n        button_success: \"Saved!\"\n      }\n    };\n\n    // Initialize\n    window.myop_init_interface(mockConfig);\n\n    </script>\n</body>\n\n</html>"
        },
        "id": "417c1911-7ea3-4aa2-b9d4-2e947ea6a20c"
      }
    ]
  }
}