    "consume_variant": [
      {
        "id": "c5c33420-c6f0-489c-9a20-8aee3fbfce45",
        "name": "myop 2 aligned",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Table Component - Blue Theme</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n    <style>\n        html {\n            height: 100%;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            background: transparent;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;\n        }\n\n        /* Loader Styles */\n        #loader-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100%;\n            width: 100%;\n            gap: 16px;\n        }\n\n        .loader-spinner {\n            width: 40px;\n            height: 40px;\n            border: 3px solid #e5e7eb;\n            border-top-color: #3B82F6;\n            border-radius: 50%;\n            animation: spin 0.8s linear infinite;\n        }\n\n        @keyframes spin {\n            to { transform: rotate(360deg); }\n        }\n\n        .loader-text {\n            color: #6b7280;\n            font-size: 14px;\n            font-weight: 500;\n        }\n\n        /* App Container */\n        #app-root {\n            opacity: 0;\n            transition: opacity 0.3s ease;\n            height: 100%;\n        }\n\n        #app-root.visible {\n            opacity: 1;\n        }\n\n        .main-container {\n            width: 1178px;\n            max-width: 100%;\n            height: 100%;\n            padding: 0;\n            background: transparent;\n            margin: 0;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .team-table {\n            flex: 1;\n            min-height: 0;\n            border-radius: 10px;\n            border: 1px solid rgba(0, 0, 0, 0.10);\n            background: #FFF;\n            overflow: auto;\n            position: relative;\n            -webkit-overflow-scrolling: touch;\n        }\n\n        .team-table::-webkit-scrollbar {\n            width: 8px;\n            height: 8px;\n        }\n\n        .team-table::-webkit-scrollbar-track {\n            background: #FFFFFF;\n        }\n\n        .team-table::-webkit-scrollbar-thumb {\n            background: rgba(0, 0, 0, 0.1);\n            border-radius: 4px;\n        }\n\n        .team-table::-webkit-scrollbar-thumb:hover {\n            background: rgba(0, 0, 0, 0.15);\n        }\n\n        table {\n            width: 100%;\n            border-collapse: separate;\n            border-spacing: 0;\n        }\n\n        thead {\n            position: sticky;\n            top: 0;\n            z-index: 100;\n        }\n\n        thead tr {\n            background: #F9FAFB;\n        }\n\n        th {\n            padding: 16px 24px;\n            text-align: left;\n            font-size: 13px;\n            font-weight: 500;\n            color: #666;\n            text-transform: capitalize;\n            background: #F9FAFB;\n            border-bottom: 1px solid #e8e8e8;\n            position: sticky;\n            top: 0;\n            white-space: nowrap;\n        }\n\n        th.sortable {\n            cursor: pointer;\n            user-select: none;\n            transition: background 0.15s ease;\n        }\n\n        th.sortable:hover {\n            background: #f0f0f0;\n        }\n\n        th.sortable .th-content {\n            display: flex;\n            align-items: center;\n            gap: 6px;\n        }\n\n        th.sortable .sort-icon {\n            display: flex;\n            flex-direction: column;\n            gap: 2px;\n            opacity: 0.3;\n        }\n\n        th.sortable.active .sort-icon {\n            opacity: 1;\n            color: #3B82F6;\n        }\n\n        th.sortable .sort-icon svg {\n            width: 10px;\n            height: 10px;\n        }\n\n        tbody tr {\n            border-bottom: 1px solid #f0f0f0;\n            transition: all 0.15s ease;\n            background: #FFF;\n        }\n\n        tbody tr:last-child {\n            border-bottom: none;\n        }\n\n        tbody tr:hover {\n            background: rgba(80, 255, 238, 0.20);\n        }\n\n        td {\n            padding: 20px 24px;\n            font-size: 12px;\n            color: #1a1a1a;\n        }\n\n        .member-cell {\n            display: flex;\n            align-items: center;\n            gap: 12px;\n        }\n\n        .member-avatar {\n            width: 40px;\n            height: 40px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 11px;\n            font-weight: 600;\n            color: #FFFFFF;\n            flex-shrink: 0;\n            overflow: hidden;\n        }\n\n        .member-avatar img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n        }\n\n        .member-name {\n            color: #363740;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 24px;\n            letter-spacing: 0;\n            white-space: nowrap;\n        }\n\n        .location-text,\n        .title-text {\n            color: #717182;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 24px;\n            letter-spacing: 0;\n            white-space: nowrap;\n        }\n\n        .tenure-text,\n        .experience-text {\n            color: #363740;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 24px;\n            letter-spacing: 0;\n        }\n\n        .skills-cell {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 6px;\n            width: 320px;\n            height: 50px;\n        }\n\n        .skill-tag {\n            display: flex;\n            height: 22px;\n            padding: 2px 8px;\n            justify-content: center;\n            align-items: center;\n            gap: 4px;\n            flex-shrink: 0;\n            border-radius: 10px;\n            border: 1px solid #bfdbfe;\n            background: #eff6ff;\n            color: #363740;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 12px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 16px;\n            white-space: nowrap;\n        }\n\n        .skill-more {\n            display: flex;\n            width: 31.133px;\n            height: 22px;\n            justify-content: center;\n            align-items: center;\n            flex-shrink: 0;\n            border-radius: 10px;\n            border: 1px solid #bfdbfe;\n            background: #eff6ff;\n            color: #0F0F0F;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 11px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 16px;\n        }\n\n        /* Tablet styles */\n        @media (max-width: 1200px) {\n            .main-container {\n                width: 100%;\n                padding: 0;\n            }\n\n            table {\n                min-width: 800px;\n            }\n\n            .skills-cell {\n                width: 280px;\n            }\n        }\n\n        /* Mobile styles */\n        @media (max-width: 768px) {\n            .main-container {\n                width: 100%;\n                padding: 0;\n            }\n\n            .team-table {\n                border-radius: 8px;\n            }\n\n            table {\n                min-width: 700px;\n            }\n\n            th {\n                padding: 12px 16px;\n                font-size: 12px;\n            }\n\n            td {\n                padding: 16px;\n            }\n\n            .member-avatar {\n                width: 36px;\n                height: 36px;\n                font-size: 10px;\n            }\n\n            .skills-cell {\n                width: 240px;\n                height: auto;\n            }\n\n            .skill-tag {\n                height: 20px;\n                padding: 2px 6px;\n            }\n\n            .skill-more {\n                height: 20px;\n                width: 28px;\n            }\n        }\n\n        /* Small mobile */\n        @media (max-width: 480px) {\n            .main-container {\n                padding: 0;\n                width: 100%;\n            }\n\n            table {\n                min-width: 600px;\n            }\n\n            th {\n                padding: 10px 12px;\n                font-size: 11px;\n            }\n\n            td {\n                padding: 12px;\n            }\n\n            .member-avatar {\n                width: 32px;\n                height: 32px;\n                font-size: 9px;\n            }\n\n            .skills-cell {\n                width: 200px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <!-- Loader Container - Visible by default -->\n    <div id=\"loader-container\">\n        <div class=\"loader-spinner\"></div>\n        <div class=\"loader-text\">Loading team data...</div>\n    </div>\n\n    <!-- App Root - Hidden by default -->\n    <div id=\"app-root\">\n        <div class=\"main-container\">\n            <div class=\"team-table\">\n                <table>\n                    <thead>\n                        <tr id=\"tableHeader\">\n                        </tr>\n                    </thead>\n                    <tbody id=\"teamTableBody\">\n                    </tbody>\n                </table>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // ==========================================\n        // PRIVATE SCOPE - All implementation details hidden\n        // ==========================================\n        (function() {\n            // Private state management\n            let teamDataState = [];\n            let isInitialized = false;\n            \n            // Sorting state\n            let currentSort = {\n                column: null,\n                direction: 'asc' // 'asc' or 'desc'\n            };\n\n            // Column definitions\n            const columns = [\n                { key: 'name', label: 'Member', sortable: true, sortType: 'alpha' },\n                { key: 'title', label: 'Title', sortable: true, sortType: 'alpha' },\n                { key: 'location', label: 'Location', sortable: false },\n                { key: 'tenure', label: 'Tenure', sortable: true, sortType: 'numeric' },\n                { key: 'experience', label: 'Experience', sortable: true, sortType: 'numeric' },\n                { key: 'skills', label: 'Skills', sortable: false }\n            ];\n\n            // DOM references\n            const loaderContainer = document.getElementById('loader-container');\n            const appRoot = document.getElementById('app-root');\n\n            // ==========================================\n            // PRIVATE FUNCTIONS - LOADER\n            // ==========================================\n\n            function hideLoader() {\n                loaderContainer.style.display = 'none';\n                appRoot.classList.add('visible');\n            }\n\n            function showLoader() {\n                loaderContainer.style.display = 'flex';\n                appRoot.classList.remove('visible');\n            }\n\n            // ==========================================\n            // PRIVATE FUNCTIONS - SORTING\n            // ==========================================\n\n            function parseNumericValue(value) {\n                // Extract numeric value from strings like \"12y\", \"5.5y\"\n                return parseFloat(value.replace(/[^0-9.]/g, '')) || 0;\n            }\n\n            function sortData(column, direction) {\n                const colDef = columns.find(c => c.key === column);\n                if (!colDef || !colDef.sortable) return;\n\n                teamDataState.sort((a, b) => {\n                    let valA, valB;\n\n                    if (colDef.sortType === 'alpha') {\n                        valA = (a[column] || '').toLowerCase();\n                        valB = (b[column] || '').toLowerCase();\n                        \n                        if (direction === 'asc') {\n                            return valA.localeCompare(valB);\n                        } else {\n                            return valB.localeCompare(valA);\n                        }\n                    } else if (colDef.sortType === 'numeric') {\n                        valA = parseNumericValue(a[column]);\n                        valB = parseNumericValue(b[column]);\n                        \n                        if (direction === 'asc') {\n                            return valA - valB;\n                        } else {\n                            return valB - valA;\n                        }\n                    }\n                    return 0;\n                });\n            }\n\n            function handleHeaderClick(column) {\n                const colDef = columns.find(c => c.key === column);\n                if (!colDef || !colDef.sortable) return;\n\n                // Toggle direction if same column, otherwise set default direction\n                if (currentSort.column === column) {\n                    currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';\n                } else {\n                    currentSort.column = column;\n                    // Default: alphabetical = A-Z (asc), numeric = high to low (desc)\n                    currentSort.direction = colDef.sortType === 'numeric' ? 'desc' : 'asc';\n                }\n\n                sortData(column, currentSort.direction);\n                renderTableHeader();\n                renderTableBody();\n\n                // Notify host via myop_cta_handler\n                window.myop_cta_handler('sort', {\n                    column: column,\n                    direction: currentSort.direction,\n                    sortedIds: teamDataState.map(m => m.id)\n                });\n\n                console.log('Table Component: Sorted by', column, currentSort.direction);\n            }\n\n            // ==========================================\n            // PRIVATE FUNCTIONS - UI RENDERING\n            // ==========================================\n\n            function getSortIcon(column) {\n                const isActive = currentSort.column === column;\n                const direction = currentSort.direction;\n                \n                return `\n                    <span class=\"sort-icon\">\n                        <svg viewBox=\"0 0 10 6\" fill=\"${isActive && direction === 'asc' ? 'currentColor' : '#ccc'}\">\n                            <path d=\"M5 0L10 6H0L5 0Z\"/>\n                        </svg>\n                        <svg viewBox=\"0 0 10 6\" fill=\"${isActive && direction === 'desc' ? 'currentColor' : '#ccc'}\">\n                            <path d=\"M5 6L0 0H10L5 6Z\"/>\n                        </svg>\n                    </span>\n                `;\n            }\n\n            function renderTableHeader() {\n                const thead = document.getElementById('tableHeader');\n                thead.innerHTML = '';\n\n                columns.forEach(col => {\n                    const th = document.createElement('th');\n                    \n                    if (col.sortable) {\n                        th.className = 'sortable' + (currentSort.column === col.key ? ' active' : '');\n                        th.innerHTML = `\n                            <div class=\"th-content\">\n                                <span>${col.label}</span>\n                                ${getSortIcon(col.key)}\n                            </div>\n                        `;\n                        th.addEventListener('click', () => handleHeaderClick(col.key));\n                    } else {\n                        th.textContent = col.label;\n                    }\n\n                    thead.appendChild(th);\n                });\n            }\n\n            function renderTableBody() {\n                const tbody = document.getElementById('teamTableBody');\n                tbody.innerHTML = '';\n\n                teamDataState.forEach((member, index) => {\n                    const tr = document.createElement('tr');\n                    tr.style.cursor = 'pointer';\n                    tr.onclick = () => handleMemberClick(member, index);\n\n                    const visibleSkills = member.skills.slice(0, 3);\n                    const remainingSkills = member.skills.length - 3;\n\n                    // Render avatar with image or initials\n                    let avatarContent = '';\n                    if (member.profileImage) {\n                        avatarContent = `<img src=\"${member.profileImage}\" alt=\"${member.name}\">`;\n                    } else {\n                        avatarContent = member.initials;\n                    }\n\n                    tr.innerHTML = `\n                        <td>\n                            <div class=\"member-cell\">\n                                <div class=\"member-avatar\" style=\"background: ${member.avatarColor || '#e0e0e0'};\">${avatarContent}</div>\n                                <span class=\"member-name\">${member.name}</span>\n                            </div>\n                        </td>\n                        <td class=\"title-text\">${member.title}</td>\n                        <td class=\"location-text\">${member.location}</td>\n                        <td class=\"tenure-text\">${member.tenure}</td>\n                        <td class=\"experience-text\">${member.experience}</td>\n                        <td>\n                            <div class=\"skills-cell\">\n                                ${visibleSkills.map(skill => `<span class=\"skill-tag\">${skill}</span>`).join('')}\n                                ${remainingSkills > 0 ? `<span class=\"skill-more\">+${remainingSkills}</span>` : ''}\n                            </div>\n                        </td>\n                    `;\n                    tbody.appendChild(tr);\n                });\n            }\n\n            function renderTableView() {\n                renderTableHeader();\n                renderTableBody();\n            }\n\n            // ==========================================\n            // PRIVATE FUNCTIONS - EVENT HANDLERS\n            // ==========================================\n\n            function handleMemberClick(member, index) {\n                console.log('Table Component: Member clicked:', member.name);\n                \n                // Notify host via myop_cta_handler\n                window.myop_cta_handler('member_clicked', {\n                    member: member,\n                    index: index\n                });\n            }\n\n            // ==========================================\n            // PRIVATE FUNCTIONS - DATA HANDLING\n            // ==========================================\n\n            function initializeComponent(data) {\n                // Store team data\n                if (data && data.teamData) {\n                    teamDataState = data.teamData;\n                }\n                \n                // Apply any configuration if provided\n                if (data && data.config) {\n                    console.log('Table Component: config applied:', data.config);\n                }\n                \n                // Reset sort state\n                currentSort = { column: null, direction: 'asc' };\n                \n                // Render the table\n                renderTableView();\n                \n                // Hide loader and show app\n                hideLoader();\n                \n                isInitialized = true;\n                console.log('Table Component initialized with', teamDataState.length, 'members');\n            }\n\n            function handleAction(actionData) {\n                if (!actionData || !actionData.action) {\n                    console.warn('Table Component: Action requires an action type');\n                    return;\n                }\n\n                switch (actionData.action) {\n                    case 'updateMember':\n                        // Update a single member\n                        if (actionData.payload && actionData.payload.id) {\n                            const index = teamDataState.findIndex(m => m.id === actionData.payload.id);\n                            if (index !== -1) {\n                                teamDataState[index] = { ...teamDataState[index], ...actionData.payload };\n                                console.log('Table Component: Member updated:', actionData.payload.id);\n                                renderTableView();\n                            } else {\n                                console.warn('Table Component: Member not found:', actionData.payload.id);\n                            }\n                        }\n                        break;\n\n                    case 'setData':\n                    case 'setTeamData':\n                        // Replace entire team data array\n                        if (actionData.payload && Array.isArray(actionData.payload)) {\n                            teamDataState = actionData.payload;\n                            currentSort = { column: null, direction: 'asc' };\n                            console.log('Table Component: Team data replaced, count:', teamDataState.length);\n                            renderTableView();\n                            hideLoader();\n                        }\n                        break;\n\n                    case 'addMember':\n                        // Add a new member\n                        if (actionData.payload) {\n                            teamDataState.push(actionData.payload);\n                            console.log('Table Component: Member added:', actionData.payload.id);\n                            renderTableView();\n                        }\n                        break;\n\n                    case 'removeMember':\n                        // Remove a member by id\n                        if (actionData.payload && actionData.payload.id) {\n                            const index = teamDataState.findIndex(m => m.id === actionData.payload.id);\n                            if (index !== -1) {\n                                teamDataState.splice(index, 1);\n                                console.log('Table Component: Member removed:', actionData.payload.id);\n                                renderTableView();\n                            }\n                        }\n                        break;\n\n                    case 'sort':\n                        // Sort by column\n                        if (actionData.payload && actionData.payload.column) {\n                            const colDef = columns.find(c => c.key === actionData.payload.column);\n                            if (colDef && colDef.sortable) {\n                                currentSort.column = actionData.payload.column;\n                                currentSort.direction = actionData.payload.direction || 'asc';\n                                sortData(currentSort.column, currentSort.direction);\n                                console.log('Table Component: Sorted by', currentSort.column, currentSort.direction);\n                                renderTableView();\n                            }\n                        }\n                        break;\n\n                    default:\n                        console.warn('Table Component: Unknown action:', actionData.action);\n                }\n            }\n\n            // ==========================================\n            // PUBLIC API - ONLY 2 FUNCTIONS ARE GLOBAL\n            // ==========================================\n\n            /**\n             * myop_init_interface - Initialize or update component with data\n             * \n             * Usage:\n             * - Initialize: myop_init_interface({ teamData: [...] })\n             * - Action-based update: myop_init_interface({ action: 'setData', payload: [...] })\n             * - Get current state: myop_init_interface() (no arguments)\n             */\n            window.myop_init_interface = function(data) {\n                if (arguments.length === 0) {\n                    // Getter: return current state\n                    return {\n                        teamData: teamDataState,\n                        sort: currentSort\n                    };\n                }\n\n                console.log('Table Component: myop_init_interface() called with:', data);\n\n                // Check if this is an action-based update\n                if (data && data.action) {\n                    handleAction(data);\n                } else {\n                    // Standard initialization\n                    initializeComponent(data);\n                }\n\n                return data;\n            };\n\n            /**\n             * myop_cta_handler - Handle CTA events and communicate to host\n             * \n             * Events emitted:\n             * - 'member_clicked': { member: {...}, index: number }\n             * - 'sort': { column: string, direction: 'asc'|'desc', sortedIds: string[] }\n             */\n            window.myop_cta_handler = function(action_id, payload) {\n                console.log('Table Component: myop_cta_handler called:', action_id, payload);\n                // Default implementation - host should override this\n                // The host application sets this function to handle events\n            };\n\n            // ==========================================\n            // INITIALIZATION\n            // ==========================================\n\n            console.log('Table Component: Ready for initialization');\n            console.log('Component uses Myop 2-function pattern: myop_init_interface(), myop_cta_handler()');\n            console.log('Sortable columns: Member (A-Z), Title (A-Z), Tenure, Experience');\n\n        })(); // End of IIFE - Everything above is private\n    </script>\n\n    <!-- Preview/Mock Data Script -->\n    <script id=\"myop_preview\">\n        setTimeout(() => {\n            window.myop_init_interface({\n                teamData: [\n                    {\n                        id: '1',\n                        initials: 'AR',\n                        name: 'Alex Rivera',\n                        title: 'Design Director',\n                        location: 'San Francisco, CA',\n                        tenure: '5.2y',\n                        experience: '12y',\n                        skills: ['Design Leadership', 'Strategy', 'Team Management'],\n                        avatarColor: '#9B59B6',\n                        profileImage: null\n                    },\n                    {\n                        id: '2',\n                        initials: 'JP',\n                        name: 'Jamie Park',\n                        title: 'Product Designer',\n                        location: 'Seattle, WA',\n                        tenure: '1.5y',\n                        experience: '3y',\n                        skills: ['UI Design', 'Mobile Design', 'Prototyping'],\n                        avatarColor: '#3498DB',\n                        profileImage: null\n                    },\n                    {\n                        id: '3',\n                        initials: 'SF',\n                        name: 'Sam Foster',\n                        title: 'UX Researcher',\n                        location: 'Austin, TX',\n                        tenure: '2.1y',\n                        experience: '4y',\n                        skills: ['User Research', 'Data Analysis', 'Usability Testing'],\n                        avatarColor: '#1ABC9C',\n                        profileImage: null\n                    },\n                    {\n                        id: '4',\n                        initials: 'RK',\n                        name: 'Riley Kim',\n                        title: 'Senior Product Designer',\n                        location: 'New York, NY',\n                        tenure: '3.5y',\n                        experience: '7y',\n                        skills: ['Product Design', 'Design Systems', 'Accessibility'],\n                        avatarColor: '#E74C3C',\n                        profileImage: null\n                    },\n                    {\n                        id: '5',\n                        initials: 'TB',\n                        name: 'Taylor Brooks',\n                        title: 'Senior UX Designer',\n                        location: 'Remote',\n                        tenure: '2.3y',\n                        experience: '5.5y',\n                        skills: ['UX Design', 'Information Architecture', 'Wireframing'],\n                        avatarColor: '#F39C12',\n                        profileImage: null\n                    },\n                    {\n                        id: '6',\n                        initials: 'MC',\n                        name: 'Morgan Chen',\n                        title: 'UI/UX Designer',\n                        location: 'Los Angeles, CA',\n                        tenure: '1.8y',\n                        experience: '4y',\n                        skills: ['Visual Design', 'Branding', 'Illustration', 'Animation'],\n                        avatarColor: '#F1C40F',\n                        profileImage: null\n                    },\n                    {\n                        id: '7',\n                        initials: 'JD',\n                        name: 'Jordan Davis',\n                        title: 'Product Manager',\n                        location: 'Boston, MA',\n                        tenure: '4.2y',\n                        experience: '9y',\n                        skills: ['Product Strategy', 'Roadmapping', 'Stakeholder Management'],\n                        avatarColor: '#2ECC71',\n                        profileImage: null\n                    },\n                    {\n                        id: '8',\n                        initials: 'AS',\n                        name: 'Avery Smith',\n                        title: 'Design Researcher',\n                        location: 'Chicago, IL',\n                        tenure: '0.9y',\n                        experience: '2y',\n                        skills: ['Qualitative Research', 'Ethnography', 'Workshop Facilitation'],\n                        avatarColor: '#E67E22',\n                        profileImage: null\n                    },\n                    {\n                        id: '9',\n                        initials: 'CM',\n                        name: 'Casey Martinez',\n                        title: 'Interaction Designer',\n                        location: 'Denver, CO',\n                        tenure: '2.7y',\n                        experience: '6y',\n                        skills: ['Interaction Design', 'Motion Design', 'Micro-interactions', 'Figma'],\n                        avatarColor: '#16A085',\n                        profileImage: null\n                    },\n                    {\n                        id: '10',\n                        initials: 'PS',\n                        name: 'Peyton Sullivan',\n                        title: 'Content Designer',\n                        location: 'Portland, OR',\n                        tenure: '1.3y',\n                        experience: '3.5y',\n                        skills: ['UX Writing', 'Content Strategy', 'Voice & Tone'],\n                        avatarColor: '#8E44AD',\n                        profileImage: null\n                    },\n                    {\n                        id: '11',\n                        initials: 'DR',\n                        name: 'Dakota Reed',\n                        title: 'Design Engineer',\n                        location: 'San Diego, CA',\n                        tenure: '3.1y',\n                        experience: '8y',\n                        skills: ['Front-end Development', 'React', 'CSS', 'Prototyping'],\n                        avatarColor: '#D35400',\n                        profileImage: null\n                    },\n                    {\n                        id: '12',\n                        initials: 'EW',\n                        name: 'Emerson Wong',\n                        title: 'UX Strategist',\n                        location: 'Miami, FL',\n                        tenure: '4.5y',\n                        experience: '10y',\n                        skills: ['UX Strategy', 'Service Design', 'Business Analysis', 'Workshops'],\n                        avatarColor: '#27AE60',\n                        profileImage: null\n                    }\n                ]\n            });\n        });\n    </script>\n</body>\n</html>"
        }
      }
    ]
  }
}