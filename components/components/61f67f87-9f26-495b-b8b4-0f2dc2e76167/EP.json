{
  "version": "0.2.10",
  "item": {
    "name": "Gallery vendors List",
    "id": "61f67f87-9f26-495b-b8b4-0f2dc2e76167",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "750e8186-3b4d-4305-813d-9c8aa4cf7960",
        "name": "Version 3",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":480,\"height\":600,\"minWidth\":320,\"minHeight\":400}'>\n    <title>Vendors - Inside a Gallery</title>\n\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n    vendors: Array<{\n        id: number;\n        initials: string;\n        name: string;\n        type: string;\n        galleryCount: number;\n        color: string;\n        link?: string;\n        handle?: string;\n    }>;\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n    'copy_credits': { credits: string; count: number };\n    'navigate_back': void;\n    'select_vendor': { id: number; link: string };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n    action: K,\n    payload: MyopCtaPayloads[K]\n): void;\n    </script>\n\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body, html {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            background: #f0f0f0;\n            /* Font stack attempting to match TT Norms Pro feel */\n            font-family: 'TT Norms Pro', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\n            -webkit-font-smoothing: antialiased;\n        }\n\n        .container {\n            background: white;\n            position: relative;\n            width: 100%;\n            height: 100%;\n            overflow-y: auto;\n            max-width: 480px;\n            margin: 0 auto;\n            box-shadow: 0 0 20px rgba(0,0,0,0.1);\n        }\n\n        /* --- Header Elements (Top ~70px) --- */\n\n        .back-arrow-container {\n            position: absolute;\n            height: 16.364px;\n            left: 24px;\n            top: 71px;\n            width: 7.863px;\n            cursor: pointer;\n            z-index: 100;\n        }\n\n        .back-arrow-svg {\n            display: block;\n            width: 100%;\n            height: 100%;\n        }\n\n        .copy-credits-container {\n            position: absolute;\n            top: 70px;\n            right: 24px; /* Aligned to the right */\n            display: flex;\n            align-items: center;\n            cursor: pointer;\n            z-index: 100;\n        }\n        \n        .copy-icon {\n            width: 21px;\n            height: 21px;\n            margin-right: 12px; /* Space between icon and text */\n        }\n\n        .copy-text {\n            font-size: 16px;\n            color: #222;\n            white-space: nowrap;\n        }\n\n        /* --- Page Title (Top ~142px) --- */\n\n        .page-title {\n            position: absolute;\n            left: 23px;\n            top: 142px;\n            transform: translateY(-50%);\n            font-size: 26px;\n            font-weight: 500;\n            color: #222;\n            line-height: 1.23;\n        }\n\n        /* --- Dynamic Vendor List --- */\n\n        #vendor-list-container {\n            /* List starts at 214px based on \"Vendor 1\" top position */\n            margin-top: 214px; \n            width: 100%;\n            padding-bottom: 40px;\n        }\n\n        .vendor-item-wrapper {\n            position: relative;\n            cursor: pointer;\n        }\n\n        .vendor-item {\n            display: flex;\n            flex-direction: row;\n            /* CHANGED: Align items to center (middle) instead of flex-start (top) */\n            align-items: center; \n            padding: 0 24px; /* 24px left/right padding */\n            width: 100%;\n            /* Calculated height based on divider position (310px) - start (214px) = 96px */\n            min-height: 96px; \n        }\n\n        /* Avatar */\n        .vendor-avatar-wrapper {\n            position: relative;\n            width: 52px;\n            height: 52px;\n            flex-shrink: 0;\n            margin-right: 20px; /* 96px (text left) - 24px (pad) - 52px (avatar) = 20px gap */\n        }\n\n        .vendor-circle {\n            display: block;\n            width: 100%;\n            height: 100%;\n        }\n\n        .vendor-initials {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            font-weight: 500;\n            font-size: 21px;\n            color: white;\n            letter-spacing: 0.5px;\n            text-transform: uppercase;\n        }\n\n        /* Info Text */\n        .vendor-info {\n            display: flex;\n            flex-direction: column;\n            justify-content: center; /* Ensure internal text block is centered if height varies */\n            padding-top: 0px; \n            flex-grow: 1;\n            padding-right: 20px; /* Space for chevron */\n        }\n\n        .vendor-name {\n            font-weight: 700; /* Medium/Bold in design */\n            font-size: 16px;\n            color: #222;\n            line-height: 1.25;\n            margin-bottom: 2px; /* Small visual gap */\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n        }\n\n        .vendor-role {\n            font-weight: 400;\n            font-size: 16px;\n            color: #222;\n            line-height: 1.25;\n            margin-bottom: 2px;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n        }\n\n        .vendor-galleries {\n            font-weight: 400;\n            font-size: 16px;\n            color: #222;\n            line-height: 1.25;\n        }\n\n        /* Chevron */\n        .vendor-chevron {\n            position: absolute;\n            right: 24px; \n            /* CHANGED: Centered vertically */\n            top: 50%; \n            transform: translateY(-50%);\n            width: 6px;\n            height: 12px;\n            display: flex;\n            align-items: center;\n        }\n\n        /* Divider */\n        .vendor-divider {\n            height: 1px;\n            background-color: #D5D5D5;\n            margin-left: 24px;\n            margin-right: 24px; /* Assuming full width minus padding based on width=342px */\n            margin-top: 16px;\n            margin-bottom: 16px;\n            width: auto;\n        }\n        \n        /* Hide divider for last item if desired, but design shows dividers */\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <!-- Back Arrow -->\n        <div class=\"back-arrow-container\" onclick=\"window.myop_cta_handler('navigate_back', {})\">\n            <svg class=\"back-arrow-svg\" fill=\"none\" preserveAspectRatio=\"none\" viewBox=\"0 0 10 19\">\n                <path d=\"M8.66944 1L1.13949 8.83536C0.953503 9.02889 0.953503 9.33475 1.13949 9.52828L8.66944 17.3636\" stroke=\"#222222\" stroke-linecap=\"round\" stroke-width=\"2\" />\n            </svg>\n        </div>\n\n        <!-- Copy Credits Button -->\n        <div class=\"copy-credits-container\" onclick=\"handleCopyCredits()\">\n            <div class=\"copy-icon\">\n                <!-- Custom Copy Icon imitating the group from design -->\n                <svg viewBox=\"0 0 21 21\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <rect x=\"7\" y=\"7\" width=\"10\" height=\"10\" rx=\"2\" stroke=\"black\" stroke-width=\"1.5\"/>\n                    <path d=\"M14 4H6C4.89543 4 4 4.89543 4 6V14\" stroke=\"black\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            <span class=\"copy-text\">Copy credits</span>\n        </div>\n\n        <!-- Title -->\n        <div class=\"page-title\">\n            Vendors\n        </div>\n\n        <!-- Dynamic List Container -->\n        <div id=\"vendor-list-container\">\n            <!-- Items will be injected here by JS -->\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        // Private scope - all implementation details\n        let currentState = null;\n\n        /**\n         * Handle Copy Credits\n         * 1. Constructs credits string\n         * 2. Calls CTA handler\n         * 3. Attempts to copy to clipboard\n         */\n        function handleCopyCredits() {\n            if (!currentState || !currentState.vendors || !currentState.vendors.length) return;\n\n            // Generate credit text\n            const creditsText = currentState.vendors.map(v => {\n                // Format for social media: \"Vendor Name @handle\"\n                if (v.handle) {\n                    return `${v.name} @${v.handle}`;\n                }\n                // Fallback to previous format if no handle\n                return v.link\n                    ? `${v.name} - ${v.link}`\n                    : `${v.name} - ${v.type}`;\n            }).join('\\n');\n\n            // 1. Report Action\n            window.myop_cta_handler('copy_credits', {\n                credits: creditsText,\n                count: currentState.vendors.length\n            });\n\n            // 2. Attempt Clipboard Write (May fail in some iframe contexts without permission)\n            try {\n                navigator.clipboard.writeText(creditsText).then(() => {\n                    console.log('Credits copied to clipboard');\n                }).catch(err => {\n                    console.warn('Clipboard write failed (likely iframe restriction):', err);\n                });\n            } catch (e) {\n                console.warn('Clipboard API not available');\n            }\n        }\n\n        /**\n         * Render the vendor list\n         */\n        function render(data) {\n            const container = document.getElementById('vendor-list-container');\n\n            if (!data || !data.vendors) {\n                console.error(\"render: Invalid data object\");\n                container.innerHTML = '';\n                return;\n            }\n\n            const vendorsData = data.vendors;\n\n            // Build the HTML string\n            const htmlContent = vendorsData.map((vendor, index) => {\n                const galleryText = vendor.galleryCount === 1 ? '1 gallery' : `${vendor.galleryCount} galleries`;\n                const safeId = vendor.id;\n                const safeLink = vendor.link || '';\n\n                return `\n                    <div class=\"vendor-item-wrapper\"\n                         onclick=\"window.myop_cta_handler('select_vendor', { id: ${safeId}, link: '${safeLink}' })\">\n                        <div class=\"vendor-item\">\n                            <div class=\"vendor-avatar-wrapper\">\n                                <svg class=\"vendor-circle\" fill=\"none\" preserveAspectRatio=\"none\" viewBox=\"0 0 52 52\">\n                                    <circle cx=\"26\" cy=\"26\" fill=\"${vendor.color}\" r=\"26\" />\n                                </svg>\n                                <span class=\"vendor-initials\">${vendor.initials}</span>\n                            </div>\n                            <div class=\"vendor-info\">\n                                <p class=\"vendor-name\">${vendor.name}</p>\n                                <p class=\"vendor-role\">${vendor.type}</p>\n                                <p class=\"vendor-galleries\">${galleryText}</p>\n                            </div>\n                            <div class=\"vendor-chevron\">\n                                <svg width=\"8\" height=\"14\" viewBox=\"0 0 8 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                    <path d=\"M1 13L7 7L1 1\" stroke=\"#222222\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                </svg>\n                            </div>\n                        </div>\n                        <div class=\"vendor-divider\"></div>\n                    </div>\n                `;\n            }).join('');\n\n            container.innerHTML = htmlContent;\n        }\n\n        // Make handleCopyCredits available globally for onclick handlers\n        window.handleCopyCredits = handleCopyCredits;\n\n        // Public API exposed to window\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState; // Getter mode\n            currentState = data;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            console.log(`[CTA Handler] Action: ${action_id}`, payload);\n            // Will be overridden by host application\n        };\n    })();\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            vendors: [\n                {\n                    id: 101,\n                    initials: 'VN',\n                    name: 'Kim Floral (You)',\n                    type: 'Florist',\n                    galleryCount: 12,\n                    color: '#A46D3A',\n                    link: 'profile-kim.html',\n                    handle: 'kimfloral_design'\n                },\n                {\n                    id: 102,\n                    initials: 'PT',\n                    name: 'Presley Tillman Photography',\n                    type: 'Photographer',\n                    galleryCount: 2,\n                    color: '#5A5E8A',\n                    link: 'profile-presley.html',\n                    handle: 'presleytillmanphoto'\n                },\n                {\n                    id: 103,\n                    initials: 'DA',\n                    name: 'Dominique Adam Cakes',\n                    type: 'Cake/Bakery',\n                    galleryCount: 2,\n                    color: '#AB9B78',\n                    link: 'profile-dominique.html',\n                    handle: 'domcakes'\n                },\n                {\n                    id: 104,\n                    initials: 'VN',\n                    name: 'Vivian Ng',\n                    type: 'Hair Stylist, Makeup Artist',\n                    galleryCount: 1,\n                    color: '#749BA7',\n                    link: 'profile-vivian.html',\n                    handle: 'vivianng_mua'\n                }\n            ]\n        });\n    </script>\n</body>\n</html>"
        }
      }
    ]
  }
}