    "consume_variant": [
      {
        "name": "Version 4",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Content configuration for the welcome popup\n     */\n    interface ContentConfig {\n      title?: string;\n      subtitleTemplate?: string; // e.g., \"Enjoy full access to Pic-Time 2.0 features for the next {days} days.\"\n      trialDays?: number;\n      featuresLeft?: string[];\n      featuresRight?: string[];\n      ctaText?: string;\n      buttonLabel?: string;\n      previewImage?: string;\n    }\n\n    /**\n     * Font configuration item\n     */\n    interface FontItem {\n      id: string;\n      family: string;\n      style?: string;\n      weight?: number;\n      url: string;\n    }\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n      lang: string;\n      fonts?: FontItem[];\n      content?: ContentConfig;\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n      'size-requested': {\n        width?: number | null;\n        height?: number | null;\n        minWidth?: number | null;\n        maxWidth?: number | null;\n        minHeight?: number | null;\n        maxHeight?: number | null;\n        required?: boolean;\n      };\n      'close-popup': void;\n      'upgrade-clicked': void;\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n      action: K,\n      payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <style>\n        :root {\n            --font_main: 'TT Norms Pro', sans-serif;\n            --font_main_style: normal;\n            --font_main_weight: 400;\n            --dark: #232323;\n            --white: #ffffff;\n            --preview-bg: #f1eee8;\n        }\n\n        * {\n            box-sizing: border-box;\n        }\n\n        html,\n        body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            background-color: var(--white);\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n        }\n\n        .welcome-popup {\n            display: flex;\n            width: 100%;\n            height: 100%;\n            flex-direction: row;\n        }\n\n        /* Left Content Section - 55% of width */\n        .content-section {\n            flex: 0 0 55%;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            padding: 5% 4% 5% 5%;\n            gap: clamp(20px, 4vh, 35px);\n            min-width: 0;\n            overflow-y: auto;\n        }\n\n        .header-section {\n            display: flex;\n            flex-direction: column;\n            gap: clamp(12px, 2vh, 18px);\n        }\n\n        .main-title {\n            font-size: clamp(20px, 3.5vw, 28px);\n            font-weight: 400;\n            color: var(--dark);\n            margin: 0;\n            line-height: 1.2;\n        }\n\n        .subtitle {\n            font-size: clamp(12px, 1.8vw, 14px);\n            font-weight: 400;\n            color: var(--dark);\n            margin: 0;\n            line-height: 1.4;\n        }\n\n        .subtitle strong {\n            font-weight: 500;\n        }\n\n        /* Features Section */\n        .features-section {\n            display: flex;\n            gap: clamp(20px, 5vw, 61px);\n            flex-wrap: wrap;\n        }\n\n        .features-column {\n            display: flex;\n            flex-direction: column;\n            gap: clamp(6px, 1vh, 10px);\n            flex: 1 1 auto;\n            min-width: 120px;\n        }\n\n        .feature-item {\n            font-size: clamp(9px, 1.3vw, 11px);\n            font-weight: 400;\n            color: var(--dark);\n            line-height: 1.8;\n            margin: 0;\n            padding-left: 15px;\n            position: relative;\n        }\n\n        .feature-item::before {\n            content: '\\2022';\n            position: absolute;\n            left: 0;\n            color: var(--dark);\n        }\n\n        /* CTA Section */\n        .cta-section {\n            display: flex;\n            align-items: center;\n            gap: clamp(12px, 2vw, 20px);\n            flex-wrap: wrap;\n        }\n\n        .cta-text {\n            font-size: clamp(12px, 1.8vw, 14px);\n            font-weight: 500;\n            color: var(--dark);\n            line-height: 1.3;\n            margin: 0;\n        }\n\n        .upgrade-button {\n            background-color: var(--dark);\n            color: var(--white);\n            border: none;\n            border-radius: 2px;\n            padding: clamp(9px, 1.2vh, 11px) clamp(20px, 3vw, 32px) clamp(10px, 1.3vh, 12px);\n            font-family: var(--font_main);\n            font-size: clamp(9px, 1.2vw, 10px);\n            font-weight: 500;\n            letter-spacing: 0.4px;\n            text-transform: uppercase;\n            cursor: pointer;\n            transition: opacity 0.2s;\n            white-space: nowrap;\n            flex-shrink: 0;\n        }\n\n        .upgrade-button:hover {\n            opacity: 0.85;\n        }\n\n        /* Right Preview Section - 45% of width */\n        .preview-section {\n            flex: 0 0 45%;\n            height: 100%;\n            background-color: var(--preview-bg);\n            overflow: hidden;\n        }\n\n        .preview-image {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            object-position: top left;\n        }\n\n        /* Tablet - Medium screens */\n        @media (max-width: 768px) {\n            .welcome-popup {\n                flex-direction: column;\n            }\n\n            .content-section {\n                flex: 0 0 auto;\n                padding: 6% 5%;\n                gap: 20px;\n                order: 2;\n            }\n\n            .preview-section {\n                flex: 0 0 40%;\n                min-height: 150px;\n                order: 1;\n            }\n\n            .main-title {\n                font-size: clamp(18px, 5vw, 24px);\n            }\n\n            .subtitle {\n                font-size: clamp(12px, 3vw, 14px);\n            }\n\n            .features-section {\n                gap: 30px;\n            }\n\n            .features-column {\n                min-width: 100px;\n            }\n\n            .feature-item {\n                font-size: clamp(9px, 2.5vw, 11px);\n            }\n\n            .cta-section {\n                flex-direction: column;\n                align-items: flex-start;\n                gap: 15px;\n            }\n\n            .cta-text {\n                font-size: clamp(12px, 3vw, 14px);\n            }\n        }\n\n        /* Mobile - Small screens */\n        @media (max-width: 480px) {\n            .content-section {\n                padding: 5% 4%;\n                gap: 16px;\n            }\n\n            .header-section {\n                gap: 10px;\n            }\n\n            .main-title {\n                font-size: 18px;\n            }\n\n            .subtitle {\n                font-size: 12px;\n            }\n\n            .features-section {\n                flex-direction: column;\n                gap: 12px;\n            }\n\n            .features-column {\n                gap: 6px;\n            }\n\n            .feature-item {\n                font-size: 10px;\n                line-height: 1.6;\n            }\n\n            .cta-text {\n                font-size: 12px;\n            }\n\n            .upgrade-button {\n                width: 100%;\n                padding: 12px 20px;\n                font-size: 10px;\n            }\n\n            .preview-section {\n                flex: 0 0 35%;\n                min-height: 120px;\n            }\n        }\n\n        /* Large screens */\n        @media (min-width: 1200px) {\n            .content-section {\n                padding: 5% 4% 5% 6%;\n            }\n\n            .main-title {\n                font-size: 32px;\n            }\n\n            .subtitle {\n                font-size: 15px;\n            }\n\n            .feature-item {\n                font-size: 12px;\n            }\n\n            .cta-text {\n                font-size: 15px;\n            }\n\n            .upgrade-button {\n                font-size: 11px;\n                padding: 12px 36px 13px;\n            }\n        }\n    </style>\n</head>\n\n<body>\n    <div id=\"app-root\">\n        <div class=\"welcome-popup\" id=\"welcome-popup\">\n            <!-- Content will be rendered by JavaScript -->\n        </div>\n    </div>\n\n    <script>\n        (function() {\n        let currentState = null;\n\n        // Default content values\n        const defaultContent = {\n            title: 'Welcome to Pic-Time 2.0',\n            subtitleTemplate: 'Enjoy full access to Pic-Time 2.0 features for the next <strong>{days} days</strong>.',\n            trialDays: 21,\n            featuresLeft: [\n                'Cover color selection',\n                'Scene header color selection',\n                'Button styles',\n                'Font and icon weights',\n                'Gallery templates',\n                'Cover text styles'\n            ],\n            featuresRight: [\n                'Gallery themes',\n                'Gallery colors',\n                'Font sets',\n                'Cover and layout styles',\n                'Designed scene headers'\n            ],\n            ctaText: 'Pay now to keep your features open',\n            buttonLabel: 'UPGRADE NOW',\n            previewImage: './uploads/image_popup.jpg'\n        };\n\n        function deepMerge(target, source) {\n            const result = { ...target };\n            for (const key in source) {\n                if (source[key] && typeof source[key] === 'object' && !Array.isArray(source[key])) {\n                    result[key] = deepMerge(target[key] || {}, source[key]);\n                } else if (source[key] !== undefined) {\n                    result[key] = source[key];\n                }\n            }\n            return result;\n        }\n\n        function render(inputData) {\n            const lang = inputData.lang || 'en';\n            const content = deepMerge(defaultContent, inputData.content || {});\n\n            currentState = { lang, content, fonts: inputData.fonts };\n\n            // Apply fonts\n            if (inputData.fonts && Array.isArray(inputData.fonts)) {\n                inputData.fonts.forEach(function(font) {\n                    if (font.url) {\n                        const existingLink = document.querySelector('link[href=\"' + font.url + '\"]');\n                        if (!existingLink) {\n                            const link = document.createElement('link');\n                            link.rel = 'stylesheet';\n                            link.href = font.url;\n                            document.head.appendChild(link);\n                        }\n                    }\n                    const varPrefix = '--font_' + font.id;\n                    document.documentElement.style.setProperty(varPrefix, font.family);\n                    document.documentElement.style.setProperty(varPrefix + '_style', font.style || 'normal');\n                    document.documentElement.style.setProperty(varPrefix + '_weight', font.weight !== undefined ? font.weight : 400);\n                });\n            }\n\n            // Build subtitle with days\n            const subtitle = content.subtitleTemplate.replace('{days}', content.trialDays);\n\n            // Build features HTML\n            const featuresLeftHtml = content.featuresLeft.map(function(feature) {\n                return '<p class=\"feature-item\">' + feature + '</p>';\n            }).join('');\n\n            const featuresRightHtml = content.featuresRight.map(function(feature) {\n                return '<p class=\"feature-item\">' + feature + '</p>';\n            }).join('');\n\n            // Render the component\n            const container = document.getElementById('welcome-popup');\n            container.innerHTML =\n                '<div class=\"content-section\">' +\n                    '<div class=\"header-section\">' +\n                        '<h1 class=\"main-title\">' + content.title + '</h1>' +\n                        '<p class=\"subtitle\">' + subtitle + '</p>' +\n                    '</div>' +\n                    '<div class=\"features-section\">' +\n                        '<div class=\"features-column\">' + featuresLeftHtml + '</div>' +\n                        '<div class=\"features-column\">' + featuresRightHtml + '</div>' +\n                    '</div>' +\n                    '<div class=\"cta-section\">' +\n                        '<p class=\"cta-text\">' + content.ctaText + '</p>' +\n                        '<button class=\"upgrade-button\">' + content.buttonLabel + '</button>' +\n                    '</div>' +\n                '</div>' +\n                '<div class=\"preview-section\">' +\n                    '<img class=\"preview-image\" src=\"' + content.previewImage + '\" alt=\"Preview\">' +\n                '</div>';\n\n            // Attach button listener\n            const upgradeButton = container.querySelector('.upgrade-button');\n            if (upgradeButton) {\n                upgradeButton.addEventListener('click', function() {\n                    window.myop_cta_handler('upgrade-clicked', undefined);\n                    window.myop_cta_handler('close-popup', undefined);\n                });\n            }\n        }\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            console.log('CTA:', action_id, payload);\n        };\n    })();\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            lang: 'en',\n            fonts: [\n                {\n                    id: 'main',\n                    family: \"'TT Norms Pro', sans-serif\",\n                    style: 'normal',\n                    weight: 400,\n                    url: ''\n                }\n            ],\n            content: {\n                title: 'Welcome to Pic-Time 2.0',\n                subtitleTemplate: 'Enjoy full access to Pic-Time 2.0 features for the next <strong>{days} days</strong>.',\n                trialDays: 21,\n                featuresLeft: [\n                    'Cover color selection',\n                    'Scene header color selection',\n                    'Button styles',\n                    'Font and icon weights',\n                    'Gallery templates',\n                    'Cover text styles'\n                ],\n                featuresRight: [\n                    'Gallery themes',\n                    'Gallery colors',\n                    'Font sets',\n                    'Cover and layout styles',\n                    'Designed scene headers'\n                ],\n                ctaText: 'Pay now to keep your features open',\n                buttonLabel: 'UPGRADE NOW',\n                previewImage: './uploads/image_popup.jpg'\n            }\n        });\n    </script>\n</body>\n\n</html>\n"
        },
        "id": "39546631-1b9d-4a72-9020-fb06a93940a0"
      }
    ]
