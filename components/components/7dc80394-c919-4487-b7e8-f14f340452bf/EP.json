    "consume_variant": [
      {
        "id": "ced25ca8-5311-4f44-8ee5-b695c06d3227",
        "name": "Version 4",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"utf-8\" />\n    <title>Activities & recommendations Widget</title>\n    <meta name=\"viewport\" content=\"content=\" width=device-width, initial-scale=1.0\" />\n    <!-- External CSS link removed as per requirement -->\n    <style>\n        /* All CSS is now self-contained */\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            /* Using a system font stack for consistency since external fonts are disallowed */\n            font-family: ui-sans-serif, system-ui, sans-serif, \"Arial\", sans-serif;\n        }\n\n        body {\n            background-color: transparent;\n            /* Changed to transparent for embedding */\n            display: flex;\n            flex-direction: column;\n            justify-content: flex-start;\n            align-items: stretch;\n            min-height: auto;\n            padding: 0;\n            margin: 0;\n            /* Font stack applied here as well for maximum coverage */\n            font-family: ui-sans-serif, system-ui, sans-serif, \"Arial\", sans-serif;\n        }\n\n        /* Utility Classes (all custom classes defined here) */\n        .bg-transparent {\n            background-color: transparent;\n        }\n\n        .flex {\n            display: flex;\n        }\n\n        .flex-row {\n            flex-direction: row;\n        }\n\n        .flex-col {\n            flex-direction: column;\n        }\n\n        .justify-center {\n            justify-content: center;\n        }\n\n        .justify-between {\n            justify-content: space-between;\n        }\n\n        .justify-start {\n            justify-content: flex-start;\n        }\n\n        .justify-end {\n            justify-content: flex-end;\n        }\n\n        .items-center {\n            align-items: center;\n        }\n\n        .w-full {\n            width: 100%;\n        }\n\n        .h-full {\n            height: 100%;\n        }\n\n        .overflow-hidden {\n            overflow: hidden;\n        }\n\n        .relative {\n            position: relative;\n        }\n\n        .absolute {\n            position: absolute;\n        }\n\n        .rounded-\\[20px\\] {\n            border-radius: 20px;\n        }\n\n        .shadow-card {\n            box-shadow: 0px 0px 15px rgba(0, 0, 0, 0.07);\n        }\n\n        .p-0 {\n            padding: 0;\n        }\n\n        .p-1 {\n            padding: 0.25rem;\n        }\n\n        .p-5 {\n            padding: 1.25rem;\n        }\n\n        .px-6 {\n            padding-left: 1.5rem;\n            padding-right: 1.5rem;\n        }\n\n        .px-8 {\n            padding-left: 2rem;\n            padding-right: 2rem;\n        }\n\n        .pt-\\[15px\\] {\n            padding-top: 15px;\n        }\n\n        .pt-\\[19px\\] {\n            padding-top: 19px;\n        }\n\n        .pb-\\[19px\\] {\n            padding-bottom: 19px;\n        }\n\n        .pr-4 {\n            padding-right: 1rem;\n        }\n\n        .mt-1 {\n            margin-top: 0.25rem;\n        }\n\n        .mt-3 {\n            margin-top: 0.75rem;\n        }\n\n        .mr-3 {\n            margin-right: 0.75rem;\n        }\n\n        .mt-\\[22px\\] {\n            margin-top: 22px;\n        }\n\n        .mx-6 {\n            margin-left: 1.5rem;\n            margin-right: 1.5rem;\n        }\n\n        .my-auto {\n            margin-top: auto;\n            margin-bottom: auto;\n        }\n\n        .gap-6 {\n            gap: 1.5rem;\n        }\n\n        .text-sm {\n            font-size: 0.875rem;\n        }\n\n        .text-xs {\n            font-size: 0.75rem;\n        }\n\n        .text-base {\n            font-size: 16px;\n        }\n\n        /* FONT WEIGHTS (500 is the target 'medium' weight) */\n        .font-medium {\n            font-weight: 500;\n        }\n\n        .font-normal {\n            font-weight: 400;\n        }\n\n        .text-\\[\\#8c8c8c\\] {\n            color: #8c8c8c;\n        }\n\n        .underline {\n            text-decoration: underline;\n        }\n\n        .h-auto {\n            height: auto;\n        }\n\n\n\n        .w-\\[81px\\] {\n            width: 81px;\n        }\n\n        .w-3 {\n            width: 0.75rem;\n        }\n\n        .h-3 {\n            height: 0.75rem;\n        }\n\n        .flex-1 {\n            flex: 1 1 0%;\n        }\n\n        .flex-shrink-0 {\n            flex-shrink: 0;\n        }\n\n        .card {\n            background-color: white;\n            border: 1px solid #e5e7eb;\n            height: auto;\n            overflow: visible;\n        }\n\n        .separator-horizontal {\n            height: 1px;\n            background-color: #e5e7eb;\n        }\n\n        .btn {\n            background: none;\n            border: none;\n            cursor: pointer;\n            font-size: 1rem;\n            font-weight: 500;\n        }\n\n        .btn-link {\n            color: #111827;\n            text-decoration: underline;\n        }\n\n        .activity-item {\n            transition: transform 0.3s ease-out, opacity 0.3s ease-out;\n        }\n\n        .goto-gallery-trigger {\n            cursor: pointer;\n        }\n\n        .activity-description {\n            color: #000;\n            line-height: 120%;\n        }\n\n        #activity-feed {\n            overflow-y: auto;\n            max-height: 400px;\n        }\n\n        /* Custom Scrollbar */\n        #activity-feed::-webkit-scrollbar {\n            width: 8px;\n        }\n\n        #activity-feed::-webkit-scrollbar-track {\n            background: #f1f1f1;\n            border-radius: 10px;\n        }\n\n        #activity-feed::-webkit-scrollbar-thumb {\n            background: #ccc;\n            border-radius: 10px;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"bg-transparent flex flex-row w-full\">\n        <div class=\"relative w-full\">\n            <div id=\"main-widget-card\" class=\"card rounded-[20px] shadow-card w-full\">\n                <div class=\"p-0\">\n                    <div class=\"flex justify-between items-center px-6 pt-[15px]\">\n                        <h2 id=\"dashboard-title\" class=\"font-medium text-base\">Activities & recommendations</h2>\n                        <button id=\"menu-button\" class=\"btn p-1\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                                <circle cx=\"12\" cy=\"12\" r=\"1\"></circle>\n                                <circle cx=\"12\" cy=\"5\" r=\"1\"></circle>\n                                <circle cx=\"12\" cy=\"19\" r=\"1\"></circle>\n                            </svg>\n                        </button>\n                    </div>\n\n                    <div class=\"separator-horizontal mt-3\" style=\"margin-left: 1.5rem; margin-right: 1.5rem;\"></div>\n\n                    <div id=\"activity-feed\" class=\"mt-[22px] px-6 pb-2\"> <!-- Tighter bottom padding (pb-2) -->\n                        <!-- Activity items will be dynamically inserted here -->\n                    </div>\n                    <div id=\"toggle-view-container\" class=\"text-center pb-2\"> <!-- Tighter bottom padding (pb-2) -->\n                        <!-- Toggle buttons will be dynamically inserted here -->\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // --- GLOBAL STATE ---\n        let activities = [];\n        let showMenu = true;\n        let isExpanded = false;\n        const ACTIVITY_ITEM_HEIGHT_PX = 100; // Estimated height for one activity row\n\n        let lang = {\n            \"dashboardActivitiesWidgetTitle\": \"Activities & recommendations\",\n            \"dashboardActivitiesNoActivity\": \"You're on track !\",\n            \"dashboardActivitiesTimeElapsed\": \"{time} ago\",\n            \"dashboardActivitiesShowAll\": \"Show all activity >\",\n            \"dashboardActivitiesShowLess\": \"Show less <\"\n        };\n\n        // --- DOM ELEMENTS ---\n        let feedContainer = null;\n        let toggleViewContainer = null;\n        let dashboardTitle = null;\n        let menuButton = null;\n        let mainCard = null;\n\n        function initDOMElements() {\n            feedContainer = document.getElementById('activity-feed');\n            toggleViewContainer = document.getElementById('toggle-view-container');\n            dashboardTitle = document.getElementById('dashboard-title');\n            menuButton = document.getElementById('menu-button');\n            mainCard = document.getElementById('main-widget-card');\n        }\n\n        // --- PUBLIC CTA HANDLER ---\n\n        /**\n         * Public method to handle all actions (CTAs) reported back to the main application.\n         * @param {string} action_id - Identifier for the action (e.g., 'GoToGallery', 'remove_item').\n         * @param {object} payload - Data associated with the action.\n         */\n        window.myop_cta_handler = function(action_id, payload) {\n            // Log the CTA action to the console (required for reporting)\n            const update = {\n                timestamp: new Date().toISOString(),\n                action_id: action_id,\n                payload: payload\n            };\n            console.log(\"CTA HANDLER CALL:\", JSON.stringify(update, null, 2));\n\n            // Internal logic for dismissal (since the widget must update itself)\n            if (action_id === 'remove_item' && payload && payload.activityId) {\n                handleDismissalLocally(payload.activityId);\n            }\n        };\n\n        // --- INTERNAL LOGIC FUNCTIONS ---\n\n        function handleDismissalLocally(activityId) {\n            const itemElement = document.querySelector(`.activity-item[data-id=\"${activityId}\"]`);\n            if (itemElement) {\n                // Animate removal\n                itemElement.style.transform = 'scale(0.95)';\n                itemElement.style.opacity = '0';\n                setTimeout(() => {\n                    // Update state and re-render\n                    activities = activities.filter(a => a.id != activityId);\n                    renderScreen();\n                }, 300);\n            }\n        }\n\n        /**\n         * Calculates the time part for the \"time ago\" string.\n         * @param {string} utcTimestamp - The UTC timestamp string.\n         * @returns {string} A string like \"Just now\" or \"5 min\".\n         */\n        function formatTimePart(utcTimestamp) {\n            if (!utcTimestamp) return '';\n            const now = new Date();\n            const past = new Date(utcTimestamp);\n            const seconds = Math.floor((now - past) / 1000);\n\n            if (seconds < 60) {\n                return \"Just now\";\n            }\n\n            const minutes = Math.floor(seconds / 60);\n            if (minutes < 60) {\n                return `${minutes} min`;\n            }\n\n            const hours = Math.floor(minutes / 60);\n            if (hours < 24) {\n                return `${hours} hr`;\n            }\n\n            const days = Math.floor(hours / 24);\n            return `${days}d`;\n        }\n\n\n        /**\n         * Renders all activity items and updates language-dependent text.\n         */\n        function renderScreen() {\n            dashboardTitle.textContent = lang.dashboardActivitiesWidgetTitle || \"Activities & recommendations\";\n            menuButton.style.display = showMenu ? 'block' : 'none';\n            feedContainer.innerHTML = '';\n            toggleViewContainer.innerHTML = '';\n\n            // --- Dynamic Height and Expansion Logic ---\n            // Height is now controlled by CSS max-height: 400px with overflow-y: auto\n            feedContainer.style.height = 'auto';\n\n            // --- Render Content ---\n            if (activities.length === 0) {\n                // Empty state message\n                feedContainer.innerHTML = `<div class=\"flex justify-center items-center py-10\" style=\"text-align: right; justify-content: flex-end; padding-right: 50px;\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" style=\"margin-right: 8px;\">\n                        <path d=\"M13.439 3.39867L6.56193 10.4391L3.06144 6.93864C2.86872 6.74609 2.55219 6.74609 2.35947 6.93864C2.16675 7.13119 2.16675 7.44772 2.35947 7.64027L6.16278 11.4436C6.3555 11.6362 6.67203 11.6362 6.86475 11.4436L14.439 3.86937C14.6317 3.67682 14.6317 3.36029 14.439 3.16774C14.2463 2.97519 13.9298 2.97519 13.737 3.16774L13.439 3.39867Z\" fill=\"black\"/>\n                    </svg>\n                    <p class=\"text-[#8c8c8c]\">${lang.dashboardActivitiesNoActivity}</p>\n                </div>`;\n                return;\n            }\n\n            // Show all activities - scrolling handles overflow\n            const activitiesToShowList = activities;\n\n            activitiesToShowList.forEach((activity, index) => {\n                const activityElement = document.createElement('div');\n                activityElement.className = 'activity-item';\n                activityElement.dataset.id = activity.id;\n\n                const timeValue = formatTimePart(activity.timestamp);\n                const timeText = timeValue === \"Just now\" ? timeValue : lang.dashboardActivitiesTimeElapsed.replace('{time}', timeValue);\n\n                const actionOneButton = activity.actionOneCaption ? `<button class=\"btn btn-link font-medium text-base underline h-auto p-0 action-one-btn\" data-id=\"${activity.id}\">${activity.actionOneCaption}</button>` : '';\n                const actionTwoButton = activity.actionTwoCaption ? `<button class=\"btn btn-link font-medium text-base underline h-auto p-0 action-two-btn\" data-id=\"${activity.id}\">${activity.actionTwoCaption}</button>` : '';\n                const separator = index < activitiesToShowList.length - 1 ? '<div class=\"separator-horizontal mt-3\"></div>' : '';\n\n                activityElement.innerHTML = `\n                    <div class=\"flex h-auto items-center py-3\"> <!-- Vertical padding increased to py-3 for better spacing -->\n                        <div class=\"flex-shrink-0 mr-3\"> <!-- Tighter right margin -->\n                            <img class=\"w-[81px] h-[81px] goto-gallery-trigger rounded-[10px]\" data-id=\"${activity.id}\" alt=\"Gallery thumbnail cover\" src=\"${activity.galleryThumbnailCoverUrl}\" onerror=\"this.onerror=null;this.src='https://placehold.co/81x81/e0e0e0/333333?text=Error';\">\n                        </div>\n                        <div class=\"flex-1\">\n                            <h3 class=\"font-medium text-base goto-gallery-trigger\" data-id=\"${activity.id}\">${activity.galleryName}</h3>\n                            <p class=\"mt-1 text-base font-normal activity-description\">${activity.description}</p>\n                            <span class=\"text-[#8c8c8c] text-xs block mt-3\">${timeText}</span>\n                        </div>\n                        <div class=\"flex items-center justify-end gap-6 flex-shrink-0 ml-4\">\n                            ${actionOneButton}\n                            ${actionTwoButton}\n                            <button class=\"btn close-btn\" data-id=\"${activity.id}\">\n                                <img class=\"w-3 h-3\" alt=\"Close\" src=\"https://c.animaapp.com/mcx6xd3lwWuNBl/img/group-1000003110.png\">\n                            </button>\n                        </div>\n                    </div>\n                    ${separator}\n                `;\n                feedContainer.appendChild(activityElement);\n            });\n\n            // Toggle buttons removed - all activities shown with scrolling\n        }\n\n        /**\n         * Event handler for activity item clicks.\n         */\n        function handleFeedClick(e) {\n            const target = e.target;\n\n            const galleryTrigger = target.closest('.goto-gallery-trigger');\n            const closeButton = target.closest('.close-btn');\n            const actionOneButton = target.closest('.action-one-btn');\n            const actionTwoButton = target.closest('.action-two-btn');\n\n            if (galleryTrigger) {\n                const activityId = galleryTrigger.dataset.id;\n                // Report action to the main application\n                window.myop_cta_handler('GoToGallery', { activity_ID: activityId, action_name: 'GoToGallery' });\n                return;\n            }\n\n            if (closeButton) {\n                const activityId = closeButton.dataset.id;\n                // Report action to the main application, the handler will trigger local removal\n                window.myop_cta_handler('remove_item', { activityId });\n                return;\n            }\n\n            if (actionOneButton) {\n                const activityId = actionOneButton.dataset.id;\n                window.myop_cta_handler('action_one_click', { activityId, action_caption: actionOneButton.textContent });\n                return;\n            }\n\n            if (actionTwoButton) {\n                 const activityId = actionTwoButton.dataset.id;\n                 window.myop_cta_handler('action_two_click', { activityId, action_caption: actionTwoButton.textContent });\n                 return;\n            }\n        }\n\n        function handleToggleViewClick(e) {\n            if (e.target.id === 'show-all-btn') {\n                isExpanded = true;\n                renderScreen();\n            } else if (e.target.id === 'show-less-btn') {\n                isExpanded = false;\n                renderScreen();\n            }\n        }\n\n        // --- PUBLIC INITIALIZATION FUNCTION ---\n\n        /**\n         * Public method to initialize the entire widget interface with full configuration.\n         * @param {object} config - The full configuration object.\n         * @param {array|string} config.activities - Array of activities or URL string to fetch JSON.\n         * @param {object} config.lang - Language keys/values.\n         * @param {boolean} config.showMenu - Flag to show/hide the 3-dots menu.\n         * @param {string} config.fontFamily - Custom font name to use for the widget.\n         */\n        window.myop_init_interface = async function(config) {\n            if (typeof config !== 'object' || config === null) {\n                 console.error(\"myop_init_interface: Invalid config provided. Must be an object.\", config);\n                 return;\n            }\n\n            try {\n                // Step 1: Handle global config updates\n                if (config.fontFamily) {\n                    // Apply the configured font (e.g., 'TT Norms Pro'), relying on the host environment to load it.\n                    document.body.style.fontFamily = `'${config.fontFamily}', ui-sans-serif, system-ui, sans-serif`;\n                } else {\n                    // Ensure the robust system font stack is maintained if no custom font is provided\n                    document.body.style.fontFamily = `ui-sans-serif, system-ui, sans-serif`;\n                }\n\n                if (config.lang) {\n                    lang = { ...lang, ...config.lang };\n                }\n                if (typeof config.showMenu === 'boolean') {\n                    showMenu = config.showMenu;\n                }\n\n                // Step 2: Handle Activities Data (Array or URL string)\n                let activityData = config.activities;\n\n                if (typeof activityData === 'string') {\n                    // Fetch activities from URL\n                    const response = await fetch(activityData);\n                    if (!response.ok) {\n                        throw new Error(`HTTP error! status: ${response.status}`);\n                    }\n                    activityData = await response.json();\n                }\n\n                if (Array.isArray(activityData)) {\n                    activities = []; // Clear current list\n                    let itemsAdded = 0;\n                    activityData.forEach((item, index) => {\n                        if (item && item.id && item.galleryName && item.description) {\n                            const newActivity = {\n                                id: item.id,\n                                galleryName: item.galleryName,\n                                description: item.description,\n                                timestamp: item.timestamp || new Date().toISOString(),\n                                galleryThumbnailCoverUrl: item.galleryThumbnailCoverUrl || \"https://placehold.co/81x81/cccccc/ffffff?text=New\",\n                                closeIconUrl: item.closeIconUrl || \"https://c.animaapp.com/mcx6xd3lwWuNBl/img/group-1000003110.png\",\n                                actionOneCaption: item.actionOneCaption || null,\n                                actionTwoCaption: item.actionTwoCaption || null\n                            };\n                            activities.push(newActivity);\n                            itemsAdded++;\n                        } else {\n                            console.error(`Error: Item at index ${index} in the received activities array has an invalid structure. It must have 'id', 'galleryName', and 'description'.`, item);\n                        }\n                    });\n                } else if (activityData !== undefined) {\n                     console.error(\"Invalid 'activities' input. Must be an array or a URL string.\");\n                }\n\n                // Step 3: Render the updated screen\n                renderScreen();\n\n            } catch (error) {\n                console.error(\"An error occurred during widget initialization (myop_init_interface):\", error);\n            }\n        };\n\n        // --- MOCK DATA FOR INITIAL CALL ---\n        const MOCK_ACTIVITIES = [\n            {\n                id: 1,\n                galleryName: \"Sarah & Mike Wedding\",\n                galleryThumbnailCoverUrl: \"https://picsum.photos/seed/wedding1/81/81\",\n                description: \"Selection completed for 'Favourite photos for edit'\",\n                timestamp: new Date(Date.now() - 5 * 60 * 1000).toISOString(),\n                actionOneCaption: \"View\",\n                actionTwoCaption: null\n            },\n            {\n                id: 2,\n                galleryName: \"Johnson Family Portrait\",\n                galleryThumbnailCoverUrl: \"https://picsum.photos/seed/family1/81/81\",\n                description: \"You've got an order! Approve to move it forward\",\n                timestamp: new Date(Date.now() - 60 * 60 * 1000).toISOString(),\n                actionOneCaption: \"Approve\",\n                actionTwoCaption: \"View order\"\n            },\n            {\n                id: 3,\n                galleryName: \"Emma's Graduation\",\n                galleryThumbnailCoverUrl: \"https://picsum.photos/seed/grad1/81/81\",\n                description: \"Cindy has registered for the gallery\",\n                timestamp: new Date(Date.now() - 3 * 60 * 60 * 1000).toISOString(),\n                actionOneCaption: \"Share photos with vendor\",\n                actionTwoCaption: null\n            },\n            {\n                id: 4,\n                galleryName: \"Corporate Event 2024\",\n                galleryThumbnailCoverUrl: \"https://picsum.photos/seed/corp1/81/81\",\n                description: \"New album created - 'Keynote Highlights'\",\n                timestamp: new Date(Date.now() - 5 * 60 * 60 * 1000).toISOString(),\n                actionOneCaption: \"View album\",\n                actionTwoCaption: null\n            },\n            {\n                id: 5,\n                galleryName: \"Beach Photoshoot\",\n                galleryThumbnailCoverUrl: \"https://picsum.photos/seed/beach1/81/81\",\n                description: \"Client left a 5-star review!\",\n                timestamp: new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString(),\n                actionOneCaption: \"Read review\",\n                actionTwoCaption: \"Reply\"\n            },\n            {\n                id: 6,\n                galleryName: \"Anniversary Dinner\",\n                galleryThumbnailCoverUrl: \"https://picsum.photos/seed/dinner1/81/81\",\n                description: \"Download request pending approval\",\n                timestamp: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toISOString(),\n                actionOneCaption: \"Approve\",\n                actionTwoCaption: \"Decline\"\n            },\n            {\n                id: 7,\n                galleryName: \"Spring Collection\",\n                galleryThumbnailCoverUrl: \"https://picsum.photos/seed/spring1/81/81\",\n                description: \"Gallery link was shared 15 times today\",\n                timestamp: new Date(Date.now() - 3 * 24 * 60 * 60 * 1000).toISOString(),\n                actionOneCaption: \"View stats\",\n                actionTwoCaption: null\n            }\n        ];\n\n        // --- INITIALIZATION AND LISTENERS ---\n\n        // Initialize when DOM is ready\n        function initWidget() {\n            // Initialize DOM element references\n            initDOMElements();\n\n            // Add event listeners\n            if (feedContainer) {\n                feedContainer.addEventListener('click', handleFeedClick);\n            }\n            if (toggleViewContainer) {\n                toggleViewContainer.addEventListener('click', handleToggleViewClick);\n            }\n\n            // Initial call to the new global initialization method with mock data\n            window.myop_init_interface({\n                activities: MOCK_ACTIVITIES,\n                fontFamily: \"TT Norms Pro\", // Passed as configuration\n                showMenu: true,\n                lang: lang // Pass default language\n            });\n\n            // Auto-Refresh interval for timestamps\n            setInterval(renderScreen, 60000);\n        }\n\n        // Try multiple initialization strategies for different environments\n        if (document.readyState === 'loading') {\n            document.addEventListener('DOMContentLoaded', initWidget);\n        } else {\n            // DOM is already ready\n            initWidget();\n        }\n    </script>\n</body>\n\n</html>"
        }
      }
    ]
  }
