    "consume_variant": [
      {
        "id": "176c8574-2749-4016-a773-25e6c3622940",
        "name": "V0",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"utf-8\" />\n    <title>Activity Dashboard</title>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    \n    <!-- \n      FIX: Removed external Google Fonts dependency. \n      The widget will now use the system's default sans-serif font.\n    -->\n    \n    <style>\n        /* Original custom utility classes, font updated to system default */\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            /* FIX: Font family updated to system default sans-serif */\n            font-family: sans-serif;\n        }\n        \n        body {\n            background-color: #f3f4f6;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            padding: 1rem;\n        }\n        \n        .bg-transparent {\n            background-color: transparent;\n        }\n        \n        .flex {\n            display: flex;\n        }\n        \n        .flex-row {\n            flex-direction: row;\n        }\n        \n        .flex-col {\n            flex-direction: column;\n        }\n        \n        .justify-center {\n            justify-content: center;\n        }\n        \n        .justify-between {\n            justify-content: space-between;\n        }\n        \n        .justify-start {\n            justify-content: flex-start;\n        }\n\n        .items-center {\n            align-items: center;\n        }\n        \n        .w-full {\n            width: 100%;\n        }\n        \n        .h-full {\n            height: 100%;\n        }\n        \n        .overflow-hidden {\n            overflow: hidden;\n        }\n        \n        .relative {\n            position: relative;\n        }\n        \n        .absolute {\n            position: absolute;\n        }\n        \n        .rounded-\\[20px\\] {\n            border-radius: 20px;\n        }\n        \n        .shadow-card {\n            box-shadow: 0px 0px 15px rgba(0, 0, 0, 0.07);\n        }\n        \n        .p-0 {\n            padding: 0;\n        }\n        \n        .p-1 {\n            padding: 0.25rem;\n        }\n        \n        .p-5 {\n            padding: 1.25rem;\n        }\n        \n        .px-6 {\n            padding-left: 1.5rem;\n            padding-right: 1.5rem;\n        }\n        \n        .px-8 {\n            padding-left: 2rem;\n            padding-right: 2rem;\n        }\n        \n        .pt-\\[15px\\] {\n            padding-top: 15px;\n        }\n        \n        .pt-\\[19px\\] {\n            padding-top: 19px;\n        }\n\n        .pb-\\[19px\\] {\n            padding-bottom: 19px;\n        }\n\n        .pb-4 {\n            padding-bottom: 1rem;\n        }\n\n        .pb-6 {\n            padding-bottom: 1.5rem;\n        }\n\n        .py-3 {\n            padding-top: 0.75rem;\n            padding-bottom: 0.75rem;\n        }\n\n        .py-10 {\n            padding-top: 2.5rem;\n            padding-bottom: 2.5rem;\n        }\n        \n        .pr-4 {\n            padding-right: 1rem;\n        }\n        \n        .mt-1 {\n            margin-top: 0.25rem;\n        }\n        \n        .mt-3 {\n            margin-top: 0.75rem;\n        }\n        \n        .mt-\\[22px\\] {\n            margin-top: 22px;\n        }\n\n        .mr-4 {\n            margin-right: 1rem;\n        }\n\n        .ml-4 {\n            margin-left: 1rem;\n        }\n        \n        .mx-6 {\n            margin-left: 1.5rem;\n            margin-right: 1.5rem;\n        }\n        \n        .my-auto {\n            margin-top: auto;\n            margin-bottom: auto;\n        }\n        \n        .space-y-3 > * + * {\n            margin-top: 0.75rem;\n        }\n        \n        .gap-6 {\n            gap: 1.5rem;\n        }\n\n        .text-center {\n            text-align: center;\n        }\n        \n        .text-sm {\n            font-size: 0.875rem;\n        }\n        \n        .text-xs {\n            font-size: 0.75rem;\n        }\n        \n        .text-base {\n            font-size: 16px; /* Explicitly set to 16px */\n        }\n        \n        .font-medium {\n            font-weight: 500;\n        }\n        \n        .font-normal {\n            font-weight: 400;\n        }\n        \n        .text-\\[\\#8c8c8c\\] {\n            color: #8c8c8c;\n        }\n        \n        .underline {\n            text-decoration: underline;\n        }\n        \n        .h-auto {\n            height: auto;\n        }\n\n        .h-\\[81px\\] {\n            height: 81px;\n        }\n        \n        .w-\\[900px\\] {\n            width: 900px;\n        }\n        \n        .w-\\[81px\\] {\n            width: 81px;\n        }\n        \n        .w-3 {\n            width: 0.75rem; /* 12px */\n        }\n        \n        .h-3 {\n            height: 0.75rem; /* 12px */\n        }\n        \n        .flex-1 {\n            flex: 1 1 0%;\n        }\n\n        .flex-shrink-0 {\n            flex-shrink: 0;\n        }\n        \n        .card {\n            background-color: white;\n            border: 1px solid #e5e7eb;\n        }\n        \n        .separator-horizontal {\n            height: 1px;\n            width: 100%;\n            background-color: #e5e7eb;\n        }\n        \n        .btn {\n            background: none;\n            border: none;\n            cursor: pointer;\n            font-size: 1rem;\n            font-weight: 500;\n        }\n        \n        .btn-link {\n            color: #111827;\n            text-decoration: underline;\n        }\n        \n        .btn-link:hover {\n            opacity: 0.8;\n        }\n\n        .activity-item {\n            transition: transform 0.3s ease-out, opacity 0.3s ease-out;\n        }\n\n        .goto-gallery-trigger {\n            cursor: pointer;\n        }\n\n        .activity-description {\n            color: #000;\n            line-height: 120%;\n        }\n\n        #activity-feed {\n            overflow-y: hidden;\n        }\n\n        /* Styles for expanded view with scrollbar */\n        #activity-feed.feed-expanded {\n            max-height: 720px; /* Max height for 6 items */\n            overflow-y: auto;\n            padding-right: 1rem; /* Adjust padding to make space for scrollbar */\n        }\n\n        /* Custom Scrollbar */\n        #activity-feed.feed-expanded::-webkit-scrollbar {\n            width: 8px;\n        }\n        #activity-feed.feed-expanded::-webkit-scrollbar-track {\n            background: #f1f1f1;\n            border-radius: 10px;\n        }\n        #activity-feed.feed-expanded::-webkit-scrollbar-thumb {\n            background: #ccc;\n            border-radius: 10px;\n        }\n        #activity-feed.feed-expanded::-webkit-scrollbar-thumb:hover {\n            background: #aaa;\n        }\n\n        .rounded-\\[10px\\] {\n            border-radius: 10px;\n        }\n\n        .block {\n            display: block;\n        }\n\n        .pointer-events-none {\n            pointer-events: none;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"bg-transparent flex flex-row justify-center w-full\">\n        <div class=\"relative\">\n            <div class=\"card w-[900px] rounded-[20px] shadow-card\" style=\"margin: 10px;\">\n                <div class=\"p-0\">\n                    <div class=\"flex justify-between items-center px-6 pt-[15px]\">\n                        <h2 id=\"dashboard-title\" class=\"font-medium text-base\">Activities & recommendations</h2>\n                        <button id=\"menu-button\" class=\"btn p-1\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                                <circle cx=\"12\" cy=\"12\" r=\"1\"></circle>\n                                <circle cx=\"12\" cy=\"5\" r=\"1\"></circle>\n                                <circle cx=\"12\" cy=\"19\" r=\"1\"></circle>\n                            </svg>\n                        </button>\n                    </div>\n\n                    <div class=\"separator-horizontal mt-3 mx-6\"></div>\n\n                    <div id=\"activity-feed\" class=\"mt-[22px] px-6 pb-6\">\n                        <!-- Activity items will be dynamically inserted here -->\n                    </div>\n                    <div id=\"toggle-view-container\" class=\"text-center pb-4\"></div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n    // --- PUBLIC API METHODS ---\n\n    /**\n     * FIX: 2. Defines the public CTA handler as requested.\n     * This function receives all callbacks from the widget.\n     * It logs the action and is intended to be overridden by the host application.\n     * @param {string} action_id - The ID of the action (e.g., 'GoToGallery', 'remove_item').\n     * @param {object} payload - The data associated with the action.\n     */\n    window.myop_cta_handler = function(action_id, payload) {\n        console.log(\"myop_cta_handler:\", { action_id, payload });\n        // Host application will override this function to handle callbacks.\n    };\n\n\n    // --- WIDGET IMPLEMENTATION (IIFE) ---\n    (function () {\n        // --- MODULE-LEVEL STATE & CONFIG ---\n\n        // Configuration\n        const MAX_COLLAPSED_ITEMS = 6;\n        const REFRESH_INTERVAL_MS = 60000; // 60 seconds\n\n        // Default State\n        let activities = [\n            // FIX: Updated to use placeholder images and removed closeIconUrl\n            { id: 1, galleryName: \"Dana & Tom\", galleryThumbnailCoverUrl: \"https://placehold.co/81x81/EBF5FF/667EEA?text=D%26T\", description: \"Selection completed for 'Favourite photos for edit'\", timestamp: new Date(Date.now() - 5 * 60 * 1000).toISOString(), actionOneCaption: \"View\", actionTwoCaption: null },\n            { id: 2, galleryName: \"Dana & Tom\", galleryThumbnailCoverUrl: \"https://placehold.co/81x81/EBF5FF/667EEA?text=D%26T\", description: \"You’ve got an order! Approve to move it forward\", timestamp: new Date(Date.now() - 60 * 60 * 1000).toISOString(), actionOneCaption: \"Approve\", actionTwoCaption: \"View order\" },\n            { id: 3, galleryName: \"Cindy's Gallery\", galleryThumbnailCoverUrl: \"https://placehold.co/81x81/FFFBEB/D97706?text=Cindy\", description: \"Cindy's registered for the gallery\", timestamp: new Date(Date.now() - 3 * 60 * 60 * 1000).toISOString(), actionOneCaption: \"Share photos with vendor\", actionTwoCaption: null }\n        ];\n        let defaultLang = {\n            \"dashboardActivitiesWidgetTitle\": \"Activities & recommendations\",\n            \"dashboardActivitiesNoActivity\": \"You’re on track !\",\n            \"dashboardActivitiesTimeElapsed\": \"{time} ago\",\n            \"dashboardActivitiesShowAll\": \"Show all activity >\",\n            \"dashboardActivitiesShowLess\": \"Show less <\",\n            \"timeJustNow\": \"Just now\",\n            \"timeMin\": \"min\",\n            \"timeHr\": \"hr\",\n            \"timeDay\": \"d\"\n        };\n        let lang = { ...defaultLang };\n        let showMenu = true;\n        let isExpanded = false;\n\n        // DOM Elements\n        const feedContainer = document.getElementById('activity-feed');\n        const toggleViewContainer = document.getElementById('toggle-view-container');\n        const dashboardTitle = document.getElementById('dashboard-title');\n        const menuButton = document.getElementById('menu-button');\n\n        // --- PRIVATE HELPER FUNCTIONS ---\n\n        /**\n         * Calculates the time part for the \"time ago\" string.\n         * @param {string} utcTimestamp - The UTC timestamp string.\n         * @returns {{timeValue: string, isJustNow: boolean}}\n         */\n        function _formatTimePart(utcTimestamp) {\n            if (!utcTimestamp) return { timeValue: '', isJustNow: false };\n            \n            const now = new Date();\n            const past = new Date(utcTimestamp);\n            const seconds = Math.floor((now - past) / 1000);\n\n            if (seconds < 60) {\n                return { timeValue: lang.timeJustNow, isJustNow: true };\n            }\n            \n            const minutes = Math.floor(seconds / 60);\n            if (minutes < 60) {\n                return { timeValue: `${minutes} ${lang.timeMin}`, isJustNow: false };\n            }\n\n            const hours = Math.floor(minutes / 60);\n            if (hours < 24) {\n                return { timeValue: `${hours} ${lang.timeHr}`, isJustNow: false };\n            }\n\n            const days = Math.floor(hours / 24);\n            return { timeValue: `${days}${lang.timeDay}`, isJustNow: false };\n        }\n\n        /**\n         * Formats the full time-ago string for display.\n         * @param {string} utcTimestamp\n         * @returns {string}\n         */\n        function _getFormattedTimestamp(utcTimestamp) {\n            const { timeValue, isJustNow } = _formatTimePart(utcTimestamp);\n            return isJustNow ? timeValue : lang.dashboardActivitiesTimeElapsed.replace('{time}', timeValue);\n        }\n\n        /**\n         * Triggers the external CTA handler.\n         * FIX: Removed console.log from here. Logging is now handled\n         * by the public window.myop_cta_handler function.\n         * @param {string} action_id - The ID of the action being performed.\n         * @param {object} payload - The data associated with the action.\n         */\n        function _triggerCtaHandler(action_id, payload) {\n            // Call the global handler if it exists\n            if (typeof window.myop_cta_handler === 'function') {\n                try {\n                    window.myop_cta_handler(action_id, payload);\n                } catch (error) {\n                    console.error(\"Error calling window.myop_cta_handler:\", error);\n                }\n            } else {\n                // This warning is helpful during development\n                console.warn(\"window.myop_cta_handler is not defined. Host application should implement this function to receive actions.\");\n            }\n        }\n\n        /**\n         * Creates the HTML string for a single activity item.\n         */\n        function _createActivityItemHTML(activity, isLastItem) {\n            const timeText = _getFormattedTimestamp(activity.timestamp);\n            \n            const actionOneButton = activity.actionOneCaption ? `<button class=\"btn btn-link font-medium text-base underline h-auto p-0\" data-action=\"action-one\" data-id=\"${activity.id}\">${activity.actionOneCaption}</button>` : '';\n            const actionTwoButton = activity.actionTwoCaption ? `<button class=\"btn btn-link font-medium text-base underline h-auto p-0\" data-action=\"action-two\" data-id=\"${activity.id}\">${activity.actionTwoCaption}</button>` : '';\n            const separator = !isLastItem ? '<div class=\"separator-horizontal mt-3\"></div>' : '';\n\n            // Note: data-action attributes are added for event delegation\n            return `\n                <div class=\"activity-item\" data-id=\"${activity.id}\" data-timestamp=\"${activity.timestamp}\">\n                    <div class=\"flex h-auto items-center py-3\">\n                        <div class=\"flex-shrink-0 mr-4\">\n                            <img class=\"w-[81px] h-[81px] rounded-[10px] goto-gallery-trigger object-cover\" alt=\"Gallery thumbnail cover\" src=\"${activity.galleryThumbnailCoverUrl}\" onerror=\"this.onerror=null;this.src='https://placehold.co/81x81/e0e0e0/333333?text=Error';\" data-action=\"go-to-gallery\" data-id=\"${activity.id}\">\n                        </div>\n                        <div class=\"flex-1\">\n                            <h3 class=\"font-medium text-base goto-gallery-trigger\" data-action=\"go-to-gallery\" data-id=\"${activity.id}\">${activity.galleryName}</h3>\n                            <p class=\"mt-1 text-base font-normal activity-description\">${activity.description}</p>\n                            <span class=\"activity-timestamp text-[#8c8c8c] text-xs block mt-3\">${timeText}</span>\n                        </div>\n                        <div class=\"flex items-center justify-end gap-6 flex-shrink-0 ml-4\">\n                            ${actionOneButton}\n                            ${actionTwoButton}\n                            <button class=\"btn\" data-action=\"close\" data-id=\"${activity.id}\">\n                                <!-- \n                                  FIX: Replaced external <img> with an inline SVG for the close icon.\n                                  This removes an external dependency.\n                                -->\n                                <svg class=\"w-3 h-3 pointer-events-none\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"2\" stroke=\"currentColor\">\n                                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M6 18L18 6M6 6l12 12\" />\n                                </svg>\n                            </button>\n                        </div>\n                    </div>\n                    ${separator}\n                </div>\n            `;\n        }\n\n        /**\n         * Creates the HTML for the \"Show all\" / \"Show less\" button.\n         */\n        function _createToggleViewHTML() {\n            if (activities.length > MAX_COLLAPSED_ITEMS) {\n                if (isExpanded) {\n                    return `<button id=\"show-less-btn\" class=\"btn btn-link\">${lang.dashboardActivitiesShowLess}</button>`;\n                } else {\n                    return `<button id=\"show-all-btn\" class=\"btn btn-link\">${lang.dashboardActivitiesShowAll}</button>`;\n                }\n            }\n            return ''; // No button needed\n        }\n        \n        /**\n         * Animates and removes an activity item from the list.\n         */\n        function _closeActivityItem(activityId, itemElement) {\n            if (!itemElement) return;\n\n            // Trigger the CTA handler before removing\n            _triggerCtaHandler('remove_item', { activityId: activityId });\n            \n            itemElement.style.transform = 'scale(0.95)';\n            itemElement.style.opacity = '0';\n            \n            setTimeout(() => {\n                activities = activities.filter(a => a.id != activityId);\n                renderScreen(); // Re-render after animation\n            }, 300);\n        }\n\n        /**\n         * Efficiently updates only the timestamp strings on the screen.\n         */\n        function _updateTimestamps() {\n            if (!feedContainer) return;\n            const itemElements = feedContainer.querySelectorAll('.activity-item[data-timestamp]');\n            itemElements.forEach(item => {\n                const timestampElement = item.querySelector('.activity-timestamp');\n                const utcTimestamp = item.dataset.timestamp;\n                if (timestampElement && utcTimestamp) {\n                    timestampElement.textContent = _getFormattedTimestamp(utcTimestamp);\n                }\n            });\n        }\n\n        // --- CORE FUNCTIONS ---\n\n        /**\n         * Renders the entire widget based on the current state.\n         */\n        function renderScreen() {\n            if (!feedContainer || !toggleViewContainer || !dashboardTitle || !menuButton) {\n                console.error(\"Dashboard elements not found. Render failed.\");\n                return; \n            }\n\n            // Update static elements\n            dashboardTitle.textContent = lang.dashboardActivitiesWidgetTitle || \"Activities & recommendations\";\n            menuButton.style.display = showMenu ? 'block' : 'none';\n\n            // Toggle scrollbar class\n            feedContainer.classList.toggle('feed-expanded', isExpanded);\n\n            // Handle empty state\n            if (!activities || activities.length === 0) {\n                feedContainer.innerHTML = `<p class=\"text-center text-[#8c8c8c] py-10\">${lang.dashboardActivitiesNoActivity}</p>`;\n                toggleViewContainer.innerHTML = ''; // Clear toggle button\n                return;\n            }\n\n            // Determine which activities to show\n            const activitiesToShow = isExpanded ? activities : activities.slice(0, MAX_COLLAPSED_ITEMS);\n            const lastItemIndex = activitiesToShow.length - 1;\n\n            // Generate and set HTML for activities\n            const feedHtml = activitiesToShow\n                .map((activity, index) => _createActivityItemHTML(activity, index === lastItemIndex))\n                .join('');\n            feedContainer.innerHTML = feedHtml;\n\n            // Generate and set HTML for toggle button\n            toggleViewContainer.innerHTML = _createToggleViewHTML();\n        }\n\n        // --- EVENT HANDLERS ---\n\n        /**\n         * Handles all click events on the activity feed using event delegation.\n         */\n        function handleFeedClick(e) {\n            const actionElement = e.target.closest('[data-action]');\n            if (!actionElement) return;\n\n            const action = actionElement.dataset.action;\n            const activityId = actionElement.dataset.id;\n            const activity = activities.find(a => a.id == activityId);\n            \n            switch (action) {\n                case 'go-to-gallery':\n                    _triggerCtaHandler('GoToGallery', { activity_ID: activityId, action_name: 'GoToGallery' });\n                    break;\n                case 'action-one':\n                    _triggerCtaHandler('action_one_click', { activityId, caption: activity?.actionOneCaption });\n                    break;\n                case 'action-two':\n                    _triggerCtaHandler('action_two_click', { activityId, caption: activity?.actionTwoCaption });\n                    break;\n                case 'close':\n                    const itemElement = actionElement.closest('.activity-item');\n                    _closeActivityItem(activityId, itemElement);\n                    break;\n            }\n        }\n\n        /**\n         * Handles clicks on the \"Show all\" / \"Show less\" button.\n         */\n        function handleToggleViewClick(e) {\n            if (e.target.id === 'show-all-btn') {\n                isExpanded = true;\n                renderScreen();\n                _triggerCtaHandler('toggle_view', { expanded: true });\n            } else if (e.target.id === 'show-less-btn') {\n                isExpanded = false;\n                renderScreen();\n                _triggerCtaHandler('toggle_view', { expanded: false });\n            }\n        }\n\n        // --- PUBLIC API ---\n\n        /**\n         * FIX: 1. Initializes the dashboard with a full configuration object.\n         * This function was already correctly defined on the window object.\n         * @param {object} config - The configuration object.\n         * @param {object[]} config.activities - Array of activity objects.\n         * @param {object} config.lang - Language override object.\n         * @param {boolean} config.showMenu - Whether to show the top-right menu.\n         */\n        window.myop_init_interface = function(config) {\n            if (!config) {\n                console.error(\"myop_init_interface: No config provided.\");\n                return;\n            }\n            \n            try {\n                // Reset to closed mode on new data\n                isExpanded = false; \n\n                // Set activities, ensuring it's an array\n                if (Array.isArray(config.activities)) {\n                    activities = config.activities;\n                } else if (config.activities) {\n                    console.warn(\"myop_init_interface: 'activities' in config was not an array. Defaulting to empty.\");\n                    activities = [];\n                } else {\n                    // Keep default activities if none are provided\n                }\n\n                // Set language, merging with defaults\n                if (typeof config.lang === 'object' && config.lang !== null) {\n                    lang = { ...defaultLang, ...config.lang };\n                } else {\n                    // Keep default lang if none provided\n                }\n                \n                // Set menu visibility\n                if (typeof config.showMenu === 'boolean') {\n                    showMenu = config.showMenu;\n                } else {\n                    // Keep default 'showMenu' if not provided\n                }\n                \n                // Re-render the screen with the new config\n                renderScreen();\n                _triggerCtaHandler('init_interface', { success: true });\n\n            } catch (error) {\n                console.error(\"An error occurred during myop_init_interface:\", error);\n                _triggerCtaHandler('init_interface', { success: false, error: error.message });\n            }\n        }\n\n        // --- INITIALIZATION ---\n        function init() {\n            // Ensure all required DOM elements are present before proceeding\n            if (!feedContainer || !toggleViewContainer || !dashboardTitle || !menuButton) {\n                console.error(\"Dashboard elements not found. Initialization failed. Widget will not load.\");\n                return;\n            }\n            \n            // Attach event listeners\n            feedContainer.addEventListener('click', handleFeedClick);\n            toggleViewContainer.addEventListener('click', handleToggleViewClick);\n            \n            // Initial render with default data\n            renderScreen(); \n\n            // Start the efficient timestamp updater\n            setInterval(_updateTimestamps, REFRESH_INTERVAL_MS);\n        }\n\n        // Wait for the DOM to be ready before initializing\n        document.addEventListener('DOMContentLoaded', init);\n\n    })();\n    </script>\n</body>\n</html>"
        }
      }
    ]
  }
}