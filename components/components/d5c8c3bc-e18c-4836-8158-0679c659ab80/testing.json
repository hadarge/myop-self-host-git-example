{
  "version": "0.2.10",
  "item": {
    "name": "Pic-Time 2.0 Welcome",
    "id": "d5c8c3bc-e18c-4836-8158-0679c659ab80",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "name": "Version 8",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"auto\"}'>\n    <title>Pic-Time 2.0 Welcome</title>\n\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n        dashboardP2WelcomeTitle: string;\n        dashboardP2WelcomeDescription: string;\n        dashboardP2WelcomeCtaText: string;\n        dashboardP2WelcomeVideoUrl: string;\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n        'new_gallery_clicked': {};\n        'size-requested': {\n            width?: number | null;\n            height?: number | null;\n            minWidth?: number | null;\n            maxWidth?: number | null;\n            minHeight?: number | null;\n            maxHeight?: number | null;\n            required?: boolean;\n        };\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            background: transparent;\n        }\n\n        #app-root {\n            width: 100%;\n        }\n\n        .container {\n            width: 100%;\n            max-width: 1200px;\n            container-type: inline-size;\n        }\n\n        .welcome-card {\n            background: transparent;\n            border-radius: 20px;\n            padding: 24px;\n            display: flex;\n            flex-direction: column;\n            gap: 24px;\n        }\n\n        .video-container {\n            position: relative;\n            width: 100%;\n            aspect-ratio: 572 / 355;\n            border-radius: 8px;\n            box-shadow: 0px 4px 15px 0px rgba(0, 0, 0, 0.07);\n            overflow: hidden;\n        }\n\n        .video-container iframe {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            border: none;\n        }\n\n        .content {\n            display: flex;\n            flex-direction: column;\n            gap: 16px;\n        }\n\n        .title {\n            font-size: 22px;\n            font-weight: 500;\n            color: #050505;\n            line-height: normal;\n        }\n\n        .description {\n            font-size: 14px;\n            font-weight: 400;\n            color: #534e4e;\n            line-height: 1.5;\n            letter-spacing: 0.98px;\n            text-transform: capitalize;\n        }\n\n        .cta-button {\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            background: #222;\n            color: white;\n            font-size: 16px;\n            font-weight: 500;\n            padding: 0;\n            border-radius: 50px;\n            border: none;\n            cursor: pointer;\n            height: 40px;\n            width: 137px;\n            transition: background 0.2s ease;\n            font-family: inherit;\n            line-height: 1.25;\n            white-space: nowrap;\n        }\n\n        .cta-button:hover {\n            background: #000;\n        }\n\n        .cta-button:active {\n            transform: scale(0.98);\n        }\n\n        /* Mobile layout (< 440px) */\n        @container (max-width: 439px) {\n            .welcome-card {\n                padding: 20px 18px;\n            }\n\n            .video-container {\n                aspect-ratio: 301 / 187;\n                border-radius: 5px;\n            }\n\n            .content {\n                gap: 16px;\n            }\n\n            .title {\n                font-size: 22px;\n            }\n\n            .description {\n                max-width: 269px;\n            }\n        }\n\n        /* Tablet layout (440px - 860px) */\n        @container (min-width: 440px) and (max-width: 860px) {\n            .welcome-card {\n                padding: 24px;\n            }\n\n            .video-container {\n                aspect-ratio: 572 / 355;\n            }\n\n            .content {\n                gap: 16px;\n            }\n\n            .title {\n                font-size: 22px;\n            }\n\n            .description {\n                max-width: 561px;\n            }\n        }\n\n        /* Desktop layout (> 860px) */\n        @container (min-width: 861px) {\n            .welcome-card {\n                flex-direction: row;\n                gap: 28px;\n                padding: 24px;\n                min-height: 403px;\n            }\n\n            .content {\n                flex: 1;\n                gap: 25px;\n                order: 1;\n                min-width: 0;\n            }\n\n            .video-container {\n                flex: 1;\n                max-width: 572px;\n                max-height: 355px;\n                aspect-ratio: 572 / 355;\n                order: 2;\n            }\n\n            .title {\n                font-size: 26px;\n            }\n\n            .description {\n                max-width: 407px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\">\n        <div class=\"container\">\n            <div class=\"welcome-card\">\n                <div class=\"video-container\">\n                    <iframe\n                        id=\"video-iframe\"\n                        src=\"\"\n                        frameborder=\"0\"\n                        allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write\"\n                        title=\"Vimeo video player\">\n                    </iframe>\n                </div>\n                <div class=\"content\">\n                    <h1 class=\"title\" id=\"title-text\"></h1>\n                    <p class=\"description\" id=\"description-text\"></p>\n                    <button class=\"cta-button\" id=\"cta-button\"></button>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        // Private state\n        var currentState = null;\n\n        // Cache DOM references\n        var titleEl = document.getElementById('title-text');\n        var descriptionEl = document.getElementById('description-text');\n        var ctaButtonEl = document.getElementById('cta-button');\n        var videoIframeEl = document.getElementById('video-iframe');\n\n        // Render function - synchronous\n        function render(data) {\n            titleEl.textContent = data.dashboardP2WelcomeTitle || '';\n            descriptionEl.textContent = data.dashboardP2WelcomeDescription || '';\n            ctaButtonEl.textContent = data.dashboardP2WelcomeCtaText || '';\n\n            if (data.dashboardP2WelcomeVideoUrl) {\n                videoIframeEl.src = data.dashboardP2WelcomeVideoUrl;\n            }\n\n            currentState = data;\n        }\n\n        // Event delegation for CTA button\n        ctaButtonEl.addEventListener('click', function() {\n            window.myop_cta_handler('new_gallery_clicked', {});\n        });\n\n        // Public API - must be defined at top level\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n            console.log('CTA Handler:', action_id, payload);\n        };\n    })();\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            dashboardP2WelcomeTitle: \"Welcome to Pic-Time 2.0\",\n            dashboardP2WelcomeDescription: \"Discover the newest tools for personalizing client stores, sharing galleries, and marketing your photography business.\",\n            dashboardP2WelcomeCtaText: \"Start now\",\n            dashboardP2WelcomeVideoUrl: \"https://player.vimeo.com/video/76979871?badge=0&autopause=0&player_id=0&app_id=58479\"\n        });\n    </script>\n</body>\n</html>"
        },
        "id": "59c14d67-6c43-4f93-8eaf-90c339aca63b"
      }
    ]
  }
