    "consume_variant": [
      {
        "id": "106e8992-20f0-433d-a16a-d6d5ebe73464",
        "name": "Version 2",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":700,\"height\":900,\"minWidth\":400,\"minHeight\":600}'>\n\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n  /** The image URL to crop (or existing avatar photo) */\n  imageUrl?: string;\n  /** Title text */\n  title?: string;\n  /** Shape of the crop area */\n  cropShape?: 'circle' | 'square';\n  /** Aspect ratio for square crops (width/height) */\n  aspectRatio?: number;\n  /** Avatar data - can be initials or photo URL */\n  avatar?: {\n    /** User initials (e.g., \"AS\") */\n    initials?: string;\n    /** Avatar background color (hex) */\n    color?: string;\n    /** Existing avatar photo URL */\n    photoUrl?: string;\n  };\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'cancel-requested': void;\n  'photo-saved': {\n    /** Base64 encoded cropped image */\n    croppedImage: string;\n    /** Crop area coordinates */\n    cropArea: {\n      x: number;\n      y: number;\n      width: number;\n      height: number;\n    };\n  };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n\n    <style>\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            background: #ffffff;\n        }\n\n        .header {\n            padding: 32px 32px 24px;\n            flex-shrink: 0;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n\n        .title {\n            font-size: 32px;\n            font-weight: 600;\n            color: #1a1a1a;\n            margin: 0;\n        }\n\n        .header-action {\n            flex-shrink: 0;\n        }\n\n        .crop-container {\n            flex: 1;\n            min-height: 0;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: 32px;\n            position: relative;\n        }\n\n        .crop-area {\n            position: relative;\n            touch-action: none;\n            user-select: none;\n            width: 600px;\n            height: 600px;\n            flex-shrink: 0;\n        }\n\n        .apply-button-container {\n            margin-top: 16px;\n            flex-shrink: 0;\n            width: 600px;\n        }\n\n        .apply-button-container .btn {\n            width: 100%;\n        }\n\n        .crop-image {\n            display: block;\n            width: 600px;\n            height: 600px;\n            object-fit: contain;\n            pointer-events: none;\n        }\n\n        .crop-overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            cursor: move;\n        }\n\n        .crop-box {\n            position: absolute;\n            border: 2px solid #1a1a1a;\n            box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.5);\n        }\n\n        .crop-box.circle {\n            border-radius: 50%;\n        }\n\n        .crop-handle {\n            position: absolute;\n            width: 12px;\n            height: 12px;\n            background: #fff;\n            border: 2px solid #1a1a1a;\n            cursor: pointer;\n        }\n\n        .crop-handle.nw {\n            top: -6px;\n            left: -6px;\n            cursor: nwse-resize;\n        }\n\n        .crop-handle.ne {\n            top: -6px;\n            right: -6px;\n            cursor: nesw-resize;\n        }\n\n        .crop-handle.sw {\n            bottom: -6px;\n            left: -6px;\n            cursor: nesw-resize;\n        }\n\n        .crop-handle.se {\n            bottom: -6px;\n            right: -6px;\n            cursor: nwse-resize;\n        }\n\n        .empty-state {\n            text-align: center;\n            color: #666;\n        }\n\n        .avatar-placeholder {\n            width: 200px;\n            height: 200px;\n            margin: 0 auto 24px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 80px;\n            font-weight: 600;\n            color: #fff;\n            position: relative;\n        }\n\n        .avatar-camera-icon {\n            width: 60px;\n            height: 60px;\n            background: rgba(0, 0, 0, 0.6);\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 30px;\n            position: absolute;\n            bottom: 8px;\n            right: 8px;\n            cursor: pointer;\n            transition: background 0.2s;\n        }\n\n        .avatar-camera-icon:hover {\n            background: rgba(0, 0, 0, 0.8);\n        }\n\n        .avatar-fallback-camera {\n            font-size: 60px;\n            color: #999;\n        }\n\n        .empty-state-text {\n            font-size: 18px;\n            margin-bottom: 24px;\n        }\n\n        .btn {\n            padding: 10px 20px;\n            border-radius: 8px;\n            font-size: 15px;\n            font-weight: 500;\n            cursor: pointer;\n            border: none;\n            transition: all 0.2s;\n        }\n\n        .btn-primary {\n            background: #1a1a1a;\n            color: #fff;\n        }\n\n        .btn-primary:hover {\n            background: #333;\n        }\n\n        .btn-secondary {\n            background: #f0f0f0;\n            color: #1a1a1a;\n        }\n\n        .btn-secondary:hover {\n            background: #e0e0e0;\n        }\n\n        .file-input {\n            display: none;\n        }\n\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function() {\n        let currentData = null;\n        let cropState = {\n            x: 0,\n            y: 0,\n            width: 400,\n            height: 400,\n            isDragging: false,\n            isResizing: false,\n            resizeHandle: null,\n            startX: 0,\n            startY: 0,\n            startCropX: 0,\n            startCropY: 0,\n            startCropWidth: 0,\n            startCropHeight: 0\n        };\n\n        let isPreviewMode = false;\n        let croppedImageData = null;\n\n        function render(data) {\n            currentData = data;\n            const container = document.getElementById('app-root');\n\n            if (!data.imageUrl) {\n                container.innerHTML = buildEmptyState(data);\n                return;\n            }\n\n            if (isPreviewMode) {\n                container.innerHTML = buildPreviewInterface(data);\n            } else {\n                container.innerHTML = buildCropInterface(data);\n                initializeCropper(data);\n            }\n        }\n\n        function buildEmptyState(data) {\n            const avatar = data.avatar || {};\n            const initials = avatar.initials || '';\n            const avatarColor = avatar.color || '#3b82f6';\n            const photoUrl = avatar.photoUrl;\n            const hasInitials = initials.length > 0;\n            const hasPhoto = !!photoUrl;\n\n            let avatarContent = '';\n            if (hasPhoto) {\n                avatarContent = `<img src=\"${photoUrl}\" style=\"width: 100%; height: 100%; object-fit: cover; border-radius: 50%;\" />`;\n            } else if (hasInitials) {\n                avatarContent = initials;\n            } else {\n                avatarContent = '<span class=\"avatar-fallback-camera\">📷</span>';\n            }\n\n            return `\n                <div class=\"header\">\n                    <h1 class=\"title\">${data.title || 'Profile photo'}</h1>\n                </div>\n                <div class=\"crop-container\">\n                    <div class=\"empty-state\">\n                        <div class=\"avatar-placeholder\" style=\"background-color: ${hasPhoto ? 'transparent' : (hasInitials ? avatarColor : '#f0f0f0')};\">\n                            ${avatarContent}\n                            <div class=\"avatar-camera-icon\" onclick=\"window.handleSelectPhoto()\">\n                                📷\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <input type=\"file\" id=\"file-input\" class=\"file-input\" accept=\"image/*\" onchange=\"window.handleFileSelected(event)\">\n            `;\n        }\n\n        function buildCropInterface(data) {\n            return `\n                <div class=\"header\">\n                    <h1 class=\"title\">${data.title || 'Profile photo'}</h1>\n                    <div class=\"header-action\">\n                        <button class=\"btn btn-secondary\" onclick=\"window.handleCancel()\">Cancel</button>\n                    </div>\n                </div>\n                <div class=\"crop-container\">\n                    <div class=\"crop-area\" id=\"crop-area\">\n                        <img src=\"${data.imageUrl}\" class=\"crop-image\" id=\"crop-image\" />\n                        <div class=\"crop-overlay\" id=\"crop-overlay\">\n                            <div class=\"crop-box ${data.cropShape === 'circle' ? 'circle' : ''}\" id=\"crop-box\">\n                                <div class=\"crop-handle nw\" data-handle=\"nw\"></div>\n                                <div class=\"crop-handle ne\" data-handle=\"ne\"></div>\n                                <div class=\"crop-handle sw\" data-handle=\"sw\"></div>\n                                <div class=\"crop-handle se\" data-handle=\"se\"></div>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"apply-button-container\">\n                        <button class=\"btn btn-primary\" onclick=\"window.handleApplyCrop()\">Apply</button>\n                    </div>\n                </div>\n            `;\n        }\n\n        function buildPreviewInterface(data) {\n            return `\n                <div class=\"header\">\n                    <h1 class=\"title\">${data.title || 'Profile photo'}</h1>\n                    <div class=\"header-action\">\n                        <button class=\"btn btn-primary\" onclick=\"window.handleSavePhoto()\">Done</button>\n                    </div>\n                </div>\n                <div class=\"crop-container\">\n                    <div style=\"text-align: center; width: 600px;\">\n                        <img src=\"${croppedImageData}\" style=\"width: 400px; height: 400px; object-fit: cover; border-radius: ${data.cropShape === 'circle' ? '50%' : '0'}; border: 2px solid #1a1a1a;\" />\n                        <div style=\"margin-top: 16px; width: 600px;\">\n                            <button class=\"btn btn-primary\" style=\"width: 100%;\" onclick=\"window.handleAdjustCrop()\">Adjust Crop</button>\n                        </div>\n                    </div>\n                </div>\n            `;\n        }\n\n        function initializeCropper(data) {\n            const img = document.getElementById('crop-image');\n            const cropBox = document.getElementById('crop-box');\n            const overlay = document.getElementById('crop-overlay');\n            const cropArea = document.getElementById('crop-area');\n\n            img.onload = function() {\n                const imgRect = img.getBoundingClientRect();\n                const areaRect = cropArea.getBoundingClientRect();\n\n                // Calculate initial crop size (60% of image)\n                const size = Math.min(imgRect.width, imgRect.height) * 0.6;\n                cropState.width = size;\n                cropState.height = size;\n                cropState.x = (imgRect.width - size) / 2;\n                cropState.y = (imgRect.height - size) / 2;\n\n                updateCropBox();\n            };\n\n            // Handle mouse/touch events\n            const handles = cropBox.querySelectorAll('.crop-handle');\n            handles.forEach(handle => {\n                handle.addEventListener('mousedown', startResize);\n                handle.addEventListener('touchstart', startResize);\n            });\n\n            cropBox.addEventListener('mousedown', startDrag);\n            cropBox.addEventListener('touchstart', startDrag);\n\n            document.addEventListener('mousemove', handleMove);\n            document.addEventListener('touchmove', handleMove);\n            document.addEventListener('mouseup', stopDragResize);\n            document.addEventListener('touchend', stopDragResize);\n        }\n\n        function startResize(e) {\n            e.stopPropagation();\n            cropState.isResizing = true;\n            cropState.resizeHandle = e.target.dataset.handle;\n\n            const clientX = e.touches ? e.touches[0].clientX : e.clientX;\n            const clientY = e.touches ? e.touches[0].clientY : e.clientY;\n\n            cropState.startX = clientX;\n            cropState.startY = clientY;\n            cropState.startCropX = cropState.x;\n            cropState.startCropY = cropState.y;\n            cropState.startCropWidth = cropState.width;\n            cropState.startCropHeight = cropState.height;\n        }\n\n        function startDrag(e) {\n            if (cropState.isResizing) return;\n\n            cropState.isDragging = true;\n\n            const clientX = e.touches ? e.touches[0].clientX : e.clientX;\n            const clientY = e.touches ? e.touches[0].clientY : e.clientY;\n\n            cropState.startX = clientX;\n            cropState.startY = clientY;\n            cropState.startCropX = cropState.x;\n            cropState.startCropY = cropState.y;\n        }\n\n        function handleMove(e) {\n            if (!cropState.isDragging && !cropState.isResizing) return;\n\n            e.preventDefault();\n\n            const clientX = e.touches ? e.touches[0].clientX : e.clientX;\n            const clientY = e.touches ? e.touches[0].clientY : e.clientY;\n\n            const dx = clientX - cropState.startX;\n            const dy = clientY - cropState.startY;\n\n            const img = document.getElementById('crop-image');\n            const imgRect = img.getBoundingClientRect();\n            const areaRect = document.getElementById('crop-area').getBoundingClientRect();\n\n            // Adjust for image position within area\n            const imgOffsetX = imgRect.left - areaRect.left;\n            const imgOffsetY = imgRect.top - areaRect.top;\n\n            if (cropState.isDragging) {\n                cropState.x = Math.max(0, Math.min(imgRect.width - cropState.width, cropState.startCropX + dx));\n                cropState.y = Math.max(0, Math.min(imgRect.height - cropState.height, cropState.startCropY + dy));\n            } else if (cropState.isResizing) {\n                const handle = cropState.resizeHandle;\n                const aspectRatio = currentData.cropShape === 'circle' ? 1 : (currentData.aspectRatio || 1);\n\n                if (handle === 'se') {\n                    const newWidth = Math.max(50, cropState.startCropWidth + dx);\n                    const newHeight = newWidth / aspectRatio;\n                    cropState.width = Math.min(newWidth, imgRect.width - cropState.x);\n                    cropState.height = Math.min(newHeight, imgRect.height - cropState.y);\n                } else if (handle === 'sw') {\n                    const newWidth = Math.max(50, cropState.startCropWidth - dx);\n                    const newHeight = newWidth / aspectRatio;\n                    if (cropState.startCropX + dx >= 0 && newWidth <= cropState.startCropX + cropState.startCropWidth) {\n                        cropState.x = cropState.startCropX + dx;\n                        cropState.width = newWidth;\n                        cropState.height = newHeight;\n                    }\n                } else if (handle === 'ne') {\n                    const newWidth = Math.max(50, cropState.startCropWidth + dx);\n                    const newHeight = newWidth / aspectRatio;\n                    if (cropState.startCropY - (newHeight - cropState.startCropHeight) >= 0) {\n                        cropState.width = Math.min(newWidth, imgRect.width - cropState.x);\n                        cropState.height = newHeight;\n                        cropState.y = cropState.startCropY - (cropState.height - cropState.startCropHeight);\n                    }\n                } else if (handle === 'nw') {\n                    const newWidth = Math.max(50, cropState.startCropWidth - dx);\n                    const newHeight = newWidth / aspectRatio;\n                    if (cropState.startCropX + dx >= 0 && cropState.startCropY - (newHeight - cropState.startCropHeight) >= 0) {\n                        cropState.x = cropState.startCropX + dx;\n                        cropState.width = newWidth;\n                        cropState.height = newHeight;\n                        cropState.y = cropState.startCropY - (cropState.height - cropState.startCropHeight);\n                    }\n                }\n\n                // Ensure square for circle crop\n                if (currentData.cropShape === 'circle') {\n                    const size = Math.min(cropState.width, cropState.height);\n                    cropState.width = size;\n                    cropState.height = size;\n                }\n            }\n\n            updateCropBox();\n        }\n\n        function stopDragResize() {\n            cropState.isDragging = false;\n            cropState.isResizing = false;\n            cropState.resizeHandle = null;\n        }\n\n        function updateCropBox() {\n            const cropBox = document.getElementById('crop-box');\n            if (!cropBox) return;\n\n            cropBox.style.left = cropState.x + 'px';\n            cropBox.style.top = cropState.y + 'px';\n            cropBox.style.width = cropState.width + 'px';\n            cropBox.style.height = cropState.height + 'px';\n        }\n\n        function getCroppedImage() {\n            const img = document.getElementById('crop-image');\n            const canvas = document.createElement('canvas');\n            const ctx = canvas.getContext('2d');\n\n            // Get actual image dimensions vs displayed dimensions\n            const displayWidth = img.offsetWidth;\n            const displayHeight = img.offsetHeight;\n            const naturalWidth = img.naturalWidth;\n            const naturalHeight = img.naturalHeight;\n\n            const scaleX = naturalWidth / displayWidth;\n            const scaleY = naturalHeight / displayHeight;\n\n            const cropX = cropState.x * scaleX;\n            const cropY = cropState.y * scaleY;\n            const cropWidth = cropState.width * scaleX;\n            const cropHeight = cropState.height * scaleY;\n\n            canvas.width = cropWidth;\n            canvas.height = cropHeight;\n\n            // Draw cropped image\n            ctx.drawImage(\n                img,\n                cropX, cropY, cropWidth, cropHeight,\n                0, 0, cropWidth, cropHeight\n            );\n\n            // If circle, apply circular mask\n            if (currentData.cropShape === 'circle') {\n                ctx.globalCompositeOperation = 'destination-in';\n                ctx.beginPath();\n                ctx.arc(cropWidth / 2, cropHeight / 2, cropWidth / 2, 0, Math.PI * 2);\n                ctx.fill();\n            }\n\n            return {\n                dataUrl: canvas.toDataURL('image/png'),\n                cropArea: {\n                    x: cropX,\n                    y: cropY,\n                    width: cropWidth,\n                    height: cropHeight\n                }\n            };\n        }\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentData;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n        };\n\n        // Event handlers\n        window.handleSelectPhoto = function() {\n            const fileInput = document.getElementById('file-input');\n            if (fileInput) {\n                fileInput.click();\n            }\n        };\n\n        window.handleFileSelected = function(event) {\n            const file = event.target.files[0];\n            if (!file) return;\n\n            // Validate file type\n            if (!file.type.startsWith('image/')) {\n                alert('Please select an image file');\n                return;\n            }\n\n            // Read file and convert to data URL\n            const reader = new FileReader();\n            reader.onload = function(e) {\n                // Update component with the selected image\n                currentData = {\n                    ...currentData,\n                    imageUrl: e.target.result\n                };\n                render(currentData);\n            };\n            reader.readAsDataURL(file);\n        };\n\n        window.handleCancel = function() {\n            window.myop_cta_handler('cancel-requested', undefined);\n        };\n\n        window.handleApplyCrop = function() {\n            const result = getCroppedImage();\n            croppedImageData = result.dataUrl;\n            isPreviewMode = true;\n            render(currentData);\n        };\n\n        window.handleAdjustCrop = function() {\n            isPreviewMode = false;\n            render(currentData);\n        };\n\n        window.handleSavePhoto = function() {\n            if (!croppedImageData) {\n                // If not in preview mode, apply crop first\n                const result = getCroppedImage();\n                croppedImageData = result.dataUrl;\n            }\n\n            window.myop_cta_handler('photo-saved', {\n                croppedImage: croppedImageData,\n                cropArea: {\n                    x: cropState.x,\n                    y: cropState.y,\n                    width: cropState.width,\n                    height: cropState.height\n                }\n            });\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            title: 'Profile photo',\n            cropShape: 'circle',\n            avatar: {\n                initials: 'AS',\n                color: '#8b5cf6'\n            }\n        });\n    </script>\n</body>\n</html>\n"
        }
      }
    ]
