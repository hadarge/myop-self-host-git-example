{
  "version": "0.2.10",
  "item": {
    "name": "PHDash_storage",
    "id": "4c2297a1-d5fc-467b-a5bf-e44283858527",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "name": "Version 20",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"auto\"}'>\n\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Storage data structure\n */\ninterface StorageData {\n  storageUsed: string;\n  storageLimit: string;\n  percentStorageUsed: number;\n  /** Subscription plan ID: 100=Trial, 0=Free, 5=Beginner, 10=Pro, 20=Advance */\n  subscription: 100 | 0 | 5 | 10 | 20;\n  /** Billing type */\n  billingType: 'monthly' | 'yearly' | null;\n  /** Trial expiration date in .NET format e.g. \"/Date(1868804861000)/\" */\n  expiration?: string | null;\n}\n\n/**\n * Upgrade benefit content for a specific plan/billing combination\n */\ninterface UpgradeBenefit {\n  title: string;\n  body: string;\n  buttonText: string;\n}\n\n/**\n * Keyed map of upgrade benefits.\n * Key format: \"{context}_{subscription}_{billingType}\"\n * Example: \"default_5_monthly\", \"default_100_null\"\n */\ninterface UpgradeBenefitsMap {\n  [key: string]: UpgradeBenefit;\n}\n\n/**\n * Localization strings\n */\ninterface Lang {\n  dashboardStorageLowStorageTitle: string;       // \"Low storage\"\n  dashboardStoragePlanTitle: string;             // \"{planName} plan\" (used in promotion view)\n  dashboardStoragePercentUsedPhoto: string;      // \"{percent}% photo\"\n  dashboardStoragePercentUsedVideo: string;      // \"{percent}% video\"\n  dashboardStorageUpgradeStorageButton: string;  // \"See plans\" (storage alert button)\n}\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n  planName: string;\n  isHighestPlan: boolean;\n\n  photoStorageAlert: boolean;\n  videoStorageAlert: boolean;\n\n  photoData: StorageData;\n  videoData: StorageData;\n\n  /** Keyed upgrade benefits map - component selects the right one based on photoData.subscription + photoData.billingType */\n  upgradeBenefits: UpgradeBenefitsMap;\n\n  lang: Lang;\n\n  /** Button icon SVG string, or null for no icon */\n  buttonIcon: string | null;\n\n  fonts: Array<{\n    id: string;\n    family: string;\n    style?: string;\n    weight?: number;\n    url: string;\n  }>;\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'size-requested': {\n    width?: number | null;\n    height?: number | null;\n    minWidth?: number | null;\n    maxWidth?: number | null;\n    minHeight?: number | null;\n    maxHeight?: number | null;\n    required?: boolean;\n  };\n  'upgrade-clicked': { subsProduct: number };\n  'upgrade-promo-clicked': { subsProduct: number };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n\n    <style>\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: fit-content;\n            min-height: 0;\n        }\n\n        #app-root {\n            width: 100%;\n            font-family: var(--font_main_family), sans-serif;\n            font-weight: var(--font_main_weight, 400);\n            font-style: var(--font_main_style, normal);\n        }\n\n        .widget-container {\n            background: #ffffff;\n            border: 1px solid #ddddd1;\n            border-radius: 8px;\n            padding: 24px;\n            width: 100%;\n        }\n\n        .widget-hidden {\n            display: none;\n        }\n\n        .widget-content {\n            display: flex;\n            flex-direction: column;\n        }\n\n        .widget-title {\n            font-family: var(--font_main_family), \"TT Norms Pro\", sans-serif;\n            font-weight: 500;\n            font-style: normal;\n            font-size: 16px;\n            color: #222;\n            line-height: 130%;\n            font-feature-settings: 'liga' off, 'clig' off;\n            margin: 0;\n        }\n\n        .storage-bar {\n            margin-top: 24px;\n        }\n\n        .storage-section {\n            display: flex;\n            flex-direction: column;\n            gap: 24px;\n        }\n\n        .storage-item {\n            display: flex;\n            flex-direction: column;\n            gap: 8px;\n        }\n\n        .progress-bar {\n            background: #d7d7d7;\n            border-radius: 3px;\n            height: 6px;\n            width: 100%;\n            min-width: 90px;\n            overflow: hidden;\n        }\n\n        .progress-fill {\n            height: 100%;\n            border-radius: 90px;\n            transition: width 0.3s ease;\n        }\n\n        .progress-fill.alert {\n            background: #e32626;\n        }\n\n        .progress-fill.normal {\n            background: #4caf50;\n        }\n\n        .storage-info {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            font-family: var(--font_main_family), sans-serif;\n            font-weight: var(--font_main_weight, 400);\n            font-style: var(--font_main_style, normal);\n            font-size: 14px;\n            color: #000000;\n            line-height: 1.3;\n        }\n\n        .benefits-section {\n            display: flex;\n            flex-direction: column;\n        }\n\n        .benefits-body {\n            font-family: var(--font_main_family), sans-serif;\n            font-weight: var(--font_main_weight, 400);\n            font-style: var(--font_main_style, normal);\n            font-size: 14px;\n            color: #000000;\n            line-height: 1.8;\n            margin: 8px 0 0 0;\n            word-wrap: break-word;\n            overflow-wrap: break-word;\n            white-space: normal;\n        }\n\n        .upgrade-button {\n            display: flex;\n            padding: 5px 12px;\n            justify-content: center;\n            align-items: center;\n            gap: 8px;\n            border-radius: 2px;\n            border: 1px solid #E3C4F5;\n            background: #F8ECFF;\n            cursor: pointer;\n            font-family: var(--font_main_family), sans-serif;\n            font-weight: 400;\n            font-style: normal;\n            font-size: 16px;\n            color: #54033C;\n            line-height: 22px;\n            letter-spacing: 0.16px;\n            transition: background-color 0.2s ease;\n        }\n\n        .upgrade-button:hover {\n            background: linear-gradient(rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.3)), #F8ECFF;\n        }\n\n        .upgrade-button svg {\n            width: 16px;\n            height: 16px;\n            flex-shrink: 0;\n            overflow: visible;\n        }\n\n        .button-wrapper {\n            display: flex;\n        }\n\n        .button-wrapper.promo {\n            margin-top: 16px;\n        }\n\n        .button-wrapper.storage {\n            margin-top: 24px;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function() {\n        let currentState = null;\n\n        function loadFonts(fonts) {\n            if (!fonts || !fonts.length) return;\n\n            fonts.forEach(function(font) {\n                var root = document.documentElement;\n                root.style.setProperty('--font_' + font.id + '_family', font.family);\n                if (font.weight !== undefined) {\n                    root.style.setProperty('--font_' + font.id + '_weight', font.weight);\n                }\n                if (font.style) {\n                    root.style.setProperty('--font_' + font.id + '_style', font.style);\n                }\n\n                if (font.url) {\n                    var existingLink = document.querySelector('link[href=\"' + font.url + '\"]');\n                    if (!existingLink) {\n                        var link = document.createElement('link');\n                        link.rel = 'stylesheet';\n                        link.href = font.url;\n                        document.head.appendChild(link);\n                    }\n                }\n            });\n        }\n\n        /**\n         * Parse .NET date format \"/Date(1868804861000)/\" and return days left from today.\n         * Returns 0 if expired or invalid.\n         */\n        function calculateDaysLeft(expiration) {\n            if (!expiration) return 0;\n            var match = expiration.match(/\\/Date\\((\\d+)\\)\\//);\n            if (!match) return 0;\n            var expirationMs = parseInt(match[1], 10);\n            var now = Date.now();\n            var diffMs = expirationMs - now;\n            if (diffMs <= 0) return 0;\n            return Math.ceil(diffMs / (1000 * 60 * 60 * 24));\n        }\n\n        /**\n         * Build the upgradeBenefits key: \"{context}_{subscription}_{billingType}\"\n         */\n        function buildBenefitKey(context, subscription, billingType) {\n            return context + '_' + subscription + '_' + (billingType || 'null');\n        }\n\n        /**\n         * Get the matching upgrade benefit from the map using photoData fields.\n         */\n        function getUpgradeBenefit(data) {\n            if (!data.upgradeBenefits || !data.photoData) return null;\n            var key = buildBenefitKey('default', data.photoData.subscription, data.photoData.billingType);\n            return data.upgradeBenefits[key] || null;\n        }\n\n        function getDisplayState(data) {\n            // Hidden - highest plan with no alerts\n            if (!data.photoStorageAlert && !data.videoStorageAlert && data.isHighestPlan) {\n                return 'hidden';\n            }\n            // Both alerts\n            if (data.photoStorageAlert && data.videoStorageAlert) {\n                return 'both-alerts';\n            }\n            // Photo alert only\n            if (data.photoStorageAlert) {\n                return 'photo-alert';\n            }\n            // Video alert only\n            if (data.videoStorageAlert) {\n                return 'video-alert';\n            }\n            // Upgrade promotion - but only if there's a matching benefit\n            var benefit = getUpgradeBenefit(data);\n            if (benefit) {\n                return 'promotion';\n            }\n            // No matching benefit found → hide widget\n            return 'hidden';\n        }\n\n        function formatTemplate(template, replacements) {\n            var result = template;\n            for (var key in replacements) {\n                result = result.replace('{' + key + '}', replacements[key]);\n            }\n            return result;\n        }\n\n        function buildStorageBar(percentUsedTemplate, storageData, isAlert) {\n            var storageUsed = storageData.storageUsed;\n            var storageLimit = storageData.storageLimit;\n            var percentStorageUsed = storageData.percentStorageUsed;\n            var formattedLabel = formatTemplate(percentUsedTemplate, { percent: percentStorageUsed });\n            return '<div class=\"storage-item\">' +\n                '<div class=\"progress-bar\">' +\n                    '<div class=\"progress-fill ' + (isAlert ? 'alert' : 'normal') + '\" style=\"width: ' + Math.min(percentStorageUsed, 100) + '%\"></div>' +\n                '</div>' +\n                '<div class=\"storage-info\">' +\n                    '<span>' + formattedLabel + '</span>' +\n                    '<span>' + storageUsed + ' / ' + storageLimit + '</span>' +\n                '</div>' +\n            '</div>';\n        }\n\n        function buildStorageSection(data, lang) {\n            var storageHTML = '<div class=\"storage-bar\"><div class=\"storage-section\">';\n\n            if (data.videoStorageAlert) {\n                storageHTML += buildStorageBar(lang.dashboardStoragePercentUsedVideo, data.videoData, data.videoStorageAlert);\n            }\n\n            if (data.photoStorageAlert) {\n                storageHTML += buildStorageBar(lang.dashboardStoragePercentUsedPhoto, data.photoData, data.photoStorageAlert);\n            }\n\n            storageHTML += '</div></div>';\n            return storageHTML;\n        }\n\n        function buildUpgradeButton(buttonText, buttonIcon, actionId, subsProduct) {\n            return '<button class=\"upgrade-button\" onclick=\"window.myop_cta_handler(\\'' + actionId + '\\', { subsProduct: ' + subsProduct + ' })\">' +\n                (buttonIcon || '') +\n                '<span style=\"position: relative; top: 1px;\">' + buttonText + '</span>' +\n            '</button>';\n        }\n\n        function render(data) {\n            var container = document.getElementById('app-root');\n            var state = getDisplayState(data);\n            var lang = data.lang;\n\n            if (state === 'hidden') {\n                container.innerHTML = '';\n                return;\n            }\n\n            var title = '';\n            var contentHTML = '';\n            var buttonText = '';\n            var actionId = 'upgrade-clicked';\n            var subsProduct = 0;\n\n            if (state === 'promotion') {\n                actionId = 'upgrade-promo-clicked';\n                var benefit = getUpgradeBenefit(data);\n                title = benefit.title;\n                buttonText = benefit.buttonText;\n                var bodyText = benefit.body;\n                subsProduct = 0;\n\n                // For trial users, replace {daysLeftForTrial} in title\n                if (data.photoData && data.photoData.subscription === 100 && data.photoData.expiration) {\n                    var daysLeft = calculateDaysLeft(data.photoData.expiration);\n                    title = formatTemplate(title, { daysLeftForTrial: daysLeft });\n                }\n\n                contentHTML = '<div class=\"benefits-section\">' +\n                    '<p class=\"benefits-body\">' + bodyText + '</p>' +\n                '</div>';\n            } else {\n                // Storage alert states - use \"Low storage\" title\n                title = lang.dashboardStorageLowStorageTitle;\n                buttonText = lang.dashboardStorageUpgradeStorageButton;\n\n                // Determine subsProduct based on which alert is active\n                if (state === 'video-alert') {\n                    subsProduct = 10100;\n                } else if (state === 'photo-alert') {\n                    subsProduct = 0;\n                } else if (state === 'both-alerts') {\n                    // Both alerts - photo takes precedence\n                    subsProduct = 0;\n                }\n\n                contentHTML = buildStorageSection(data, lang);\n            }\n\n            var buttonWrapperClass = state === 'promotion' ? 'button-wrapper promo' : 'button-wrapper storage';\n\n            container.innerHTML = '<div class=\"widget-container\">' +\n                '<div class=\"widget-content\">' +\n                    '<h2 class=\"widget-title\">' + title + '</h2>' +\n                    contentHTML +\n                    '<div class=\"' + buttonWrapperClass + '\">' +\n                        buildUpgradeButton(buttonText, data.buttonIcon, actionId, subsProduct) +\n                    '</div>' +\n                '</div>' +\n            '</div>';\n        }\n\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            currentState = data;\n            loadFonts(data.fonts);\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n            console.log('CTA:', action_id, payload);\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            planName: 'Beginner',\n            isHighestPlan: false,\n            photoStorageAlert: true,\n            videoStorageAlert: false,\n            photoData: {\n                storageUsed: '9.2GB',\n                storageLimit: '10GB',\n                percentStorageUsed: 92,\n                subscription: 5,\n                billingType: 'monthly',\n                expiration: null\n            },\n            videoData: {\n                storageUsed: '2GB',\n                storageLimit: '10GB',\n                percentStorageUsed: 20,\n                subscription: 5,\n                billingType: 'monthly',\n                expiration: null\n            },\n            upgradeBenefits: {\n                'default_100_null': {\n                    title: '{daysLeftForTrial} trial days',\n                    body: 'Upgrade to keep full access to all Advanced tools after your trial.',\n                    buttonText: 'See plans'\n                },\n                'default_0_monthly': {\n                    title: 'Show up like a pro',\n                    body: 'Add your logo and branding to present your work professionally for just $7/mo.',\n                    buttonText: 'See plans'\n                },\n                'default_0_yearly': {\n                    title: 'Show up like a pro',\n                    body: 'Add your logo and branding to present your work professionally for just $7/mo.',\n                    buttonText: 'See plans'\n                },\n                'default_5_monthly': {\n                    title: 'Level up',\n                    body: 'Pro delivery tools make your work go further, engage more, and pay off over time.',\n                    buttonText: 'See plans'\n                },\n                'default_5_yearly': {\n                    title: 'Level up',\n                    body: 'Pro delivery tools make your work go further, engage more, and pay off over time.',\n                    buttonText: 'See plans'\n                },\n                'default_10_monthly': {\n                    title: 'Same plan for less',\n                    body: 'Save on your Professional plan by switching to yearly billing, while keeping the same polished client experience.',\n                    buttonText: 'Switch to yearly'\n                },\n                'default_20_monthly': {\n                    title: 'Same plan for less',\n                    body: 'Save on your plan by switching to yearly, while keeping the same Advanced tools and client experience.',\n                    buttonText: 'Switch to yearly'\n                }\n            },\n            lang: {\n                dashboardStorageLowStorageTitle: 'Low storage',\n                dashboardStoragePlanTitle: '{planName} plan',\n                dashboardStoragePercentUsedPhoto: 'Photos - {percent}% used',\n                dashboardStoragePercentUsedVideo: 'Videos - {percent}% used',\n                dashboardStorageUpgradeStorageButton: 'See plans'\n            },\n            buttonIcon: '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M7.56445 1.79785C7.75552 1.45762 8.24448 1.45762 8.43555 1.79785L10.1885 4.91895C10.5922 5.63779 11.5011 5.89599 12.2227 5.49707L14.2588 4.37109C14.639 4.16088 15.0883 4.50222 14.9873 4.9248L13.0303 13.1162C12.9765 13.3412 12.7753 13.5 12.5439 13.5H3.45605C3.22469 13.5 3.02351 13.3412 2.96973 13.1162L1.0127 4.9248C0.911745 4.50222 1.36098 4.16088 1.74121 4.37109L3.77734 5.49707C4.49891 5.89599 5.40776 5.63779 5.81152 4.91895L7.56445 1.79785Z\" style=\"fill:#F8ECFF;stroke:#54033C\"/></svg>',\n            fonts: [{\n                id: 'main',\n                family: 'TT Norms Pro',\n                style: 'normal',\n                weight: 400,\n                url: 'https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css'\n            }]\n        });\n    </script>\n</body>\n</html>\n"
        },
        "id": "ee5311ac-daaf-4c3c-8522-344e3572f1b1"
      }
    ]
  }
}