        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n\n    <script type=\"myop/types\">\n        // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Feature item displayed in pricing card\n     */\n    interface FeatureItem {\n      label: string;\n      sublabel?: string;\n    }\n\n    /**\n     * FAQ item with question and answer\n     */\n    interface FaqItem {\n      question: string;\n      answer: string;\n    }\n\n    /**\n     * Content configuration for all text/numbers in the component\n     */\n    interface ContentConfig {\n      // Header section\n      promoLabel?: string;\n      mainTitle?: string;\n      subtitle?: string;\n\n      // Card configuration\n      cards?: {\n        professional?: {\n          name?: string;\n          badge?: string;\n          badgeType?: 'featured' | 'default';\n          buttonLabel?: string;\n          currentPlanLabel?: string;\n          featuresTitle?: string;\n          features?: FeatureItem[];\n          savingsTextTemplate?: string; // e.g., \"Upgrade to {plan} for {savings} less\"\n        };\n        advanced?: {\n          name?: string;\n          badge?: string;\n          badgeType?: 'featured' | 'default';\n          buttonLabel?: string;\n          currentPlanLabel?: string;\n          featuresTitle?: string;\n          features?: FeatureItem[];\n          savingsTextTemplate?: string; // e.g., \"Upgrade to {plan} for {savings} less\"\n        };\n      };\n\n      // Pricing display\n      currency?: string;\n      billingPeriodLabel?: string;\n\n      // FAQs section\n      faqTitle?: string;\n      faqs?: FaqItem[];\n    }\n\n    /**\n     * Font configuration item\n     */\n    interface FontItem {\n      id: string;           // Font identifier used for CSS variable, e.g., \"main\" -> --font_main\n      family: string;       // Font family name, e.g., \"TT Norms Pro\"\n      style?: string;       // Optional font style, e.g., \"normal\", \"italic\"\n      weight?: number;      // Optional font weight, e.g., 400, 700\n      url: string;          // URL to the font CSS file\n    }\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n      lang: string;\n      fonts?: FontItem[];   // Array of font configurations\n      subscription: 0 | 10 | 20; // 0=Free, 10=Professional, 20=Advanced\n      pricing?: Array<{\n        fullPaymentAmount: number;\n        amount: number;\n        subscriptionExpiration?: string;\n        subscription: number;       // tier: 10=Professional, 20=Advanced\n        collectInterval: 0 | 10;    // 0=Monthly, 10=Yearly\n      }>;\n      content?: ContentConfig;\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n      'subscription-selected': {\n        plan: 'professional' | 'advanced';\n        tier: 10 | 20;\n        price: number;\n      };\n      'size-requested': {\n        width?: number | null;\n        height?: number | null;\n        minWidth?: number | null;\n        maxWidth?: number | null;\n        minHeight?: number | null;\n        maxHeight?: number | null;\n        required?: boolean;\n      };\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n      action: K,\n      payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500&display=swap');\n\n        :root {\n            /* Font CSS variables - set dynamically from fonts array */\n            --font_main: sans-serif;\n            --font_serif: 'EB Garamond', 'Garamond Premier Pro', Georgia, serif;\n\n            /* Color palette from Figma */\n            --dark-violet: #54033c;\n            --brown-saturated: #250b0b;\n            --gray-text: #666666;\n            --border-gray: #dbdbdb;\n            --bg-featured: #fbf5ff;\n            --bg-card-header: #f7f7f7;\n        }\n\n        * {\n            box-sizing: border-box;\n        }\n\n        html,\n        body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            overflow-y: auto;\n            font-family: var(--font_main);\n            background: #ffffff;\n        }\n\n        .pricing-container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 40px 20px;\n            width: 100%;\n            position: relative;\n        }\n\n        .header-section {\n            text-align: center;\n            margin-bottom: 32px;\n        }\n\n        .promo-label {\n            display: inline-flex;\n            align-items: center;\n            gap: 6px;\n            background: #ffffff;\n            color: #222222;\n            padding: 8px 20px;\n            border-radius: 100px;\n            font-size: 10px;\n            font-weight: 500;\n            letter-spacing: 0.8px;\n            text-transform: uppercase;\n            margin-bottom: 20px;\n            border: 0.5px solid #E2D4BB;\n        }\n\n        .promo-label-icon {\n            width: 16px;\n            height: 16px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: var(--dark-violet);\n        }\n\n        .promo-label-icon svg {\n            width: 16px;\n            height: 16px;\n        }\n\n        .main-title {\n            font-family: var(--font_main);\n            font-size: 30px;\n            font-weight: 500;\n            color: var(--brown-saturated);\n            margin: 0 0 14px 0;\n            line-height: 1.3;\n        }\n\n        .main-title .italic {\n            font-style: italic;\n        }\n\n        .subtitle {\n            font-family: var(--font_main);\n            font-size: 16px;\n            color: var(--brown-saturated);\n            margin: 0;\n            font-weight: 400;\n            line-height: 1.34;\n        }\n\n        .pricing-grid {\n            display: flex;\n            justify-content: center;\n            gap: 14px;\n            margin-bottom: 20px;\n        }\n\n        .pricing-card {\n            background: white;\n            padding: 0;\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n            position: relative;\n            overflow: hidden;\n            flex: 0 0 auto;\n            width: 239px;\n            border: 0.7px solid var(--border-gray);\n            border-radius: 10px;\n        }\n\n        .pricing-card:hover {\n            z-index: 1;\n        }\n\n        .pricing-card.featured {\n            background: #F9F7F7;\n            border-color: #E2D4BB;\n            border-width: 1px;\n            border-radius: 8px;\n        }\n\n        .card-badge {\n            background: var(--bg-card-header);\n            color: var(--brown-saturated);\n            text-align: center;\n            padding: 8.5px 7px;\n            font-size: 10px;\n            font-weight: 500;\n            letter-spacing: 0.79px;\n            text-transform: uppercase;\n            border-bottom: none;\n            height: 25px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .card-badge.featured-badge {\n            background: #E2D4BB;\n            color: var(--brown-saturated);\n            height: 25px;\n        }\n\n        .card-header {\n            padding: 38px 38px 0 38px;\n            text-align: center;\n        }\n\n        .plan-name {\n            font-family: var(--font_main);\n            font-size: 14.57px;\n            font-weight: 500;\n            color: var(--brown-saturated);\n            margin-bottom: 22.6px;\n            letter-spacing: -0.29px;\n            line-height: 1.2;\n        }\n\n        .price-display {\n            display: flex;\n            align-items: baseline;\n            justify-content: center;\n            gap: 4px;\n            margin-bottom: 13px;\n            font-family: var(--font_serif);\n            letter-spacing: -1.35px;\n        }\n\n        .original-price {\n            font-family: var(--font_serif);\n            font-size: 49px;\n            color: var(--brown-saturated);\n            opacity: 0.3;\n            text-decoration: line-through;\n            font-weight: 400;\n            line-height: 1.34;\n        }\n\n        .original-price .currency-small {\n            font-size: 23px;\n            text-decoration: none;\n            display: inline-block;\n        }\n\n        .current-price {\n            display: flex;\n            align-items: baseline;\n            font-family: var(--font_serif);\n        }\n\n        .currency {\n            font-family: var(--font_serif);\n            font-size: 23px;\n            color: var(--brown-saturated);\n            line-height: 1.34;\n        }\n\n        .price {\n            font-family: var(--font_serif);\n            font-size: 49px;\n            font-weight: 400;\n            color: var(--brown-saturated);\n            line-height: 1.34;\n        }\n\n        .billing-period {\n            font-family: var(--font_main);\n            font-size: 10px;\n            color: var(--gray-text);\n            margin-top: 0;\n            line-height: 1.64;\n        }\n\n        .cta-button {\n            width: 162px;\n            height: 38px;\n            margin: 22.6px auto 10.6px auto;\n            padding: 0 22px;\n            background: white;\n            color: #000000;\n            border: 0.7px solid #c9cac1;\n            font-family: var(--font_main);\n            font-size: 10px;\n            letter-spacing: 0.79px;\n            text-transform: uppercase;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            font-weight: 500;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            border-radius: 2px;\n        }\n\n        .cta-button:hover {\n            background: #F9F7F7;\n            color: #000000;\n            border-color: #c9cac1;\n        }\n\n        .featured .cta-button {\n            background: #222222;\n            border-color: #222222;\n            color: white;\n        }\n\n        .featured .cta-button:hover {\n            background: #444444;\n            border-color: #444444;\n        }\n\n        .cta-button.current-plan {\n            background: #f0f0f0;\n            border-color: #ccc;\n            color: #999;\n            cursor: default;\n        }\n\n        .savings-text {\n            text-align: center;\n            font-family: var(--font_main);\n            font-size: 8.5px;\n            color: var(--gray-text);\n            margin: 0 20px 22.6px 20px;\n            line-height: 1.64;\n        }\n\n        .savings-text .savings-amount {\n            color: var(--brown-saturated);\n            font-weight: 500;\n        }\n\n        .features-list {\n            padding: 0 38px 38px 38px;\n            list-style: none;\n            margin: 0;\n        }\n\n        .features-title {\n            font-family: var(--font_main);\n            font-size: 11.3px;\n            font-weight: 700;\n            color: var(--brown-saturated);\n            margin-bottom: 8.5px;\n            text-align: left;\n            line-height: 1.34;\n        }\n\n        .feature-item {\n            padding: 0;\n            margin-bottom: 8.5px;\n            font-family: var(--font_main);\n            font-size: 11.3px;\n            line-height: 1.34;\n            color: var(--brown-saturated);\n            display: flex;\n            align-items: center;\n        }\n\n        .feature-item:last-child {\n            margin-bottom: 0;\n        }\n\n        .feature-item .feature-icon {\n            color: #888;\n            font-weight: 400;\n            flex-shrink: 0;\n            width: 9.866px;\n            height: 6.83px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            margin-right: 8.5px;\n        }\n\n        .feature-item .feature-icon svg {\n            width: 9.866px;\n            height: 6.83px;\n        }\n\n\n        .feature-value {\n            font-family: var(--font_main);\n            font-size: 11.3px;\n            line-height: 1.34;\n            color: var(--brown-saturated);\n            font-weight: 500;\n            margin-right: 4px;\n        }\n\n        .feature-sublabel {\n            font-family: var(--font_main);\n            font-size: 11.3px;\n            line-height: 1.34;\n            color: var(--brown-saturated);\n            font-weight: 400;\n        }\n\n        /* FAQ Section */\n        .faq-section {\n            background: #ffffff;\n            padding: 20px 20px 80px;\n            margin-top: 0;\n        }\n\n        .faq-container {\n            max-width: 700px;\n            margin: 0 auto;\n        }\n\n        .faq-title {\n            font-family: var(--font_main);\n            font-size: 26px;\n            font-weight: 500;\n            color: #000000;\n            margin: 0 0 30px 0;\n            line-height: normal;\n            text-align: left;\n        }\n\n        .faq-list {\n            list-style: none;\n            margin: 0;\n            padding: 0;\n        }\n\n        .faq-item {\n            border-bottom: 1px solid #e5e5e5;\n        }\n\n        .faq-question {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: 20px 0;\n            cursor: pointer;\n            background: transparent;\n            border: none;\n            width: 100%;\n            text-align: left;\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;\n            font-size: 15px;\n            color: var(--brown-saturated);\n            line-height: 1.4;\n        }\n\n        .faq-question:hover {\n            color: var(--gray-text);\n        }\n\n        .faq-icon {\n            font-size: 20px;\n            color: #999;\n            flex-shrink: 0;\n            margin-left: 20px;\n            transition: transform 0.3s ease;\n        }\n\n        .faq-item.expanded .faq-icon {\n            transform: rotate(45deg);\n        }\n\n        .faq-answer {\n            max-height: 0;\n            overflow: hidden;\n            transition: max-height 0.3s ease, padding 0.3s ease;\n        }\n\n        .faq-answer-content {\n            padding: 0 0 20px 0;\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;\n            font-size: 14px;\n            color: var(--gray-text);\n            line-height: 1.6;\n        }\n\n        .faq-item.expanded .faq-answer {\n            max-height: 500px;\n        }\n\n        @media (max-width: 768px) {\n            .pricing-grid {\n                flex-direction: column;\n                align-items: center;\n            }\n\n            .pricing-card {\n                width: 100%;\n                max-width: 280px;\n            }\n\n            .main-title {\n                font-size: 24px;\n            }\n\n            .price {\n                font-size: 42px;\n            }\n\n            .faq-title {\n                font-size: 28px;\n            }\n\n            .faq-question {\n                font-size: 14px;\n            }\n        }\n    </style>\n</head>\n\n<body>\n    <div id=\"app-root\">\n        <div class=\"pricing-container\">\n            <div class=\"header-section\">\n                <div class=\"promo-label\">\n                    <span class=\"promo-label-icon\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M2 12L1 4.5L5 7.5L8 2L11 7.5L15 4.5L14 12H2Z\" stroke=\"#222222\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n                    <span id=\"promo-label\"></span>\n                </div>\n                <h1 class=\"main-title\" id=\"main-title\"></h1>\n                <p class=\"subtitle\" id=\"subtitle\"></p>\n            </div>\n\n            <div class=\"pricing-grid\" id=\"pricing-grid\">\n                <!-- Pricing cards will be inserted here -->\n            </div>\n\n        </div>\n\n        <!-- FAQ Section -->\n        <div class=\"faq-section\" id=\"faq-section\">\n            <div class=\"faq-container\">\n                <h2 class=\"faq-title\" id=\"faq-title\">FAQs</h2>\n                <ul class=\"faq-list\" id=\"faq-list\">\n                    <!-- FAQ items will be inserted here -->\n                </ul>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        (function() {\n        let currentState = null;\n        let loadedFontUrls = new Set(); // Track which font URLs have been loaded\n\n        // Load font from URL and set CSS variables\n        function loadFonts(fonts) {\n            if (!fonts || !Array.isArray(fonts)) return;\n\n            fonts.forEach(font => {\n                // Load font CSS if not already loaded\n                if (font.url && !loadedFontUrls.has(font.url)) {\n                    const link = document.createElement('link');\n                    link.rel = 'stylesheet';\n                    link.href = font.url;\n                    document.head.appendChild(link);\n                    loadedFontUrls.add(font.url);\n                }\n\n                // Set CSS variable for this font\n                if (font.id && font.family) {\n                    const varName = `--font_${font.id}`;\n                    document.documentElement.style.setProperty(varName, `\"${font.family}\", sans-serif`);\n\n                    // Set font-style variable if provided\n                    if (font.style) {\n                        document.documentElement.style.setProperty(`${varName}_style`, font.style);\n                    }\n\n                    // Set font-weight variable if provided\n                    if (font.weight) {\n                        document.documentElement.style.setProperty(`${varName}_weight`, font.weight.toString());\n                    }\n                }\n            });\n        }\n\n        // Default content configuration\n        const defaultContent = {\n            promoLabel: 'UPGRADE YOUR PLAN',\n            mainTitle: 'More Tools. More Possibilities.',\n            subtitle: 'Choose the Plan That Fits You Best',\n            cards: {\n                professional: {\n                    name: 'Professional',\n                    badge: '',\n                    badgeType: 'default',\n                    buttonLabel: 'UPGRADE',\n                    currentPlanLabel: 'CURRENT PLAN',\n                    featuresTitle: '',\n                    features: [\n                        { label: '100GB', sublabel: 'Photo Storage' },\n                        { label: '30GB', sublabel: 'Video Storage' },\n                        { label: 'Slideshow Creator', sublabel: '' },\n                        { label: 'Blog Builder & SEO Tools', sublabel: '' },\n                        { label: 'Vendor Network', sublabel: '' },\n                        { label: 'AI Search for Photographers', sublabel: '' },\n                        { label: '& much more', sublabel: '' }\n                    ],\n                    savingsTextTemplate: 'Upgrade to {plan} for {savings} less'\n                },\n                advanced: {\n                    name: 'Advanced',\n                    badge: 'MOST POPULAR',\n                    badgeType: 'featured',\n                    buttonLabel: 'UPGRADE',\n                    currentPlanLabel: 'CURRENT PLAN',\n                    featuresTitle: 'All Professional features plus:',\n                    features: [\n                        { label: 'Unlimited', sublabel: 'Photo Storage' },\n                        { label: '60GB', sublabel: 'Video Storage' },\n                        { label: 'AI Face Search for Clients', sublabel: '' },\n                        { label: '10K Licensed Music Tracks for Slideshows', sublabel: '' },\n                        { label: '& much more', sublabel: '' }\n                    ],\n                    savingsTextTemplate: 'Upgrade to {plan} for {savings} less'\n                }\n            },\n            currency: '$',\n            billingPeriodLabel: 'per month, billed yearly',\n            faqTitle: 'FAQs',\n            faqs: [\n                { question: 'What happens when I upgrade my plan?', answer: 'When you upgrade, regardless of whether you are adding on more time to your current plan, or upgrading to a new plan, you will: Be charged immediately. Get 1 year of the new plan added to your subscription. Be upgraded to the new plan right away, and whatever remaining time you had on your current subscription is converted to the new subscription, with your subscription expiration adjusted to account for the price difference.' },\n                { question: 'How do I Retrieve Invoices for the Plan Subscription?', answer: 'When the photographer\\'s credit card is charged for the plan subscription or the product/shipping cost, the receipts are saved under \\'Billing\\' in the Settings tab. The invoices can be easily printed or saved as PDF files at any time. Please allow a few days for the invoices to prepare once the card is charged.' },\n                { question: 'How do I check my subscription plan details?', answer: 'To check the details and features of your subscription plan, go to Settings from the Main Dashboard. In the Plans & Billing tab, you can see your current subscription and when your next subscription payment will be. If you want to see past payments, click View Billing History. Click Manage next to your current subscription to upgrade and view all the features and details of your subscription.' },\n                { question: 'Unlimited Storage Accounts', answer: 'The Pic-Time Advanced plan includes unlimited storage, but it\\'s designed for individual photographers\\' business only (see our Terms of Service). We monitor usage to make sure the service is used as intended. If your usage exceeds the fair limits (more than 20GB per gallery and 100 GB of bandwidth per month), additional fees may apply. We offer custom plans for accounts that serve more than one photographer (e.g., agencies or teams). Please fill in our Agency Inquiry Form, and our support team will be in touch.' },\n                { question: 'Need Help? Here\\'s How to Reach Us', answer: 'The Pic-Time support team works 24 hours a day, 7 days a week. We have agents working around the world, covering all time zones and working through the weekends. First, check out our Help Center. If you don\\'t find what you need contact our support team via the chat widget or email support@pic-time.com. We\\'re here to help whenever you need and on any question.' }\n            ]\n        };\n\n        function getContent(data) {\n            // Deep merge content with defaults\n            const content = data.content || {};\n            return {\n                promoLabel: content.promoLabel ?? defaultContent.promoLabel,\n                mainTitle: content.mainTitle ?? defaultContent.mainTitle,\n                subtitle: content.subtitle ?? defaultContent.subtitle,\n                cards: {\n                    professional: {\n                        name: content.cards?.professional?.name ?? defaultContent.cards.professional.name,\n                        badge: content.cards?.professional?.badge ?? defaultContent.cards.professional.badge,\n                        badgeType: content.cards?.professional?.badgeType ?? defaultContent.cards.professional.badgeType,\n                        buttonLabel: content.cards?.professional?.buttonLabel ?? defaultContent.cards.professional.buttonLabel,\n                        currentPlanLabel: content.cards?.professional?.currentPlanLabel ?? defaultContent.cards.professional.currentPlanLabel,\n                        featuresTitle: content.cards?.professional?.featuresTitle ?? defaultContent.cards.professional.featuresTitle,\n                        features: content.cards?.professional?.features ?? defaultContent.cards.professional.features,\n                        savingsTextTemplate: content.cards?.professional?.savingsTextTemplate ?? defaultContent.cards.professional.savingsTextTemplate\n                    },\n                    advanced: {\n                        name: content.cards?.advanced?.name ?? defaultContent.cards.advanced.name,\n                        badge: content.cards?.advanced?.badge ?? defaultContent.cards.advanced.badge,\n                        badgeType: content.cards?.advanced?.badgeType ?? defaultContent.cards.advanced.badgeType,\n                        buttonLabel: content.cards?.advanced?.buttonLabel ?? defaultContent.cards.advanced.buttonLabel,\n                        currentPlanLabel: content.cards?.advanced?.currentPlanLabel ?? defaultContent.cards.advanced.currentPlanLabel,\n                        featuresTitle: content.cards?.advanced?.featuresTitle ?? defaultContent.cards.advanced.featuresTitle,\n                        features: content.cards?.advanced?.features ?? defaultContent.cards.advanced.features,\n                        savingsTextTemplate: content.cards?.advanced?.savingsTextTemplate ?? defaultContent.cards.advanced.savingsTextTemplate\n                    }\n                },\n                currency: content.currency ?? defaultContent.currency,\n                billingPeriodLabel: content.billingPeriodLabel ?? defaultContent.billingPeriodLabel,\n                faqTitle: content.faqTitle ?? defaultContent.faqTitle,\n                faqs: content.faqs ?? defaultContent.faqs\n            };\n        }\n\n        function buildFaqItem(faq, index) {\n            return `\n                <li class=\"faq-item\" data-faq-index=\"${index}\">\n                    <button class=\"faq-question\" type=\"button\">\n                        <span>${faq.question}</span>\n                        <span class=\"faq-icon\">+</span>\n                    </button>\n                    <div class=\"faq-answer\">\n                        <div class=\"faq-answer-content\">${faq.answer}</div>\n                    </div>\n                </li>\n            `;\n        }\n\n        function buildSavingsText(cardContent, pricing, content) {\n            if (!cardContent.savingsTextTemplate || !pricing.originalYearly || pricing.originalYearly === pricing.yearly) {\n                return '';\n            }\n\n            // Calculate yearly savings (original - discounted, multiplied by 12 for full year)\n            const yearlySavings = (pricing.originalYearly - pricing.yearly) * 12;\n            if (yearlySavings <= 0) return '';\n\n            const savingsFormatted = `${content.currency}${yearlySavings}`;\n\n            // Replace placeholders in template\n            const text = cardContent.savingsTextTemplate\n                .replace('{plan}', cardContent.name)\n                .replace('{savings}', `<span class=\"savings-amount\">${savingsFormatted}</span>`);\n\n            return `<div class=\"savings-text\">${text}</div>`;\n        }\n\n        // SVG icons\n        const checkmarkIcon = `<svg width=\"9.866\" height=\"6.83\" viewBox=\"0 0 10 7\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M1 3.5L3.5 6L9 1\" stroke=\"#222222\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>`;\n\n        const lineIcon = `<svg width=\"10\" height=\"7\" viewBox=\"0 0 10 7\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M1 3.5H9\" stroke=\"#54033c\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n        </svg>`;\n\n        const plusIcon = `<svg width=\"9\" height=\"9\" viewBox=\"0 0 9 9\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M4.5 1V8M1 4.5H8\" stroke=\"#54033c\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n        </svg>`;\n\n        function buildPricingCard(plan, data, content, parsedPricing) {\n            const cardContent = content.cards[plan];\n            const isCurrent = getTierFromPlan(plan) === data.subscription;\n            const isFeatured = cardContent.badgeType === 'featured';\n            const pricing = parsedPricing[plan] || getDefaultPricing(plan);\n            const features = cardContent.features;\n\n            // Badge HTML - always show for featured, show empty header for non-featured\n            let badgeHTML = '';\n            if (isFeatured) {\n                badgeHTML = `<div class=\"card-badge featured-badge\">${cardContent.badge}</div>`;\n            } else {\n                // Empty header for non-featured cards (like Figma design)\n                badgeHTML = `<div class=\"card-badge\"></div>`;\n            }\n\n            // Build price display with original price on left (strikethrough) and current price on right\n            let priceHTML = '';\n            if (pricing.originalYearly && pricing.originalYearly !== pricing.yearly) {\n                priceHTML = `\n                    <span class=\"original-price\"><span class=\"currency-small\">${content.currency}</span>${pricing.originalYearly}</span>\n                    <span class=\"current-price\">\n                        <span class=\"currency\">${content.currency}</span><span class=\"price\">${pricing.yearly}</span>\n                    </span>\n                `;\n            } else {\n                priceHTML = `\n                    <span class=\"current-price\">\n                        <span class=\"currency\">${content.currency}</span><span class=\"price\">${pricing.yearly}</span>\n                    </span>\n                `;\n            }\n\n            // Choose icon based on card type\n            // Use checkmark icon for all cards (vi icon)\n            const featureIcon = checkmarkIcon;\n\n            let cardHTML = `\n                <div class=\"pricing-card ${isFeatured ? 'featured' : ''}\">\n                    ${badgeHTML}\n\n                    <div class=\"card-header\">\n                        <div class=\"plan-name\">${cardContent.name}</div>\n                        <div class=\"price-display\">\n                            ${priceHTML}\n                        </div>\n                        <div class=\"billing-period\">${content.billingPeriodLabel}</div>\n                    </div>\n\n                    <button class=\"cta-button ${isCurrent ? 'current-plan' : ''}\"\n                            data-plan=\"${plan}\"\n                            data-tier=\"${getTierFromPlan(plan)}\"\n                            data-price=\"${pricing.yearly}\">\n                        ${isCurrent ? cardContent.currentPlanLabel : cardContent.buttonLabel}\n                    </button>\n\n                    ${buildSavingsText(cardContent, pricing, content)}\n\n                    <div class=\"features-list\">\n                        ${cardContent.featuresTitle ? `<div class=\"features-title\">${cardContent.featuresTitle}</div>` : ''}\n                        <ul style=\"list-style: none; margin: 0; padding: 0;\">\n                        ${features.map((f, index) => {\n                            // Check if this is the \"& much more\" item - no icon for this\n                            const isMoreItem = f.label === '& much more';\n                            const icon = isMoreItem ? '' : featureIcon;\n                            const moreClass = isMoreItem ? ' more-item' : '';\n                            return `\n                            <li class=\"feature-item${moreClass}\">\n                                <span class=\"feature-icon\">${icon}</span>\n                                <span class=\"feature-value\">${f.label}</span>${f.sublabel ? `\t<span class=\"feature-sublabel\">${f.sublabel}</span>` : ''}\n                            </li>\n                        `}).join('')}\n                        </ul>\n                    </div>\n                </div>\n            `;\n\n            return cardHTML;\n        }\n\n        function getTierFromPlan(plan) {\n            const tierMap = {\n                'professional': 10,\n                'advanced': 20\n            };\n            return tierMap[plan];\n        }\n\n        function getDefaultPricing(plan) {\n            const defaults = {\n                professional: { monthly: 21, yearly: 15, originalYearly: 21 },\n                advanced: { monthly: 42, yearly: 29, originalYearly: 42 }\n            };\n            return defaults[plan];\n        }\n\n        function parsePricing(pricingArray) {\n            const tierMap = { 10: 'professional', 20: 'advanced' };\n            const result = {};\n\n            if (!Array.isArray(pricingArray)) return result;\n\n            for (const entry of pricingArray) {\n                const planName = tierMap[entry.subscription];\n                if (!planName) continue;\n\n                if (!result[planName]) {\n                    result[planName] = {};\n                }\n\n                if (entry.collectInterval === 0) {\n                    // Monthly\n                    result[planName].monthly = entry.amount;\n                } else if (entry.collectInterval === 10) {\n                    // Yearly - divide by 12 to get per-month price\n                    result[planName].yearly = Math.round(entry.amount / 12);\n                    result[planName].originalYearly = Math.round(entry.fullPaymentAmount / 12);\n                }\n            }\n\n            return result;\n        }\n\n        function render(data) {\n            currentState = data;\n            const content = getContent(data);\n\n            // Load and apply fonts from the fonts array\n            loadFonts(data.fonts);\n\n            // Update header section\n            document.getElementById('promo-label').textContent = content.promoLabel;\n            document.getElementById('main-title').textContent = content.mainTitle;\n            document.getElementById('subtitle').textContent = content.subtitle;\n\n            // Parse pricing array into per-plan format\n            const parsedPricing = parsePricing(data.pricing);\n\n            // Build pricing cards\n            const grid = document.getElementById('pricing-grid');\n            const plans = ['professional', 'advanced'];\n            grid.innerHTML = plans.map(plan => buildPricingCard(plan, data, content, parsedPricing)).join('');\n\n            // Build FAQ section\n            document.getElementById('faq-title').textContent = content.faqTitle;\n            const faqList = document.getElementById('faq-list');\n            if (content.faqs && content.faqs.length > 0) {\n                faqList.innerHTML = content.faqs.map((faq, index) => buildFaqItem(faq, index)).join('');\n                document.getElementById('faq-section').style.display = 'block';\n            } else {\n                document.getElementById('faq-section').style.display = 'none';\n            }\n\n            // Attach event listeners\n            attachEventListeners();\n        }\n\n        function attachEventListeners() {\n            const buttons = document.querySelectorAll('.cta-button:not(.current-plan)');\n            buttons.forEach(button => {\n                button.addEventListener('click', function() {\n                    const plan = this.getAttribute('data-plan');\n                    const tier = parseInt(this.getAttribute('data-tier'));\n                    const price = parseFloat(this.getAttribute('data-price'));\n\n                    window.myop_cta_handler('subscription-selected', {\n                        plan: plan,\n                        tier: tier,\n                        price: price\n                    });\n                });\n            });\n\n            // FAQ accordion functionality\n            const faqQuestions = document.querySelectorAll('.faq-question');\n            faqQuestions.forEach(question => {\n                question.addEventListener('click', function() {\n                    const faqItem = this.closest('.faq-item');\n                    const isExpanded = faqItem.classList.contains('expanded');\n\n                    // Close all other FAQs\n                    document.querySelectorAll('.faq-item.expanded').forEach(item => {\n                        item.classList.remove('expanded');\n                    });\n\n                    // Toggle current FAQ\n                    if (!isExpanded) {\n                        faqItem.classList.add('expanded');\n                    }\n                });\n            });\n        }\n\n        // Public API - must be defined at top level\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n            console.log('CTA:', action_id, payload);\n        };\n    })();\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            lang: 'en',\n            fonts: [\n                {\n                    id: 'main',\n                    family: 'TT Norms Pro',\n                    style: 'normal',\n                    weight: 400,\n                    url: 'https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css'\n                }\n            ],\n            subscription: 0, // Current subscription: Free (no plan)\n            pricing: [\n                { fullPaymentAmount: 252, amount: 180, subscription: 10, collectInterval: 10 },  // Professional yearly: $21->$15/mo\n                { fullPaymentAmount: 504, amount: 348, subscription: 20, collectInterval: 10 } // Advanced yearly: $42->$29/mo\n            ],\n            content: {\n                promoLabel: 'UPGRADE YOUR PLAN',\n                mainTitle: 'More Tools. More Possibilities.',\n                subtitle: 'Choose the Plan That Fits You Best',\n                cards: {\n                    professional: {\n                        name: 'Professional',\n                        badge: '',\n                        badgeType: 'default',\n                        buttonLabel: 'UPGRADE',\n                        currentPlanLabel: 'CURRENT PLAN',\n                        featuresTitle: '',\n                        features: [\n                            { label: '100GB', sublabel: 'Photo Storage' },\n                            { label: '30GB', sublabel: 'Video Storage' },\n                            { label: 'Slideshow Creator', sublabel: '' },\n                            { label: 'Blog Builder & SEO Tools', sublabel: '' },\n                            { label: 'Vendor Network', sublabel: '' },\n                            { label: 'AI Search for Photographers', sublabel: '' },\n                            { label: '& much more', sublabel: '' }\n                        ],\n                        savingsTextTemplate: 'Upgrade to {plan} for {savings} less'\n                    },\n                    advanced: {\n                        name: 'Advanced',\n                        badge: 'MOST POPULAR',\n                        badgeType: 'featured',\n                        buttonLabel: 'UPGRADE',\n                        currentPlanLabel: 'CURRENT PLAN',\n                        featuresTitle: 'All Professional features plus:',\n                        features: [\n                            { label: 'Unlimited', sublabel: 'Photo Storage' },\n                            { label: '60GB', sublabel: 'Video Storage' },\n                            { label: 'AI Face Search for Clients', sublabel: '' },\n                            { label: '10K Licensed Music Tracks for Slideshows', sublabel: '' },\n                            { label: '& much more', sublabel: '' }\n                        ],\n                        savingsTextTemplate: 'Upgrade to {plan} for {savings} less'\n                    }\n                },\n                currency: '$',\n                billingPeriodLabel: 'per month, billed yearly',\n                faqTitle: 'FAQs',\n                faqs: [\n                    { question: 'What happens when I upgrade my plan?', answer: 'When you upgrade, regardless of whether you are adding on more time to your current plan, or upgrading to a new plan, you will: Be charged immediately. Get 1 year of the new plan added to your subscription. Be upgraded to the new plan right away, and whatever remaining time you had on your current subscription is converted to the new subscription, with your subscription expiration adjusted to account for the price difference.' },\n                    { question: 'How do I Retrieve Invoices for the Plan Subscription?', answer: 'When the photographer\\'s credit card is charged for the plan subscription or the product/shipping cost, the receipts are saved under \\'Billing\\' in the Settings tab. The invoices can be easily printed or saved as PDF files at any time. Please allow a few days for the invoices to prepare once the card is charged.' },\n                    { question: 'How do I check my subscription plan details?', answer: 'To check the details and features of your subscription plan, go to Settings from the Main Dashboard. In the Plans & Billing tab, you can see your current subscription and when your next subscription payment will be. If you want to see past payments, click View Billing History. Click Manage next to your current subscription to upgrade and view all the features and details of your subscription.' },\n                    { question: 'Unlimited Storage Accounts', answer: 'The Pic-Time Advanced plan includes unlimited storage, but it\\'s designed for individual photographers\\' business only (see our Terms of Service). We monitor usage to make sure the service is used as intended. If your usage exceeds the fair limits (more than 20GB per gallery and 100 GB of bandwidth per month), additional fees may apply. We offer custom plans for accounts that serve more than one photographer (e.g., agencies or teams). Please fill in our Agency Inquiry Form, and our support team will be in touch.' },\n                    { question: 'Need Help? Here\\'s How to Reach Us', answer: 'The Pic-Time support team works 24 hours a day, 7 days a week. We have agents working around the world, covering all time zones and working through the weekends. First, check out our Help Center. If you don\\'t find what you need contact our support team via the chat widget or email support@pic-time.com. We\\'re here to help whenever you need and on any question.' }\n                ]\n            }\n        });\n    </script>\n</body>\n\n</html>"
        }
      }
