0.5756 50.5675C50.6882 50.6912 50.8408 50.7608 50.9999 50.7608C51.4773 50.7608 51.9351 50.9694 52.2727 51.3407C52.6103 51.712 52.7999 52.2157 52.7999 52.7408C52.7999 52.9158 52.8631 53.0837 52.9756 53.2075C53.0882 53.3312 53.2408 53.4008 53.3999 53.4008C53.559 53.4008 53.7116 53.3312 53.8242 53.2075C53.9367 53.0837 53.9999 52.9158 53.9999 52.7408C53.9999 52.2157 54.1895 51.712 54.5271 51.3407C54.8647 50.9694 55.3225 50.7608 55.7999 50.7608C55.959 50.7608 56.1116 50.6912 56.2242 50.5675C56.3367 50.4437 56.3999 50.2758 56.3999 50.1008C56.3999 49.9257 56.3367 49.7579 56.2242 49.6341C56.1116 49.5103 55.959 49.4408 55.7999 49.4408Z\" fill=\"url(#sparkle2_grad)\"/>\n                    <path class=\"sparkle sparkle-3\" d=\"M12.5997 26.0423C12.1223 26.0423 11.6645 25.8337 11.3269 25.4624C10.9893 25.0911 10.7997 24.5875 10.7997 24.0623C10.7997 23.8873 10.7365 23.7194 10.624 23.5957C10.5114 23.4719 10.3588 23.4023 10.1997 23.4023C10.0406 23.4023 9.88797 23.4719 9.77544 23.5957C9.66292 23.7194 9.59971 23.8873 9.59971 24.0623C9.59971 24.5875 9.41006 25.0911 9.0725 25.4624C8.73493 25.8337 8.2771 26.0423 7.79971 26.0423C7.64058 26.0423 7.48796 26.1119 7.37544 26.2357C7.26292 26.3594 7.19971 26.5273 7.19971 26.7023C7.19971 26.8774 7.26292 27.0453 7.37544 27.169C7.48796 27.2928 7.64058 27.3623 7.79971 27.3623C8.2771 27.3623 8.73493 27.5709 9.0725 27.9423C9.41006 28.3136 9.59971 28.8172 9.59971 29.3423C9.59971 29.5174 9.66292 29.6853 9.77544 29.809C9.88797 29.9328 10.0406 30.0023 10.1997 30.0023C10.3588 30.0023 10.5114 29.9328 10.624 29.809C10.7365 29.6853 10.7997 29.5174 10.7997 29.3423C10.7997 28.8172 10.9893 28.3136 11.3269 27.9423C11.6645 27.5709 12.1223 27.3623 12.5997 27.3623C12.7588 27.3623 12.9114 27.2928 13.024 27.169C13.1365 27.0453 13.1997 26.8774 13.1997 26.7023C13.1997 26.5273 13.1365 26.3594 13.024 26.2357C12.9114 26.1119 12.7588 26.0423 12.5997 26.0423Z\" fill=\"url(#sparkle3_grad)\"/>\n                    <path class=\"sparkle sparkle-4\" d=\"M52.4999 3.84C51.7838 3.84 51.0971 3.53657 50.5907 2.99647C50.0844 2.45636 49.7999 1.72382 49.7999 0.96C49.7999 0.705392 49.7051 0.461213 49.5363 0.281178C49.3675 0.101143 49.1386 0 48.8999 0C48.6612 0 48.4323 0.101143 48.2635 0.281178C48.0947 0.461213 47.9999 0.705392 47.9999 0.96C47.9999 1.72382 47.7154 2.45636 47.2091 2.99647C46.7027 3.53657 46.016 3.84 45.2999 3.84C45.0612 3.84 44.8323 3.94114 44.6635 4.12118C44.4947 4.30121 44.3999 4.54539 44.3999 4.8C44.3999 5.05461 44.4947 5.29879 44.6635 5.47882C44.8323 5.65886 45.0612 5.76 45.2999 5.76C46.016 5.76 46.7027 6.06343 47.2091 6.60353C47.7154 7.14364 47.9999 7.87618 47.9999 8.64C47.9999 8.89461 48.0947 9.13879 48.2635 9.31882C48.4323 9.49886 48.6612 9.6 48.8999 9.6C49.1386 9.6 49.3675 9.49886 49.5363 9.31882C49.7051 9.13879 49.7999 8.89461 49.7999 8.64C49.7999 7.87618 50.0844 7.14364 50.5907 6.60353C51.0971 6.06343 51.7838 5.76 52.4999 5.76C52.7386 5.76 52.9675 5.65886 53.1363 5.47882C53.3051 5.29879 53.3999 5.05461 53.3999 4.8C53.3999 4.54539 53.3051 4.30121 53.1363 4.12118C52.9675 3.94114 52.7386 3.84 52.4999 3.84Z\" fill=\"url(#sparkle4_grad)\"/>\n                </svg>\n                \n                <!-- Diamond layer (rotates) -->\n                <svg class=\"diamond-icon\" width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <defs>\n                        <linearGradient id=\"paint0_linear\" x1=\"55.6\" y1=\"14.7999\" x2=\"47.6368\" y2=\"52.1087\" gradientUnits=\"userSpaceOnUse\">\n                            <stop offset=\"0.045\" stop-color=\"#FF7133\"/>\n                            <stop offset=\"0.945\" stop-color=\"#7C69FD\"/>\n                        </linearGradient>\n                        <linearGradient id=\"paint1_linear\" x1=\"10.4622\" y1=\"47.2544\" x2=\"29.8247\" y2=\"45.9531\" gradientUnits=\"userSpaceOnUse\">\n                            <stop stop-color=\"#F0E8FF\"/>\n                            <stop offset=\"0.783654\" stop-color=\"white\"/>\n                            <stop offset=\"0.966346\" stop-color=\"#FFEDE7\"/>\n                        </linearGradient>\n                        <linearGradient id=\"paint2_linear\" x1=\"41.121\" y1=\"47.8191\" x2=\"20.7769\" y2=\"67.4306\" gradientUnits=\"userSpaceOnUse\">\n                            <stop offset=\"0.08\" stop-color=\"#FF8651\"/>\n                            <stop offset=\"0.515337\" stop-color=\"#FFBEA8\"/>\n                            <stop offset=\"0.945\" stop-color=\"#A397F5\"/>\n                        </linearGradient>\n                        <linearGradient id=\"paint3_linear\" x1=\"38.7217\" y1=\"21.278\" x2=\"38.3764\" y2=\"40.1133\" gradientUnits=\"userSpaceOnUse\">\n                            <stop offset=\"0.08\" stop-color=\"#FF8651\"/>\n                            <stop offset=\"0.515337\" stop-color=\"#FFBEA8\"/>\n                            <stop offset=\"0.945\" stop-color=\"#A397F5\"/>\n                        </linearGradient>\n                        <linearGradient id=\"paint4_linear\" x1=\"40.9399\" y1=\"49.9404\" x2=\"18.5636\" y2=\"46.6708\" gradientUnits=\"userSpaceOnUse\">\n                            <stop offset=\"0.08\" stop-color=\"#FF8651\"/>\n                            <stop offset=\"0.515337\" stop-color=\"#FFBEA8\"/>\n                            <stop offset=\"0.945\" stop-color=\"#A397F5\"/>\n                        </linearGradient>\n                    </defs>\n                    <path d=\"M36.3631 5.16308C32.8488 1.64879 27.151 1.64879 23.6367 5.16308L14.3999 14.3999L7.28509 21.5147C2.5988 26.201 2.59879 33.799 7.28508 38.4853L21.5146 52.7148C26.2009 57.4011 33.7989 57.4011 38.4852 52.7148L52.7147 38.4853C57.401 33.799 57.401 26.201 52.7147 21.5147L45.6 14.3999L36.3631 5.16308Z\" stroke=\"url(#paint0_linear)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                    <rect x=\"11.5981\" y=\"30\" width=\"17.2544\" height=\"17.2544\" rx=\"8\" transform=\"rotate(-45 11.5981 30)\" fill=\"url(#paint1_linear)\" fill-opacity=\"0.4\"/>\n                    <rect opacity=\"0.4\" x=\"4.7998\" y=\"30\" width=\"35.6382\" height=\"35.6382\" rx=\"8\" transform=\"rotate(-45 4.7998 30)\" fill=\"url(#paint2_linear)\"/>\n                    <path opacity=\"0.4\" d=\"M18.8566 35.6569C15.7324 32.5327 15.7324 27.4673 18.8566 24.3431L24.3429 18.8569C27.467 15.7327 32.5324 15.7327 35.6566 18.8569L41.1428 24.3431C44.267 27.4673 44.267 32.5327 41.1428 35.6569L35.6566 41.1431C32.5324 44.2673 27.467 44.2673 24.3429 41.1431L18.8566 35.6569Z\" fill=\"url(#paint3_linear)\"/>\n                    <rect opacity=\"0.4\" x=\"20.9995\" y=\"30\" width=\"12.7279\" height=\"12.7279\" rx=\"6\" transform=\"rotate(-45 20.9995 30)\" fill=\"url(#paint4_linear)\"/>\n                </svg>\n            </div>\n            \n            <!-- Text Content -->\n            <div class=\"text-content\" id=\"textContent\">\n                <div class=\"primary-text\" id=\"primaryText\">Creating your component...</div>\n                <div class=\"secondary-text\" id=\"secondaryText\">\n                    <!-- Messages will be injected here -->\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        let currentState = {\n            primaryText: 'Creating your component...',\n            messages: [\n                'Setting up your layout and design',\n                'Styling and fine-tuning details',\n                'Testing everything under the hood',\n                'Making it fast and smooth',\n                'Getting your preview ready'\n            ],\n            finalMessage: 'Almost there, just final touches',\n            showFinalMessage: false\n        };\n        \n        let currentMessageIndex = 0;\n        let messageInterval = null;\n        let messageElements = [];\n        \n        function createMessageElements() {\n            const container = document.getElementById('secondaryText');\n            container.innerHTML = '';\n            messageElements = [];\n            \n            const allMessages = currentState.showFinalMessage \n                ? [currentState.finalMessage]\n                : currentState.messages;\n            \n            allMessages.forEach((msg, index) => {\n                const el = document.createElement('div');\n                el.className = 'message';\n                el.textContent = msg;\n                container.appendChild(el);\n                messageElements.push(el);\n            });\n            \n            // Set initial active\n            if (messageElements.length > 0) {\n                messageElements[0].classList.add('active');\n            }\n        }\n        \n        function rotateMessages() {\n            if (currentState.showFinalMessage || messageElements.length <= 1) return;\n            \n            const currentEl = messageElements[currentMessageIndex];\n            currentEl.classList.remove('active');\n            currentEl.classList.add('exit');\n            \n            currentMessageIndex = (currentMessageIndex + 1) % messageElements.length;\n            const nextEl = messageElements[currentMessageIndex];\n            \n            setTimeout(() => {\n                currentEl.classList.remove('exit');\n                nextEl.classList.add('active');\n            }, 300);\n        }\n        \n        function startMessageRotation() {\n            if (messageInterval) clearInterval(messageInterval);\n            if (!currentState.showFinalMessage && currentState.messages.length > 1) {\n                messageInterval = setInterval(rotateMessages, 3500);\n            }\n        }\n        \n        function render(data) {\n            if (data.primaryText !== undefined) {\n                currentState.primaryText = data.primaryText;\n            }\n            if (data.messages !== undefined) {\n                currentState.messages = data.messages;\n            }\n            if (data.finalMessage !== undefined) {\n                currentState.finalMessage = data.finalMessage;\n            }\n            if (data.showFinalMessage !== undefined) {\n                currentState.showFinalMessage = data.showFinalMessage;\n            }\n            \n            document.getElementById('primaryText').textContent = currentState.primaryText;\n            \n            const textContent = document.getElementById('textContent');\n            if (currentState.showFinalMessage) {\n                textContent.classList.add('final');\n            } else {\n                textContent.classList.remove('final');\n            }\n            \n            currentMessageIndex = 0;\n            createMessageElements();\n            startMessageRotation();\n        }\n        \n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            render(data);\n        };\n        \n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            primaryText: 'Creating your component...',\n            messages: [\n                'Setting up your layout and design',\n                'Styling and fine-tuning details',\n                'Testing everything under the hood',\n                'Making it fast and smooth',\n                'Getting your preview ready'\n            ],\n            finalMessage: 'Almost there, just final touches',\n            showFinalMessage: false\n        });\n        \n        // Demo: After 20 seconds, show final message\n        // setTimeout(() => {\n        //     window.myop_init_interface({ showFinalMessage: true });\n        // }, 20000);\n    </script>\n</body>\n</html>"
        }
      }
    ]
