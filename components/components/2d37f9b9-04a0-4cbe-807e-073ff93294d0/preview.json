      {
        "id": "16c0e7b6-ce75-4afa-8e4f-1a7549d7c86e",
        "name": "V3",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <title>Creating Component</title>\n    \n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n        primaryText?: string;\n        messages?: string[];\n        finalMessage?: string;\n        showFinalMessage?: boolean;\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n        'creation-complete': void;\n        'size-requested': {\n            width?: number | null;\n            height?: number | null;\n            minWidth?: number | null;\n            maxWidth?: number | null;\n            minHeight?: number | null;\n            maxHeight?: number | null;\n            required?: boolean;\n        };\n    }\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n    \n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&display=swap\" rel=\"stylesheet\">\n    \n    <style>\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n        \n        html, body {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n        }\n        \n        body {\n            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;\n            background: #FAFAFA;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n        \n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n        \n        .loading-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 32px;\n            padding: 40px;\n        }\n        \n        /* Diamond Icon Container */\n        .icon-wrapper {\n            position: relative;\n            width: 60px;\n            height: 60px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n        \n        /* Sparkles layer - stays completely still */\n        .sparkles-layer {\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            z-index: 2;\n        }\n\n        /* Individual sparkle fade animations */\n        .sparkle {\n            opacity: 0;\n        }\n\n        .sparkle-1 {\n            animation: fadeSparkle1 2.5s ease-in-out infinite;\n        }\n\n        .sparkle-2 {\n            animation: fadeSparkle2 3.2s ease-in-out infinite;\n            animation-delay: 0.8s;\n        }\n\n        .sparkle-3 {\n            animation: fadeSparkle3 2.8s ease-in-out infinite;\n            animation-delay: 1.5s;\n        }\n\n        .sparkle-4 {\n            animation: fadeSparkle4 3.5s ease-in-out infinite;\n            animation-delay: 0.3s;\n        }\n\n        @keyframes fadeSparkle1 {\n            0%, 100% { opacity: 0; }\n            30%, 70% { opacity: 1; }\n        }\n\n        @keyframes fadeSparkle2 {\n            0%, 100% { opacity: 0; }\n            25%, 75% { opacity: 1; }\n        }\n\n        @keyframes fadeSparkle3 {\n            0%, 100% { opacity: 0; }\n            35%, 65% { opacity: 1; }\n        }\n\n        @keyframes fadeSparkle4 {\n            0%, 100% { opacity: 0; }\n            20%, 80% { opacity: 1; }\n        }\n        \n        /* Main Diamond SVG - slow rotation */\n        .diamond-icon {\n            position: absolute;\n            width: 60px;\n            height: 60px;\n            animation: rotate 4s linear infinite;\n            filter: drop-shadow(0 8px 24px rgba(124, 105, 253, 0.3));\n            z-index: 1;\n        }\n        \n        @keyframes rotate {\n            0% {\n                transform: rotate(0deg);\n            }\n            100% {\n                transform: rotate(360deg);\n            }\n        }\n        \n        /* Text Content */\n        .text-content {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 12px;\n            text-align: center;\n        }\n        \n        .primary-text {\n            font-size: 20px;\n            font-weight: 500;\n            color: #1A1A1A;\n            letter-spacing: -0.02em;\n        }\n        \n        .secondary-text {\n            position: relative;\n            height: 24px;\n            min-width: 280px;\n            overflow: hidden;\n        }\n        \n        .message {\n            font-size: 15px;\n            font-weight: 400;\n            color: #6B6B6B;\n            letter-spacing: -0.01em;\n            position: absolute;\n            left: 0;\n            right: 0;\n            text-align: center;\n            opacity: 0;\n            transform: translateY(10px);\n            transition: opacity 0.4s ease, transform 0.4s ease;\n            white-space: nowrap;\n        }\n        \n        .message.active {\n            opacity: 1;\n            transform: translateY(0);\n        }\n        \n        .message.exit {\n            opacity: 0;\n            transform: translateY(-10px);\n        }\n        \n        /* Final state styling */\n        .text-content.final .secondary-text {\n            height: auto;\n        }\n        \n        .text-content.final .message.active {\n            color: #7C69FD;\n            font-weight: 500;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\">\n        <div class=\"loading-container\">\n            <!-- Animated Diamond Icon -->\n            <div class=\"icon-wrapper\">\n                <!-- Sparkles layer (doesn't rotate) -->\n                <svg class=\"sparkles-layer\" width=\"80\" height=\"80\" viewBox=\"0 0 60 60\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <defs>\n                        <linearGradient id=\"sparkle1_grad\" x1=\"39.9231\" y1=\"14.0016\" x2=\"35.3344\" y2=\"16.7056\" gradientUnits=\"userSpaceOnUse\">\n                            <stop offset=\"0.045\" stop-color=\"#FF7133\"/>\n                            <stop offset=\"0.945\" stop-color=\"#7C69FD\"/>\n                        </linearGradient>\n                        <linearGradient id=\"sparkle2_grad\" x1=\"57.323\" y1=\"51.2008\" x2=\"52.7343\" y2=\"53.9048\" gradientUnits=\"userSpaceOnUse\">\n                            <stop offset=\"0.045\" stop-color=\"#FF7133\"/>\n                            <stop offset=\"0.945\" stop-color=\"#7C69FD\"/>\n                        </linearGradient>\n                        <linearGradient id=\"sparkle3_grad\" x1=\"14.1228\" y1=\"27.8023\" x2=\"9.53411\" y2=\"30.5064\" gradientUnits=\"userSpaceOnUse\">\n                            <stop offset=\"0.045\" stop-color=\"#FF7133\"/>\n                            <stop offset=\"0.945\" stop-color=\"#7C69FD\"/>\n                        </linearGradient>\n                        <linearGradient id=\"sparkle4_grad\" x1=\"54.7845\" y1=\"6.4\" x2=\"48.0123\" y2=\"10.5154\" gradientUni