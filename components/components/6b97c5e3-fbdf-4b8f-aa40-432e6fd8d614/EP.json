        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!doctype html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\" />\r\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\r\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}' />\r\n    <title>Success - Price List Ready</title>\r\n    <script type=\"myop/types\">\r\n// =============================================================================\r\n// MYOP COMPONENT TYPE DEFINITIONS\r\n// =============================================================================\r\n\r\n/**\r\n * Font configuration object\r\n */\r\ninterface FontConfig {\r\n  /** Font identifier used for CSS variable naming (e.g., \"main\" -> --font_main) */\r\n  id: string;\r\n  /** Font family name */\r\n  family: string;\r\n  /** Font style (optional) */\r\n  style?: string;\r\n  /** Font weight (optional) */\r\n  weight?: number;\r\n  /** URL to font CSS file (optional) */\r\n  url?: string;\r\n}\r\n\r\n/**\r\n * Data structure passed to myop_init_interface(data)\r\n */\r\ninterface MyopInitData {\r\n  /** Array of font configurations */\r\n  fonts?: FontConfig[];\r\n  /** Dynamic data for template substitution */\r\n  data?: {\r\n    gallery_name?: string;\r\n  };\r\n  /** Localization strings */\r\n  lang?: {\r\n    title?: string;\r\n    subtitle?: string;\r\n    button?: string;\r\n    button_success?: string;\r\n    errorTitle?: string;\r\n    errorMessage?: string;\r\n  };\r\n}\r\n\r\n/**\r\n * Actions and payloads for myop_cta_handler(action, payload)\r\n */\r\ninterface MyopCtaPayloads {\r\n  'done_clicked': Record<string, never>;\r\n  'size-requested': {\r\n    width?: number | null;\r\n    height?: number | null;\r\n    minWidth?: number | null;\r\n    maxWidth?: number | null;\r\n    minHeight?: number | null;\r\n    maxHeight?: number | null;\r\n    required?: boolean;\r\n  };\r\n}\r\n\r\n// =============================================================================\r\n// DO NOT EDIT BELOW - Standard Myop type declarations\r\n// =============================================================================\r\n\r\ndeclare function myop_init_interface(): MyopInitData;\r\ndeclare function myop_init_interface(data: MyopInitData): void;\r\n\r\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\r\n  action: K,\r\n  payload: MyopCtaPayloads[K]\r\n): void;\r\n    </script>\r\n    <style>\r\n        :root {\r\n            --bg: #ffffff;\r\n            --text: #444444;\r\n            --muted: #6b6b6b;\r\n            --btn: #222;\r\n\r\n            /* Font variables - set via JS from fonts array */\r\n            --font_main: system-ui, -apple-system, sans-serif;\r\n            --font_main_style: normal;\r\n            --font_main_weight: 400;\r\n\r\n            /* Button Variables */\r\n            --1-Button-H-1-1-1-primary-button: #222;\r\n            --3-Text-H-3-5-1-inverted-color-text: #FFF;\r\n        }\r\n\r\n        * {\r\n            box-sizing: border-box;\r\n        }\r\n\r\n        html,\r\n        body {\r\n            width: 100%;\r\n            height: 100%;\r\n            margin: 0;\r\n            padding: 0;\r\n            overflow: hidden;\r\n        }\r\n\r\n        body {\r\n            background: var(--bg);\r\n            font-family: var(--font_main);\r\n            font-style: var(--font_main_style);\r\n            font-weight: var(--font_main_weight);\r\n            color: var(--text);\r\n        }\r\n\r\n        /* Stage */\r\n        .stage {\r\n            position: relative;\r\n            width: 100%;\r\n            height: 100%;\r\n            overflow: hidden;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n        }\r\n\r\n\r\n        /* Content */\r\n        .content {\r\n            position: relative;\r\n            z-index: 1;\r\n            text-align: center;\r\n            width: min(860px, 92vw);\r\n            transform: translateY(-38px);\r\n        }\r\n\r\n        .kicker {\r\n            color: #000;\r\n            text-align: center;\r\n            font-family: var(--font_main);\r\n            font-size: 32px;\r\n            font-style: var(--font_main_style);\r\n            font-weight: var(--font_main_weight);\r\n            line-height: 150%;\r\n            /* 48px */\r\n            margin: 0 0 24px;\r\n        }\r\n\r\n        .title {\r\n            color: #000;\r\n            text-align: center;\r\n            font-family: var(--font_main);\r\n            font-size: 50px;\r\n            font-style: var(--font_main_style);\r\n            font-weight: var(--font_main_weight);\r\n            line-height: 150%;\r\n            /* 75px */\r\n            margin: 0 0 18px;\r\n        }\r\n\r\n        .subtitle {\r\n            color: #000;\r\n            text-align: center;\r\n            font-family: var(--font_main);\r\n            font-size: 24px;\r\n            font-style: var(--font_main_style);\r\n            font-weight: var(--font_main_weight);\r\n            line-height: 150%;\r\n            /* 36px */\r\n            width: 500px;\r\n            max-width: 100%;\r\n            margin: 0 auto 26px;\r\n        }\r\n\r\n        .btn {\r\n            appearance: none;\r\n            border: 0;\r\n            display: inline-flex;\r\n            min-width: 248px;\r\n            min-height: 56px;\r\n            padding: 6px 48px;\r\n            justify-content: center;\r\n            align-items: center;\r\n            gap: 4px;\r\n            background: var(--1-Button-H-1-1-1-primary-button, #222);\r\n\r\n            color: var(--3-Text-H-3-5-1-inverted-color-text, #FFF);\r\n            text-align: center;\r\n            font-feature-settings: 'liga' off, 'clig' off;\r\n            font-family: var(--font_main);\r\n            font-size: 16px;\r\n            font-style: var(--font_main_style);\r\n            font-weight: var(--font_main_weight);\r\n            line-height: 125%;\r\n            /* 20px */\r\n\r\n            border-radius: 2px;\r\n            cursor: pointer;\r\n            box-shadow: 0 1px 0 rgba(0, 0, 0, 0.25);\r\n            transition: all 0.2s ease;\r\n        }\r\n\r\n        .btn:focus {\r\n            outline: 2px solid rgba(0, 0, 0, 0.25);\r\n            outline-offset: 3px;\r\n        }\r\n\r\n        .btn:active {\r\n            transform: translateY(1px);\r\n        }\r\n\r\n        /* Small responsiveness */\r\n        @media (max-width:520px) {\r\n            .kicker {\r\n                margin-bottom: 36px;\r\n            }\r\n\r\n            .title {\r\n                font-size: 32px;\r\n            }\r\n\r\n            .subtitle {\r\n                font-size: 13px;\r\n            }\r\n\r\n            .content {\r\n                transform: translateY(-18px);\r\n            }\r\n        }\r\n    </style>\r\n</head>\r\n\r\n<body>\r\n    <div class=\"stage\">\r\n        <main class=\"content\" role=\"main\" aria-label=\"Error message\">\r\n            <p class=\"kicker\" id=\"ui-kicker\"></p>\r\n\r\n            <h1 class=\"title\" id=\"ui-title\"></h1>\r\n\r\n            <p class=\"subtitle\" id=\"ui-subtitle\"></p>\r\n\r\n            <!-- Added data-success-text to store localized success message -->\r\n            <button class=\"btn\" type=\"button\" id=\"doneBtn\" data-success-text=\"Saved!\"></button>\r\n        </main>\r\n    </div>\r\n\r\n    <script>\r\n        /**\r\n     * 1. Global CTA Handler\r\n     * Receives action_id and payload. Logs to console.\r\n     */\r\n    window.myop_cta_handler = function(action_id, payload) {\r\n      console.log(`[CTA Handler] Action: ${action_id}`, payload);\r\n    };\r\n\r\n    /**\r\n     * 2. Global Init Interface\r\n     * Receives config object (DTO) and populates the UI.\r\n     */\r\n    window.myop_init_interface = function(config) {\r\n      // Set Fonts via CSS Variables from fonts array\r\n      const root = document.documentElement;\r\n      if (config.fonts && Array.isArray(config.fonts)) {\r\n        config.fonts.forEach(font => {\r\n          if (font.id && font.family) {\r\n            // Load font CSS if url provided\r\n            if (font.url) {\r\n              const linkId = `font-${font.id}`;\r\n              if (!document.getElementById(linkId)) {\r\n                const link = document.createElement('link');\r\n                link.id = linkId;\r\n                link.rel = 'stylesheet';\r\n                link.href = font.url;\r\n                document.head.appendChild(link);\r\n              }\r\n            }\r\n            // Set CSS variables using font id (e.g., --font_main)\r\n            root.style.setProperty(`--font_${font.id}`, `\"${font.family}\", system-ui, sans-serif`);\r\n            if (font.style) {\r\n              root.style.setProperty(`--font_${font.id}_style`, font.style);\r\n            }\r\n            if (font.weight) {\r\n              root.style.setProperty(`--font_${font.id}_weight`, font.weight);\r\n            }\r\n          }\r\n        });\r\n      }\r\n\r\n      // Set Text Content from Lang Object\r\n      const lang = config.lang || {};\r\n      const data = config.data || {};\r\n\r\n      if (lang.title) {\r\n        document.getElementById('ui-title').textContent = lang.title;\r\n      }\r\n      if (lang.subtitle) {\r\n        let subtitleHTML = lang.subtitle;\r\n        // Handle dynamic gallery name replacement from data object\r\n        if (data.gallery_name) {\r\n          subtitleHTML = subtitleHTML.replace('{gallery_name}', data.gallery_name);\r\n        }\r\n        // InnerHTML used to support <br/> tag in subtitle\r\n        document.getElementById('ui-subtitle').innerHTML = subtitleHTML;\r\n      }\r\n\r\n      // Error state handling\r\n      if (lang.errorTitle) {\r\n        document.getElementById('ui-title').textContent = lang.errorTitle;\r\n      }\r\n      if (lang.errorMessage) {\r\n        document.getElementById('ui-subtitle').innerHTML = lang.errorMessage;\r\n      }\r\n\r\n      if (lang.button) {\r\n        const btn = document.getElementById('doneBtn');\r\n        btn.textContent = lang.button;\r\n\r\n        // Update localized success message if provided\r\n        if (lang.button_success) {\r\n          btn.dataset.successText = lang.button_success;\r\n        }\r\n      }\r\n    }\r\n\r\n    /**\r\n     * Event Listeners\r\n     */\r\n    const btn = document.getElementById(\"doneBtn\");\r\n    btn.addEventListener(\"click\", () => {\r\n      // Close the component\r\n      if (window.myop_cta_handler) {\r\n        window.myop_cta_handler('done_clicked', {});\r\n      }\r\n    });\r\n\r\n    /**\r\n     * Mock Initialization\r\n     * This mimics the app calling the init method with data.\r\n     */\r\n    const mockConfig = {\r\n      fonts: [\r\n        {\r\n          id: \"main\",\r\n          family: \"TT Norms Pro\",\r\n          style: \"normal\",\r\n          weight: 400,\r\n          url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\r\n        }\r\n      ],\r\n      // Dynamic Data\r\n      data: {\r\n        gallery_name: \"Jessica & Ben\"\r\n      },\r\n      // Localization Strings\r\n      lang: {\r\n        errorTitle: \"Payment failed\",\r\n        errorMessage: \"We couldn't process your payment details.<br/>Please try again or contact support.\",\r\n        button: \"Close\"\r\n      }\r\n    };\r\n\r\n    // Initialize\r\n    window.myop_init_interface(mockConfig);\r\n\r\n    </script>\r\n</body>\r\n\r\n</html>"
        }
      }
