          "HTML": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":800}'>\r\n\r\n    <script type=\"myop/types\">\r\n// =============================================================================\r\n// MYOP COMPONENT TYPE DEFINITIONS\r\n// =============================================================================\r\n\r\ninterface VideoItem {\r\n  designSetID: string;\r\n  url: string;\r\n}\r\n\r\ninterface FontConfig {\r\n  id: string;\r\n  family: string;\r\n  style?: string;\r\n  weight?: number;\r\n  url: string;\r\n}\r\n\r\ninterface LangStrings {\r\n  ctaText?: string;\r\n  title?: string;\r\n  subtitle?: string;\r\n  scratchOr?: string;\r\n  scratchAction?: string;\r\n}\r\n\r\ninterface MyopInitData {\r\n  videos: VideoItem[];\r\n  fonts?: FontConfig[];\r\n  lang?: LangStrings;\r\n  mode?: 'gallery' | 'waitMode';\r\n}\r\n\r\ninterface MyopCtaPayloads {\r\n  'playground_clicked': { designSetID?: string };\r\n  'size-requested': {\r\n    width?: number | null;\r\n    height?: number | null;\r\n    minWidth?: number | null;\r\n    maxWidth?: number | null;\r\n    minHeight?: number | null;\r\n    maxHeight?: number | null;\r\n    required?: boolean;\r\n  };\r\n}\r\n\r\n// =============================================================================\r\n// DO NOT EDIT BELOW - Standard Myop type declarations\r\n// =============================================================================\r\n\r\ndeclare function myop_init_interface(): MyopInitData;\r\ndeclare function myop_init_interface(data: MyopInitData): void;\r\n\r\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\r\n  action: K,\r\n  payload: MyopCtaPayloads[K]\r\n): void;\r\n    </script>\r\n\r\n    <style>\r\n        * {\r\n            box-sizing: border-box;\r\n            margin: 0;\r\n            padding: 0;\r\n        }\r\n\r\n        html, body {\r\n            margin: 0;\r\n            padding: 0;\r\n            width: 100%;\r\n        }\r\n\r\n        #app-root {\r\n            width: 100%;\r\n            min-height: 600px;\r\n            display: flex;\r\n            flex-direction: column;\r\n            align-items: center;\r\n            background-color: #f1eee8;\r\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\r\n            font-weight: var(--fontWeight_main, 500);\r\n            font-style: var(--fontStyle_main, normal);\r\n            position: relative;\r\n        }\r\n\r\n        /* ===== SCALED WRAPPER ===== */\r\n        .scaled-wrapper {\r\n            width: 100%;\r\n            display: flex;\r\n            flex-direction: column;\r\n            align-items: center;\r\n            padding: 40px 16px;\r\n            /* JS sets --s (scale factor) based on container width / 1177 */\r\n        }\r\n\r\n        /* ===== HEADER ===== */\r\n        .header {\r\n            display: flex;\r\n            flex-direction: column;\r\n            align-items: center;\r\n            text-align: center;\r\n            padding-top: calc(40 * var(--s, 1) * 1px);\r\n            padding-bottom: 64px;\r\n            padding-left: 16px;\r\n            padding-right: 16px;\r\n            gap: 24px;\r\n            width: 100%;\r\n            flex-shrink: 0;\r\n        }\r\n\r\n        .header__subtitle {\r\n            color: #98452A;\r\n            text-align: center;\r\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\r\n            font-size: 14px;\r\n            font-style: var(--fontStyle_main, normal);\r\n            font-weight: var(--fontWeight_main, 500);\r\n            line-height: 1.3;\r\n            letter-spacing: 1.12px;\r\n            text-transform: uppercase;\r\n        }\r\n\r\n        .header__title {\r\n            color: #232323;\r\n            text-align: center;\r\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\r\n            font-size: 38px;\r\n            font-style: var(--fontStyle_main, normal);\r\n            font-weight: var(--fontWeight_main, 400);\r\n            line-height: 1.2;\r\n            font-feature-settings: 'liga' off;\r\n            max-width: 90%;\r\n            word-wrap: break-word;\r\n        }\r\n\r\n        /* ===== CAROUSEL ===== */\r\n        .carousel-section {\r\n            display: flex;\r\n            flex-direction: column;\r\n            align-items: center;\r\n            width: 100%;\r\n            min-height: 0;\r\n            position: relative;\r\n        }\r\n\r\n        .carousel-viewport {\r\n            width: 100%;\r\n            position: relative;\r\n            overflow: hidden;\r\n        }\r\n\r\n        .carousel-track {\r\n            position: absolute;\r\n            top: 0;\r\n            left: 0;\r\n            width: 100%;\r\n            height: 100%;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n        }\r\n\r\n        .carousel-slide {\r\n            position: absolute;\r\n            border-radius: 2px;\r\n            overflow: hidden;\r\n            box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.1);\r\n            cursor: pointer;\r\n            will-change: transform, opacity;\r\n            transition:\r\n                transform 0.6s cubic-bezier(0.4, 0, 0.2, 1),\r\n                opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1);\r\n        }\r\n\r\n        .carousel-slide video {\r\n            width: 100%;\r\n            height: 100%;\r\n            object-fit: cover;\r\n            display: block;\r\n        }\r\n\r\n        .carousel-slide--center {\r\n            z-index: 3;\r\n            opacity: 1;\r\n        }\r\n\r\n        .carousel-slide--left {\r\n            z-index: 2;\r\n            opacity: 0.4;\r\n        }\r\n\r\n        .carousel-slide--right {\r\n            z-index: 2;\r\n            opacity: 0.4;\r\n        }\r\n\r\n        .carousel-slide--hidden {\r\n            z-index: 1;\r\n            opacity: 0;\r\n            pointer-events: none;\r\n            transition:\r\n                transform 0.6s cubic-bezier(0.4, 0, 0.2, 1),\r\n                opacity 0.15s ease;\r\n        }\r\n\r\n        /* ===== CTA OVERLAY ===== */\r\n        .slide-overlay {\r\n            position: absolute;\r\n            top: 0;\r\n            left: 0;\r\n            width: 100%;\r\n            height: 100%;\r\n            display: none;\r\n            align-items: flex-end;\r\n            justify-content: center;\r\n            padding-bottom: calc(32 * var(--s, 1) * 1px);\r\n            background: transparent;\r\n            z-index: 5;\r\n            pointer-events: none;\r\n        }\r\n\r\n        .carousel-slide--center .slide-overlay {\r\n            display: flex;\r\n            pointer-events: auto;\r\n        }\r\n\r\n        .carousel-slide--center:hover .slide-overlay {\r\n            background: rgba(0, 0, 0, 0.15);\r\n        }\r\n\r\n        .cta-btn {\r\n            display: inline-flex;\r\n            justify-content: center;\r\n            align-items: center;\r\n            gap: calc(16 * var(--s, 1) * 1px);\r\n            padding: calc(8 * var(--s, 1) * 1px) calc(16 * var(--s, 1) * 1px);\r\n            background: #ffffff;\r\n            color: #232323;\r\n            border: none;\r\n            border-radius: calc(1.902 * var(--s, 1) * 1px);\r\n            box-shadow: 0 0 calc(3.804 * var(--s, 1) * 1px) 0 rgba(0, 0, 0, 0.25);\r\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\r\n            font-weight: var(--fontWeight_main, 500);\r\n            font-style: var(--fontStyle_main, normal);\r\n            font-size: 16px;\r\n            line-height: 1.25;\r\n            font-feature-settings: 'liga' off, 'clig' off;\r\n            cursor: pointer;\r\n            text-align: center;\r\n            transition: background 150ms ease-out;\r\n  