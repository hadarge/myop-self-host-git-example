r\n            text-decoration-line: underline;\r\n            text-decoration-style: solid;\r\n            text-decoration-skip-ink: auto;\r\n            text-decoration-thickness: auto;\r\n            text-underline-offset: auto;\r\n            text-underline-position: from-font;\r\n            cursor: pointer;\r\n            background: none;\r\n            border: none;\r\n            padding: 0;\r\n        }\r\n\r\n        .scratch-action:hover {\r\n            opacity: 0.7;\r\n        }\r\n\r\n        /* ===== WAIT MODE ===== */\r\n        .wait-mode {\r\n            width: 100%;\r\n            min-height: 400px;\r\n            display: flex;\r\n            flex-direction: column;\r\n            align-items: center;\r\n            justify-content: center;\r\n            gap: 32px;\r\n            padding: 60px 16px;\r\n        }\r\n\r\n        .wait-mode__text {\r\n            color: #232323;\r\n            text-align: center;\r\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\r\n            font-size: 28px;\r\n            font-style: var(--fontStyle_main, normal);\r\n            font-weight: var(--fontWeight_main, 500);\r\n            line-height: 1.3;\r\n        }\r\n\r\n        .wait-mode__spinner {\r\n            width: 48px;\r\n            height: 48px;\r\n            border: 4px solid rgba(152, 69, 42, 0.2);\r\n            border-top-color: #98452A;\r\n            border-radius: 50%;\r\n            animation: spin 1s linear infinite;\r\n        }\r\n\r\n        @keyframes spin {\r\n            to { transform: rotate(360deg); }\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div id=\"app-root\"></div>\r\n\r\n    <script>\r\n    (function() {\r\n        var state = null;\r\n        var currentIndex = 0;\r\n        var hoverTimer = null;\r\n        var isHoveringCenter = false;\r\n        var listenersAttached = false;\r\n\r\n        // ---- Video sizing with min/max constraints ----\r\n        // Center video: min 620×336, max 728×394\r\n        // Side video:   min 545×295, max 639×346\r\n        // Aspect ratio: ~1.847 (w/h) or ~0.5415 (h/w)\r\n        var REF_W = 1177;              // reference container width (shows max sizes)\r\n        var MIN_CONTAINER_W = 900;     // container width where min sizes apply\r\n\r\n        var SIDE_MIN_W = 545;\r\n        var SIDE_MAX_W = 639;\r\n        var SIDE_MIN_H = 295;\r\n        var SIDE_MAX_H = 346;\r\n\r\n        var CENTER_MIN_W = 620;\r\n        var CENTER_MAX_W = 728;\r\n        var CENTER_MIN_H = 336;\r\n        var CENTER_MAX_H = 394;\r\n\r\n        var REF_GAP = 28;              // px gap at reference width\r\n        var MIN_SCALE = 0.45;          // floor so text stays readable\r\n\r\n        function lerp(min, max, t) {\r\n            return min + (max - min) * Math.max(0, Math.min(1, t));\r\n        }\r\n\r\n        function getScaleFactor(containerW) {\r\n            var s = containerW / REF_W;\r\n            return Math.max(s, MIN_SCALE);\r\n        }\r\n\r\n        function getVideoSizes(containerW) {\r\n            // t=0 at MIN_CONTAINER_W (min sizes), t=1 at REF_W (max sizes)\r\n            // For wider screens, t > 1 but sizes are clamped to max\r\n            var t = (containerW - MIN_CONTAINER_W) / (REF_W - MIN_CONTAINER_W);\r\n            // Clamp t to [0, 1] so sizes stay within min/max bounds\r\n            t = Math.max(0, Math.min(1, t));\r\n\r\n            return {\r\n                sideW: lerp(SIDE_MIN_W, SIDE_MAX_W, t),\r\n                sideH: lerp(SIDE_MIN_H, SIDE_MAX_H, t),\r\n                centerW: lerp(CENTER_MIN_W, CENTER_MAX_W, t),\r\n                centerH: lerp(CENTER_MIN_H, CENTER_MAX_H, t)\r\n            };\r\n        }\r\n\r\n        function computeSlots(containerW, containerH) {\r\n            var sizes = getVideoSizes(containerW);\r\n            var s = containerW / REF_W;\r\n            var gap = REF_GAP * Math.max(s, 0.5);\r\n\r\n            var cx = containerW / 2;\r\n            var cy = containerH / 2;\r\n\r\n            var rightX = cx + sizes.centerW / 2 + gap + sizes.sideW / 2;\r\n            var leftX  = cx - sizes.centerW / 2 - gap - sizes.sideW / 2;\r\n\r\n            return {\r\n                center: {\r\n                    x: cx,\r\n                    y: cy,\r\n                    opacity: 1\r\n                },\r\n                left: {\r\n                    x: leftX,\r\n                    y: cy,\r\n                    opacity: 0.4\r\n                },\r\n                right: {\r\n                    x: rightX,\r\n                    y: cy,\r\n                    opacity: 0.4\r\n                },\r\n                hiddenLeft: {\r\n                    x: leftX - containerW * 0.35,\r\n                    y: cy,\r\n                    opacity: 0\r\n                },\r\n                hiddenRight: {\r\n                    x: rightX + containerW * 0.35,\r\n                    y: cy,\r\n                    opacity: 0\r\n                },\r\n                baseW: sizes.sideW,\r\n                baseH: sizes.sideH,\r\n                centerW: sizes.centerW,\r\n                centerH: sizes.centerH\r\n            };\r\n        }\r\n\r\n        function getSlotName(offset, total) {\r\n            if (total < 2) return offset === 0 ? 'center' : 'hiddenRight';\r\n            if (total === 2) {\r\n                if (offset === 0) return 'center';\r\n                if (offset === 1) return 'right';\r\n                return 'hiddenRight';\r\n            }\r\n            if (offset === 0) return 'center';\r\n            if (offset === 1) return 'right';\r\n            if (offset === -1 || offset === total - 1) return 'left';\r\n            return offset > 0 ? 'hiddenRight' : 'hiddenLeft';\r\n        }\r\n\r\n        function mod(n, m) {\r\n            return ((n % m) + m) % m;\r\n        }\r\n\r\n        function buildHTML(data) {\r\n            // Wait mode UI\r\n            if (data.mode === 'waitMode') {\r\n                return '<div class=\"wait-mode\">' +\r\n                    '<div class=\"wait-mode__text\">Creating your playground</div>' +\r\n                    '<div class=\"wait-mode__spinner\"></div>' +\r\n                    '</div>';\r\n            }\r\n\r\n            // Gallery mode UI\r\n            var lang = data.lang || {};\r\n            var subtitle = lang.subtitle || 'Welcome to pic-time';\r\n            var title = lang.title || 'Create a P2 Playground Gallery';\r\n            var ctaText = lang.ctaText || 'GET STARTED';\r\n            var scratchOr = lang.scratchOr || 'or';\r\n            var scratchAction = lang.scratchAction || 'start from scratch';\r\n\r\n            var videosHTML = '';\r\n            if (data.videos && data.videos.length > 0) {\r\n                for (var i = 0; i < data.videos.length; i++) {\r\n                    var v = data.videos[i];\r\n                    videosHTML += '<div class=\"carousel-slide\" data-index=\"' + i + '\" data-design-id=\"' + (v.designSetID || '') + '\">' +\r\n                        '<video muted loop playsinline preload=\"metadata\" src=\"' + v.url + '\"></video>' +\r\n                        '<div class=\"slide-overlay\"><button class=\"cta-btn\" data-action=\"cta\" data-design-id=\"' + (v.designSetID || '') + '\">' + ctaText + '</button></div>' +\r\n                        '</div>';\r\n                }\r\n            }\r\n\r\n            return '<div class=\"scaled-wrapper\">' +\r\n                '<div class=\"header\">' +\r\n                    '<div class=\"header__subtitle\">' + subtitle + '</div>' +\r\n                    '<div class=\"header__title\">' + title + '</div>' +\r\n                '</div>' +\r\n                '<div class=\"carousel-section\">' +\r\n                    '<div class=\"carousel-viewport\">' +\r\n                        '<div class=\"carousel-track\">' + videosHTML + '</div>' +\r\n                    '</div>' +\r\n                    '<div class=\"carousel-nav\">' +\r\n                        '<button class=\"nav-arrow\" data-action=\"prev\" aria-label=\"Previous\">' +\r\n                            '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">' +\r\n                            '<g clip-path=\"url(#clip0_prev)\"><path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M11.5303 1.53034C11.8232 1.23745 11.8232 0.762691 11.5303 0.469798C11.2374 0.176905 10.7627 0.176905 10.4698 0.469798L3.46978 7.4698C3.32913 7.61045 3.25006 7.80116 3.25006 8.00007C3.25006 8.19898 3.32913 8.38969 3.46978 8.53035L10.4698 15.5303C10.7627 15.8232 11.2374 15.8232 11.5303 15.5303C11.8232 15.2375 11.8232 14.7627 11.5303 14.4698L5.0606 8.00007L11.5303 1.53034Z\" fill=\"#222222\"/></g>' +\r\n                            '<defs><clipPath id=\"clip0_prev\"><rect width=\"16\" height=\"16\" fill=\"white\" transform=\"matrix(-1 0 0 1 16 0)\"/></clipPath></defs>' +\r\n                            '</svg>' +\r\n                        '</button>' +\r\n                        '<button class=\"nav-arrow\" data-action=\"next\" aria-label=\"Next\">' +\r\n                            '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">' +\r\n                            '<g clip-path=\"url(#clip0_next)\"><path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M4.46967 14.4697C4.17678 14.7626 4.17678 15.2373 4.46967 15.5302C4.76256 15.8231 5.23744 15.8231 5.53033 15.5302L12.5303 8.5302C12.671 8.38955 12.75 8.19884 12.75 7.99993C12.75 7.80102 12.671 7.61031 12.5303 7.46965L5.53033 0.469653C5.23744 0.17676 4.76256 0.17676 4.46967 0.469653C4.17678 0.762547 4.17678 1.23733 4.46967 1.53022L10.9393 7.99993L4.46967 14.4697Z\" fill=\"#222222\"/></g>' +\r\n                            '<defs><clipPath id=\"clip0_next\"><rect width=\"16\" height=\"16\" fill=\"white\"/></clipPath></defs>' +\r\n                            '</svg>' +\r\n                        '</button>' +\r\n                    '</div>' +\r\n                '</div>' +\r\n                '<div class=\"scratch-link\"><span class=\"scratch-or\">' + scratchOr + '</span> <button class=\"scratch-action\" data-action=\"scratch\">' + scratchAction + '</button></div>' +\r\n                '</div>';\r\n        }\r\n\r\n        function positionSlides(skipTransition) {\r\n            if (!state || !state.videos || state.videos.length === 0) return;\r\n\r\n            var viewport = document.querySelector('.carousel-viewport');\r\n            var wrapper = document.querySelector('.scaled-wrapper');\r\n            if (!viewport || !wrapper) return;\r\n\r\n            var containerW = viewport.offsetWidth;\r\n            var s = getScaleFactor(containerW);\r\n\r\n            // Set the --s CSS variable on the wrapper so all children scale\r\n            wrapper.style.setProperty('--s', s);\r\n\r\n            // Get video sizes based on container width\r\n            var sizes = getVideoSizes(containerW);\r\n\r\n            // Set viewport height to match center video height\r\n            viewport.style.height = sizes.centerH + 'px';\r\n\r\n            var containerH = sizes.centerH;\r\n            var info = computeSlots(containerW, containerH);\r\n            var slides = document.querySelectorAll('.carousel-slide');\r\n            var total = state.videos.length;\r\n\r\n            for (var i = 0; i < slides.length; i++) {\r\n                var slide = slides[i];\r\n                var offset = mod(i - currentIndex, total);\r\n                if (offset > Math.floor(total / 2)) {\r\n                    offset = offset - total;\r\n                }\r\n                var slotName = getSlotName(offset, total);\r\n                var slot = info[slotName];\r\n\r\n                // Set size based on slot (center gets center size, sides get side size)\r\n                var isCenter = slotName === 'center';\r\n                var slideW = isCenter ? info.centerW : info.baseW;\r\n                var slideH = isCenter ? info.centerH : info.baseH;\r\n                slide.style.width = slideW + 'px';\r\n                slide.style.height = slideH + 'px';\r\n                // Fixed top-left at 0,0; all positioning via transform\r\n                slide.style.left = '0';\r\n                slide.style.top = '0';\r\n\r\n                // Compute translate so the slide's center ends up at slot.x, slot.y\r\n                var tx = slot.x - slideW / 2;\r\n                var ty = slot.y - slideH / 2;\r\n\r\n                // If we want to skip transition (initial render / resize)\r\n                if (skipTransition) {\r\n                    slide.style.transition = 'none';\r\n                }\r\n\r\n                // No scaling needed - each slide has its correct size\r\n                slide.style.transform = 'translate3d(' + tx + 'px,' + ty + 'px,0)';\r\n                slide.style.opacity = slot.opacity;\r\n\r\n                // Force reflow then restore transition when skipping\r\n                if (skipTransition) {\r\n                    slide.offsetHeight; // force reflow\r\n                    slide.style.transition = '';\r\n                }\r\n\r\n                // Update slot classes\r\n                slide.classList.remove('carousel-slide--center', 'carousel-slide--left', 'carousel-slide--right', 'carousel-slide--hidden');\r\n                if (slotName === 'center') {\r\n                    slide.classList.add('carousel-slide--center');\r\n                } else if (slotName === 'left') {\r\n                    slide.classList.add('carousel-slide--left');\r\n                } else if (slotName === 'right') {\r\n                    slide.classList.add('carousel-slide--right');\r\n                } else {\r\n                    slide.classList.add('carousel-slide--hidden');\r\n                }\r\n            }\r\n        }\r\n\r\n        function navigateTo(newIndex) {\r\n            if (!state || !state.videos || state.videos.length === 0) return;\r\n            stopCenterVideo();\r\n            currentIndex = mod(newIndex, state.videos.length);\r\n            positionSlides();\r\n        }\r\n\r\n        function playCenterVideo() {\r\n            var centerSlide = document.querySelector('.carousel-slide--center');\r\n            if (centerSlide) {\r\n                var video = centerSlide.querySelector('video');\r\n                if (video) {\r\n                    video.currentTime = 0;\r\n                    video.play().catch(function() {});\r\n                }\r\n            }\r\n            isHoveringCenter = true;\r\n        }\r\n\r\n        function stopCenterVideo() {\r\n            var centerSlide = document.querySelector('.carousel-slide--center');\r\n            if (centerSlide) {\r\n                var video = centerSlide.querySelector('video');\r\n                if (video) {\r\n                    video.pause();\r\n                    video.currentTime = 0;\r\n                }\r\n            }\r\n            isHoveringCenter = false;\r\n        }\r\n\r\n        function attachSlideHoverListeners() {\r\n            var slides = document.querySelectorAll('.carousel-slide');\r\n            slides.forEach(function(slide) {\r\n                slide.addEventListener('pointerenter', function(e) {\r\n                    if (slide.classList.contains('carousel-slide--center')) {\r\n                        // Hover on center: play video\r\n                        clearTimeout(hoverTimer);\r\n                        playCenterVideo();\r\n                    } else if (slide.classList.contains('carousel-slide--left') || slide.classList.contains('carousel-slide--right')) {\r\n                        // Hover on side: navigate after delay\r\n                        clearTimeout(hoverTimer);\r\n                        var idx = parseInt(slide.getAttribute('data-index'), 10);\r\n                        hoverTimer = setTimeout(function() {\r\n                            navigateTo(idx);\r\n                        }, 350);\r\n                    }\r\n                });\r\n\r\n                slide.addEventListener('pointerleave', function(e) {\r\n                    if (slide.classList.contains('carousel-slide--center')) {\r\n                        stopCenterVideo();\r\n                    }\r\n                    // Clear side hover timer\r\n                    if (slide.classList.contains('carousel-slide--left') || slide.classList.contains('carousel-slide--right')) {\r\n                        clearTimeout(hoverTimer);\r\n                    }\r\n                });\r\n            });\r\n        }\r\n\r\n        function attachListeners() {\r\n            if (listenersAttached) return;\r\n            listenersAttached = true;\r\n\r\n            var root = document.getElementById('app-root');\r\n            if (!root) return;\r\n\r\n            // Click delegation (only needs to be attached once to root)\r\n            root.addEventListener('click', function(e) {\r\n                var target = e.target;\r\n\r\n                // CTA button\r\n                var ctaBtn = target.closest('[data-action=\"cta\"]');\r\n                if (ctaBtn) {\r\n                    var designId = ctaBtn.getAttribute('data-design-id');\r\n                    window.myop_cta_handler('playground_clicked', { designSetID: designId });\r\n                    // Automatically switch to wait mode\r\n                    render({ videos: state.videos, fonts: state.fonts, lang: state.lang, mode: 'waitMode' });\r\n                    return;\r\n                }\r\n\r\n                // Scratch link\r\n                if (target.closest('[data-action=\"scratch\"]')) {\r\n                    window.myop_cta_handler('playground_clicked', {});\r\n                    // Automatically switch to wait mode\r\n                    render({ videos: state.videos, fonts: state.fonts, lang: state.lang, mode: 'waitMode' });\r\n                    return;\r\n                }\r\n\r\n                // Prev arrow\r\n                if (target.closest('[data-action=\"prev\"]')) {\r\n                    navigateTo(currentIndex - 1);\r\n                    return;\r\n                }\r\n\r\n                // Next arrow\r\n                if (target.closest('[data-action=\"next\"]')) {\r\n                    navigateTo(currentIndex + 1);\r\n                    return;\r\n                }\r\n\r\n                // Click on a side slide -> navigate to it\r\n                var slide = target.closest('.carousel-slide');\r\n                if (slide && !slide.classList.contains('carousel-slide--center')) {\r\n                    var idx = parseInt(slide.getAttribute('data-index'), 10);\r\n                    navigateTo(idx);\r\n                    return;\r\n                }\r\n            });\r\n        }\r\n\r\n        function loadFonts(fonts) {\r\n            if (!fonts || fonts.length === 0) return;\r\n\r\n            var root = document.documentElement;\r\n\r\n            for (var i = 0; i < fonts.length; i++) {\r\n                var f = fonts[i];\r\n\r\n                // Set CSS variables\r\n                root.style.setProperty('--font_' + f.id, f.family + ', sans-serif');\r\n                root.style.setProperty('--fontWeight_' + f.id, f.weight || 500);\r\n                root.style.setProperty('--fontStyle_' + f.id, f.style || 'normal');\r\n\r\n                // Load the font CSS file\r\n                if (f.url) {\r\n                    var existing = document.querySelector('link[data-font-id=\"' + f.id + '\"]');\r\n                    if (!existing) {\r\n                        var link = document.createElement('link');\r\n                        link.rel = 'stylesheet';\r\n                        link.href = f.url;\r\n                        link.setAttribute('data-font-id', f.id);\r\n                        document.head.appendChild(link);\r\n                    }\r\n                }\r\n            }\r\n        }\r\n\r\n        function render(data) {\r\n            state = data;\r\n            currentIndex = 0;\r\n            isHoveringCenter = false;\r\n\r\n            var root = document.getElementById('app-root');\r\n            if (!root) return;\r\n\r\n            // Load fonts\r\n            loadFonts(data.fonts);\r\n\r\n            // Build and inject HTML\r\n            root.innerHTML = buildHTML(data);\r\n\r\n            // Wait mode doesn't need carousel setup\r\n            if (data.mode === 'waitMode') return;\r\n\r\n            // Position slides after DOM is ready (skip transition on initial render)\r\n            positionSlides(true);\r\n\r\n            // Attach click delegation (once) and slide hover listeners (every render)\r\n            attachListeners();\r\n            attachSlideHoverListeners();\r\n        }\r\n\r\n        // Handle resize\r\n        var resizeTimer;\r\n        window.addEventListener('resize', function() {\r\n            clearTimeout(resizeTimer);\r\n            resizeTimer = setTimeout(function() {\r\n                positionSlides(true);\r\n            }, 50);\r\n        });\r\n\r\n        // Public API\r\n        window.myop_init_interface = function(data) {\r\n            if (!data) return state;\r\n            render(data);\r\n        };\r\n\r\n        window.myop_cta_handler = function(action_id, payload) {\r\n            // Will be overridden by host application\r\n        };\r\n    })();\r\n    </script>\r\n\r\n    <script id=\"myop_preview\">\r\n        window.myop_init_interface({\r\n            videos: [\r\n                { designSetID: \"ds-001\", url: \"https://videos.pexels.com/video-files/3195440/3195440-uhd_2560_1440_25fps.mp4\" },\r\n                { designSetID: \"ds-002\", url: \"https://videos.pexels.com/video-files/3015488/3015488-hd_1920_1080_24fps.mp4\" },\r\n                { designSetID: \"ds-003\", url: \"https://videos.pexels.com/video-files/2795391/2795391-uhd_2560_1440_25fps.mp4\" },\r\n                { designSetID: \"ds-004\", url: \"https:/