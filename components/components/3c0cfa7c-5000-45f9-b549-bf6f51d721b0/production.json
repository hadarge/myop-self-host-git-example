  "version": "0.2.10",
  "item": {
    "name": "P2 Mini Dashboard Header",
    "id": "3c0cfa7c-5000-45f9-b549-bf6f51d721b0",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "b123b473-5797-4935-972b-6c8df07bf26e",
        "name": "Version 3",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":100,\"minHeight\":80,\"maxHeight\":150}'>\n  <title>P2 Mini Dashboard - Header</title>\n\n  <script type=\"myop/types\">\n  // =============================================================================\n  // MYOP COMPONENT TYPE DEFINITIONS\n  // =============================================================================\n\n  /**\n   * Data structure passed to myop_init_interface(data)\n   */\n  interface MyopInitData {\n    userName: string;\n    greeting: 'Good morning' | 'Good afternoon' | 'Good evening';\n    subtitle?: string;\n  }\n\n  /**\n   * Actions and payloads for myop_cta_handler(action, payload)\n   */\n  interface MyopCtaPayloads {\n    'header-clicked': { section: 'greeting' | 'subtitle' };\n    'refresh-requested': void;\n  }\n\n  // =============================================================================\n  // DO NOT EDIT BELOW - Standard Myop type declarations\n  // =============================================================================\n\n  declare function myop_init_interface(): MyopInitData;\n  declare function myop_init_interface(data: MyopInitData): void;\n\n  declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n    action: K,\n    payload: MyopCtaPayloads[K]\n  ): void;\n  </script>\n\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    html, body {\n      margin: 0;\n      padding: 0;\n      width: 100%;\n      height: 100%;\n      overflow: hidden;\n      background: transparent;\n    }\n\n    #app-root {\n      width: 100%;\n      height: 100%;\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n    }\n\n    @font-face {\n      font-family: 'TT Norms Pro';\n      src: local('TT Norms Pro Medium'), local('TTNormsPro-Medium');\n      font-weight: 500;\n      font-style: normal;\n    }\n\n    @font-face {\n      font-family: 'TT Norms Pro';\n      src: local('TT Norms Pro Regular'), local('TTNormsPro-Regular');\n      font-weight: 400;\n      font-style: normal;\n    }\n\n    .header {\n      position: relative;\n    }\n\n    .header-title {\n      color: #050505;\n      font-family: 'TT Norms Pro', sans-serif;\n      font-weight: 500;\n      font-size: 32px;\n      line-height: normal;\n      margin-bottom: 12px;\n      font-style: normal;\n    }\n\n    .header-subtitle {\n      color: #050505;\n      font-family: 'TT Norms Pro', sans-serif;\n      font-weight: 400;\n      font-size: 18px;\n      line-height: normal;\n      max-width: 576px;\n      font-style: normal;\n    }\n\n    /* Mobile styles - screens smaller than 1000px */\n    @media (max-width: 999px) {\n      .header-title {\n        font-size: 22px;\n        max-width: 293px;\n      }\n\n      .header-subtitle {\n        font-size: 16px;\n        max-width: 293px;\n        margin-top: 8px;\n      }\n    }\n\n    /* Empty state before data loads */\n    .header-title:empty,\n    .header-subtitle:empty {\n      background: #f0f0f0;\n      border-radius: 4px;\n      min-height: 1em;\n      min-width: 200px;\n    }\n\n    .header-title:empty {\n      min-width: 250px;\n      min-height: 38px;\n    }\n\n    .header-subtitle:empty {\n      min-width: 300px;\n      min-height: 22px;\n    }\n  </style>\n</head>\n<body>\n  <div id=\"app-root\">\n    <header class=\"header\">\n      <h1 class=\"header-title\" id=\"greeting\"></h1>\n      <p class=\"header-subtitle\" id=\"subtitle\"></p>\n    </header>\n  </div>\n\n  <script>\n    (function() {\n      // Private state\n      let currentState = {\n        userName: '',\n        greeting: 'Good morning',\n        subtitle: 'Oversee your photography operations'\n      };\n\n      /**\n       * Render the header synchronously\n       */\n      function render(data) {\n        const greetingElement = document.getElementById('greeting');\n        const subtitleElement = document.getElementById('subtitle');\n\n        greetingElement.textContent = `${data.greeting}, ${data.userName}`;\n\n        if (data.subtitle) {\n          subtitleElement.textContent = data.subtitle;\n        }\n      }\n\n      // Public API - defined at top level synchronously\n      window.myop_init_interface = function(data) {\n        if (!data) return currentState;\n\n        currentState = { ...currentState, ...data };\n        render(currentState);\n      };\n\n      window.myop_cta_handler = function(action_id, payload) {\n        // Will be overridden by host application\n        console.log('CTA:', action_id, payload);\n      };\n    })();\n  </script>\n\n  <!-- Preview script - replaced in production -->\n  <script id=\"myop_preview\">\n    window.myop_init_interface({\n      userName: 'Sam',\n      greeting: 'Good morning',\n      subtitle: 'Oversee your photography operations'\n    });\n  </script>\n</body>\n</html>\n"
        }
      }
    ]
  }
}