        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400;1,9..40,500&display=swap\" rel=\"stylesheet\">\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n  request: {\n    icon?: string;\n    title: string;\n    contactLabel: string;\n    contactValue: string;\n    descriptionLabel: string;\n    descriptionValue: string;\n    deadlineLabel: string;\n    deadlineValue: string;\n  };\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'size-requested': {\n    width?: number | null;\n    height?: number | null;\n    minWidth?: number | null;\n    maxWidth?: number | null;\n    minHeight?: number | null;\n    maxHeight?: number | null;\n    required?: boolean;\n  };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n    <style>\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            background: #FFFFFF;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n        }\n\n        /* ===== MODAL CARD ===== */\n        .modal {\n            background: #FFFFFF;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            position: relative;\n        }\n\n        /* ===== MODAL CONTENT ===== */\n        .modal__content {\n            display: flex;\n            width: 100%;\n            flex-direction: column;\n            align-items: flex-start;\n            padding: 24px 32px 24px 32px;\n            gap: 16px;\n            overflow-y: auto;\n            box-sizing: border-box;\n            min-height: 0;\n            flex: 1;\n        }\n\n        .modal__content::-webkit-scrollbar {\n            width: 8px;\n        }\n\n        .modal__content::-webkit-scrollbar-track {\n            background: transparent;\n        }\n\n        .modal__content::-webkit-scrollbar-thumb {\n            background: #D9D9D9;\n            border-radius: 80px;\n        }\n\n        .request-icon {\n            width: 60px;\n            height: 60px;\n            flex-shrink: 0;\n        }\n\n        .request-icon svg {\n            width: 60px;\n            height: 60px;\n        }\n\n        .request-title {\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 24px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 32px;\n            color: var(--Grey-90, #3E3D3E);\n            margin: 0;\n            align-self: stretch;\n            padding-right: 32px;\n        }\n\n        .request-fields {\n            display: flex;\n            flex-direction: column;\n            gap: 24px;\n            width: 100%;\n            margin-top: 8px;\n        }\n\n        .request-field {\n            display: flex;\n            flex-direction: column;\n            gap: 4px;\n            flex-shrink: 0;\n        }\n\n\n        .request-field__label {\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 700;\n            line-height: 24px;\n            color: var(--Grey-90, #3E3D3E);\n        }\n\n        .request-field__value {\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 18px;\n            color: var(--Grey-90, #3E3D3E);\n            white-space: pre-wrap;\n            word-break: break-word;\n        }\n\n        .request-field__value a {\n            color: var(--Purple-100, #6C18FF);\n            text-decoration: none;\n        }\n\n        .request-field__value a:hover {\n            text-decoration: underline;\n        }\n\n        /* ===== MODAL HEADER ===== */\n        .modal__header {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            height: 16px;\n            background: #FFFFFF;\n            pointer-events: none;\n        }\n\n        /* ===== MODAL FOOTER ===== */\n        .modal__footer {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            right: 0;\n            height: 8px;\n            background: #FFFFFF;\n            pointer-events: none;\n        }\n\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function() {\n        var currentState = null;\n\n        function escapeHtml(str) {\n            if (!str) return '';\n            return String(str)\n                .replace(/&/g, '&amp;')\n                .replace(/</g, '&lt;')\n                .replace(/>/g, '&gt;')\n                .replace(/\"/g, '&quot;');\n        }\n\n        function linkify(str) {\n            var escaped = escapeHtml(str);\n            return escaped.replace(/(https?:\\/\\/[^\\s<]+)/g, '<a href=\"$1\" target=\"_blank\" rel=\"noopener noreferrer\">$1</a>');\n        }\n\n        function buildModal(data) {\n            var r = data.request;\n            var html = '<div class=\"modal\">' +\n                '<div class=\"modal__content\">' +\n                    '<div class=\"request-icon\">' +\n                        '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"60\" height=\"61\" viewBox=\"0 0 60 61\" fill=\"none\">' +\n                            '<path d=\"M0.998535 30.9512C0.998535 24.3237 6.37112 18.9512 12.9985 18.9512H34.2566C40.884 18.9512 46.2566 24.3238 46.2566 30.9512V48.9297C46.2566 55.5571 40.884 60.9296 34.2566 60.9296H12.9985C6.37111 60.9296 0.998535 55.5571 0.998535 48.9296V30.9512Z\" fill=\"url(#paint0_icon)\" fill-opacity=\"0.4\"/>' +\n                            '<path d=\"M0.998535 28.4619C0.998535 23.2093 5.25664 18.9512 10.5093 18.9512H36.7458C41.9985 18.9512 46.2566 23.2093 46.2566 28.4619C46.2566 33.7146 41.9985 37.9727 36.7458 37.9727H10.5093C5.25664 37.9727 0.998535 33.7146 0.998535 28.4619Z\" fill=\"url(#paint1_icon)\" fill-opacity=\"0.4\"/>' +\n                            '<path d=\"M16.5986 19.0078C16.5986 15.3627 19.5536 12.4078 23.1986 12.4078C26.8437 12.4078 29.7986 15.3627 29.7986 19.0078\" stroke=\"url(#paint2_icon)\" stroke-width=\"3\"/>' +\n                            '<path d=\"M7.16382 25.9863C7.16382 19.3589 12.5364 13.9863 19.1638 13.9863H40.4219C47.0493 13.9863 52.4219 19.3589 52.4219 25.9863V43.9648C52.4219 50.5922 47.0493 55.9648 40.4219 55.9648H19.1638C12.5364 55.9648 7.16382 50.5922 7.16382 43.9648V25.9863Z\" fill=\"url(#paint3_icon)\" fill-opacity=\"0.4\"/>' +\n                            '<path d=\"M7.16382 23.4971C7.16382 18.2444 11.4219 13.9863 16.6746 13.9863H42.9111C48.1637 13.986