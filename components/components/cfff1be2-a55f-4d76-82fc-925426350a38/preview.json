                 '<linearGradient id=\"paint3_icon\" x1=\"60.5019\" y1=\"13.9863\" x2=\"18.0103\" y2=\"61.2924\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                                '<linearGradient id=\"paint4_icon\" x1=\"60.5019\" y1=\"13.9863\" x2=\"46.9786\" y2=\"47.2122\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                                '<linearGradient id=\"paint5_icon\" x1=\"67.1381\" y1=\"8.04103\" x2=\"24.6465\" y2=\"55.347\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                                '<linearGradient id=\"paint6_icon\" x1=\"67.1381\" y1=\"8.04102\" x2=\"53.6148\" y2=\"41.2669\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                                '<linearGradient id=\"paint7_icon\" x1=\"35.4198\" y1=\"8.09961\" x2=\"36.1934\" y2=\"1.60434\" gradientUnits=\"userSpaceOnUse\"><stop offset=\"0.08\" stop-color=\"#FF8651\"/><stop offset=\"0.504183\" stop-color=\"#FFBEA8\"/><stop offset=\"0.97139\" stop-color=\"#A397F5\"/></linearGradient>' +\n                            '</defs>' +\n                        '</svg>' +\n                    '</div>' +\n                    '<h1 class=\"request-title\">' + escapeHtml(r.title) + '</h1>' +\n                    '<div class=\"request-fields\">';\n\n            // Contact details\n            html += '<div class=\"request-field\">' +\n                '<div class=\"request-field__label\">' + escapeHtml(r.contactLabel) + '</div>' +\n                '<div class=\"request-field__value\">' + escapeHtml(r.contactValue) + '</div>' +\n            '</div>';\n\n            // Deadline\n            html += '<div class=\"request-field\">' +\n                '<div class=\"request-field__label\">' + escapeHtml(r.deadlineLabel) + '</div>' +\n                '<div class=\"request-field__value\">' + escapeHtml(r.deadlineValue) + '</div>' +\n            '</div>';\n\n            // Description\n            html += '<div class=\"request-field request-field--description\">' +\n                '<div class=\"request-field__label\">' + escapeHtml(r.descriptionLabel) + '</div>' +\n                '<div class=\"request-field__value\">' + linkify(r.descriptionValue) + '</div>' +\n            '</div>';\n\n            html += '</div>'; // close .request-fields\n            html += '</div>'; // close .modal__content\n            html += '<div class=\"modal__header\"></div>'; // header to cover scrolling text\n            html += '<div class=\"modal__footer\"></div>'; // footer to cover scrolling text\n\n            html += '</div>'; // close .modal\n            return html;\n        }\n\n        function render(data) {\n            var container = document.getElementById('app-root');\n            container.innerHTML = buildModal(data);\n        }\n\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            currentState = data;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            request: {\n                title: \"Implementation request for <Component name>\",\n                contactLabel: \"Contact details\",\n                contactValue: \"Daphna@pendalogic.com\",\n                descriptionLabel: \"Description\",\n                descriptionValue: \"We need to redesign and rebuild the product data table. The focus should be on creating an improved user experience, especially for mobile devices. Please change the table to use our brand colors and typography, as specified in the attached style guide and links. Make sure the new design follows the conventions outlined in the attached style documents.\",\n                deadlineLabel: \"Deadline\",\n                deadlineValue: \"N/A\"\n            }\n        });\n    </script>\n</body>\n</html>\n"
        },
