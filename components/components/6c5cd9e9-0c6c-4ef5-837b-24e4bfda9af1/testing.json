{
  "version": "0.2.10",
  "item": {
    "name": "SceneViewer",
    "id": "6c5cd9e9-0c6c-4ef5-837b-24e4bfda9af1",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "b64cfd28-815e-4fc0-b0e8-3607c470328b",
        "name": "Version 0",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n    <title>Canvas Viewer</title>\n    <!-- Tailwind CSS for utility classes -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- FontAwesome for Icons -->\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <!-- Google Fonts -->\n    <link href=\"https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Inter:wght@400;600&family=Lato:wght@400;700&family=Merriweather:wght@300;700&family=Montserrat:wght@400;600&family=Nunito:wght@400;700&family=Oswald:wght@400;500&family=Playfair+Display:wght@400;700&family=Poppins:wght@400;600&family=Raleway:wght@400;600&family=Roboto:wght@400;700&display=swap\" rel=\"stylesheet\">\n\n    <style>\n        /* --- Core Viewer Styles --- */\n        body {\n            background-color: #f3f4f6;\n            margin: 0;\n            padding: 0;\n            overflow: hidden;\n            font-family: 'Inter', sans-serif;\n        }\n\n        #app-container {\n            width: 100vw;\n            height: 100vh;\n            display: flex;\n            flex-direction: column;\n            overflow: hidden;\n        }\n\n        #viewer-scroll-area {\n            flex: 1;\n            overflow-y: auto;\n            overflow-x: hidden;\n            display: flex;\n            justify-content: center;\n            padding-top: 20px; \n            padding-bottom: 50px; \n        }\n\n        #main-canvas {\n            width: 100%;\n            max-width: 100%; \n            min-height: 800px;\n            background-color: white;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.1);\n            position: relative;\n            transform-origin: top center;\n            overflow: hidden;\n            transition: height 0.3s ease; \n        }\n\n        /* --- Element Rendering --- */\n        .canvas-element {\n            position: absolute;\n            user-select: none;\n            box-sizing: border-box;\n            touch-action: none;\n            transform-origin: center center;\n            transition: top 0.2s ease, left 0.2s ease, width 0.2s ease, height 0.2s ease;\n        }\n\n        .element-content {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            position: relative;\n        }\n\n        /* Text Specifics */\n        .text-content {\n            white-space: pre-wrap;\n            word-wrap: break-word;\n            line-height: 1.2;\n            padding: 0;\n            margin: 0;\n            cursor: default;\n        }\n\n        /* --- Image Selection Styles --- */\n        \n        /* Base Image Styling */\n        .image-content {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            pointer-events: none;\n            display: block;\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* Smooth shrink animation */\n        }\n\n        /* Selected State: Shrink Logic */\n        .canvas-element.is-selected .image-content {\n            width: calc(100% - 20px);\n            height: calc(100% - 20px);\n            margin: 10px;\n            border-radius: 4px; \n            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);\n        }\n\n        /* --- Action Buttons (Shared Base) --- */\n        .canvas-btn {\n            position: absolute;\n            width: 32px;\n            height: 32px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            cursor: pointer;\n            z-index: 50;\n            opacity: 0;\n            transform: scale(0.8);\n            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n            pointer-events: auto;\n            box-shadow: 0 2px 5px rgba(0,0,0,0.15);\n        }\n\n        /* Show buttons on hover */\n        .canvas-element:hover .canvas-btn {\n            opacity: 1;\n            transform: scale(1);\n        }\n\n        /* 1. Checkmark Button (Bottom Right) */\n        .select-btn {\n            bottom: 15px;\n            right: 15px;\n            background: rgba(255, 255, 255, 0.9);\n            color: #d1d5db;\n            border: 2px solid #e5e7eb;\n        }\n\n        .canvas-element.is-selected .select-btn {\n            opacity: 1; /* Always visible when selected */\n            transform: scale(1);\n            background: #10b981;\n            color: white;\n            border-color: #10b981;\n        }\n        \n        .canvas-element.is-selected .select-btn:hover {\n            background: #059669;\n        }\n\n        /* 2. Enlarge Button (Bottom Left) */\n        .enlarge-btn {\n            bottom: 15px;\n            left: 15px;\n            background: #FFF8E1; /* Creamy beige background */\n            color: #1f2937;       /* Dark icon */\n            border: 1px solid #fde68a; /* Subtle border */\n        }\n\n        .enlarge-btn:hover {\n            background: #fef3c7;\n            transform: scale(1.1);\n        }\n        \n        /* Font size tweak for the icons */\n        .canvas-btn i {\n            font-size: 14px;\n        }\n\n        /* Hide scrollbar */\n        ::-webkit-scrollbar { width: 0px; background: transparent; }\n    </style>\n</head>\n<body>\n\n<div id=\"app-container\">\n    <div id=\"viewer-scroll-area\">\n        <div id=\"main-canvas\">\n            <!-- Elements injected here -->\n        </div>\n    </div>\n</div>\n\n<script>\n    // --- State Management ---\n    const state = {\n        elements: [],\n        selectedImages: new Set(), // Track selected IDs\n        canvasWidth: 0,\n        canvasHeight: 800,\n        originalDesignWidth: 0\n    };\n\n    const canvas = document.getElementById('main-canvas');\n    \n    // Placeholder CTA handler - Override this in your app\n    window.myop_cta_handler = window.myop_cta_handler || function(action, payload) {\n        console.log('CTA Triggered:', action, payload);\n    };\n\n    // --- Helper: Send Height CTA ---\n    function sendHeightCTA() {\n        if(window.myop_cta_handler) {\n            window.myop_cta_handler('canvasHeight', { height: state.canvasHeight });\n        }\n    }\n\n    // --- Public API ---\n    window.myop_init_interface = function(config) {\n        state.canvasWidth = canvas.getBoundingClientRect().width;\n        \n        if(config.loadDesign) {\n            if(config.loadDesign.canvasHeight) {\n                state.canvasHeight = config.loadDesign.canvasHeight;\n                canvas.style.height = state.canvasHeight + 'px';\n            }\n\n            state.originalDesignWidth = config.loadDesign.canvasWidth || state.canvasWidth;\n\n            if(config.loadDesign.elements) {\n                state.elements = config.loadDesign.elements;\n                const scaleFactor = state.canvasWidth / state.originalDesignWidth;\n                \n                if(Math.abs(scaleFactor - 1) > 0.01) {\n                    scaleElements(scaleFactor);\n                }\n\n                renderAllElements();\n            }\n        }\n        \n        // Notify height after initial render\n        sendHeightCTA();\n    };\n\n    // --- Interaction Logic ---\n    \n    function toggleImageSelection(id) {\n        const elDiv = document.getElementById(id);\n        if (!elDiv) return;\n\n        if (state.selectedImages.has(id)) {\n            // Deselect\n            state.selectedImages.delete(id);\n            elDiv.classList.remove('is-selected');\n            window.myop_cta_handler('element_selection_change', { id: id, selected: false });\n        } else {\n            // Select\n            state.selectedImages.add(id);\n            elDiv.classList.add('is-selected');\n            window.myop_cta_handler('element_selection_change', { id: id, selected: true });\n        }\n    }\n\n    function requestEnlarge(id) {\n        // Prevent event bubbling if necessary, though absolute positioning usually separates them\n        window.myop_cta_handler('element_enlarge_request', { id: id });\n    }\n\n    // --- Rendering Logic ---\n\n    function renderAllElements() {\n        canvas.innerHTML = ''; \n        state.elements.forEach(renderElementDOM);\n    }\n\n    function renderElementDOM(elData) {\n        const elDiv = document.createElement('div');\n        elDiv.id = elData.id;\n        elDiv.className = 'canvas-element';\n        \n        elDiv.style.width = `${elData.w}px`;\n        elDiv.style.height = `${elData.h}px`;\n        elDiv.style.top = `${elData.y}px`;\n        elDiv.style.left = `${elData.x}px`;\n        elDiv.style.transform = `rotate(${elData.rotation || 0}deg)`;\n        elDiv.style.zIndex = elData.zIndex;\n\n        let contentHtml = '';\n        \n        if (elData.type === 'rect') {\n            contentHtml = `<div class=\"element-content\" style=\"background-color: ${elData.color}; border-radius: 4px;\"></div>`;\n        } \n        else if (elData.type === 'image') {\n            // Inject Image + UI Buttons\n            contentHtml = `\n                <img src=\"${elData.src}\" class=\"element-content image-content\" draggable=\"false\" alt=\"canvas element\">\n                \n                <!-- Enlarge Button (Bottom Left) -->\n                <div class=\"canvas-btn enlarge-btn\" onclick=\"requestEnlarge('${elData.id}')\" title=\"Enlarge\">\n                    <i class=\"fas fa-magnifying-glass-plus\"></i>\n                </div>\n\n                <!-- Select Button (Bottom Right) -->\n                <div class=\"canvas-btn select-btn\" onclick=\"toggleImageSelection('${elData.id}')\" title=\"Select Image\">\n                    <i class=\"fas fa-check\"></i>\n                </div>\n            `;\n            // Restore selection state if re-rendering\n            if (state.selectedImages.has(elData.id)) {\n                elDiv.classList.add('is-selected');\n            }\n        } \n        else if (elData.type === 'text') {\n            contentHtml = `<div class=\"element-content text-content\" \n                           style=\"color: ${elData.color}; \n                                  font-family: ${elData.fontFamily}; \n                                  text-align: ${elData.textAlign}; \n                                  font-size: ${elData.fontSize}px;\">${elData.content}</div>`;\n        }\n\n        elDiv.innerHTML = contentHtml;\n        canvas.appendChild(elDiv);\n    }\n\n    // --- Logic Helpers ---\n\n    function scaleElements(scale) {\n        state.elements.forEach(el => {\n            el.x *= scale;\n            el.y *= scale;\n            el.w *= scale;\n            el.h *= scale;\n            if (el.type === 'text') el.fontSize *= scale;\n            if (el.cropX) el.cropX *= scale;\n            if (el.cropY) el.cropY *= scale;\n        });\n        \n        state.originalDesignWidth = state.canvasWidth;\n        state.canvasHeight *= scale;\n        canvas.style.height = state.canvasHeight + 'px';\n        \n        // Notify height change after scaling\n        sendHeightCTA();\n    }\n\n    // --- Responsive Resize Engine ---\n    \n    let resizeTimer;\n    window.onresize = () => {\n        clearTimeout(resizeTimer);\n        resizeTimer = setTimeout(() => {\n            const newWidth = canvas.getBoundingClientRect().width;\n            if (state.canvasWidth === 0 || Math.abs(newWidth - state.canvasWidth) < 1) return;\n            const scale = newWidth / state.canvasWidth;\n            scaleElements(scale);\n            state.canvasWidth = newWidth;\n            renderAllElements();\n        }, 100);\n    };\n\n    // --- Initialization Example ---\n    window.onload = () => {\n        const mockDesign = {\n            canvasWidth: 480,\n            canvasHeight: 900,\n            elements: [\n                {\n                    id: 'header_text',\n                    type: 'text',\n                    x: 20, y: 40, w: 440, h: 60,\n                    content: 'My Travel Gallery',\n                    fontSize: 40,\n                    fontFamily: 'Playfair Display',\n                    textAlign: 'center',\n                    color: '#111827',\n                    zIndex: 10\n                },\n                {\n                    id: 'photo_1',\n                    type: 'image',\n                    x: 20, y: 120, w: 215, h: 280,\n                    src: 'https://picsum.photos/id/15/400/600',\n                    zIndex: 1\n                },\n                {\n                    id: 'photo_2',\n                    type: 'image',\n                    x: 245, y: 120, w: 215, h: 160,\n                    src: 'https://picsum.photos/id/11/400/300',\n                    zIndex: 2\n                },\n                {\n                    id: 'photo_3',\n                    type: 'image',\n                    x: 245, y: 290, w: 215, h: 280,\n                    src: 'https://picsum.photos/id/20/400/600',\n                    zIndex: 3\n                },\n                {\n                    id: 'rect_deco',\n                    type: 'rect',\n                    x: 20, y: 410, w: 215, h: 10,\n                    color: '#3b82f6',\n                    zIndex: 5\n                },\n                {\n                    id: 'caption_text',\n                    type: 'text',\n                    x: 20, y: 430, w: 215, h: 140,\n                    content: \"Hover over images to see the buttons. Click the check to select, or the magnifier to enlarge.\",\n                    fontSize: 16,\n                    fontFamily: 'Inter',\n                    textAlign: 'left',\n                    color: '#4b5563',\n                    zIndex: 11\n                }\n            ]\n        };\n\n        window.myop_init_interface({\n            loadDesign: mockDesign\n        });\n    };\n\n</script>\n</body>\n</html>"
        }
      }
    ]
  }
}