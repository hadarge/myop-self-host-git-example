          "HTML": "<!-- Start coding here -->\n<div>Add your design here</div>\n\n<script type=\"myop/types\">\n    // =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Font size token\n */\ninterface ConfigDtoFontSizeToken {\n  fontSize: string;\n  lineHeight: string;\n  letterSpacing: string;\n}\n\n/**\n * Text style token\n */\ninterface ConfigDtoTextStyle {\n  fontFamily: string;\n  fontSize: string;\n  lineHeight: string;\n  letterSpacing: string;\n  fontWeight: number;\n}\n\n/**\n * Font repository item\n */\ninterface ConfigDtoFontRepositoryItem {\n  id: string;\n  family: string;\n  weights: Record<string, number>;\n  url: string;\n}\n\n/**\n * Font sizes scale (FS-10 to FS-260)\n */\ninterface ConfigDtoFontSizes {\n  [key: string]: ConfigDtoFontSizeToken;\n}\n\n/**\n * Dominant color from media palette\n */\ninterface DominantColor {\n  r: number;\n  g: number;\n  b: number;\n}\n\n/**\n * Person/identity in media\n */\ninterface ConfigDtoMediaPerson {\n  id: string | number;\n  age?: number;\n  gender?: string;\n  facePosition?: { x: number; y: number; width: number; height: number };\n}\n\n/**\n * Media item from gallery (image or videoclip)\n */\ninterface ConfigDtoMediaItem {\n  id: number | string;\n  type: 'image' | 'videoclip';\n  proportions: number;\n  widthApx?: number;\n  heightApx?: number;\n  dominantColor?: DominantColor;\n  palette?: Array<{ color: DominantColor; score: number }>;\n  isHighlighted: boolean;\n  isLarge: boolean;\n  isFavorite: boolean;\n  isInCollection: boolean;\n  likes: number;\n  aiRanking: number;\n  persons?: ConfigDtoMediaPerson[];\n  suggestions?: string[];\n  isVendorPhoto?: boolean;\n  favoritesCount?: number;\n  focalPoint?: { x: number; y: number };\n  goodResUrl: string;\n  midResUrl: string;\n}\n\n/**\n * Product from storefront\n */\ninterface ConfigDtoProduct {\n  id: number;\n  name: string;\n  description?: string;\n  price?: number;\n  imageUrl?: string;\n  hasPdp: boolean;\n}\n\n/**\n * Brand information\n */\ninterface ConfigDtoBrand {\n  name: string;\n  logos: string[];\n  social: Record<string, string>;\n}\n\n/**\n * Design system configuration\n */\ninterface ConfigDtoDesign {\n  colors: Record<string, Record<string, string>>;\n  fonts: {\n    fontFamilies: ConfigDtoFontRepositoryItem[];\n    fontSizes: ConfigDtoFontSizes;\n  };\n  textStyles?: Record<string, ConfigDtoTextStyle>;\n}\n\n/**\n * Scene block content\n */\ninterface ConfigDtoScene {\n  media: ConfigDtoMediaItem[];\n  title: string;\n  description: string;\n}\n\n/**\n * Storefront configuration\n */\ninterface ConfigDtoStore {\n  products: ConfigDtoProduct[];\n}\n\n/**\n * Configuration DTO from host application\n */\ninterface ConfigDTO {\n  brand?: ConfigDtoBrand;\n  design?: ConfigDtoDesign;\n  scene?: ConfigDtoScene;\n  store?: ConfigDtoStore;\n  flavor?: string;\n}\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData extends ConfigDTO {\n  message?: string;\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'media-clicked': { mediaId: number | string; type: 'image' | 'videoclip' };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n\n<script>\n// Called on initialization and whenever the host sends configuration or state updates to this component\nmyop_init_interface = () => {}\n\n// Provided by the host - call this function to send data or trigger actions in the host app\nmyop_cta_handler = () => {}\n\n</script>"
