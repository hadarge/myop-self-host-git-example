        "name": "fix entity type",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Unsaved Changes Modal</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap\" rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            width: 100%;\n            height: auto;\n            min-height: 400px;\n            overflow: visible;\n            background: transparent;\n            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n            font-size: 13px;\n            color: #18181b;\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n        }\n\n        .modal-container {\n            width: 480px;\n            padding-right: 32px;\n            padding-left: 32px;\n            display: flex;\n            align-items: flex-start;\n            justify-content: center;\n        }\n\n        .modal-content {\n            width: 100%;\n            max-width: 600px;\n            background: #ffffff;\n        }\n\n        .modal-icon {\n            width: 61px;\n            height: 61px;\n            margin-bottom: 24px;\n        }\n\n        @keyframes moveGradient {\n            0% {\n                transform: translate(0, 0);\n            }\n            50% {\n                transform: translate(5px, 5px);\n            }\n            100% {\n                transform: translate(0, 0);\n            }\n        }\n\n\n        .modal-title {\n            font-size: 24px;\n            font-weight: 600;\n            color: #18181b;\n            margin-bottom: 16px;\n            line-height: 1.3;\n        }\n\n        .modal-message {\n            font-size: 15px;\n            color: #71717a;\n            margin-bottom: 12px;\n            line-height: 1.6;\n        }\n\n        .modal-question {\n            font-size: 15px;\n            color: #18181b;\n            margin-bottom: 32px;\n            line-height: 1.6;\n        }\n\n        .modal-actions {\n            display: flex;\n            gap: 12px;\n            justify-content: flex-start;\n        }\n\n        .btn {\n            padding: 8px 16px;\n            border-radius: 6px;\n            font-size: 13px;\n            font-weight: 500;\n            font-family: 'DM Sans', sans-serif;\n            cursor: pointer;\n            transition: all 0.15s ease;\n            border: 1px solid #D3D1D5;\n            background: #ffffff;\n            color: #18181b;\n        }\n\n        .btn:hover {\n            border-radius: 6px;\n            border: 1px solid #DECCFF;\n            background: #F0E8FF;\n        }\n\n        .btn-primary {\n            background: #3f3f46;\n            color: #ffffff;\n            border: 1px solid #3f3f46;\n        }\n\n        .btn-primary:hover {\n            background: #18181b;\n            border: 1px solid #18181b;\n        }\n\n        /* Loader */\n        #loader-container {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 200px;\n        }\n\n        .loader-spinner {\n            width: 32px;\n            height: 32px;\n            border: 3px solid #D3D1D5;\n            border-top-color: #DECCFF;\n            border-radius: 50%;\n            animation: spin 0.8s linear infinite;\n        }\n\n        @keyframes spin {\n            to { transform: rotate(360deg); }\n        }\n\n        /* App Root - hidden by default until data loads */\n        #app-root {\n            opacity: 0;\n            transition: opacity 0.2s ease;\n        }\n\n        #app-root.loaded {\n            opacity: 1;\n        }\n    </style>\n</head>\n<body>\n\n<!-- Loader Container -->\n<div id=\"loader-container\">\n    <div class=\"loader-spinner\"></div>\n</div>\n\n<!-- App Root -->\n<div id=\"app-root\">\n<div class=\"modal-container\" id=\"modalContainer\">\n    <div class=\"modal-content\">\n        <div class=\"modal-icon\">\n            <svg width=\"61\" height=\"61\" viewBox=\"0 0 61 61\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                <rect\n                        opacity=\"0.4\"\n                        x=\"9.5\"\n                        y=\"5.30078\"\n                        width=\"47.4\"\n                        height=\"47.4\"\n                        rx=\"23.7\"\n                        fill=\"url(#paint0_linear_3673_176764)\"\n                        style=\"animation: moveGradient 4s ease-in-out infinite;\"\n                />\n                <path\n                        d=\"M30.7587 53.8162C43.4935 53.8162 53.8172 43.4926 53.8172 30.7577C53.8172 18.0229 43.4935 7.69922 30.7587 7.69922C18.0238 7.69922 7.7002 18.0229 7.7002 30.7577C7.7002 43.4926 18.0238 53.8162 30.7587 53.8162Z\"\n                        stroke=\"#0A090A\"\n                        stroke-miterlimit=\"10\"\n                        stroke-linecap=\"round\"\n                />\n                <path\n                        d=\"M30.7587 42.3523C31.3409 42.3523 31.8128 41.8804 31.8128 41.2982C31.8128 40.7161 31.3409 40.2441 30.7587 40.2441C30.1765 40.2441 29.7046 40.7161 29.7046 41.2982C29.7046 41.8804 30.1765 42.3523 30.7587 42.3523Z\"\n                        stroke=\"#0A090A\"\n                        stroke-linecap=\"round\"\n                />\n                <path\n                        d=\"M30.7593 20.2773V32.8547\"\n                        stroke=\"#0A090A\"\n                        stroke-miterlimit=\"10\"\n                        stroke-linecap=\"round\"\n                />\n                <defs>\n                    <linearGradient id=\"paint0_linear_3673_176764\" x1=\"57.8085\" y1=\"29.0008\" x2=\"30.7501\" y2=\"55.0848\" gradientUnits=\"userSpaceOnUse\">\n                        <stop offset=\"0.08\" stop-color=\"#FF8651\"/>\n                        <stop offset=\"0.515337\" stop-color=\"#FFBEA8\"/>\n                        <stop offset=\"0.945\" stop-color=\"#A397F5\"/>\n                    </linearGradient>\n                </defs>\n            </svg>\n        </div>\n        <h1 class=\"modal-title\" id=\"modalTitle\">You have unsaved changes</h1>\n        <p class=\"modal-message\" id=\"modalMessage\">\n            If you leave 'ReactTemplateComponent', your changes will not be saved.\n        </p>\n        <p class=\"modal-question\" id=\"modalQuestion\">\n            Are you sure you want to continue?\n        </p>\n        <div class=\"modal-actions\">\n            <button class=\"btn\" id=\"btnSecondary\">Leave without saving</button>\n            <button class=\"btn btn-primary\" id=\"btnPrimary\">Stay</button>\n        </div>\n    </div>\n</div>\n</div><!-- End App Root -->\n\n<script>\n    (function() {\n        // ==========================================\n        // PRIVATE SCOPE\n        // ==========================================\n\n        // Private state\n        let contentState = {\n            title: 'You have unsaved changes',\n            message: \"If you leave this {entityType}, your changes will not be saved.\",\n            question: 'Are you sure you want to continue?',\n            primaryButtonText: 'Stay',\n            secondaryButtonText: 'Leave without saving',\n            entityType: 'item'\n        };\n        let isInitialized = false;\n\n        // Cache DOM elements\n        const elements = {\n            loaderContainer: document.getElementById('loader-container'),\n            appRoot: document.getElementById('app-root'),\n            modalTitle: document.getElementById('modalTitle'),\n            modalMessage: document.getElementById('modalMessage'),\n            modalQuestion: document.getElementById('modalQuestion'),\n            btnPrimary: document.getElementById('btnPrimary'),\n            btnSecondary: document.getElementById('btnSecondary')\n        };\n\n        // Private helper functions\n        function hideLoader() {\n            elements.loaderContainer.style.display = 'none';\n            elements.appRoot.classList.add('loaded');\n        }\n\n        function render() {\n            if (elements.modalTitle) elements.modalTitle.textContent = contentState.title;\n            if (elements.modalMessage) {\n                // Replace {entityType} placeholder with actual entity type\n                elements.modalMessage.textContent = contentState.message.replace(\n                    '{entityType}',\n                    contentState.entityType\n                );\n            }\n            if (elements.modalQuestion) elements.modalQuestion.textContent = contentState.question;\n            if (elements.btnPrimary) elements.btnPrimary.textContent = contentState.primaryButtonText;\n            if (elements.btnSecondary) elements.btnSecondary.textContent = contentState.secondaryButtonText;\n\n            // Report height after rendering\n            setTimeout(reportHeight, 100);\n        }\n\n        function reportHeight() {\n            const container = document.querySelector('.modal-container');\n            if (container) {\n                const height = container.scrollHeight;\n                window.myop_cta_handler('heightChange', { height: height });\n            }\n        }\n\n        function handlePrimaryClick() {\n            console.log('Component: Primary button clicked (Stay)');\n            window.myop_cta_handler('primaryClick', { action: 'stay' });\n        }\n\n        function handleSecondaryClick() {\n            console.log('Component: Secondary button clicked (Leave)');\n            window.myop_cta_handler('secondaryClick', { action: 'leave' });\n        }\n\n        // ==========================================\n        // PUBLIC API - Only 2 global functions\n        // ==========================================\n\n        /**\n         * Initialize component with data OR receive updates from host\n         * Handles both initialization and subsequent updates\n         */\n        window.myop_init_interface = function(data) {\n            if (arguments.length > 0) {\n                console.log('Component: myop_init_interface() called with:', data);\n\n                // Handle initialization data\n                if (data.title !== undefined) contentState.title = data.title;\n                if (data.message !== undefined) contentState.message = data.message;\n                if (data.question !== undefined) contentState.question = data.question;\n                if (data.primaryButtonText !== undefined) contentState.primaryButtonText = data.primaryButtonText;\n                if (data.secondaryButtonText !== undefined) contentState.secondaryButtonText = data.secondaryButtonText;\n                if (data.entityType !== undefined) contentState.entityType = data.entityType;\n\n                // Handle action-based updates\n                if (data.action) {\n                    switch (data.action) {\n                        case 'setContent':\n                            if (data.payload) {\n                                contentState = { ...contentState, ...data.payload };\n                            }\n                            break;\n\n                        case 'updateEntityType':\n                            if (data.payload && data.payload.entityType) {\n                                contentState.entityType = data.payload.entityType;\n                            }\n                            break;\n\n                        case 'reset':\n                            contentState = {\n                                title: 'You have unsaved changes',\n                                message: \"If you leave this {entityType}, your changes will not be saved.\",\n                                question: 'Are you sure you want to continue?',\n                                primaryButtonText: 'Stay',\n                                secondaryButtonText: 'Leave without saving',\n                                entityType: 'item'\n                            };\n                            break;\n\n                        default:\n                            console.warn('Component: Unknown action:', data.action);\n                    }\n                }\n\n                // Attach event listeners only once\n                if (!isInitialized) {\n                    elements.btnPrimary.addEventListener('click', handlePrimaryClick);\n                    elements.btnSecondary.addEventListener('click', handleSecondaryClick);\n                    isInitialized = true;\n                }\n\n                render();\n                hideLoader();\n                return data;\n            }\n            // Getter: Return current state\n            return { ...contentState };\n        };\n\n        /**\n         * Handle user actions and communicate back to the host application\n         * @param {string} action_id - The action identifier\n         * @param {object} payload - The action payload\n         */\n        window.myop_cta_handler = function(action_id, payload) {\n            console.log('Component: myop_cta_handler called with:', action_id, payload);\n            // This function is overridden by the host application\n        };\n\n        console.log('Component loaded, waiting for myop_init_interface() call');\n\n    })(); // End IIFE\n</script>\n\n<!-- Preview/Mock Data for Development -->\n<script id=\"myop_preview\">\n    setTimeout(() => {\n        window.myop_init_interface({\n            entityType: 'component'\n        });\n    });\n</script>\n</body>\n\n</html>"
        },
        "id": "03ea8d80-6446-41f3-8698-6aa9108d664f"
      }
    ]
