        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Referral Component</title>\n    <style>\n        /* General Reset and Font Fallback */\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            /* Using a robust font stack since 'TT Norms Pro' is external and no URL was provided. */\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;\n            padding: 40px;\n            background: transparent;\n            min-height: 100vh;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .container {\n            position: relative;\n        }\n\n        .referral-card {\n            position: relative;\n            width: 367px;\n            margin: 0 auto;\n            cursor: pointer;\n        }\n\n        .card-wrapper {\n            position: relative;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 0 15px rgba(0, 0, 0, 0.07);\n            padding: 23px 28px;\n            display: flex;\n            align-items: center;\n            gap: 18px;\n            transition: all 0.3s ease;\n        }\n\n        /* Hover Effect */\n        .card-wrapper:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\n        }\n\n        /* State Sizing and Alignment */\n        .card-wrapper.empty-state {\n            height: 88px;\n        }\n\n        .card-wrapper.active-state {\n            height: 147px;\n            align-items: flex-start; /* Aligns content to the top for vertical layout */\n        }\n\n        /* Icon Styling */\n        .gift-icon {\n            flex-shrink: 0;\n            width: 32.345px;\n            height: 32px;\n            transition: transform 0.3s ease-in-out;\n        }\n\n        .gift-icon svg {\n            width: 100%;\n            height: 100%;\n        }\n\n        /* Icon Animation (Pulse) for Server-side trigger */\n        @keyframes pulse {\n            0% { transform: scale(1); opacity: 1; }\n            50% { transform: scale(1.1); opacity: 0.9; }\n            100% { transform: scale(1); opacity: 1; }\n        }\n        \n        .gift-icon.animate-pulse {\n            animation: pulse 1.5s infinite ease-in-out;\n        }\n\n        .content {\n            flex: 1;\n        }\n\n        /* Arrow Icon Positioning */\n        .arrow-icon {\n            position: absolute;\n            right: 28px;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 24px;\n            height: 24px;\n        }\n\n        .active-state .arrow-icon {\n            top: 51px; /* Repositioned for the taller active state card */\n            transform: none;\n        }\n\n        /* Empty State Typography */\n        .empty-title {\n            font-size: 16px;\n            font-weight: 500;\n            color: #000;\n            margin-bottom: 4px;\n        }\n\n        .empty-subtitle {\n            font-size: 14px;\n            color: #757575;\n        }\n\n        /* Active State Typography */\n        .earnings {\n            font-size: 32px;\n            font-weight: 400;\n            color: #000;\n            line-height: 1.25;\n            display: inline-block;\n            margin-right: 5px;\n        }\n\n        .earnings-label {\n            font-size: 14px;\n            font-weight: 400;\n            color: #000;\n            display: inline-block;\n            vertical-align: super;\n        }\n\n        .stats {\n            font-size: 14px;\n            color: #000;\n            margin-top: 9px;\n            font-weight: 500;\n        }\n\n        .cta {\n            font-size: 14px;\n            color: #757575;\n            margin-top: 9px;\n        }\n\n        /* Confetti Canvas - Fixed position to cover the whole screen */\n        #confetti-canvas {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: 9999;\n            background: transparent;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <!-- Confetti canvas is rendered outside the card but covers the viewport -->\n        <canvas id=\"confetti-canvas\"></canvas>\n        <div id=\"referral-card\" class=\"referral-card\">\n            <!-- Content will be injected here by JavaScript -->\n        </div>\n    </div>\n\n    <script>\n        // --- GLOBAL VARIABLES ---\n        let currentConfig = null;\n        const referralCardContainer = document.getElementById('referral-card');\n        const confettiCanvas = document.getElementById('confetti-canvas');\n        \n        // SVG Paths (Gift and Arrow)\n        const giftIconPath = \"M4.0752 2.63329C5.10507 0.583067 7.51754 -0.607567 10.1982 0.318836C12.2788 1.03801 14.3539 2.96231 16.1719 6.3579C17.9899 2.96211 20.0659 1.03809 22.1465 0.318836C24.827 -0.60766 27.2395 0.582347 28.2695 2.63231C29.1939 4.47273 28.9254 6.81089 27.1875 8.6411H32.3447V17.6255H30.5479V32.0015H1.79688V17.6255H0V8.6411H5.15723C3.41947 6.81108 3.15104 4.47365 4.0752 2.63329ZM4.49219 29.3052H14.375L14.376 18.5239H4.49219V29.3052ZM17.0713 29.3052H27.8525V18.5239H17.0713V29.3052ZM2.69531 14.9302H14.376V11.7827C12.9294 11.7382 11.6404 11.5841 10.5 11.3364H2.69531V14.9302ZM21.8447 11.3364C20.4736 11.6342 18.8875 11.7971 17.0713 11.7964V14.9302H29.6494V11.3364H21.8447ZM25.8613 3.84227C25.4311 2.98608 24.4174 2.38625 23.0273 2.86669C21.6877 3.32979 19.8295 4.87985 18.0459 8.6411H21.5322C23.039 8.2821 24.0967 7.75135 24.8008 7.18309C26.2403 6.02125 26.2852 4.68627 25.8613 3.84227ZM9.31738 2.86669C7.92737 2.38634 6.91366 2.98603 6.4834 3.84227C6.05946 4.68635 6.1044 6.02217 7.54395 7.18407C8.24763 7.7519 9.30444 8.28211 10.8096 8.6411H14.2998C12.5161 4.87946 10.6571 3.32973 9.31738 2.86669Z\";\n        const arrowIconSVG = `<svg fill=\"none\" viewBox=\"0 0 24 24\"><path d=\"M9 6L15 12L9 18\" stroke=\"#000\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>`;\n\n        // --- PUBLIC GLOBAL CTA HANDLER ---\n        /**\n         * Function called to report actions back to the hosting application.\n         * @param {string} action_id - Identifier of the action (e.g., 'navigation_item').\n         * @param {object} payload - Data related to the action.\n         */\n        window.myop_cta_handler = (action_id, payload) => {\n            // Logs the action instead of using alert()\n            console.log(`CTA Handler: Action ID: ${action_id}, Payload:`, payload);\n        };\n\n        // --- CONFETTI LOGIC (Canvas-based) ---\n        class Confetti {\n            constructor(canvas) {\n                this.canvas = canvas;\n                this.ctx = canvas.getContext('2d');\n                this.particles = [];\n                this.animationId = null;\n                this.resize();\n                window.addEventListener('resize', () => this.resize());\n            }\n\n            resize() {\n                this.canvas.width = window.innerWidth;\n                this.canvas.height = window.innerHeight;\n            }\n\n            createParticle() {\n                const colors = ['#FF6B35', '#5B8DEE', '#FF4081', '#FFC107', '#00BFA5', '#7B68EE'];\n                const shapes = ['square', 'dash', 'circle', 'squiggle'];\n                \n                // Center the confetti effect around the component area\n                const centerX = this.canvas.width / 2;\n                const componentWidth = 367;\n                const confettiWidth = componentWidth + 200; // Wider burst area\n                \n                return {\n                    x: centerX - confettiWidth / 2 + Math.random() * confettiWidth,\n                    y: Math.random() * 50, // Start from near the top\n                    size: Math.random() * 8 + 4,\n                    speedY: Math.random() * 3 + 2,\n                    speedX: Math.random() * 2 - 1,\n                    color: colors[Math.floor(Math.random() * colors.length)],\n                    shape: shapes[Math.floor(Math.random() * shapes.length)],\n                    rotation: Math.random() * 360,\n                    rotationSpeed: Math.random() * 5 - 2.5,\n                    opacity: 1\n                };\n            }\n\n            start() {\n                // Clear and stop any previous animation\n                this.stop(); \n                \n                // Create initial burst of 80 particles\n                for (let i = 0; i < 80; i++) {\n                    this.particles.push(this.createParticle());\n                }\n                this.animate();\n            }\n\n            animate() {\n                this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);\n\n                for (let i = this.particles.length - 1; i >= 0; i--) {\n                    const p = this.particles[i];\n                    \n                    p.y += p.speedY;\n                    p.x += p.speedX;\n                    p.rotation += p.rotationSpeed;\n                    \n                    // Fade out as it falls further down\n                    if (p.y > this.canvas.height * 0.7) {\n                        p.opacity -= 0.015;\n                    }\n\n                    if (p.y > this.canvas.height || p.opacity <= 0) {\n                        this.particles.splice(i, 1);\n                        continue;\n                    }\n\n                    // Draw particle\n                    this.ctx.save();\n                    this.ctx.globalAlpha = p.opacity;\n                    this.ctx.translate(p.x, p.y);\n                    this.ctx.rotate((p.rotation * Math.PI) / 180);\n                    this.ctx.fillStyle = p.color;\n                    this.ctx.strokeStyle = p.color;\n                    this.ctx.lineWidth = 2;\n                    this.ctx.lineCap = 'round';\n                    \n                    // Simple shapes for confetti\n                    if (p.shape === 'circle') {\n                        this.ctx.beginPath();\n                        this.ctx.arc(0, 0, p.size / 2, 0, Math.PI * 2);\n                        this.ctx.fill();\n                    } else if (p.shape === 'square') {\n                        this.ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);\n                    } else if (p.shape === 'dash') {\n                        this.ctx.beginPath();\n                        this.ctx.moveTo(-p.size/2, 0);\n                        this.ctx.lineTo(p.size/2, 0);\n                        this.ctx.stroke();\n                    } else if (p.shape === 'squiggle') {\n                        this.ctx.beginPath();\n                        this.ctx.moveTo(-p.size, 0);\n                        this.ctx.quadraticCurveTo(-p.size/2, -p.size/2, 0, 0);\n                        this.ctx.quadraticCurveTo(p.size/2, p.size/2, p.size, 0);\n                        this.ctx.stroke();\n                    }\n\n                    this.ctx.restore();\n                }\n\n                if (this.particles.length > 0) {\n                    this.animationId = requestAnimationFrame(() => this.animate());\n                } else {\n                    this.stop();\n                }\n            }\n\n            stop() {\n                if (this.animationId) {\n                    cancelAnimationFrame(this.animationId);\n                    this.animationId = null;\n                }\n                this.particles = [];\n                this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);\n            }\n        }\n\n        const confettiInstance = new Confetti(confettiCanvas);\n\n        // --- RENDER LOGIC ---\n\n        /**\n         * Renders the referral component based on the configuration.\n         * @param {object} data - The component data from currentConfig.\n         */\n        function renderComponent(data) {\n            const lang = data.lang;\n            const isEmptyState = data.signedUp === 0;\n            const iconAnimationClass = data.animation ? 'animate-pulse' : '';\n\n            // Stop confetti if component is re-rendered or not in celebration mode\n            confettiInstance.stop();\n            \n            let html = '';\n            \n            if (isEmptyState) {\n                // Case 1: Empty State\n                html = `\n                    <div class=\"card-wrapper empty-state\">\n                        <div class=\"gift-icon ${iconAnimationClass}\">\n                            <svg fill=\"none\" viewBox=\"0 0 33 32\">\n                                <path d=\"${giftIconPath}\" fill=\"#222222\"/>\n                            </svg>\n                        </div>\n                        <div class=\"content\">\n                            <div class=\"empty-title\">${data.reward}</div>\n                            <div class=\"empty-subtitle\">${lang.subtitle}</div>\n                        </div>\n                        <div class=\"arrow-icon\">\n                            ${arrowIconSVG}\n                        </div>\n                    </div>\n                `;\n            } else {\n                // Case 2 & 3: Active/Earned State (with or without confetti)\n                const isMoneyReward = data.reward.includes('$');\n                let displayReward;\n                \n                if (isMoneyReward) {\n                    // Updated to use lang.totalEarnings\n                    displayReward = `<span class=\"earnings\">${data.reward}</span> <span class=\"earnings-label\">${lang.totalEarnings}</span>`;\n                } else {\n                    // Updated to use lang.earned\n                    displayReward = `<span class=\"earnings\">${data.reward}</span> <span class=\"earnings-label\">${lang.earned}</span>`;\n                }\n                \n                html = `\n                    <div class=\"card-wrapper active-state\">\n                        <div class=\"gift-icon ${iconAnimationClass}\">\n                            <svg fill=\"none\" viewBox=\"0 0 33 32\">\n                                <path d=\"${giftIconPath}\" fill=\"#222222\"/>\n                            </svg>\n                        </div>\n                        <div class=\"content\">\n                            <div>${displayReward}</div>\n                            <!-- Updated to use lang.statsSignedUp and lang.statsPending -->\n                            <div class=\"stats\">${data.signedUp} ${lang.statsSignedUp}, ${data.pending} ${lang.statsPending}</div>\n                            <div class=\"cta\">${lang.cta}</div>\n                        </div>\n                        <div class=\"arrow-icon\">\n                            ${arrowIconSVG}\n                        </div>\n                    </div>\n                `;\n                \n                // Case 3: Celebration mode (Confetti = true)\n                if (data.confetti) {\n                    // Start confetti animation shortly after rendering\n                    setTimeout(() => confettiInstance.start(), 100);\n                }\n            }\n            \n            referralCardContainer.innerHTML = html;\n        }\n\n        // --- PUBLIC GLOBAL INITIALIZATION FUNCTION ---\n        /**\n         * Initializes the component interface with configuration data.\n         * @param {object} config - The full configuration object.\n         */\n        window.myop_init_interface = (config) => {\n            // Apply external font if provided in config\n            if (config.fontUrl) {\n                // Note: The prompt requires 'no external dependency' except via config for fonts.\n                // This simulates loading the font URL if provided.\n                const link = document.createElement('link');\n                link.href = config.fontUrl;\n                link.rel = 'stylesheet';\n                document.head.appendChild(link);\n            }\n\n            // Map and sanitize config data\n            currentConfig = {\n                reward: config.Rewards || \"Get 1 month free\",\n                signedUp: parseInt(config['# of signed up'], 10) || 0,\n                pending: parseInt(config['# of pending'], 10) || 0,\n                confetti: config.Confetti === true, // Ensure boolean type\n                animation: config.animation === true, // Ensure boolean type\n                // Removed animationLottieFile mapping, relying only on local CSS animation\n                lang: config.lang || {\n                    subtitle: \"Invite a friend to Pic-Time\",\n                    totalEarnings: \"total earnings\", /* Updated to camelCase */\n                    earned: \"earned\",\n                    statsSignedUp: \"Signed up\", /* Updated to camelCase */\n                    statsPending: \"Pending\", /* Updated to camelCase */\n                    cta: \"Invite more friends and earn more\"\n                }\n            };\n\n            // Initial render\n            renderComponent(currentConfig);\n        };\n\n        // --- EVENT LISTENER FOR CTA ---\n        referralCardContainer.addEventListener('click', () => {\n            // All clicks on the card trigger the navigation CTA handler\n            window.myop_cta_handler('navigation_item', { target: 'referral' });\n        });\n\n        // --- MOCK DATA CALLS ---\n        // Demonstrate the three required states:\n        \n        // 1. Empty State Mock Call (Initial State for demonstration)\n        window.myop_init_interface({\n            Rewards: \"Get 1 month free\",\n            '# of signed up': 0,\n            '# of pending': 0,\n            Confetti: false,\n            animation: true,\n            lang: {\n                subtitle: \"Invite a friend to Pic-Time\",\n                totalEarnings: \"total earnings\", /* Updated to camelCase */\n                earned: \"earned\",\n                statsSignedUp: \"Signed up\", /* Updated to camelCase */\n                statsPending: \"Pending\", /* Updated to camelCase */\n                cta: \"Invite more friends and earn more\"\n            }\n        });\n\n        /*\n        // 2. Active State (Earnings) Mock Call - uncomment to test\n        setTimeout(() => {\n            window.myop_init_interface({\n                Rewards: \"$150\",\n                '# of signed up': 3,\n                '# of pending': 1,\n                Confetti: false,\n                animation: false,\n                lang: {\n                    subtitle: \"Invite a friend to Pic-Time\",\n                    totalEarnings: \"total earnings\", // Updated\n                    earned: \"earned\",\n                    statsSignedUp: \"Signed up\", // Updated\n                    statsPending: \"Pending\", // Updated\n                    cta: \"Invite more friends and earn more\"\n                }\n            });\n        }, 3000); \n\n        // 3. Celebration State Mock Call - uncomment to test\n        setTimeout(() => {\n            window.myop_init_interface({\n                Rewards: \"$200\", // Increased earnings to simulate new referral\n                '# of signed up': 4,\n                '# of pending': 1,\n                Confetti: true,\n                animation: true,\n                lang: {\n                    subtitle: \"Invite a friend to Pic-Time\",\n                    totalEarnings: \"total earnings\", // Updated\n                    earned: \"earned\",\n                    statsSignedUp: \"Signed up\", // Updated\n                    statsPending: \"Pending\", // Updated\n                    cta: \"Invite more friends and earn more\"\n                }\n            });\n        }, 6000);\n        */\n    </script>\n</body>\n</html>"
        }
