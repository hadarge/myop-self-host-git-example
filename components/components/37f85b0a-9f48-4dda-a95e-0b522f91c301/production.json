    "consume_variant": [
      {
        "name": "Version 13",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n  <title>Vendor Network</title>\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    html, body {\n      width: 100%;\n      height: 100%;\n      overflow: hidden;\n      margin: 0;\n      padding: 0;\n    }\n\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;\n      -webkit-font-smoothing: antialiased;\n      -moz-osx-font-smoothing: grayscale;\n      background-color: #ffffff;\n    }\n\n    .container {\n      display: flex;\n      flex-direction: column;\n      height: 100%;\n      width: 100%;\n    }\n\n    main {\n      flex: 1;\n      overflow-y: auto;\n      width: 100%;\n      min-height: 0;\n    }\n\n    .content {\n      max-width: 1280px;\n      margin: 0 auto;\n      padding: 40px 48px;\n    }\n\n    .header {\n      display: flex;\n      align-items: flex-start;\n      justify-content: space-between;\n      margin-bottom: 32px;\n    }\n\n    .header h1 {\n      font-size: 24px;\n      color: #111827;\n      margin-bottom: 8px;\n      font-weight: 600;\n    }\n\n    .header p {\n      color: #4b5563;\n      font-size: 14px;\n      line-height: 1.5;\n    }\n\n    .help-button {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      color: #374151;\n      font-size: 14px;\n      background: none;\n      border: none;\n      cursor: pointer;\n      transition: color 0.2s;\n    }\n\n    .help-button:hover {\n      color: #111827;\n    }\n\n    .cards-grid {\n      display: grid;\n      grid-template-columns: repeat(2, 1fr);\n      gap: 24px;\n      margin-bottom: 48px;\n    }\n\n    .action-card {\n      display: flex;\n      align-items: flex-start;\n      gap: 16px;\n      padding: 24px;\n      background: white;\n      border: 1px solid #e5e7eb;\n      border-radius: 4px;\n      cursor: pointer;\n      transition: all 0.2s;\n      text-align: left;\n      width: 100%;\n    }\n\n    .action-card:hover {\n      border-color: #d1d5db;\n      box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);\n    }\n\n    /* Disabled state for action cards */\n    .action-card.disabled {\n      opacity: 0.6;\n      pointer-events: none; /* Disables clicks */\n      background-color: #f3f4f6;\n      border-color: #e5e7eb;\n      box-shadow: none;\n      cursor: default;\n    }\n\n    .icon-circle {\n      flex-shrink: 0;\n      width: 40px;\n      height: 40px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background-color: #f3f4f6;\n      border-radius: 50%;\n    }\n    \n    /* Ensure injected content fits the circle while preserving aspect ratio */\n    .icon-circle svg, \n    .icon-circle img {\n        width: auto;\n        height: auto;\n        max-width: 22px; \n        max-height: 22px;\n        object-fit: contain;\n        display: block;\n    }\n\n    .card-content {\n      flex: 1;\n    }\n\n    .card-content h3 {\n      font-size: 14px;\n      color: #111827;\n      margin-bottom: 4px;\n      font-weight: 500;\n    }\n\n    .card-content p {\n      font-size: 12px;\n      color: #6b7280;\n      line-height: 1.5;\n    }\n\n    /* Style both <a> tags and .learn-more spans to match design */\n    .card-content a,\n    .card-content .learn-more {\n      color: #2563eb;\n      text-decoration: none;\n      margin-left: 4px;\n      cursor: pointer;\n      pointer-events: auto; /* Ensure links are clickable even if parent is disabled, if desired */\n    }\n\n    .card-content a:hover,\n    .card-content .learn-more:hover {\n      text-decoration: underline;\n    }\n\n    .videos-grid {\n      display: grid;\n      grid-template-columns: repeat(2, 1fr);\n      gap: 24px;\n    }\n\n    .video-section h3 {\n      font-size: 14px;\n      color: #111827;\n      margin-bottom: 12px;\n      font-weight: 500;\n    }\n\n    .video-thumbnail {\n      position: relative;\n      border-radius: 4px;\n      overflow: hidden;\n      aspect-ratio: 16 / 9;\n      background-color: #e5e7eb; /* Fallback/Loading color */\n    }\n\n    /* Iframe Styling within the thumbnail container */\n    .video-thumbnail iframe {\n        width: 100%;\n        height: 100%;\n        border: none;\n    }\n\n    @media (max-width: 768px) {\n      body {\n        height: auto;\n        overflow: auto;\n      }\n      .container {\n        height: auto;\n        display: block;\n      }\n      .content {\n        padding: 24px;\n      }\n      .header {\n        flex-direction: column;\n        gap: 16px;\n      }\n      .cards-grid,\n      .videos-grid {\n        grid-template-columns: 1fr;\n      }\n    }\n  </style>\n</head>\n<body>\n  <div id=\"app\" class=\"container\">\n     <!-- Dynamic Content Injected Here -->\n  </div>\n\n  <script>\n    // --- 1. Default Data (Moved to top) ---\n    const defaultConfig = {\n      \"_myopName\": \"Vendors empty state with vendors\",\n      \"includedInCurrentPlan\": true, // Updated to true\n      \"betaFlags\": {\n        \"vendor_integration\": true\n      },\n      \"lang\": {},\n      \"header\": {\n        \"title\": \"The Vendor Network: Build Connections and Boost Business\",\n        \"description\": \"Share curated galleries, collect contact details, and make impactful connections with other professionals\",\n        \"helpText\": \"Help\"\n      },\n      \"actionCards\": [\n        {\n          \"title\": \"Invite new vendor\",\n          \"description\": \"Enter a vendor's details and share curated photos\",\n          \"actionId\": \"invite_new_clicked\",\n          \"iconContent\": '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"></rect><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"></path></svg>'\n        },\n        {\n          \"title\": \"Invite existing vendors\",\n          \"description\": \"Select vendors you've added or worked with before\",\n          \"actionId\": \"invite_existing_clicked\",\n          \"iconContent\": '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"></line><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line></svg>'\n        },\n        {\n          \"title\": \"Share registration link\",\n          \"description\": \"Let clients and vendors add contacts for you\",\n          \"actionId\": \"share_link\",\n          \"iconContent\": '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg>'\n        },\n        {\n          \"title\": \"Import from Wedding Workflows\",\n          \"description\": \"Automatically collect vendor details <span class=\\\"learn-more\\\">Learn More</span>\",\n          \"actionId\": \"import_from_ww_clicked\",\n          \"iconContent\": `<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"31\" height=\"22\" viewBox=\"0 0 31 22\" fill=\"none\"><path d=\"M30.9988 8.37365V8.55481C30.3143 8.58581 30.065 9.34144 29.7751 9.84964L25.727 19.9852L25.6322 20.0272C25.5143 20.0144 25.3793 20.043 25.2669 20.0217C24.9368 19.9579 24.2498 18.8691 24.0723 18.5469C22.8395 16.3116 22.0158 13.6229 20.8596 11.3244C20.8194 11.2454 20.7854 11.1633 20.7155 11.105L17.7039 20.015L16.845 20.0107C16.2194 19.4107 15.789 18.6351 15.4152 17.8606C15.152 17.3153 14.5398 16.0618 14.4024 15.5348C14.3793 15.4466 14.3568 15.3676 14.3872 15.2764L15.1635 13.3499C15.8912 14.9955 16.5617 16.6813 17.338 18.305C17.3647 18.3615 17.49 18.7305 17.5909 18.6284L20.9216 8.41134L21.1903 8.37305L25.7514 18.6892L29.1514 9.65147C29.2772 9.08976 29.2547 8.62715 28.5732 8.55603V8.37487H31L30.9988 8.37365Z\" fill=\"#967240\"/><path d=\"M3.3932 2.85352V3.09485C2.42542 3.10762 2.74579 4.04014 2.96706 4.6444C3.96281 7.36172 5.56646 10.0559 6.59807 12.7836L6.82117 13.1672L10.2868 2.86081L10.4838 2.86203L13.6218 10.011L12.8564 11.8328L12.7683 11.7702C11.8303 9.87966 11.119 7.86324 10.1981 5.9678C10.1355 5.83893 10.0801 5.6523 9.94518 5.58422L7.02238 14.4018C6.92998 14.5538 6.22178 14.538 6.06251 14.4711C5.82542 14.3715 5.14944 13.2657 4.99807 12.9873C3.50019 10.2347 2.547 6.92586 1.13788 4.1064C0.995635 3.8213 0.702018 3.26993 0.402929 3.14227C0.236972 3.07175 -0.177618 3.11917 0.0849961 2.85352H3.39138H3.3932Z\" fill=\"#967240\"/><path d=\"M19.2901 0.122189L10.7338 21.4778L10.1284 21.3562L18.6846 0L19.2901 0.122189Z\" fill=\"#967240\"/></svg>`\n        }\n      ],\n      \"videoCards\": [\n        {\n          \"id\": \"1\",\n          \"title\": \"How it works\",\n          \"src\": \"https://player.vimeo.com/video/985695931?h=fcc95795a7&badge=0&autopause=0&player_id=0&app_id=58479\",\n          \"className\": \"vendors_empty-novendors_video0\"\n        },\n        {\n          \"id\": \"2\",\n          \"title\": \"How to share photos with vendors\",\n          \"src\": \"https://player.vimeo.com/video/981654429?h=831c3b398f&badge=0&autopause=0&player_id=0&app_id=58479\",\n          \"className\": \"vendors_empty-novendors_video1\"\n        }\n      ],\n      \"vendorsKBLink\": \"https://help.pic-time.com/en/articles/9523692-how-do-i-add-vendors-to-my-gallery\"\n    };\n\n    // --- 2. Global Handlers ---\n\n    /**\n     * Handles all interface actions and logs them.\n     */\n    window.myop_cta_handler = function(action_id, payload) {\n        const timestamp = new Date().toISOString();\n        console.log(`[CTA HANDLER] Action: ${action_id}`, payload);\n        console.log(`Time: ${timestamp}`);\n    };\n\n    /**\n     * Receives configuration object and renders the entire interface.\n     */\n    window.myop_init_interface = function(config) {\n        const appContainer = document.getElementById('app');\n        if (!appContainer) return;\n\n        // ROBUSTNESS FIX:\n        // Use defaultConfig if config is undefined, null, or empty.\n        // This prevents the interface from disappearing if the host app initializes it with empty data.\n        const safeConfig = (config && Object.keys(config).length > 0) ? config : defaultConfig;\n        \n        // Determine if cards should be enabled. Default to true if the property is missing.\n        const isIncludedInPlan = safeConfig.includedInCurrentPlan !== false;\n\n        appContainer.innerHTML = ''; // Clear content\n\n        // Create main structure\n        const mainEl = document.createElement('main');\n        const contentEl = document.createElement('div');\n        contentEl.className = 'content';\n        mainEl.appendChild(contentEl);\n        appContainer.appendChild(mainEl);\n\n        // Render sections into contentEl\n        renderHeader(contentEl, safeConfig.header || {}, safeConfig.vendorsKBLink);\n        // Pass the isIncludedInPlan flag and betaFlags\n        renderActionCards(contentEl, safeConfig.actionCards || [], isIncludedInPlan, safeConfig.betaFlags);\n        renderVideoCards(contentEl, safeConfig.videoCards || []);\n    };\n\n    // --- 3. Rendering Helpers ---\n\n    function renderHeader(container, data, kbLink) {\n        const headerEl = document.createElement('div');\n        headerEl.className = 'header';\n        \n        // Use the new SVG icon from the design\n        const helpIconSvg = `\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <circle cx=\"12\" cy=\"12\" r=\"10\"></circle>\n              <path d=\"M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3\"></path>\n              <line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"></line>\n            </svg>\n        `;\n\n        headerEl.innerHTML = `\n            <div>\n                <h1>${data.title || ''}</h1>\n                <p>${data.description || ''}</p>\n            </div>\n            <button class=\"help-button\" id=\"help-btn\">\n                ${helpIconSvg}\n                <span>${data.helpText || 'Help'}</span>\n            </button>\n        `;\n        \n        const helpBtn = headerEl.querySelector('#help-btn');\n        if(helpBtn) {\n            helpBtn.onclick = () => {\n                const url = kbLink || \"https://help.pic-time.com/en/articles/9523692-how-do-i-add-vendors-to-my-gallery\";\n                window.open(url, \"_blank\");\n            };\n        }\n        \n        container.appendChild(headerEl);\n    }\n\n    function renderActionCards(container, cards, enabled, betaFlags) {\n        if (!cards || !cards.length) return;\n\n        const cardsContainer = document.createElement('div');\n        cardsContainer.className = 'cards-grid';\n\n        const fragment = document.createDocumentFragment();\n\n        cards.forEach((card, index) => {\n            // Hide Wedding Workflows card if vendor_integration beta flag is false\n            if (card.actionId === 'import_from_ww_clicked') {\n                const vendorIntegrationEnabled = betaFlags?.vendor_integration !== false;\n                if (!vendorIntegrationEnabled) {\n                    return; // Skip rendering this card\n                }\n            }\n\n            const cardEl = document.createElement('button');\n            cardEl.className = 'action-card';\n\n            // Apply disabled styling if plan doesn't include it\n            if (!enabled) {\n                cardEl.classList.add('disabled');\n            }\n\n            cardEl.setAttribute('aria-label', card.title);\n\n            cardEl.innerHTML = `\n                <div class=\"icon-circle\">\n                    ${card.iconContent}\n                </div>\n                <div class=\"card-content\">\n                    <h3>${card.title}</h3>\n                    <p>${card.description}</p>\n                </div>\n            `;\n\n            // Only attach click handler if enabled\n            if (enabled) {\n                cardEl.onclick = () => window.myop_cta_handler(card.actionId, {\n                    cardIndex: index,\n                    title: card.title\n                });\n            }\n\n            // Specific handler for Wedding Workflows Learn More link\n            if (card.actionId === 'import_from_ww_clicked') {\n                const learnMoreSpan = cardEl.querySelector('.learn-more');\n                if (learnMoreSpan) {\n                    learnMoreSpan.onclick = (e) => {\n                        e.stopPropagation();\n                        window.open(\"https://help.pic-time.com/en/articles/12689343-how-do-i-invite-vendors-from-wedding-workflows\", \"_blank\");\n                    };\n                }\n            }\n\n            fragment.appendChild(cardEl);\n        });\n\n        cardsContainer.appendChild(fragment);\n        container.appendChild(cardsContainer);\n    }\n\n    function renderVideoCards(container, videos) {\n        if (!videos || !videos.length) return;\n\n        const videoContainer = document.createElement('div');\n        videoContainer.className = 'videos-grid';\n        \n        const fragment = document.createDocumentFragment();\n\n        videos.forEach((video) => {\n            const sectionEl = document.createElement('div');\n            sectionEl.className = 'video-section';\n\n            // Structure: Title outside, Iframe inside video-thumbnail container\n            sectionEl.innerHTML = `\n                <h3>${video.title}</h3>\n                <div class=\"video-thumbnail\">\n                    <iframe \n                        class=\"${video.className || ''}\" \n                        src=\"${video.src}\" \n                        title=\"${video.title}\"\n                        frameborder=\"0\" \n                        allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write\">\n                    </iframe>\n                </div>\n            `;\n            \n            fragment.appendChild(sectionEl);\n        });\n\n        videoContainer.appendChild(fragment);\n        container.appendChild(videoContainer);\n    }\n\n    // --- 4. Initialization ---\n\n    document.addEventListener('DOMContentLoaded', () => {\n        try {\n            // Initialize immediately with default config\n            window.myop_init_interface(defaultConfig);\n        } catch (error) {\n            console.error('Failed to initialize interface:', error);\n        }\n    });\n\n  </script>\n</body>\n</html>"
        },
        "id": "5e3bf731-f4bd-4fd0-b9b6-7ccde54cce40"
      }
