x-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n        }\n\n        #app-root {\n            width: 100%;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            background-color: #f1eee8;\n            font-family: var(--font_main);\n            font-weight: var(--fontWeight_main);\n            font-style: var(--fontStyle_main);\n            position: relative;\n        }\n\n        /* ===== SCALED WRAPPER ===== */\n        .scaled-wrapper {\n            width: 100%;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            /* JS sets --s (scale factor) based on container width / 1177 */\n        }\n\n        /* ===== HEADER ===== */\n        .header {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            text-align: center;\n            padding-top: calc(40 * var(--s, 1) * 1px);\n            padding-bottom: 64px;\n            padding-left: 16px;\n            padding-right: 16px;\n            gap: 24px;\n            width: 100%;\n            flex-shrink: 0;\n        }\n\n        .header__subtitle {\n            color: #98452A;\n            text-align: center;\n            font-family: var(--font_main);\n            font-size: 14px;\n            font-style: var(--fontStyle_main);\n            font-weight: var(--fontWeight_main);\n            line-height: 1.3;\n            letter-spacing: 1.12px;\n            text-transform: uppercase;\n        }\n\n        .header__title {\n            color: #232323;\n            text-align: center;\n            font-family: var(--font_main);\n            font-size: 38px;\n            font-style: var(--fontStyle_main);\n            font-weight: var(--fontWeight_main);\n            line-height: 1.2;\n            font-feature-settings: 'liga' off;\n            max-width: 90%;\n            word-wrap: break-word;\n        }\n\n        /* ===== CAROUSEL ===== */\n        .carousel-section {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            width: 100%;\n            position: relative;\n        }\n\n        .carousel-viewport {\n            width: 100%;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .carousel-track {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .carousel-slide {\n            position: absolute;\n            border-radius: 2px;\n            overflow: hidden;\n            box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.1);\n            cursor: pointer;\n            will-change: transform, opacity;\n            transition:\n                transform 0.17s cubic-bezier(0.4, 0, 0.2, 1),\n                opacity 0.17s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .carousel-slide img,\n        .carousel-slide iframe {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n            border: none;\n        }\n\n        .carousel-slide--center {\n            z-index: 3;\n            opacity: 1;\n        }\n\n        .carousel-slide--left {\n            z-index: 2;\n            opacity: 0.4;\n        }\n\n        .carousel-slide--right {\n            z-index: 2;\n            opacity: 0.4;\n        }\n\n        .carousel-slide--hidden {\n            z-index: 1;\n            opacity: 0;\n            pointer-events: none;\n            transition:\n                transform 0.17s cubic-bezier(0.4, 0, 0.2, 1),\n                opacity 0.045s ease;\n        }\n\n        /* ===== NAV ARROWS ===== */\n        .carousel-nav {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 24px;\n            padding-top: 40px;\n            padding-bottom: 32px;\n            flex-shrink: 0;\n        }\n\n        .nav-arrow {\n            width: 16px;\n            height: 16px;\n            flex-shrink: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background: none;\n            border: none;\n            cursor: pointer;\n            padding: 0;\n            opacity: 0.8;\n            transition: opacity 0.2s ease;\n        }\n\n        .nav-arrow:hover {\n            opacity: 1;\n        }\n\n        .nav-arrow svg {\n            width: 16px;\n            height: 16px;\n        }\n\n        /* ===== CTA BUTTON ===== */\n        .header-cta {\n            display: inline-flex;\n            justify-content: center;\n            align-items: center;\n            padding: 12px 24px;\n            background: #232323;\n            color: #ffffff;\n            border: none;\n            border-radius: 6px;\n            font-family: var(--font_main);\n            font-size: 16px;\n            font-style: var(--fontStyle_main);\n            font-weight: var(--fontWeight_main);\n            line-height: 1.25;\n            cursor: pointer;\n            transition: background 150ms ease-out;\n        }\n\n        .header-cta:hover {\n            background: #3a3a3a;\n        }\n\n        /* ===== RESPONSIVE STYLES ===== */\n\n        /* Tablet (768px - 1024px) */\n        @media (max-width: 1024px) {\n            .header {\n                padding-top: 32px;\n                padding-bottom: 48px;\n                gap: 20px;\n            }\n\n            .header__title {\n                font-size: 32px;\n            }\n\n            .header__subtitle {\n                font-size: 13px;\n                letter-spacing: 1px;\n            }\n\n            .carousel-nav {\n                padding