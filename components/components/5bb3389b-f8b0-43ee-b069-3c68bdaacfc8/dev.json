</style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function() {\n        var state = null;\n        var currentIndex = 0;\n        var hoverTimer = null;\n        var hoverTimerSlideIdx = -1;    // which slide index the hover timer is for\n        var listenersAttached = false;\n        var hoverNavAnimating = false; // true while transition is in progress\n\n        // ---- Image sizing with min/max constraints ----\n        // Desktop: Center image: min 620×336, max 728×394\n        //          Side image:   min 545×295, max 639×346\n        // Aspect ratio: ~1.847 (w/h) or ~0.5415 (h/w)\n        var REF_W = 1177;              // reference container width (shows max sizes)\n        var MIN_CONTAINER_W = 900;     // container width where min sizes apply\n        var MOBILE_BREAKPOINT = 767;   // below this, show single centered slide\n        var TABLET_BREAKPOINT = 1024;  // tablet adjustments\n\n        var SIDE_MIN_W = 545;\n        var SIDE_MAX_W = 639;\n        var SIDE_MIN_H = 295;\n        var SIDE_MAX_H = 346;\n\n        var CENTER_MIN_W = 620;\n        var CENTER_MAX_W = 728;\n        var CENTER_MIN_H = 336;\n        var CENTER_MAX_H = 394;\n\n        var REF_GAP = 28;              // px gap at reference width\n        var MIN_SCALE = 0.45;          // floor so text stays readable\n\n        // Aspect ratio for carousel slides (width / height)\n        var ASPECT_RATIO = 728 / 394;  // ~1.847\n\n        function lerp(min, max, t) {\n            return min + (max - min) * Math.max(0, Math.min(1, t));\n        }\n\n        function getScaleFactor(containerW) {\n            var s = containerW / REF_W;\n            return Math.max(s, MIN_SCALE);\n        }\n\n        function isMobile(containerW) {\n            return containerW <= MOBILE_BREAKPOINT;\n        }\n\n        function getImageSizes(containerW) {\n            // Mobile: single centered slide that fills most of the width\n            if (isMobile(containerW)) {\n                var mobileW = containerW * 0.85; // 85% of container width\n                var mobileH = mobileW / ASPECT_RATIO;\n                return {\n                    sideW: mobileW,\n                    sideH: mobileH,\n                    centerW: mobileW,\n                    centerH: mobileH\n                };\n            }\n\n            // Tablet: slightly smaller sizes\n            if (containerW <= TABLET_BREAKPOINT) {\n                var tabletScale = containerW / TABLET_BREAKPOINT;\n                var tCenterW = Math.min(CENTER_MAX_W * tabletScale, CENTER_MAX_W * 0.85);\n                var tCenterH = tCenterW / ASPECT_RATIO;\n                var tSideW = Math.min(SIDE_MAX_W * tabletScale, SIDE_MAX_W * 0.85);\n                var tSideH = tSideW / ASPECT_RATIO;\n                return {\n                    sideW: tSideW,\n                    sideH: tSideH,\n                    centerW: tCenterW,\n                    centerH: tCenterH\n                };\n            }\n\n            // Desktop: t=0 at MIN_CONTAINER_W (min sizes), t=1 at REF_W (max sizes)\n            var t = (containerW - MIN_CONTAINER_W) / (REF_W - MIN_CONTAINER_W);\n            t = Math.max(0, Math.min(1, t));\n\n            return {\n                sideW: lerp(SIDE_MIN_W, SIDE_MAX_W, t),\n                sideH: lerp(SIDE_MIN_H, SIDE_MAX_H, t),\n                centerW: lerp(CENTER_MIN_W, CENTER_MAX_W, t),\n                centerH: lerp(CENTER_MIN_H, CENTER_MAX_H, t)\n            };\n        }\n\n        function computeSlots(containerW, containerH) {\n            var sizes = getImageSizes(containerW);\n            var s = containerW / REF_W;\n            var gap = REF_GAP * Math.max(s, 0.5);\n\n            var cx = containerW / 2;\n            var cy = containerH / 2;\n\n            // Mobile: all slides centered, side slides hidden via CSS\n            if (isMobile(containerW)) {\n                return {\n                    center: { x: cx, y: cy, opacity: 1 },\n                    left: { x: -sizes.sideW, y: cy, opacity: 0 },\n                    right: { x: containerW + sizes.sideW, y: cy, opacity: 0 },\n                    hiddenLeft: { x: -sizes.sideW * 2, y: cy, opacity: 0 },\n                    hiddenRight: { x: containerW + sizes.sideW * 2, y: cy, opacity: 0 },\n                    baseW: sizes.sideW,\n                    baseH: sizes.sideH,\n                    centerW: sizes.centerW,\n                    centerH: sizes.centerH\n                };\n            }\n\n            var rightX = cx + sizes.centerW / 2 + gap + sizes.sideW / 2;\n            var leftX  = cx - sizes.centerW / 2 - gap - sizes.sideW / 2;\n\n            return {\n                center: {\n                    x: cx,\n                    y: cy,\n                    opacity: 1\n                },\n                left: {\n                    x: leftX,\n                    y: cy,\n                    opacity: 0.4\n                },\n                right: {\n                    x: rightX,\n                    y: cy,\n                    opacity: 0.4\n                },\n                hiddenLeft: {\n                    x: leftX - containerW * 0.35,\n                    y: cy,\n                    opacity: 0\n                },\n                hiddenRight: {\n                    x: rightX + containerW * 0.35,\n                    y: cy,\n                    opacity: 0\n                },\n                baseW: sizes.sideW,\n                baseH: sizes.sideH,\n                centerW: sizes.centerW,\n                centerH: sizes.centerH\n            };\n        }\n\n        function getSlotName(offset, total) {\n            if (total < 2) return offset === 0 ? 'center' : 'hiddenRight';\n            if (total === 2) {\n                if (offset === 0) return 'center';\n                if (offset === 1) return 'right';\n                return 'hiddenRight';\n            }\n            if (offset === 0) return 'center';\n            if (offset === 1) return 'right';\n            if (offset === -1 || offset === total - 1) return 'left';\n            return offset > 0 ? 'hiddenRight' : 'hiddenLeft';\n        }\n\n        function mod(n, m) {\n            return ((n % m) + m) % m;\n        }\n\n        // Detect media type from URL\n        function getMediaType(item) {\n            if (item.type) return item.type;\n            var url = (item.url || '').toLowerCase();\n            if (url.includes('vimeo.com') || url.includes('player.vimeo.com')) {\n                return 'vimeo';\n            }\n            return 'image';\n        }\n\n        // Extract Vimeo video ID and optional hash from URL\n        function getVimeoId(url) {\n            // Match vimeo.com/123456789 or player.vimeo.com/video/123456789\n            // Also handles private links: vimeo.com/123456789/hashcode\n            var match = url.match(/vimeo\\.com\\/(?:video\\/)?(\\d+)(?:\\/([a-zA-Z0-9]+))?/);\n            if (match) {\n                return { id: match[1], hash: match[2] || null };\n            }\n            return null;\n        }\n\n        // Build media element HTML based on type\n        function buildMediaElement(item) {\n            var mediaType = getMediaType(item);\n\n            if (mediaType === 'vimeo') {\n                var vimeoInfo = getVimeoId(item.url);\n                if (vimeoInfo) {\n                    var embedUrl = 'https://player.vimeo.com/video/' + vimeoInfo.id;\n                    // Add hash parameter for private videos\n                    if (vimeoInfo.hash) {\n                        embedUrl += '?h=' + vimeoInfo.hash + '&background=1&autoplay=1&loop=1&muted=1&controls=0';\n                    } else {\n                        embedUrl += '?background=1&autoplay=1&loop=1&muted=1&controls=0';\n                    }\n                    return '<iframe src=\"' + embedUrl + '\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>';\n                }\n                // Fallback if ID extraction fails