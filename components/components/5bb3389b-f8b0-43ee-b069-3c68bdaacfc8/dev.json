rt = document.querySelector('.carousel-viewport');\n            var wrapper = document.querySelector('.scaled-wrapper');\n            if (!viewport || !wrapper) return;\n\n            var containerW = viewport.offsetWidth;\n            var s = getScaleFactor(containerW);\n\n            // Set the --s CSS variable on the wrapper so all children scale\n            wrapper.style.setProperty('--s', s);\n\n            // Get image sizes based on container width\n            var sizes = getImageSizes(containerW);\n\n            // Set viewport height to match center image height\n            viewport.style.height = sizes.centerH + 'px';\n\n            var containerH = sizes.centerH;\n            var info = computeSlots(containerW, containerH);\n            var slides = document.querySelectorAll('.carousel-slide');\n            var total = state.images.length;\n\n            for (var i = 0; i < slides.length; i++) {\n                var slide = slides[i];\n                var offset = mod(i - currentIndex, total);\n                if (offset > Math.floor(total / 2)) {\n                    offset = offset - total;\n                }\n                var slotName = getSlotName(offset, total);\n                var slot = info[slotName];\n\n                // Set size based on slot (center gets center size, sides get side size)\n                var isCenter = slotName === 'center';\n                var slideW = isCenter ? info.centerW : info.baseW;\n                var slideH = isCenter ? info.centerH : info.baseH;\n                slide.style.width = slideW + 'px';\n                slide.style.height = slideH + 'px';\n                // Fixed top-left at 0,0; all positioning via transform\n                slide.style.left = '0';\n                slide.style.top = '0';\n\n                // Compute translate so the slide's center ends up at slot.x, slot.y\n                var tx = slot.x - slideW / 2;\n                var ty = slot.y - slideH / 2;\n\n                // If we want to skip transition (initial render / resize)\n                if (skipTransition) {\n                    slide.style.transition = 'none';\n                }\n\n                // No scaling needed - each slide has its correct size\n                slide.style.transform = 'translate3d(' + tx + 'px,' + ty + 'px,0)';\n                slide.style.opacity = slot.opacity;\n\n                // Force reflow then restore transition when skipping\n                if (skipTransition) {\n                    slide.offsetHeight; // force reflow\n                    slide.style.transition = '';\n                }\n\n                // Update slot classes\n                slide.classList.remove('carousel-slide--center', 'carousel-slide--left', 'carousel-slide--right', 'carousel-slide--hidden');\n                if (slotName === 'center') {\n                    slide.classList.add('carousel-slide--center');\n                } else if (slotName === 'left') {\n                    slide.classList.add('carousel-slide--left');\n                } else if (slotName === 'right') {\n                    slide.classList.add('carousel-slide--right');\n                } else {\n                    slide.classList.add('carousel-slide--hidden');\n                }\n            }\n        }\n\n        function navigateTo(newIndex) {\n            if (!state || !state.images || state.images.length === 0) return;\n            currentIndex = mod(newIndex, state.images.length);\n            positionSlides();\n        }\n\n        // Hover-to-navigate: hovering a side slide moves it to center.\n        // First hover triggers after 600ms. If the cursor stays on the side,\n        // subsequent navigations use a longer 1500ms dwell to prevent rapid scrolling.\n        var HOVER_DWELL_FIRST = 600;\n        var HOVER_DWELL_NEXT = 1500;\n        var lastPointerX = 0;\n        var lastPointerY = 0;\n\n        function startHoverTimer(slide, dwell) {\n            var idx = parseInt(slide.getAttribute('dat