          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":700}'>\n\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\ninterface VideoItem {\n  designSetID: string;\n  url: string;\n}\n\ninterface FontConfig {\n  id: string;\n  family: string;\n  style?: string;\n  weight?: number;\n  url: string;\n}\n\ninterface LangStrings {\n  ctaText?: string;\n  title?: string;\n  subtitle?: string;\n  scratchOr?: string;\n  scratchAction?: string;\n}\n\ninterface MyopInitData {\n  videos: VideoItem[];\n  fonts?: FontConfig[];\n  lang?: LangStrings;\n}\n\ninterface MyopCtaPayloads {\n  'new_gallery_clicked': { designSetID?: string };\n  'size-requested': {\n    width?: number | null;\n    height?: number | null;\n    minWidth?: number | null;\n    maxWidth?: number | null;\n    minHeight?: number | null;\n    maxHeight?: number | null;\n    required?: boolean;\n  };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n\n    <style>\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n        }\n\n        #app-root {\n            width: 100%;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            background-color: #f1eee8;\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\n            font-weight: var(--fontWeight_main, 500);\n            font-style: var(--fontStyle_main, normal);\n            position: relative;\n        }\n\n        /* ===== SCALED WRAPPER ===== */\n        .scaled-wrapper {\n            width: 100%;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            /* JS sets --s (scale factor) based on container width / 1177 */\n        }\n\n        /* ===== HEADER ===== */\n        .header {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            text-align: center;\n            padding-top: calc(40 * var(--s, 1) * 1px);\n            padding-bottom: 64px;\n            padding-left: 16px;\n            padding-right: 16px;\n            gap: 24px;\n            width: 100%;\n            flex-shrink: 0;\n        }\n\n        .header__subtitle {\n            color: #98452A;\n            text-align: center;\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\n            font-size: 14px;\n            font-style: var(--fontStyle_main, normal);\n            font-weight: var(--fontWeight_main, 500);\n            line-height: 1.3;\n            letter-spacing: 1.12px;\n            text-transform: uppercase;\n        }\n\n        .header__title {\n            color: #232323;\n            text-align: center;\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\n            font-size: 38px;\n            font-style: var(--fontStyle_main, normal);\n            font-weight: var(--fontWeight_main, 400);\n            line-height: 1.2;\n            font-feature-settings: 'liga' off;\n            max-width: 90%;\n            word-wrap: break-word;\n        }\n\n        /* ===== CAROUSEL ===== */\n        .carousel-section {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            width: 100%;\n            position: relative;\n        }\n\n        .carousel-viewport {\n            width: 100%;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .carousel-track {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .carousel-slide {\n            position: absolute;\n            border-radius: 2px;\n            overflow: hidden;\n            box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.1);\n            cursor: pointer;\n            will-change: transform, opacity;\n            transition:\n                transform 0.17s cubic-bezier(0.4, 0, 0.2, 1),\n                opacity 0.17s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .carousel-slide video {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        .carousel-slide--center {\n            z-index: 3;\n            opacity: 1;\n        }\n\n        .carousel-slide--left {\n            z-index: 2;\n            opacity: 0.4;\n        }\n\n        .carousel-slide--right {\n            z-index: 2;\n            opacity: 0.4;\n        }\n\n        .carousel-slide--hidden {\n            z-index: 1;\n            opacity: 0;\n            pointer-events: none;\n            transition:\n                transform 0.17s cubic-bezier(0.4, 0, 0.2, 1),\n                opacity 0.045s ease;\n        }\n\n        /* ===== CTA OVERLAY ===== */\n        .slide-overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            display: none;\n            align-items: flex-end;\n            justify-content: center;\n            padding-bottom: calc(32 * var(--s, 1) * 1px);\n            background: transparent;\n            z-index: 5;\n            pointer-events: none;\n        }\n\n        .carousel-slide--center .slide-overlay {\n            display: flex;\n            pointer-events: auto;\n        }\n\n        .carousel-slide--center:hover .slide-overlay {\n            background: rgba(0, 0, 0, 0.15);\n        }\n\n        .cta-btn {\n            display: inline-flex;\n            justify-content: center;\n            align-items: center;\n            gap: calc(16 * var(--s, 1) * 1px);\n            padding: calc(8 * var(--s, 1) * 1px) calc(16 * var(--s, 1) * 1px);\n            background: #ffffff;\n            color: #232323;\n            border: none;\n            border-radius: calc(1.902 * var(--s, 1) * 1px);\n            box-shadow: 0 0 calc(3.804 * var(--s, 1) * 1px) 0 rgba(0, 0, 0, 0.25);\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\n            font-weight: var(--fontWeight_main, 500);\n            font-style: var(--fontStyle_main, normal);\n            font-size: 16px;\n            line-height: 1.25;\n            font-feature-settings: 'liga' off, 'clig' off;\n            cursor: pointer;\n            text-align: center;\n            transition: background 150ms ease-out;\n        }\n\n        .cta-btn:hover {\n            background: #F2F2ED;\n        }\n\n        /* ===== NAV ARROWS ===== */\n        .carousel-nav {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 24px;\n            padding-top: 40px;\n            padding-bottom: 32px;\n            flex-shrink: 0;\n        }\n\n        .nav-arrow {\n            width: 16px;\n            height: 16px;\n            flex-shrink: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background: none;\n            border: none;\n            cursor: pointer;\n            padding: 0;\n            opacity: 0.8;\n            transition: opacity 0.2s ease;\n        }\n\n        .nav-arrow:hover {\n            opacity: 1;\n        }\n\n        .nav-arrow svg {\n            width: 16px;\n            height: 16px;\n        }\n\n        /* ===== SCRATCH LINK ===== */\n        .scratch-link {\n            color: #6B6B6B;\n            text-align: center;\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\n            font-size: 16px;\n            font-style: var(--fontStyle_main, normal);\n            font-weight: var(--fontWeight_main, 500);\n            line-height: 1.42;\n            font-feature-settings: 'liga' off, 'clig' off;\n            padding: 0 16px 40px;\n        }\n\n        .scratch-or {\n            color: #6B6B6B;\n        }\n\n        .scratch-action {\n            color: #6B6B6B;\n            font-family: var(--font_main, 'TT Norms Pro', sans-serif);\n            font-size: 16px;\n            font-style: var(--fontStyle_main, normal);\n            font-weight: var(--fontWeight_main, 500);\n            line-height: 142%;\n            font-feature-settings: 'liga' off, 'clig' off;\n            text-decoration-line: underline;\n            text-decoration-style: solid;\n            text-decoration-skip-ink: auto;\n            text-decoration-thickness: auto;\n            text-underline-offset: auto;\n            text-underline-position: from-font;\n            cursor: pointer;\n            background: none;\n            border: none;\n            padding: 0;\n        }\n\n        .scratch-action:hover {\n            opacity: 0.7;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function() {\n        var state = null;\n        var currentIndex = 0;\n        var hoverTimer = null;\n        var hoverTimerSlideIdx = -1;    // which slide index the hover timer is for\n        var isHoveringCenter = false;\n        var listenersAttached = false;\n        var hoverNavAnimating = false; // true while transition is in progress\n\n        // ---- Video sizing with min/max constraints ----\n        // Center video: min 620×336, max 728×394\n        // Side video:   min 545×295, max 639×346\n        // Aspect ratio: ~1.847 (w/h) or ~0.5415 (h/w)\n        var REF_W = 1177;              // reference container width (shows max sizes)\n        var MIN_CONTAINER_W = 900;     // container width where min sizes apply\n\n        var SIDE_MIN_W = 545;\n        var SIDE_MAX_W = 639;\n        var SIDE_MIN_H = 295;\n        var SIDE_MAX_H = 346;\n\n        var CENTER_MIN_W = 620;\n        var CENTER_MAX_W = 728;\n        var CENTER_MIN_H = 336;\n        var CENTER_MAX_H = 394;\n\n        var REF_GAP = 28;              // px gap at reference width\n        var MIN_SCALE = 0.45;          // floor so text stays readable\n\n        function lerp(min, max, t) {\n            return min + (max - min) * Math.max(0, Math.min(1, t));\n        }\n\n        function getScaleFactor(containerW) {\n            var s = containerW / REF_W;\n            return Math.max(s, MIN_SCALE);\n        }\n\n        function getVideoSizes(containerW) {\n            // t=0 at MIN_CONTAINER_W (min sizes), t=1 at REF_W (max sizes)\n            // For wider screens, t > 1 but sizes are clamped to max\n            var t = (containerW - MIN_CONTAINER_W) / (REF_W - MIN_CONTAINER_W);\n            // Clamp t to [0, 1] so sizes stay within min/max bounds\n            t = Math.max(0, Math.min(1, t));\n\n            return {\n                sideW: lerp(SIDE_MIN_W, SIDE_MAX_W, t),\n                sideH: lerp(SIDE_MIN_H, SIDE_MAX_H, t),\n                centerW: lerp(CENTER_MIN_W, CENTER_MAX_W, t),\n                centerH: lerp(CENTER_MIN_H, CENTER_MAX_H, t)\n            };\n        }\n\n        function computeSlots(containerW, containerH) {\n            var sizes = getVideoSizes(containerW);\n            var s = containerW / REF_W;\n            var gap = REF_GAP * Math.max(s, 0.5);\n\n            var cx = containerW / 2;\n            var cy = containerH / 2;\n\n            var rightX = cx + sizes.centerW / 2 + gap + sizes.sideW / 2;\n            var leftX  = cx - sizes.centerW / 2 - gap - sizes.sideW / 2;\n\n            return {\n                center: {\n                    x: cx,\n                    y: cy,\n                    opacity: 1\n                },\n                left: {\n                    x: leftX,\n                    y: cy,\n                    opacity: 0.4\n                },\n                right: {\n                    x: rightX,\n                    y: cy,\n                    opacity: 0.4\n                },\n                hiddenLeft: {\n                    x: leftX - containerW * 0.35,\n                    y: cy,\n                    opacity: 0\n                },\n                hiddenRight: {\n                    x: rightX + containerW * 0.35,\n                    y: cy,\n                    opacity: 0\n                },\n                baseW: sizes.sideW,\n                baseH: sizes.sideH,\n                centerW: sizes.centerW,\n                centerH: sizes.centerH\n            };\n        }\n\n        function getSlotName(offset, total) {\n            if (total < 2) return offset === 0 ? 'center' : 'hiddenRight';\n            if (total === 2) {\n                if (offset === 0) return 'center';\n                if (offset === 1) return 'right';\n                return 'hiddenRight';\n            }\n            if (offset === 0) return 'center';\n            if (offset === 1) return 'right';\n            if (offset === -1 || offset === total - 1) return 'left';\n            return offset > 0 ? 'hiddenRight' : 'hiddenLeft';\n        }\n\n        function mod(n, m) {\n            return ((n % m) + m) % m;\n        }\n\n        function buildHTML(data) {\n            var lang = data.lang || {};\n            var subtitle = lang.subtitle || 'Welcome to pic-time';\n            var title = lang.title || 'Create Your First Gallery';\n            var ctaText = lang.ctaText || 'GET STARTED';\n            var scratchOr = lang.scratchOr || 'or';\n            var scratchAction = lang.scratchAction || 'start from scratch';\n\n            var videosHTML = '';\n            if (data.videos && data.videos.length > 0) {\n                for (var i = 0; i < data.videos.length; i++) {\n                    var v = data.videos[i];\n                    videosHTML += '<div class=\"carousel-slide\" data-index=\"' + i + '\" data-design-id=\"' + (v.designSetID || '') + '\">' +\n                        '<video muted loop playsinline preload=\"metadata\" src=\"' + v.url + '\"></video>' +\n                        '<div class=\"slide-overlay\"><button class=\"cta-btn\" data-action=\"cta\" data-design-id=\"' + (v.designSetID || '') + '\">' + ctaText + '</button></div>' +\n                        '</div>';\n                }\n            }\n\n            return '<div class=\"scaled-wrapper\">' +\n                '<div class=\"header\">' +\n                    '<div class=\"header__subtitle\">' + subtitle + '</div>' +\n                    '<div class=\"header__title\">' + title + '</div>' +\n                '</div>' +\n                '<div class=\"carousel-section\">' +\n                    '<div class=\"carousel-viewport\">' +\n                        '<div class=\"carousel-track\">' + videosHTML + '</div>' +\n                    '</div>' +\n                    '<div class=\"carousel-nav\">' +\n                        '<button class=\"nav-arrow\" data-action=\"prev\" aria-label=\"Previous\">' +\n                            '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">' +\n                            '<g clip-path=\"url(#clip0_prev)\"><path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M11.5303 1.53034C11.8232 1.23745 11.8232 0.762691 11.5303 0.469798C11.2374 0.176905 10.7627 0.176905 10.4698 0.469798L3.46978 7.4698C3.32913 7.61045 3.25006 7.80116 3.25006 8.00007C3.25006 8.19898 3.32913 8.38969 3.46978 8.53035L10.4698 15.5303C10.7627 15.8232 11.2374 15.8232 11.5303 15.5303C11.8232 15.2375 11.8232 14.7627 11.5303 14.4698L5.0606 8.00007L11.5303 1.53034Z\" fill=\"#222222\"/></g>' +\n                            '<defs><clipPath id=\"clip0_prev\"><rect width=\"16\" height=\"16\" fill=\"white\" transform=\"matrix(-1 0 0 1 16 0)\"/></clipPath></defs>' +\n                            '</svg>' +\n                        '</button>' +\n                        '<button class=\"nav-arrow\" data-action=\"next\" aria-label=\"Next\">' +\n                            '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">' +\n                            '<g clip-path=\"url(#clip0_next)\"><path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M4.46967 14.4697C4.17678 14.7626 4.17678 15.2373 4.46967 15.5302C4.76256 15.8231 5.23744 15.8231 5.53033 15.5302L12.5303 8.5302C12.671 8.38955 12.75 8.19884 12.75 7.99993C12.75 7.80102 12.671 7.61031 12.5303 7.46965L5.53033 0.469653C5.23744 0.17676 4.76256 0.17676 4.46967 0.469653C4.17678 0.762547 4.17678 1.23733 4.46967 1.53022L10.9393 7.99993L4.46967 14.4697Z\" fill=\"#222222\"/></g>' +\n                            '<defs><clipPath id=\"clip0_next\"><rect width=\"16\" height=\"16\" fill=\"white\"/></clipPath></defs>' +\n                            '</svg>' +\n                        '</button>' +\n                    '</div>' +\n                '</div>' +\n                '<div class=\"scratch-link\"><span class=\"scratch-or\">' + scratchOr + '</span> <button class=\"scratch-action\" data-action=\"scratch\">' + scratchAction + '</button></div>' +\n                '</div>';\n        }\n\n        function positionSlides(skipTransition) {\n            if (!state || !state.videos || state.videos.length === 0) return;\n\n            var viewport = document.querySelector('.carousel-viewport');\n            var wrapper = document.querySelector('.scaled-wrapper');\n            if (!viewport || !wrapper) return;\n\n            var containerW = viewport.offsetWidth;\n            var s = getScaleFactor(containerW);\n\n            // Set the --s CSS variable on the wrapper so all children scale\n            wrapper.style.setProperty('--s', s);\n\n            // Get video sizes based on container width\n            var sizes = getVideoSizes(containerW);\n\n            // Set viewport height to match center video height\n            viewport.style.height = sizes.centerH + 'px';\n\n            var containerH = sizes.centerH;\n            var info = computeSlots(containerW, containerH);\n            var slides = document.querySelectorAll('.carousel-slide');\n            var total = state.videos.length;\n\n            for (var i = 0; i < slides.length; i++) {\n                var slide = slides[i];\n                var offset = mod(i - currentIndex, total);\n                if (offset > Math.floor(total / 2)) {\n                    offset = offset - total;\n                }\n                var slotName = getSlotName(offset, total);\n                var slot = info[slotName];\n\n                // Set size based on slot (center gets center size, sides get side size)\n                var isCenter = slotName === 'center';\n                var slideW = isCenter ? info.centerW : info.baseW;\n                var slideH = isCenter ? info.centerH : info.baseH;\n                slide.style.width = slideW + 'px';\n                slide.style.height = slideH + 'px';\n                // Fixed top-left at 0,0; all positioning via transform\n                slide.style.left = '0';\n                slide.style.top = '0';\n\n                // Compute translate so the slide's center ends up at slot.x, slot.y\n                var tx = slot.x - slideW / 2;\n                var ty = slot.y - slideH / 2;\n\n                // If we want to skip transition (initial render / resize)\n                if (skipTransition) {\n                    slide.style.transition = 'none';\n                }\n\n                // No scaling needed - each slide has its correct size\n                slide.style.transform = 'translate3d(' + tx + 'px,' + ty + 'px,0)';\n                slide.style.opacity = slot.opacity;\n\n                // Force reflow then restore transition when skipping\n                if (skipTransition) {\n                    slide.offsetHeight; // force reflow\n                    slide.style.transition = '';\n                }\n\n                // Update slot classes\n                slide.classList.remove('carousel-slide--center', 'carousel-slide--left', 'carousel-slide--right', 'carousel-slide--hidden');\n                if (slotName === 'center') {\n                    slide.classList.add('carousel-slide--center');\n                } else if (slotName === 'left') {\n                    slide.classList.add('carousel-slide--left');\n                } else if (slotName === 'right') {\n                    slide.classList.add('carousel-slide--right');\n                } else {\n                    slide.classList.add('carousel-slide--hidden');\n                }\n            }\n        }\n\n        function navigateTo(newIndex) {\n            if (!state || !state.videos || state.videos.length === 0) return;\n            stopCenterVideo();\n            currentIndex = mod(newIndex, state.videos.length);\n            positionSlides();\n        }\n\n        function playCenterVideo() {\n            var centerSlide = document.querySelector('.carousel-slide--center');\n            if (centerSlide) {\n                var video = centerSlide.querySelector('video');\n                if (video) {\n                    video.currentTime = 0;\n                    video.play().catch(function() {});\n                }\n            }\n            isHoveringCenter = true;\n        }\n\n        function stopCenterVideo() {\n            var centerSlide = document.querySelector('.carousel-slide--center');\n            if (centerSlide) {\n                var video = centerSlide.querySelector('video');\n                if (video) {\n                    video.pause();\n                    video.currentTime = 0;\n                }\n            }\n            isHoveringCenter = false;\n        }\n\n        // Hover-to-navigate: hovering a side slide moves it to center.\n        // First hover triggers after 600ms. If the cursor stays on the side,\n        // subsequent navigations use a longer 1500ms dwell to prevent rapid scrolling.\n        var HOVER_DWELL_FIRST = 600;\n        var HOVER_DWELL_NEXT = 1500;\n        var lastPointerX = 0;\n        var lastPointerY = 0;\n\n        function startHoverTimer(slide, dwell) {\n            var idx = parseInt(slide.getAttribute('data-index'), 10);\n            if (hoverTimer && hoverTimerSlideIdx === idx) return;\n\n            clearTimeout(hoverTimer);\n            hoverTimerSlideIdx = idx;\n            hoverTimer = setTimeout(function() {\n                hoverTimer = null;\n                hoverTimerSlideIdx = -1;\n                hoverNavAnimating = true;\n                navigateTo(idx);\n                // After transition, re-check if pointer is still over a side slide\n                setTimeout(function() {\n                    hoverNavAnimating = false;\n                    var el = document.elementFromPoint(lastPointerX, lastPointerY);\n                    if (!el) return;\n                    var s = el.closest('.carousel-slide');\n                    if (s && (s.classList.contains('carousel-slide--left') || s.classList.contains('carousel-slide--right'))) {\n                        startHoverTimer(s, HOVER_DWELL_NEXT);\n                    }\n                }, 220);\n            }, dwell);\n        }\n\n        function attachSlideHoverListeners() {\n            var slides = document.querySelectorAll('.carousel-slide');\n            slides.forEach(function(slide) {\n                slide.addEventListener('pointerenter', function(e) {\n                    if (slide.classList.contains('carousel-slide--center')) {\n                        clearTimeout(hoverTimer);\n                        hoverTimerSlideIdx = -1;\n                        playCenterVideo();\n                    } else if (slide.classList.contains('carousel-slide--left') || slide.classList.contains('carousel-slide--right')) {\n                        if (hoverNavAnimating) return;\n                        startHoverTimer(slide, HOVER_DWELL_FIRST);\n                    }\n                });\n\n                slide.addEventListener('pointerleave', function(e) {\n                    if (slide.classList.contains('carousel-slide--center')) {\n                        stopCenterVideo();\n                    }\n                    if (slide.classList.contains('carousel-slide--left') || slide.classList.contains('carousel-slide--right')) {\n                        clearTimeout(hoverTimer);\n                        hoverTimer = null;\n                        hoverTimerSlideIdx = -1;\n                    }\n                });\n\n                slide.addEventListener('pointermove', function(e) {\n                    lastPointerX = e.clientX;\n                    lastPointerY = e.clientY;\n                });\n            });\n\n            var track = document.querySelector('.carousel-track');\n            if (track) {\n                track.addEventListener('pointerleave', function() {\n                    hoverNavAnimating = false;\n                    clearTimeout(hoverTimer);\n                    hoverTimer = null;\n                    hoverTimerSlideIdx = -1;\n                });\n            }\n        }\n\n        function attachListeners() {\n            if (listenersAttached) return;\n            listenersAttached = true;\n\n            var root = document.getElementById('app-root');\n            if (!root) return;\n\n            // Click delegation (only needs to be attached once to root)\n            root.addEventListener('click', function(e) {\n                var target = e.target;\n\n                // CTA button\n                var ctaBtn = target.closest('[data-action=\"cta\"]');\n                if (ctaBtn) {\n                    var designId = ctaBtn.getAttribute('data-design-id');\n                    window.myop_cta_handler('new_gallery_clicked', { designSetID: designId });\n                    return;\n                }\n\n                // Scratch link\n                if (target.closest('[data-action=\"scratch\"]')) {\n                    window.myop_cta_handler('new_gallery_clicked', {});\n                    return;\n                }\n\n                // Prev arrow\n                if (target.closest('[data-action=\"prev\"]')) {\n                    navigateTo(currentIndex - 1);\n                    return;\n                }\n\n                // Next arrow\n                if (target.closest('[data-action=\"next\"]')) {\n                    navigateTo(currentIndex + 1);\n                    return;\n                }\n\n                // Click on a side slide -> navigate to it\n                var slide = target.closest('.carousel-slide');\n                if (slide && !slide.classList.contains('carousel-slide--center')) {\n                    var idx = parseInt(slide.getAttribute('data-index'), 10);\n                    navigateTo(idx);\n                    return;\n                }\n            });\n        }\n\n        function loadFonts(fonts) {\n            if (!fonts || fonts.length === 0) return;\n\n            var root = document.documentElement;\n\n            for (var i = 0; i < fonts.length; i++) {\n                var f = fonts[i];\n\n                // Set CSS variables\n                root.style.setProperty('--font_' + f.id, f.family + ', sans-serif');\n                root.style.setProperty('--fontWeight_' + f.id, f.weight || 500);\n                root.style.setProperty('--fontStyle_' + f.id, f.style || 'normal');\n\n                // Load the font CSS file\n                if (f.url) {\n                    var existing = document.querySelector('link[data-font-id=\"' + f.id + '\"]');\n                    if (!existing) {\n                        var link = document.createElement('link');\n                        link.rel = 'stylesheet';\n                        link.href = f.url;\n                        link.setAttribute('data-font-id', f.id);\n                        document.head.appendChild(link);\n                    }\n                }\n            }\n        }\n\n        function render(data) {\n            state = data;\n            currentIndex = 0;\n            isHoveringCenter = false;\n\n            var root = document.getElementById('app-root');\n            if (!root) return;\n\n            // Load fonts\n            loadFonts(data.fonts);\n\n            // Build and inject HTML\n            root.innerHTML = buildHTML(data);\n\n            // Position slides after DOM is ready (skip transition on initial render)\n            positionSlides(true);\n\n            // Attach click delegation (once) and slide hover listeners (every render)\n            attachListeners();\n            attachSlideHoverListeners();\n        }\n\n        // Handle resize\n        var resizeTimer;\n        window.addEventListener('resize', function() {\n            clearTimeout(resizeTimer);\n            resizeTimer = setTimeout(function() {\n                positionSlides(true);\n            }, 50);\n        });\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return state;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            videos: [\n                { designSetID: \"ds-001\", url: \"https://videos.pexels.com/video-files/3195440/3195440-uhd_2560_1440_25fps.mp4\" },\n                { designSetID: \"ds-002\", url: \"https://videos.pexels.com/video-files/3015488/3015488-hd_1920_1080_24fps.mp4\" },\n                { designSetID: \"ds-003\", url: \"https://videos.pexels.com/video-files/2795391/2795391-uhd_2560_1440_25fps.mp4\" },\n                { designSetID: \"ds-004\", url: \"https://videos.pexels.com/video-files/1536654/1536654-hd_1920_1080_30fps.mp4\" },\n                { designSetID: \"ds-005\", url: \"https://videos.pexels.com/video-files/3327804/3327804-uhd_2560_1440_30fps.mp4\" }\n            ],\n            lang: {\n                subtitle: \"Welcome to pic-time\",\n                title: \"Create Your First Gallery\",\n                ctaText: \"Create gallery\",\n                scratchOr: \"or\",\n                scratchAction: \"start from scratch\"\n            }\n        });\n    </script>\n</body>\n</html>\n"
