    "consume_variant": [
      {
        "name": "Version 32",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n\n    <script type=\"myop/types\">\n        // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Font configuration entry\n     * Each font creates CSS variables: --font_{id}, --font_{id}_style, --font_{id}_weight\n     * Common font IDs: \"main\" (body text), \"display\" (headings, prices)\n     */\n    interface FontConfig {\n      id: string;              // e.g., \"main\", \"display\" - used for CSS variable name --font_{id}\n      family: string;          // e.g., \"TT Norms Pro\", \"EB Garamond\"\n      style?: string;          // e.g., \"normal\", \"italic\" (optional)\n      weight?: number;         // e.g., 400, 700 (optional)\n      url: string;             // URL to load the font CSS\n    }\n\n    /**\n     * Feature item for plan features list\n     */\n    interface PlanFeature {\n      label: string;           // e.g., \"20 GB\" or \"Client Organizer\"\n      sublabel?: string;       // e.g., \"Photo Storage\"\n      isHeader?: boolean;      // true for \"All X features plus:\" lines\n      isMore?: boolean;        // true for \"More\" link\n    }\n\n    /**\n     * Pricing entry from config.pricing array\n     * Each entry represents pricing for a specific tier + billing interval combo\n     */\n    interface PricingEntry {\n      fullPaymentAmount: number;           // Non-discounted price (yearly = total for year)\n      amount: number;                      // Price charged now (yearly = total for year)\n      subscriptionExpiration: string;      // e.g., \"/Date(1772288806784)/\"\n      subscription: 5 | 10 | 20;          // Tier: 5=Beginner, 10=Professional, 20=Advanced\n      collectInterval: 0 | 10;            // 0=Monthly, 10=Yearly\n    }\n\n    /**\n     * Configuration for a single pricing plan (display settings, no pricing)\n     */\n    interface PlanConfig {\n      name: string;            // \"Beginner\", \"Professional\", \"Advanced\"\n      badge?: string;          // \"MOST POPULAR\" - only shown if provided\n      currency?: string;       // \"$\", \"€\", etc.\n      billingPeriod: string;   // \"per month, billed yearly\"\n      ctaText: string;         // \"UPGRADE\"\n      trialText?: string;      // \"Upgrade to Professional for $72 less\"\n      features: PlanFeature[];\n    }\n\n    /**\n     * FAQ item\n     */\n    interface FAQItem {\n      question: string;\n      answer: string;\n    }\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n      lang: string;\n      fonts?: FontConfig[];    // Array of font configurations\n      content?: {\n        promoLabel?: string;      // \"UPGRADE YOUR PLAN\"\n        mainTitle?: string;       // \"More Tools.\"\n        mainTitleHighlight?: string; // \"More Possibilities.\"\n        subtitle?: string;        // \"Choose the Plan That Fits You Best\"\n        faqTitle?: string;        // \"FAQs\"\n      };\n      subscription: 0 | 5 | 10 | 20; // 0=Free, 5=Beginner, 10=Professional, 20=Advanced\n      pricing: PricingEntry[];       // Pricing for all tiers and intervals\n      plans?: {\n        beginner?: PlanConfig;\n        professional?: PlanConfig;\n        advanced?: PlanConfig;\n      };\n      discount?: {\n        percentage?: number;\n        endDate?: string;\n      };\n      faqs?: FAQItem[];            // Array of FAQ items\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n      'subscription-selected': {\n        plan: 'beginner' | 'professional' | 'advanced';\n        tier: 5 | 10 | 20;\n        price: number;\n      };\n      'more-features-clicked': {\n        plan: 'beginner' | 'professional' | 'advanced';\n      };\n      'size-requested': {\n        width?: number | null;\n        height?: number | null;\n        minWidth?: number | null;\n        maxWidth?: number | null;\n        minHeight?: number | null;\n        maxHeight?: number | null;\n        required?: boolean;\n      };\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n      action: K,\n      payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <style>\n        :root {\n            /* Font variables - set dynamically from fonts array */\n            --font_main: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            --font_main_style: normal;\n            --font_main_weight: 400;\n            --font_display: Georgia, serif;\n            --font_display_style: normal;\n            --font_display_weight: 400;\n            /* Color variables */\n            --accent: #232323;\n            --accent-featured: #54033c;\n            --brown-saturated: #250b0b;\n            --pale-violet: #fbf5ff;\n            --light-grey: #fbfbfb;\n        }\n\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n\n        html,\n        body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            overflow-y: auto;\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            background: #FFF;\n            position: relative;\n        }\n\n        /* Main container */\n        .pricing-container {\n            max-width: 1060px;\n            margin: 0 auto;\n            padding: 50px 30px 60px;\n            width: 100%;\n        }\n\n        /* Header */\n        .header-section {\n            text-align: center;\n            margin-bottom: 32px;\n        }\n\n        .header-label {\n            display: inline-flex;\n            align-items: center;\n            gap: 6px;\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: 500;\n            font-size: 10px;\n            letter-spacing: 0.8px;\n            text-transform: uppercase;\n            color: #222;\n            background: #fff;\n            padding: 8px 20px;\n            border-radius: 100px;\n            border: 0.5px solid rgba(34, 34, 34, 0.3);\n            margin-bottom: 20px;\n        }\n\n        .header-label-icon {\n            width: 16px;\n            height: 16px;\n        }\n\n        .main-title {\n            font-family: Helvetica, Arial, sans-serif;\n            font-style: normal;\n            font-weight: 500;\n            font-size: 30px;\n            color: var(--brown-saturated);\n            margin: 0 0 14px;\n            line-height: 1;\n        }\n\n        .main-title .highlight {\n            font-style: normal;\n        }\n\n        .subtitle {\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            font-size: 16px;\n            color: var(--brown-saturated);\n            margin: 0;\n            line-height: 1.34;\n        }\n\n        /* Pricing grid */\n        .pricing-grid {\n            display: flex;\n            justify-content: center;\n            gap: 14px;\n            align-items: stretch;\n        }\n\n        /* Cards */\n        .pricing-card {\n            background: #fff;\n            border: 0.7px solid #dbdbdb;\n            text-align: center;\n            position: relative;\n            transition: box-shadow 0.3s ease;\n            width: 238.7px;\n            flex-shrink: 0;\n            display: flex;\n            flex-direction: column;\n            border-radius: 10px;\n            overflow: hidden;\n        }\n\n        .pricing-card.featured {\n            background: #F9F7F7;\n            border: 1px solid #E2D4BB;\n            border-radius: 8px;\n        }\n\n        /* Badge header - empty for non-featured, \"MOST POPULAR\" for featured */\n        .card-badge {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background: #f7f7f7;\n            padding: 8.475px 7.062px;\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: 500;\n            font-size: 9.887px;\n            letter-spacing: 0.791px;\n            text-transform: uppercase;\n            text-align: center;\n            min-height: 25px;\n            border-bottom: none;\n        }\n\n        /* Featured badge styling - cream/tan background */\n        .featured .card-badge {\n            background: #E2D4BB;\n            color: #222;\n        }\n\n        /* Card content */\n        .card-content {\n            padding: 38.14px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 22.6px;\n            flex: 1;\n        }\n\n        .plan-info {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 0;\n        }\n\n        .plan-name {\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: 500;\n            font-size: 14.57px;\n            color: var(--brown-saturated);\n            letter-spacing: -0.29px;\n            margin: 0 0 12.95px 0;\n            line-height: 1.2;\n        }\n\n        /* Price section */\n        .price-section {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 13px;\n        }\n\n        /* Price display */\n        .price-display {\n            display: flex;\n            align-items: baseline;\n            justify-content: center;\n            gap: 4.24px;\n            letter-spacing: -1.35px;\n        }\n\n        .original-price {\n            font-family: var(--font_display);\n            font-style: var(--font_display_style);\n            font-weight: var(--font_display_weight);\n            color: rgba(0, 0, 0, 0.3);\n            line-height: 1.34;\n        }\n\n        .original-price .currency {\n            font-size: 23.47px;\n            text-decoration: none;\n        }\n\n        .original-price .price-value {\n            font-size: 48.56px;\n            text-decoration: line-through;\n        }\n\n        .current-price {\n            font-family: var(--font_display);\n            font-style: var(--font_display_style);\n            font-weight: var(--font_display_weight);\n            color: var(--brown-saturated);\n            line-height: 1.34;\n        }\n\n        .current-price .currency {\n            font-size: 23.47px;\n        }\n\n        .current-price .price-value {\n            font-size: 48.56px;\n        }\n\n        .billing-text {\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            font-size: 8.475px;\n            color: #666;\n            text-align: center;\n            line-height: 1.64;\n        }\n\n        /* CTA section */\n        .cta-section {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 10.59px;\n        }\n\n        /* CTA Button */\n        .cta-button {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            width: 162.43px;\n            height: 38.14px;\n            padding: 16.16px 21.55px;\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: 500;\n            font-size: 9.89px;\n            letter-spacing: 0.79px;\n            text-transform: uppercase;\n            cursor: pointer;\n            transition: all 0.25s ease;\n            border: 0.706px solid #c9cac1;\n            border-radius: 2px;\n            background: #fff;\n            color: #000;\n        }\n\n        .cta-button:hover {\n            background: #F9F7F7;\n            color: #222;\n            border-color: #222;\n        }\n\n        .featured .cta-button {\n            background: #222;\n            color: #fff;\n            border: none;\n        }\n\n        .featured .cta-button:hover {\n            background: #444;\n            border: 1px solid #444;\n        }\n\n        /* Savings text */\n        .savings-text {\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            font-size: 8.475px;\n            color: #666;\n            text-align: center;\n            line-height: 1.64;\n        }\n\n        .savings-text .savings-amount {\n            color: var(--brown-saturated);\n            font-weight: 500;\n        }\n\n        /* Features list */\n        .features-section {\n            width: 100%;\n            display: flex;\n            flex-direction: column;\n            align-items: flex-start;\n        }\n\n        .features-list {\n            list-style: none;\n            text-align: left;\n            padding: 0;\n            margin: 0;\n            display: flex;\n            flex-direction: column;\n            gap: 7.77px;\n            width: 100%;\n            align-items: flex-start;\n        }\n\n        .feature-item {\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            font-size: 11.3px;\n            color: var(--brown-saturated);\n            display: flex;\n            align-items: flex-start;\n            gap: 8.09px;\n            line-height: 1.34;\n        }\n\n        .feature-check {\n            color: var(--brown-saturated);\n            flex-shrink: 0;\n            width: 16.19px;\n            height: 16.19px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .feature-check svg {\n            width: 9.87px;\n            height: 6.83px;\n        }\n\n        .feature-text {\n            flex: 1;\n        }\n\n        .feature-text .feature-value {\n            font-weight: 700;\n        }\n\n        .feature-header {\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: 700;\n            font-size: 11.3px;\n            color: var(--brown-saturated);\n            line-height: 1.34;\n            text-align: left;\n            margin-bottom: 0;\n            white-space: nowrap;\n        }\n\n        /* More text */\n        .feature-more {\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            font-size: 11.3px;\n            color: var(--brown-saturated);\n            line-height: 1.34;\n            margin-left: 24.28px; /* Align with feature text (16.19px icon + 8.09px gap) */\n        }\n\n        /* FAQ Section */\n        .faq-section {\n            max-width: 800px;\n            width: 100%;\n            margin: 20px auto 0;\n            padding: 0 30px 120px;\n        }\n\n        .faq-title {\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: 500;\n            font-size: 26px;\n            color: #000;\n            margin: 0 0 30px;\n            line-height: normal;\n        }\n\n        .faq-list {\n            display: flex;\n            flex-direction: column;\n            width: 100%;\n        }\n\n        .faq-item {\n            border-top: 1px solid #d9d9d9;\n        }\n\n        .faq-item:first-child {\n            border-top: none;\n        }\n\n        .faq-question {\n            display: flex;\n            align-items: center;\n            gap: 16px;\n            padding: 16px 0;\n            cursor: pointer;\n            background: none;\n            border: none;\n            width: 100%;\n            text-align: left;\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            font-size: 14px;\n            color: #1c1b1a;\n            line-height: 1.4;\n        }\n\n        .faq-question-text {\n            flex: 1 0 0;\n            min-width: 1px;\n            min-height: 1px;\n        }\n\n        .faq-icon {\n            flex-shrink: 0;\n            width: 20px;\n            height: 20px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: #999;\n            transition: transform 0.3s ease;\n        }\n\n        .faq-icon svg {\n            width: 100%;\n            height: 100%;\n        }\n\n        .faq-item.open .faq-icon {\n            transform: rotate(45deg);\n        }\n\n        .faq-answer {\n            max-height: 0;\n            overflow: hidden;\n            transition: max-height 0.3s ease, padding 0.3s ease;\n        }\n\n        .faq-item.open .faq-answer {\n            max-height: 800px;\n            padding-bottom: 16px;\n        }\n\n        .faq-answer-content {\n            font-family: var(--font_main);\n            font-size: 13px;\n            color: #666;\n            line-height: 1.6;\n        }\n\n        /* Responsive */\n        @media (max-width: 900px) {\n            .pricing-grid {\n                flex-direction: column;\n                align-items: center;\n                gap: 20px;\n            }\n\n            .main-title {\n                font-size: 26px;\n            }\n\n            .current-price .price-value {\n                font-size: 40px;\n            }\n\n            .card-content {\n                padding: 30px;\n            }\n\n            .faq-section {\n                margin-top: 50px;\n            }\n\n            .faq-title {\n                font-size: 22px;\n                margin-bottom: 24px;\n            }\n\n            .faq-question {\n                font-size: 13px;\n                padding: 14px 0;\n            }\n        }\n    </style>\n</head>\n\n<body>\n    <div id=\"app-root\">\n        <div class=\"pricing-container\">\n            <div class=\"header-section\">\n                <div class=\"header-label\" id=\"header-label\">\n                    <svg class=\"header-label-icon\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                        <path d=\"M3 11.5L2 4.5L5.5 7L8 3L10.5 7L14 4.5L13 11.5H3Z\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                    </svg>\n                    <span>UPGRADE YOUR PLAN</span>\n                </div>\n                <h1 class=\"main-title\" id=\"main-title\">More Tools. <span class=\"highlight\">More Possibilities.</span></h1>\n                <p class=\"subtitle\" id=\"subtitle\">Choose the Plan That Fits You Best</p>\n            </div>\n\n            <div class=\"pricing-grid\" id=\"pricing-grid\">\n                <!-- Pricing cards rendered by JS -->\n            </div>\n        </div>\n\n        <!-- FAQ Section -->\n        <div class=\"faq-section\" id=\"faq-section\">\n            <h2 class=\"faq-title\">FAQs</h2>\n            <div class=\"faq-list\" id=\"faq-list\">\n                <!-- FAQ items rendered by JS -->\n            </div>\n        </div>\n    </div>\n\n    <script>\n        (function () {\n            let currentState = null;\n\n            const defaultFAQs = [\n                { question: 'What happens when I upgrade from a Free or Trial plan?', answer: 'If you upgrade during a free trial, you will be charged immediately for the new subscription, and the upgrade with its features will activate immediately, replacing the trial. Any remaining days you had left on your trial will be credited to the end of your subscription. If you do not upgrade, your account will automatically transition to the Free plan at the end of the trial period.<br><br><strong>Please Note:</strong> Your free trial includes access to Advanced Plan features. At the end of the trial, if you do not upgrade, your account will automatically transition to the Free plan. If you purchase a Professional or Beginner plan, you will lose some of the Advanced Plan features.' },\n                { question: 'How do I Retrieve Invoices for the Plan Subscription?', answer: 'When the photographer\\'s credit card is charged for the plan subscription or the product/shipping cost, the receipts are saved under \\'Billing\\' in the Settings tab. The invoices can be easily printed or saved as PDF files at any time. Please allow a few days for the invoices to prepare once the card is charged.' },\n                { question: 'Why has my Free Plan storage been reduced to 3GB?', answer: 'After your account has reached 6 months of use and is downgraded to a Free Plan, the storage is updated from the introductory 10GB of storage to 3GB.<br><br>This means that any galleries above that limit will be permanently deleted 1 week after the plan changes (oldest galleries first).<br><br>The 6 months includes your 30 day free trial, and is not dependent on whether you upgrade or not. (You still receive all the benefits of the Advanced Plan on your 30 day free trial.)<br><br>For example, if you upgrade to a Paid Plan within 1 month of your account creation during the free trial, and then downgrade to a Free Plan 1 month later, you\\'ll have 4 months of 10GB Storage remaining.<br><br>However, if you upgrade to a Paid Plan within 1 month of your account creation, but then downgrade to a Free Plan a year later, your storage will be reduced to 3GB immediately.' },\n                { question: 'Unlimited Storage Accounts', answer: 'The Pic-Time Advanced plan includes unlimited storage, but it\\'s designed for individual photographers\\' business only (see our Terms of Service).<br><br>We monitor usage to make sure the service is used as intended. If your usage exceeds the fair limits (more than 20GB per gallery and 100 GB of bandwidth per month), additional fees may apply. We offer custom plans for accounts that serve more than one photographer (e.g., agencies or teams). Please fill in our Agency Inquiry Form, and our support team will be in touch.' },\n                { question: 'Need Help? Here\\'s How to Reach Us', answer: 'The Pic-Time support team works 24 hours a day, 7 days a week. We have agents working around the world, covering all time zones and working through the weekends. First, check out our Help Center. If you don\\'t find what you need contact our support team via the chat widget or email support@pic-time.com. We\\'re here to help whenever you need and on any question.' }\n            ];\n\n            const defaultPlans = {\n                beginner: {\n                    name: 'Beginner',\n                    currency: '$',\n                    billingPeriod: 'per month, billed yearly',\n                    ctaText: 'UPGRADE',\n                    features: [\n                        { label: '20GB', sublabel: 'Photo Storage' },\n                        { label: '5GB', sublabel: 'Video Storage' },\n                        { label: 'Client Galleries' },\n                        { label: 'Print Store' },\n                        { label: 'Chat Support for Visitors' }\n                    ]\n                },\n                professional: {\n                    name: 'Professional',\n                    badge: 'MOST POPULAR',\n                    currency: '$',\n                    billingPeriod: 'per month, billed yearly',\n                    ctaText: 'UPGRADE',\n                    features: [\n                        { label: 'All Beginner features plus:', isHeader: true },\n                        { label: '100GB', sublabel: 'Photo Storage' },\n                        { label: '30GB', sublabel: 'Video Storage' },\n                        { label: 'Slideshow Creator' },\n                        { label: 'Blog Builder & SEO Tools' },\n                        { label: 'Vendor Network' },\n                        { label: 'AI Search for Photographers' },\n                        { label: 'More', isMore: true }\n                    ]\n                },\n                advanced: {\n                    name: 'Advanced',\n                    currency: '$',\n                    billingPeriod: 'per month, billed yearly',\n                    ctaText: 'UPGRADE',\n                    features: [\n                        { label: 'All Professional features plus:', isHeader: true },\n                        { label: 'Unlimited', sublabel: 'Photo Storage' },\n                        { label: '60GB', sublabel: 'Video Storage' },\n                        { label: 'AI Face Search for Clients' },\n                        { label: '10K Licensed Music Tracks for Slideshows' },\n                        { label: 'More', isMore: true }\n                    ]\n                }\n            };\n\n            function getTierFromPlan(plan) {\n                var tierMap = { 'beginner': 5, 'professional': 10, 'advanced': 20 };\n                return tierMap[plan];\n            }\n\n            function getPricingForTier(pricingArray, tier) {\n                if (!pricingArray || !Array.isArray(pricingArray)) {\n                    return { monthly: 0, originalMonthly: 0, hasDiscount: false, yearlySavings: 0 };\n                }\n                var yearlyEntry = null;\n                var monthlyEntry = null;\n                for (var i = 0; i < pricingArray.length; i++) {\n                    var p = pricingArray[i];\n                    if (p.subscription === tier && p.collectInterval === 10) {\n                        yearlyEntry = p;\n                    }\n                    if (p.subscription === tier && p.collectInterval === 0) {\n                        monthlyEntry = p;\n                    }\n                }\n                if (yearlyEntry) {\n                    var monthly = Math.round(yearlyEntry.amount / 12 * 100) / 100;\n                    var originalMonthly = Math.round(yearlyEntry.fullPaymentAmount / 12 * 100) / 100;\n                    return {\n                        monthly: monthly,\n                        originalMonthly: originalMonthly,\n                        hasDiscount: yearlyEntry.amount !== yearlyEntry.fullPaymentAmount,\n                        yearlySavings: yearlyEntry.fullPaymentAmount - yearlyEntry.amount\n                    };\n                }\n                if (monthlyEntry) {\n                    return {\n                        monthly: monthlyEntry.amount,\n                        originalMonthly: monthlyEntry.fullPaymentAmount,\n                        hasDiscount: monthlyEntry.amount !== monthlyEntry.fullPaymentAmount,\n                        yearlySavings: 0\n                    };\n                }\n                return { monthly: 0, originalMonthly: 0, hasDiscount: false, yearlySavings: 0 };\n            }\n\n            function buildFeatureHTML(f, planKey) {\n                if (f.isHeader) {\n                    return '<div class=\"feature-header\">' + f.label + '</div>';\n                }\n                if (f.isMore) {\n                    return '<span class=\"feature-more\" data-plan=\"' + planKey + '\">' +\n                        '& much more' +\n                    '</span>';\n                }\n                var text = '';\n                if (f.sublabel) {\n                    text = '<span class=\"feature-value\">' + f.label + '</span> ' + f.sublabel;\n                } else {\n                    text = f.label;\n                }\n                return '<li class=\"feature-item\">' +\n                    '<span class=\"feature-check\">' +\n                        '<svg viewBox=\"0 0 10 7\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">' +\n                            '<path d=\"M1 3.5L4 6L9 1\"/>' +\n                        '</svg>' +\n                    '</span>' +\n                    '<span class=\"feature-text\">' + text + '</span>' +\n                '</li>';\n            }\n\n            function buildFAQItem(faq, index) {\n                return '<div class=\"faq-item\" data-faq-index=\"' + index + '\">' +\n                    '<button class=\"faq-question\">' +\n                        '<span class=\"faq-question-text\">' + faq.question + '</span>' +\n                        '<span class=\"faq-icon\">' +\n                            '<svg viewBox=\"0 0 18 18\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">' +\n                                '<path d=\"M9 3.5V14.5M3.5 9H14.5\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>' +\n                            '</svg>' +\n                        '</span>' +\n                    '</button>' +\n                    '<div class=\"faq-answer\">' +\n                        '<div class=\"faq-answer-content\">' + faq.answer + '</div>' +\n                    '</div>' +\n                '</div>';\n            }\n\n            function buildPricingCard(planKey, data) {\n                var planConfig = (data.plans && data.plans[planKey]) || defaultPlans[planKey];\n                var isFeatured = planKey === 'professional';\n                var tier = getTierFromPlan(planKey);\n                var currency = planConfig.currency || '$';\n\n                var pricingArray = data.pricing || [];\n                var tierPricing = getPricingForTier(pricingArray, tier);\n                var displayPrice = Math.round(tierPricing.monthly);\n                var originalPrice = Math.round(tierPricing.originalMonthly);\n                var showOriginal = tierPricing.hasDiscount;\n                var yearlySavings = tierPricing.yearlySavings;\n\n                var badgeText = isFeatured ? (planConfig.badge || 'MOST POPULAR') : '';\n\n                var savingsText = '';\n                if (planConfig.trialText) {\n                    savingsText = planConfig.trialText;\n                } else if (yearlySavings > 0) {\n                    savingsText = 'Upgrade to ' + planConfig.name + ' <span class=\"savings-amount\">for $' + yearlySavings + ' less</span>';\n                }\n\n                var featuresHTML = planConfig.features.map(function (f) {\n                    return buildFeatureHTML(f, planKey);\n                }).join('');\n\n                return '<div class=\"pricing-card ' + (isFeatured ? 'featured' : '') + '\">' +\n                    '<div class=\"card-badge\">' + badgeText + '</div>' +\n                    '<div class=\"card-content\">' +\n                        '<div class=\"plan-info\">' +\n                            '<div class=\"plan-name\">' + planConfig.name + '</div>' +\n                            '<div class=\"price-section\">' +\n                                '<div class=\"price-display\">' +\n                                    (showOriginal ? '<span class=\"original-price\"><span class=\"currency\">' + currency + '</span><span class=\"price-value\">' + originalPrice + '</span></span>' : '') +\n                                    '<span class=\"current-price\"><span class=\"currency\">' + currency + '</span><span class=\"price-value\">' + displayPrice + '</span></span>' +\n                                '</div>' +\n                                '<div class=\"billing-text\">' + planConfig.billingPeriod + '</div>' +\n                            '</div>' +\n                        '</div>' +\n                        '<div class=\"cta-section\">' +\n                            '<button class=\"cta-button\" data-plan=\"' + planKey + '\" data-tier=\"' + tier + '\" data-price=\"' + displayPrice + '\">' +\n                                planConfig.ctaText +\n                            '</button>' +\n                            (savingsText ? '<div class=\"savings-text\">' + savingsText + '</div>' : '') +\n                        '</div>' +\n                        '<div class=\"features-section\">' +\n                            '<ul class=\"features-list\">' + featuresHTML + '</ul>' +\n                        '</div>' +\n                    '</div>' +\n                '</div>';\n            }\n\n            function render(data) {\n                currentState = data;\n\n                // Apply custom fonts\n                if (data.fonts && Array.isArray(data.fonts)) {\n                    data.fonts.forEach(function (font) {\n                        if (font.url) {\n                            var linkId = 'font-link-' + font.id;\n                            if (!document.getElementById(linkId)) {\n                                var link = document.createElement('link');\n                                link.id = linkId;\n                                link.rel = 'stylesheet';\n                                link.href = font.url;\n                                document.head.appendChild(link);\n                            }\n                        }\n                        var varName = '--font_' + font.id;\n                        document.documentElement.style.setProperty(varName, font.family);\n                        if (font.style) {\n                            document.documentElement.style.setProperty(varName + '_style', font.style);\n                        }\n                        if (font.weight) {\n                            document.documentElement.style.setProperty(varName + '_weight', font.weight);\n                        }\n                    });\n                }\n\n                // Apply content\n                if (data.content) {\n                    if (data.content.promoLabel) {\n                        var headerLabel = document.getElementById('header-label');\n                        headerLabel.innerHTML = '<svg class=\"header-label-icon\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M3 11.5L2 4.5L5.5 7L8 3L10.5 7L14 4.5L13 11.5H3Z\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg><span>' + data.content.promoLabel + '</span>';\n                    }\n                    if (data.content.mainTitle) {\n                        var mainTitle = document.getElementById('main-title');\n                        var highlight = data.content.mainTitleHighlight || '';\n                        if (highlight) {\n                            mainTitle.innerHTML = data.content.mainTitle + ' <span class=\"highlight\">' + highlight + '</span>';\n                        } else {\n                            mainTitle.textContent = data.content.mainTitle;\n                        }\n                    }\n                    if (data.content.subtitle) {\n                        document.getElementById('subtitle').textContent = data.content.subtitle;\n                    }\n                }\n\n                // Build pricing cards\n                var grid = document.getElementById('pricing-grid');\n                var plans = ['beginner', 'professional', 'advanced'];\n                grid.innerHTML = plans.map(function (plan) {\n                    return buildPricingCard(plan, data);\n                }).join('');\n\n                // Build FAQ section\n                var faqs = data.faqs || defaultFAQs;\n                var faqList = document.getElementById('faq-list');\n                faqList.innerHTML = faqs.map(function (faq, index) {\n                    return buildFAQItem(faq, index);\n                }).join('');\n\n                // Update FAQ title if provided\n                if (data.content && data.content.faqTitle) {\n                    document.querySelector('.faq-title').textContent = data.content.faqTitle;\n                }\n\n                // Attach event listeners\n                attachEventListeners();\n            }\n\n            function attachEventListeners() {\n                var buttons = document.querySelectorAll('.cta-button');\n                buttons.forEach(function (button) {\n                    button.addEventListener('click', function () {\n                        var plan = this.getAttribute('data-plan');\n                        var tier = parseInt(this.getAttribute('data-tier'));\n                        var price = parseFloat(this.getAttribute('data-price'));\n                        window.myop_cta_handler('subscription-selected', {\n                            plan: plan,\n                            tier: tier,\n                            price: price\n                        });\n                    });\n                });\n\n                // More features buttons\n                var moreButtons = document.querySelectorAll('.feature-more');\n                moreButtons.forEach(function (button) {\n                    button.addEventListener('click', function () {\n                        var plan = this.getAttribute('data-plan');\n                        window.myop_cta_handler('more-features-clicked', {\n                            plan: plan\n                        });\n                    });\n                });\n\n                // FAQ accordion\n                var faqQuestions = document.querySelectorAll('.faq-question');\n                faqQuestions.forEach(function (question) {\n                    question.addEventListener('click', function () {\n                        var faqItem = this.closest('.faq-item');\n                        var isOpen = faqItem.classList.contains('open');\n\n                        // Close all FAQ items\n                        document.querySelectorAll('.faq-item').forEach(function (item) {\n                            item.classList.remove('open');\n                        });\n\n                        // Open this one if it was closed\n                        if (!isOpen) {\n                            faqItem.classList.add('open');\n                        }\n                    });\n                });\n            }\n\n            // Public API\n            window.myop_init_interface = function (data) {\n                if (!data) return currentState;\n                render(data);\n            };\n\n            window.myop_cta_handler = function (action_id, payload) {\n                console.log('CTA:', action_id, payload);\n            };\n        })();\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            lang: 'en',\n            fonts: [\n                {\n                    id: 'main',\n                    family: \"'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\",\n                    style: 'normal',\n                    weight: 400,\n                    url: 'https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css'\n                },\n                {\n                    id: 'display',\n                    family: \"'EB Garamond', Georgia, serif\",\n                    style: 'normal',\n                    weight: 400,\n                    url: 'https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap'\n                }\n            ],\n            content: {\n                promoLabel: 'UPGRADE YOUR PLAN',\n                mainTitle: 'More Tools.',\n                mainTitleHighlight: 'More Possibilities.',\n                subtitle: 'Choose the Plan That Fits You Best'\n            },\n            subscription: 0,\n            pricing: [\n                { fullPaymentAmount: 8, amount: 8, subscriptionExpiration: \"/Date(1772288806784)/\", subscription: 5, collectInterval: 0 },\n                { fullPaymentAmount: 84, amount: 60, subscriptionExpiration: \"/Date(1801319206784)/\", subscription: 5, collectInterval: 10 },\n                { fullPaymentAmount: 25, amount: 25, subscriptionExpiration: \"/Date(1772288806784)/\", subscription: 10, collectInterval: 0 },\n                { fullPaymentAmount: 252, amount: 180, subscriptionExpiration: \"/Date(1801319206784)/\", subscription: 10, collectInterval: 10 },\n                { fullPaymentAmount: 50, amount: 50, subscriptionExpiration: \"/Date(1772288806799)/\", subscription: 20, collectInterval: 0 },\n                { fullPaymentAmount: 504, amount: 348, subscriptionExpiration: \"/Date(1801319206804)/\", subscription: 20, collectInterval: 10 }\n            ],\n            plans: {\n                beginner: {\n                    name: 'Beginner',\n                    currency: '$',\n                    billingPeriod: 'per month, billed yearly',\n                    ctaText: 'UPGRADE',\n                    features: [\n                        { label: '20GB', sublabel: 'Photo Storage' },\n                        { label: '5GB', sublabel: 'Video Storage' },\n                        { label: 'Client Galleries' },\n                        { label: 'Print Store' },\n                        { label: 'Chat Support for Visitors' }\n                    ]\n                },\n                professional: {\n                    name: 'Professional',\n                    badge: 'MOST POPULAR',\n                    currency: '$',\n                    billingPeriod: 'per month, billed yearly',\n                    ctaText: 'UPGRADE',\n                    features: [\n                        { label: 'All Beginner features plus:', isHeader: true },\n                        { label: '100GB', sublabel: 'Photo Storage' },\n                        { label: '30GB', sublabel: 'Video Storage' },\n                        { label: 'Slideshow Creator' },\n                        { label: 'Blog Builder & SEO Tools' },\n                        { label: 'Vendor Network' },\n                        { label: 'AI Search for Photographers' },\n                        { label: 'More', isMore: true }\n                    ]\n                },\n                advanced: {\n                    name: 'Advanced',\n                    currency: '$',\n                    billingPeriod: 'per month, billed yearly',\n                    ctaText: 'UPGRADE',\n                    features: [\n                        { label: 'All Professional features plus:', isHeader: true },\n                        { label: 'Unlimited', sublabel: 'Photo Storage' },\n                        { label: '60GB', sublabel: 'Video Storage' },\n                        { label: 'AI Face Search for Clients' },\n                        { label: '10K Licensed Music Tracks for Slideshows' },\n                        { label: 'More', isMore: true }\n                    ]\n                }\n            },\n            discount: {\n                percentage: 30\n            }\n        });\n    </script>\n</body>\n\n</html>\n"
