fy-content: center;\n            height: 40px;\n            padding: 8px 16px;\n            background: none;\n            border: none;\n            border-radius: 2px;\n            font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 16px;\n            font-weight: 400;\n            color: #222222;\n            text-decoration: underline;\n            cursor: pointer;\n        }\n\n        .reset-button:hover {\n            background: rgba(0, 0, 0, 0.03);\n        }\n\n        .upgrade-button {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 6px;\n            height: 40px;\n            padding: 8px 16px;\n            background: #f8ecff;\n            border: 1px solid #222222;\n            border-radius: 2px;\n            font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 16px;\n            font-weight: 400;\n            color: #222222;\n            line-height: 1.25;\n            cursor: pointer;\n        }\n\n        .upgrade-button:hover {\n            background: #f0dffc;\n        }\n\n        .crown-icon {\n            width: 16px;\n            height: 16px;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\">\n        <div class=\"header\">\n            <button class=\"close-button\" id=\"close-btn\">\n                <svg class=\"close-icon\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M15 5L5 15M5 5L15 15\" stroke=\"#222222\" stroke-width=\"1.67\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                </svg>\n            </button>\n        </div>\n        <div class=\"content\">\n            <h1 class=\"title\" id=\"title\"></h1>\n            <p class=\"description\" id=\"description\"></p>\n        </div>\n        <div class=\"actions\">\n            <button class=\"reset-button\" id=\"reset-btn\"></button>\n            <button class=\"upgrade-button\" id=\"upgrade-btn\">\n                <svg class=\"crown-icon\" xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n                    <path d=\"M7.56445 1.79785C7.75552 1.45762 8.24448 1.45762 8.43555 1.79785L10.1885 4.91895C10.5922 5.63779 11.5011 5.89599 12.2227 5.49707L14.3076 4.34375C14.684 4.13567 15.1302 4.46859 15.0381 4.88867L13.0176 14.1074C12.9672 14.3366 12.7639 14.4998 12.5293 14.5H3.4707C3.23611 14.4998 3.03278 14.3366 2.98242 14.1074L0.961914 4.88867C0.869812 4.46859 1.31601 4.13567 1.69238 4.34375L3.77734 5.49707C4.49891 5.89599 5.40776 5.63779 5.81152 4.91895L7.56445 1.79785Z\" fill=\"#F8ECFF\" stroke=\"#222222\"/>\n                </svg>\n                <span id=\"upgrade-text\"></span>\n            </button>\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        let currentState = null;\n\n        function render(data) {\n            currentState = data;\n\n            document.getElementById('title').textContent = data.title;\n            document.getElementById('description').textContent = data.description;\n            document.getElementById('reset-btn').textContent = data.resetText;\n            document.getElementById('upgrade-text').textContent = data.upgradeText;\n        }\n\n        function attachEventListeners() {\n            document.getElementById('close-btn').addEventListener('click', function() {\n                window.myop_cta_handler('close-clicked', undefined);\n            });\n\n            document.getElementById('reset-btn').addEventListener('click', function() {\n                window.myop_cta_handler('reset-clicked', undefined);\n            });\n\n            document.getElementById('upgrade-btn').addEventListener('click', function() {\n                window.myop_cta_handler('upgrade-clicked', undefined);\n            });\n        }\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action, payload) {\n            // Overridden by host application\n            console.log('CTA:', action, payload);\n        };\n\n        // Initialize event listeners once\n        attachEventListeners();\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            title: 'Your design includes pro features',\n            description: 'Upgrade to keep this design and access advanced design options.',\n            resetText: 'Reset design',\n            upgradeText: 'Upgrade'\n        });\n    </script>\n</body>\n</html>\n"
