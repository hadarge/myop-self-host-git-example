        "name": "Default Version",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Print Product Shop</title>\n\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        :root {\n            --C1: #FFFFFF;\n            --C8: #444444;\n        }\n\n        body {\n            /* Fallback fonts until external fonts load */\n            font-family: \"Gotham Narrow SSm\", -apple-system, BlinkMacSystemFont, sans-serif;\n            line-height: 1.6;\n            color: #333;\n            background-color: #ffffff;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 60px 20px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        /* Header Section */\n        .header-section {\n            text-align: center;\n            margin-bottom: 60px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        .header-title {\n            color: #444444;\n            text-align: center;\n            font-family: \"Gotham Narrow SSm\", sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 22px;\n            /* 137.5% */\n            letter-spacing: 1.5px;\n            text-transform: uppercase;\n            margin-bottom: 24px;\n        }\n\n        .header-description {\n            color: var(--C8, #444);\n            text-align: center;\n            font-family: \"Gotham Narrow SSm\", sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 325;\n            line-height: 24px;\n            /* 150% */\n            letter-spacing: 0.246px;\n            max-width: 700px;\n            margin: 0 auto 32px;\n        }\n\n        /* Updated CTA Button */\n        .cta-button {\n            width: 240px;\n            height: 40px;\n            flex-shrink: 0;\n            background: var(--C8, #444);\n            color: var(--C1, #FFF);\n            text-align: center;\n            font-family: \"Gotham Narrow SSm\", sans-serif;\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 325;\n            line-height: 150%;\n            /* 21px */\n            letter-spacing: 0.2px;\n\n            /* Layout & Reset */\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            text-decoration: none;\n            border: none;\n            cursor: pointer;\n            transition: opacity 0.3s ease;\n        }\n\n        .cta-button:hover {\n            opacity: 0.9;\n        }\n\n        /* Updated Video Section */\n        .video-section {\n            width: 556px;\n            height: 313px;\n            flex-shrink: 0;\n            background: rgba(0, 0, 0, 0.25);\n            position: relative;\n            border-radius: 8px;\n            /* Kept for aesthetics */\n            overflow: hidden;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\n        }\n\n        .video-container {\n            position: relative;\n            width: 100%;\n            height: 100%;\n            cursor: pointer;\n        }\n\n        .video-image {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        .video-overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background-color: rgba(0, 0, 0, 0.1);\n            transition: background-color 0.3s ease;\n        }\n\n        .video-container:hover .video-overlay {\n            background-color: rgba(0, 0, 0, 0.2);\n        }\n\n        /* Updated Video Title */\n        .video-title {\n            position: absolute;\n            top: 40px;\n            left: 50%;\n            transform: translateX(-50%);\n            z-index: 2;\n            width: 100%;\n\n            color: #FFF;\n            text-align: center;\n            font-family: \"TT Norms Pro\", sans-serif;\n            font-size: 30px;\n            font-style: normal;\n            font-weight: 500;\n            line-height: 140%;\n            /* 42px */\n            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);\n        }\n\n        /* Play Icon SVG Wrapper */\n        .play-button-wrapper {\n            transition: transform 0.3s ease;\n        }\n\n        .video-container:hover .play-button-wrapper {\n            transform: scale(1.1);\n        }\n\n        .play-icon-svg {\n            width: 58.954px;\n            height: 58.842px;\n            flex-shrink: 0;\n            display: block;\n        }\n\n        /* Responsive */\n        @media (max-width: 600px) {\n            .video-section {\n                width: 100%;\n                height: auto;\n                aspect-ratio: 556/313;\n            }\n\n            .container {\n                padding: 40px 20px;\n            }\n\n            .video-title {\n                font-size: 24px;\n                top: 30px;\n            }\n        }\n    </style>\n</head>\n\n<body>\n\n    <!-- App Container -->\n    <div id=\"app-container\"></div>\n\n    <script>\n        // ===================================================================\n        // 1. GLOBAL VARIABLES\n        // ===================================================================\n        let globalConfig = {\n            lang: {},\n            data: {},\n            fonts: []\n        };\n\n        // ===================================================================\n        // 2. PUBLIC INTERFACE METHODS\n        // ===================================================================\n\n        /**\n         * Initializes the interface with the provided configuration.\n         * @param {object} config - Configuration DTO (Data Transfer Object).\n         */\n        window.myop_init_interface = function(config) {\n            try {\n                // 1. Merge Config\n                globalConfig = {\n                    ...globalConfig,\n                    ...config\n                };\n\n                // 2. Load External Fonts\n                if (globalConfig.fonts && Array.isArray(globalConfig.fonts)) {\n                    globalConfig.fonts.forEach(url => {\n                        if (!document.querySelector(`link[href=\"${url}\"]`)) {\n                            const link = document.createElement('link');\n                            link.rel = 'stylesheet';\n                            link.href = url;\n                            document.head.appendChild(link);\n                        }\n                    });\n                }\n\n                // 3. Render Interface\n                renderApp();\n\n                console.log('INTERFACE_INIT: Shop interface initialized.');\n\n            } catch (e) {\n                console.error('Failed to initialize interface:', e);\n            }\n        };\n\n        /**\n         * Handles all calls to action (CTA) from the interface.\n         * Reports back to the application logic.\n         * @param {string} action_id - Unique identifier for the action.\n         * @param {object} payload - Data payload associated with the action.\n         */\n        window.myop_cta_handler = function(action_id, payload) {\n            const logEntry = {\n                action: action_id,\n                payload: payload,\n                timestamp: new Date().toISOString()\n            };\n            \n            // Write to log as requested (no alerts)\n            console.log('CTA_HANDLER:', JSON.stringify(logEntry, null, 2));\n            \n            // Dispatch custom event for external listeners/host application\n            const event = new CustomEvent('myop-cta', { \n                detail: logEntry,\n                bubbles: true, \n                composed: true \n            });\n            document.body.dispatchEvent(event);\n        };\n\n        // ===================================================================\n        // 3. RENDERING LOGIC\n        // ===================================================================\n\n        function renderApp() {\n            const container = document.getElementById('app-container');\n            const { lang, data } = globalConfig;\n\n            // Safe defaults in case config is partial\n            const title = lang.title || \"Print Product Shop\";\n            const description = lang.description || \"\";\n            const btnText = lang.ctaButton || \"Setup\";\n            const videoTitle = lang.videoTitle || \"\";\n            const imageUrl = data.videoImage || \"\";\n            \n            // New Data Fields for URLs\n            const setupUrl = data.setupUrl || \"\";\n            const videoUrl = data.videoUrl || \"\";\n\n            const html = `\n                <div class=\"container\">\n                    <!-- Header Section -->\n                    <div class=\"header-section\">\n                        <h1 class=\"header-title\">${title}</h1>\n                        <p class=\"header-description\">${description}</p>\n                        <!-- Added data-url attribute -->\n                        <button class=\"cta-button\" data-action=\"setupShop\" data-url=\"${setupUrl}\">${btnText}</button>\n                    </div>\n\n                    <!-- Video Section -->\n                    <div class=\"video-section\">\n                        <!-- Added data-url attribute -->\n                        <div class=\"video-container\" data-action=\"playVideo\" data-url=\"${videoUrl}\">\n                            <img \n                                src=\"${imageUrl}\" \n                                alt=\"${title}\" \n                                class=\"video-image\"\n                            />\n                            <h2 class=\"video-title\">${videoTitle}</h2>\n                            <div class=\"video-overlay\">\n                                <div class=\"play-button-wrapper\">\n                                    <svg class=\"play-icon-svg\" xmlns=\"http://www.w3.org/2000/svg\" width=\"61\" height=\"61\" viewBox=\"0 0 61 61\" fill=\"none\">\n                                        <ellipse cx=\"30.1972\" cy=\"30.1399\" rx=\"29.4772\" ry=\"29.4212\" fill=\"#868686\" fill-opacity=\"0.5\" stroke=\"white\" stroke-width=\"1.44\"/>\n                                        <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M45.8024 30.1421L23.261 43.9874V16.2969L45.8024 30.1421Z\" fill=\"white\"/>\n                                    </svg>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            `;\n\n            container.innerHTML = html;\n            attachEventListeners(container);\n        }\n\n        function attachEventListeners(container) {\n            // Using event delegation\n            container.addEventListener('click', function(e) {\n                // Handle button clicks or video container clicks\n                const target = e.target.closest('[data-action]');\n                \n                if (target) {\n                    const action = target.dataset.action;\n                    const url = target.dataset.url; // Extract URL from data attribute\n                    \n                    // Route to the global handler with URL in payload\n                    window.myop_cta_handler(action, {\n                        origin: 'print-product-shop-intro',\n                        url: url\n                    });\n                }\n            });\n        }\n\n        // ===================================================================\n        // 4. MOCK DATA / BOOTSTRAP\n        // ===================================================================\n        \n        document.addEventListener('DOMContentLoaded', () => {\n            // Configuration DTO\n            const demoConfig = {\n                lang: {\n                    title: \"Set Up Your Online Print Product Shop\",\n                    description: \"Let your client order prints and photo albums directly through their galleries, without ever taking care of production and shipping!\",\n                    ctaButton: \"Setup your shop\",\n                    videoTitle: \"Print Product Shop\"\n                },\n                data: {\n                    // Using the Unsplash URL for preview purposes. \n                    // In production, this would be the local file path or CDN URL.\n                    videoImage: \"https://images.unsplash.com/photo-1513519245088-0e12902e35ca?w=900&h=600&fit=crop\",\n                    // New fields for URLs\n                    setupUrl: \"/admin/settings/shop/setup\",\n                    videoUrl: \"https://www.youtube.com/watch?v=dQw4w9WgXcQ\"\n                },\n                fonts: [\n                    \"https://pictimecloudaf-pub-g3csanfebyefg3dm.a.c-sty.com/pictures/webfonts/701366/550D4A6EF889DED55.css\",\n                    \"https://pictimecloudaf-pub-g3csanfebyefg3dm.a.c-sty.com/pictures/scripts/platform2/resources/stores/4/environments/ep/r1323/assets_css/index.css\"\n                ]\n            };\n\n            // Call the init method\n            if (window.myop_init_interface) {\n                window.myop_init_interface(demoConfig);\n            }\n        });\n\n    </script>\n</body>\n\n</html>"
        }
      }
    ]
  }
