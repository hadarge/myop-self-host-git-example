    "consume_variant": [
      {
        "name": "Version 32",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Feature item displayed in pricing card\n     */\n    interface FeatureItem {\n      label: string;\n      sublabel?: string;\n    }\n\n    /**\n     * FAQ item with question and answer\n     */\n    interface FaqItem {\n      question: string;\n      answer: string;\n    }\n\n    /**\n     * Content configuration for all text/numbers in the component\n     */\n    interface ContentConfig {\n      // Header section\n      promoLabel?: string;\n      mainTitle?: string;\n      subtitle?: string;\n\n      // Card configuration\n      cards?: {\n        professional?: {\n          name?: string;\n          badge?: string;\n          badgeType?: 'featured' | 'default';\n          buttonLabel?: string;\n          currentPlanLabel?: string;\n          featuresTitle?: string;\n          features?: FeatureItem[];\n          savingsTextTemplate?: string; // e.g., \"Upgrade to {plan} for {savings} less\"\n        };\n        advanced?: {\n          name?: string;\n          badge?: string;\n          badgeType?: 'featured' | 'default';\n          buttonLabel?: string;\n          currentPlanLabel?: string;\n          featuresTitle?: string;\n          features?: FeatureItem[];\n          savingsTextTemplate?: string; // e.g., \"Upgrade to {plan} for {savings} less\"\n        };\n      };\n\n      // Pricing display\n      currency?: string;\n      billingPeriodLabel?: string;\n\n      // FAQs section\n      faqTitle?: string;\n      faqs?: FaqItem[];\n    }\n\n    /**\n     * Font configuration item\n     */\n    interface FontItem {\n      id: string;           // Font identifier used for CSS variable, e.g., \"main\" -> --font_main\n      family: string;       // Font family name, e.g., \"TT Norms Pro\"\n      style?: string;       // Optional font style, e.g., \"normal\", \"italic\"\n      weight?: number;      // Optional font weight, e.g., 400, 700\n      url: string;          // URL to the font CSS file\n    }\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n      lang: string;\n      fonts?: FontItem[];   // Array of font configurations\n      subscription: 0 | 10 | 20; // 0=Free, 10=Professional, 20=Advanced\n      pricing?: Array<{\n        fullPaymentAmount: number;\n        amount: number;\n        subscriptionExpiration?: string;\n        subscription: number;       // tier: 10=Professional, 20=Advanced\n        collectInterval: 0 | 10;    // 0=Monthly, 10=Yearly\n      }>;\n      content?: ContentConfig;\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n      'faq-toggled': { index: number; question: string; isOpen: boolean };\n      'size-requested': {\n        width?: number | null;\n        height?: number | null;\n        minWidth?: number | null;\n        maxWidth?: number | null;\n        minHeight?: number | null;\n        maxHeight?: number | null;\n        required?: boolean;\n      };\n      'subscription-selected': {\n        plan: 'professional' | 'advanced';\n        tier: 10 | 20;\n        price: number;\n      };\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n      action: K,\n      payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <style>\n        :root {\n            /* Font variables - set dynamically from config.fonts */\n            --font_main: sans-serif;\n            --font_main_style: normal;\n            --font_main_weight: 400;\n            --font_heading: sans-serif;\n            --font_heading_style: normal;\n            --font_heading_weight: 400;\n            /* Color variables */\n            --primary-color: #54033c;\n            --card-background-color: #F9F7F7;\n            --background-color: #FFF;\n            --text-color: #250b0b;\n            --muted-text-color: #666666;\n            --border-color: rgba(54, 5, 39, 0.3);\n            --card-border-radius: 8px;\n            --button-border-radius: 2px;\n        }\n\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            overflow-y: auto;\n            font-family: var(--font_main);\n            font-style: var(--font_main_style);\n            font-weight: var(--font_main_weight);\n            background-color: var(--background-color);\n        }\n\n        .main-container {\n            width: 100%;\n            max-width: 800px;\n            padding: 40px 40px 20px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        /* Header Section */\n        .header-section {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 20px;\n            margin-bottom: 32px;\n        }\n\n        .upgrade-badge {\n            display: flex;\n            align-items: center;\n            gap: 4px;\n            padding: 8px 20px;\n            background: #ffffff;\n            border: 1px solid rgba(54, 5, 39, 0.2);\n            border-radius: 100px;\n        }\n\n        .upgrade-badge-icon {\n            width: 22px;\n            height: 22px;\n            flex-shrink: 0;\n        }\n\n        .upgrade-badge-text {\n            font-family: var(--font_main);\n            font-size: 10px;\n            font-weight: 500;\n            letter-spacing: 0.8px;\n            text-transform: uppercase;\n            color: #222;\n        }\n\n        .header-content {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 14px;\n            text-align: center;\n        }\n\n        .main-title {\n            font-family: var(--font_heading);\n            font-style: var(--font_heading_style);\n            font-weight: var(--font_heading_weight);\n            font-size: 30px;\n            color: var(--text-color);\n            margin: 0;\n            line-height: normal;\n        }\n\n        .subtitle {\n            font-family: var(--font_main);\n            font-size: 16px;\n            color: var(--text-color);\n            margin: 0;\n            line-height: 1.34;\n        }\n\n        /* Pricing Card */\n        .pricing-card {\n            width: 100%;\n            max-width: 238px;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .card-badge {\n            background-color: #E2D4BB;\n            color: #222;\n            text-align: center;\n            padding: 8px 7px;\n            font-family: var(--font_main);\n            font-size: 10px;\n            font-weight: 500;\n            letter-spacing: 0.8px;\n            text-transform: uppercase;\n            border-top-left-radius: var(--card-border-radius);\n            border-top-right-radius: var(--card-border-radius);\n        }\n\n        .card-content {\n            background-color: var(--card-background-color);\n            border: 1px solid #E2D4BB;\n            border-top: none;\n            border-bottom-left-radius: var(--card-border-radius);\n            border-bottom-right-radius: var(--card-border-radius);\n            padding: 38px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 23px;\n        }\n\n        .plan-name {\n            font-family: var(--font_main);\n            font-size: 14.5px;\n            font-weight: 500;\n            color: var(--text-color);\n            letter-spacing: -0.29px;\n            line-height: 1.2;\n        }\n\n        .price-section {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 13px;\n        }\n\n        .price-display {\n            display: flex;\n            align-items: flex-start;\n            gap: 4px;\n            font-family: var(--font_heading);\n            font-style: var(--font_heading_style);\n            font-weight: var(--font_heading_weight);\n            letter-spacing: -1.3px;\n        }\n\n        .original-price {\n            opacity: 0.3;\n            color: var(--text-color);\n        }\n\n        .original-price .currency {\n            font-size: 23px;\n            line-height: 1.34;\n        }\n\n        .original-price .amount {\n            font-size: 49px;\n            line-height: 1.34;\n            text-decoration: line-through;\n        }\n\n        .current-price {\n            color: var(--text-color);\n        }\n\n        .current-price .currency {\n            font-size: 23px;\n            line-height: 1.34;\n        }\n\n        .current-price .amount {\n            font-size: 49px;\n            line-height: 1.34;\n        }\n\n        .price-suffix {\n            font-family: var(--font_main);\n            font-size: 11px;\n            color: var(--muted-text-color);\n            text-align: center;\n            line-height: 1.64;\n        }\n\n        /* CTA Section */\n        .cta-section {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 10.5px;\n            width: 100%;\n        }\n\n        .cta-button {\n            width: 162px;\n            height: 38px;\n            padding: 0 22px;\n            background-color: #222;\n            color: white;\n            border: none;\n            border-radius: var(--button-border-radius);\n            font-family: var(--font_main);\n            font-size: 10px;\n            font-weight: 500;\n            letter-spacing: 0.8px;\n            text-transform: uppercase;\n            cursor: pointer;\n            transition: opacity 0.2s;\n        }\n\n        .cta-button:hover {\n            background-color: #444;\n        }\n\n        .savings-text {\n            font-family: var(--font_main);\n            font-size: 8px;\n            color: var(--muted-text-color);\n            text-align: center;\n            line-height: 1.64;\n        }\n\n        .savings-highlight {\n            font-weight: 500;\n            color: var(--text-color);\n        }\n\n        /* Features Section */\n        .features-section {\n            display: flex;\n            flex-direction: column;\n            gap: 8.5px;\n            align-items: flex-start;\n        }\n\n        .features-title {\n            font-family: var(--font_main);\n            font-size: 11.3px;\n            font-weight: 700;\n            color: var(--text-color);\n            line-height: 1.34;\n            margin: 0 0 3px 0;\n        }\n\n        .feature-item {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            font-family: var(--font_main);\n            font-size: 11px;\n            color: var(--text-color);\n            line-height: 1.34;\n        }\n\n        .feature-icon {\n            color: #222;\n            font-size: 12px;\n            width: 12px;\n            flex-shrink: 0;\n        }\n\n        .feature-icon.plus {\n            font-size: 14px;\n        }\n\n        .feature-value {\n            font-weight: 500;\n        }\n\n        .feature-text {\n            font-weight: 400;\n        }\n\n        .feature-item.multiline {\n            align-items: flex-start;\n        }\n\n        .feature-item.multiline .feature-content {\n            max-width: 136px;\n        }\n\n        /* FAQ Section */\n        .faq-section {\n            width: 100%;\n            background-color: var(--background-color);\n            padding: 40px 20px;\n            margin-top: 0;\n        }\n\n        .faq-container {\n            max-width: 700px;\n            margin: 0 auto;\n        }\n\n        .faq-title {\n            font-family: var(--font_main);\n            font-size: 32px;\n            font-weight: 500;\n            color: black;\n            margin: 0 0 30px 0;\n        }\n\n        .faq-list {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n        }\n\n        .faq-item {\n            border-top: 0.5px solid #999;\n        }\n\n        .faq-item:first-child {\n            border-top: none;\n        }\n\n        .faq-question {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: 16px 0;\n            cursor: pointer;\n            gap: 16px;\n        }\n\n        .faq-question:hover {\n            opacity: 0.7;\n        }\n\n        .faq-question-text {\n            font-family: var(--font_main);\n            font-size: 14px;\n            color: #1c1b1a;\n            line-height: 1.5;\n            margin: 0;\n            flex: 1;\n        }\n\n        .faq-icon {\n            font-size: 18px;\n            color: #999;\n            flex-shrink: 0;\n            transition: transform 0.3s ease;\n        }\n\n        .faq-item.open .faq-icon {\n            transform: rotate(45deg);\n        }\n\n        .faq-answer {\n            max-height: 0;\n            overflow: hidden;\n            transition: max-height 0.3s ease;\n        }\n\n        .faq-item.open .faq-answer {\n            max-height: 500px;\n        }\n\n        .faq-answer-text {\n            font-family: var(--font_main);\n            font-size: 14px;\n            color: var(--muted-text-color);\n            line-height: 1.5;\n            margin: 0;\n            padding-bottom: 16px;\n        }\n    </style>\n</head>\n\n<body>\n    <div id=\"app-root\">\n        <div class=\"main-container\" id=\"main-container\">\n            <!-- Content will be rendered by JavaScript -->\n        </div>\n        <div class=\"faq-section\" id=\"faq-section\">\n            <!-- FAQ content will be rendered by JavaScript -->\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        let currentState = null;\n\n        // Default content values\n        const defaultContent = {\n            promoLabel: 'UPGRADE YOUR PLAN',\n            mainTitle: 'More Tools. More Possibilities.',\n            subtitle: 'All the Tools a World-Class Photographer needs',\n            currency: '$',\n            billingPeriodLabel: 'per month, billed yearly',\n            cards: {\n                professional: {\n                    name: 'Professional',\n                    badge: 'Popular',\n                    badgeType: 'default',\n                    buttonLabel: 'UPGRADE',\n                    currentPlanLabel: 'Current Plan',\n                    featuresTitle: 'All Beginner features plus:',\n                    features: [\n                        { label: '100GB', sublabel: 'Photo Storage' },\n                        { label: '30GB', sublabel: 'Video Storage' },\n                        { label: 'AI Face Search' }\n                    ],\n                    savingsTextTemplate: 'Upgrade to {plan} for {savings} less'\n                },\n                advanced: {\n                    name: 'Advanced',\n                    badge: 'Most popular',\n                    badgeType: 'featured',\n                    buttonLabel: 'UPGRADE',\n                    currentPlanLabel: 'Current Plan',\n                    featuresTitle: 'All Professional features plus:',\n                    features: [\n                        { label: 'Unlimited', sublabel: 'Photo Storage' },\n                        { label: '60GB', sublabel: 'Video Storage' },\n                        { label: 'AI Face Search for Clients' },\n                        { label: '10K', sublabel: 'Licensed Music Tracks for Slideshows' },\n                        { label: '& much more' }\n                    ],\n                    savingsTextTemplate: 'Upgrade to {plan} for {savings} less'\n                }\n            },\n            faqTitle: 'FAQs',\n            faqs: [\n                { question: 'What happens when I upgrade my plan?', answer: 'When you upgrade, regardless of whether you are adding on more time to your current plan, or upgrading to a new plan, you will: Be charged immediately. Get 1 year of the new plan added to your subscription. Be upgraded to the new plan right away, and whatever remaining time you had on your current subscription is converted to the new subscription, with your subscription expiration adjusted to account for the price difference.' },\n                { question: 'How do I Retrieve Invoices for the Plan Subscription?', answer: 'When the photographer\\'s credit card is charged for the plan subscription or the product/shipping cost, the receipts are saved under \\'Billing\\' in the Settings tab. The invoices can be easily printed or saved as PDF files at any time. Please allow a few days for the invoices to prepare once the card is charged.' },\n                { question: 'How do I check my subscription plan details?', answer: 'To check the details and features of your subscription plan, go to Settings from the Main Dashboard. In the Plans & Billing tab, you can see your current subscription and when your next subscription payment will be. If you want to see past payments, click View Billing History. Click Manage next to your current subscription to upgrade and view all the features and details of your subscription.' },\n                { question: 'Unlimited Storage Accounts', answer: 'The Pic-Time Advanced plan includes unlimited storage, but it\\'s designed for individual photographers\\' business only (see our Terms of Service). We monitor usage to make sure the service is used as intended. If your usage exceeds the fair limits (more than 20GB per gallery and 100 GB of bandwidth per month), additional fees may apply. We offer custom plans for accounts that serve more than one photographer (e.g., agencies or teams). Please fill in our Agency Inquiry Form, and our support team will be in touch.' },\n                { question: 'Need Help? Here\\'s How to Reach Us', answer: 'The Pic-Time support team works 24 hours a day, 7 days a week. We have agents working around the world, covering all time zones and working through the weekends. First, check out our Help Center. If you don\\'t find what you need contact our support team via the chat widget or email support@pic-time.com. We\\'re here to help whenever you need and on any question.' }\n            ]\n        };\n\n        function deepMerge(target, source) {\n            const result = { ...target };\n            for (const key in source) {\n                if (source[key] && typeof source[key] === 'object' && !Array.isArray(source[key])) {\n                    result[key] = deepMerge(target[key] || {}, source[key]);\n                } else if (source[key] !== undefined) {\n                    result[key] = source[key];\n                }\n            }\n            return result;\n        }\n\n        function render(inputData) {\n            const lang = inputData.lang || 'en';\n            const subscription = inputData.subscription || 0; // 0=Free, 10=Professional, 20=Advanced\n            const pricing = inputData.pricing || [];\n            const content = deepMerge(defaultContent, inputData.content || {});\n\n            currentState = { lang, subscription, pricing, content, fonts: inputData.fonts };\n\n            // Apply fonts\n            if (inputData.fonts && Array.isArray(inputData.fonts)) {\n                inputData.fonts.forEach(function(font) {\n                    // Load font CSS if URL provided\n                    if (font.url) {\n                        const existingLink = document.querySelector('link[href=\"' + font.url + '\"]');\n                        if (!existingLink) {\n                            const link = document.createElement('link');\n                            link.rel = 'stylesheet';\n                            link.href = font.url;\n                            document.head.appendChild(link);\n                        }\n                    }\n                    // Set CSS variables for this font\n                    const varPrefix = '--font_' + font.id;\n                    document.documentElement.style.setProperty(varPrefix, font.family);\n                    document.documentElement.style.setProperty(varPrefix + '_style', font.style || 'normal');\n                    document.documentElement.style.setProperty(varPrefix + '_weight', font.weight !== undefined ? font.weight : 400);\n                });\n            }\n\n            // This component is ONLY for upgrading to Advanced (tier 20)\n            const targetTier = 20;\n            const cardKey = 'advanced';\n            const cardConfig = content.cards.advanced;\n\n            // Find pricing for tier 20 (prefer yearly billing - collectInterval 10)\n            let targetPricing = pricing.find(p => p.subscription === 20 && p.collectInterval === 10);\n            if (!targetPricing) {\n                targetPricing = pricing.find(p => p.subscription === 20);\n            }\n            if (!targetPricing) {\n                targetPricing = { fullPaymentAmount: 348, amount: 348, subscription: 20, collectInterval: 10 };\n            }\n\n            // For yearly subscriptions (collectInterval 10), divide by 12 to get monthly price\n            const isYearly = targetPricing.collectInterval === 10;\n            const rawFullAmount = targetPricing.fullPaymentAmount;\n            const rawAmount = targetPricing.amount;\n            const originalPrice = isYearly ? Math.round(rawFullAmount / 12) : rawFullAmount;\n            const currentPrice = isYearly ? Math.round(rawAmount / 12) : rawAmount;\n            const yearlySavings = rawFullAmount - rawAmount; // Savings is always yearly total\n            const currency = content.currency || '$';\n\n            // Build savings text from template\n            let savingsText = cardConfig.savingsTextTemplate || 'Upgrade to {plan} for {savings} less';\n            const planName = cardConfig.name || (cardKey === 'professional' ? 'Professional' : 'Advanced');\n            savingsText = savingsText.replace('{plan}', planName).replace('{savings}', currency + yearlySavings);\n\n            // Render main container\n            const mainContainer = document.getElementById('main-container');\n\n            // Build features HTML using new FeatureItem structure\n            const features = cardConfig.features || [];\n            const featuresHtml = features.map(function(feature) {\n                const hasValue = feature.sublabel;\n                let featureContent = '';\n                if (hasValue) {\n                    featureContent = '<span class=\"feature-content\"><span class=\"feature-value\">' + feature.label + '</span> <span class=\"feature-text\">' + feature.sublabel + '</span></span>';\n                } else {\n                    featureContent = '<span class=\"feature-content\"><span class=\"feature-text\">' + feature.label + '</span></span>';\n                }\n                return '<div class=\"feature-item\"><span class=\"feature-icon\">✓</span>' + featureContent + '</div>';\n            }).join('');\n\n            mainContainer.innerHTML =\n                '<div class=\"header-section\">' +\n                    '<div class=\"upgrade-badge\">' +\n                        '<svg class=\"upgrade-badge-icon\" width=\"22\" height=\"22\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M3 10.5L2 4.5L5.5 7L8 3.5L10.5 7L14 4.5L13 10.5H3Z\" stroke=\"#222\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>' +\n                        '<span class=\"upgrade-badge-text\">' + (content.promoLabel || 'UPGRADE YOUR PLAN') + '</span>' +\n                    '</div>' +\n                    '<div class=\"header-content\">' +\n                        '<h1 class=\"main-title\">' + (content.mainTitle || 'More Tools. More Possibilities.') + '</h1>' +\n                        '<p class=\"subtitle\">' + (content.subtitle || 'All the Tools a World-Class Photographer needs') + '</p>' +\n                    '</div>' +\n                '</div>' +\n                '<div class=\"pricing-card\">' +\n                    '<div class=\"card-badge\">' + (cardConfig.badge || 'Most popular') + '</div>' +\n                    '<div class=\"card-content\">' +\n                        '<div class=\"plan-name\">' + planName + '</div>' +\n                        '<div class=\"price-section\">' +\n                            '<div class=\"price-display\">' +\n                                (originalPrice !== currentPrice ? '<span class=\"original-price\"><span class=\"currency\">' + currency + ' </span><span class=\"amount\">' + originalPrice + '</span></span>' : '') +\n                                '<span class=\"current-price\"><span class=\"currency\">' + currency + '</span><span class=\"amount\">' + currentPrice + '</span></span>' +\n                            '</div>' +\n                            '<div class=\"price-suffix\">' + (content.billingPeriodLabel || 'per month, billed yearly') + '</div>' +\n                        '</div>' +\n                        '<div class=\"cta-section\">' +\n                            '<button class=\"cta-button\" data-tier=\"' + targetTier + '\" data-plan=\"' + cardKey + '\" data-price=\"' + currentPrice + '\">' + (cardConfig.buttonLabel || 'UPGRADE') + '</button>' +\n                            (yearlySavings > 0 ? '<div class=\"savings-text\">' + savingsText + '</div>' : '') +\n                        '</div>' +\n                        '<div class=\"features-section\">' +\n                            '<p class=\"features-title\">' + (cardConfig.featuresTitle || 'Features:') + '</p>' +\n                            featuresHtml +\n                        '</div>' +\n                    '</div>' +\n                '</div>';\n\n            // Render FAQ section\n            const faqSection = document.getElementById('faq-section');\n            const faqs = content.faqs || [];\n            if (faqs.length > 0) {\n                const faqItemsHtml = faqs.map(function(faq, index) {\n                    return '<li class=\"faq-item\" data-index=\"' + index + '\">' +\n                        '<div class=\"faq-question\">' +\n                            '<p class=\"faq-question-text\">' + faq.question + '</p>' +\n                            '<span class=\"faq-icon\">+</span>' +\n                        '</div>' +\n                        '<div class=\"faq-answer\">' +\n                            '<p class=\"faq-answer-text\">' + faq.answer + '</p>' +\n                        '</div>' +\n                    '</li>';\n                }).join('');\n\n                faqSection.innerHTML =\n                    '<div class=\"faq-container\">' +\n                        '<h2 class=\"faq-title\">' + (content.faqTitle || 'FAQs') + '</h2>' +\n                        '<ul class=\"faq-list\">' + faqItemsHtml + '</ul>' +\n                    '</div>';\n                faqSection.style.display = 'block';\n\n                // Attach FAQ listeners\n                const faqItems = faqSection.querySelectorAll('.faq-item');\n                faqItems.forEach(function(item) {\n                    const question = item.querySelector('.faq-question');\n                    question.addEventListener('click', function() {\n                        item.classList.toggle('open');\n                        const index = parseInt(item.getAttribute('data-index'));\n                        const questionText = item.querySelector('.faq-question-text').textContent;\n                        const isOpen = item.classList.contains('open');\n                        window.myop_cta_handler('faq-toggled', {\n                            index: index,\n                            question: questionText,\n                            isOpen: isOpen\n                        });\n                    });\n                });\n            } else {\n                faqSection.style.display = 'none';\n            }\n\n            // Attach button listener\n            const ctaButton = mainContainer.querySelector('.cta-button');\n            if (ctaButton) {\n                ctaButton.addEventListener('click', function() {\n                    const tier = parseInt(ctaButton.getAttribute('data-tier'));\n                    const plan = ctaButton.getAttribute('data-plan');\n                    const price = parseInt(ctaButton.getAttribute('data-price'));\n                    window.myop_cta_handler('subscription-selected', {\n                        plan: plan,\n                        tier: tier,\n                        price: price\n                    });\n                });\n            }\n        }\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n        