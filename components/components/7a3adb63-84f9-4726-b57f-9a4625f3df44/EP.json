        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js\"></script>\n\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Font configuration\n     */\n    interface FontConfig {\n        /** Font identifier used for CSS variable naming (e.g., \"main\" -> --font_main) */\n        id: string;\n        /** Font family name */\n        family: string;\n        /** Font style (optional) */\n        style?: string;\n        /** Font weight (optional) */\n        weight?: number;\n        /** URL to the font CSS file */\n        url: string;\n    }\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n        /** URL of the mp4 video to preview */\n        videoUrl: string;\n        /** URL or base64 of the QR code image */\n        qrCodeUrl: string;\n        /** Number of times the video has been downloaded */\n        downloadCount: number;\n        /** Date when the video was created (ISO 8601 format) */\n        videoCreationDate: string;\n        /** Font configurations - the font with id \"main\" is the default */\n        fonts: FontConfig[];\n        /** Localized strings for UI text */\n        lang: {\n            title: string;\n            /** Title displayed on desktop when user has previously viewed */\n            titleReturning: string;\n            /** Title displayed on mobile devices */\n            mobileTitle: string;\n            description: string;\n            /** Description displayed on desktop when user has previously viewed */\n            descriptionReturning: string;\n            /** Description displayed on mobile devices */\n            mobileDescription: string;\n            downloadLink: string;\n            /** Label for share button shown on mobile devices */\n            shareButtonLabel: string;\n            closeConfirm: string;\n            videoError: string;\n        };\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n        /** Fired when user closes the modal */\n        'close-requested': void;\n        /** Fired when user clicks the download button */\n        'download-clicked': { videoUrl: string };\n        /** Fired when user clicks the share button (mobile) */\n        'share-clicked': { videoUrl: string };\n        /** Standard layout action - request container resize */\n        'size-requested': {\n            width?: number | null;\n            height?: number | null;\n            minWidth?: number | null;\n            maxWidth?: number | null;\n            minHeight?: number | null;\n            maxHeight?: number | null;\n            required?: boolean;\n        };\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        :root {\n            --font_main_family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;\n            --font_main_weight: 400;\n            --font_main_style: normal;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            font-family: var(--font_main_family);\n            font-weight: var(--font_main_weight);\n            font-style: var(--font_main_style);\n            background-color: white;\n            overflow: hidden;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n        }\n\n        .modal {\n            display: flex;\n            flex-direction: column;\n            width: 100%;\n            height: 100%;\n            background: #fff;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .modal-header {\n            padding: 32px 112px 0 32px;\n            min-height: 64px;\n            position: relative;\n        }\n\n        .modal-title {\n            font-size: 28px;\n            font-weight: 500;\n            color: #222;\n            line-height: 1.28;\n            margin: 0;\n            max-width: 390px;\n            min-height: 32px;\n            display: flex;\n            align-items: center;\n        }\n\n        .modal-title .desktop-title {\n            display: inline;\n        }\n\n        .modal-title .mobile-title {\n            display: none;\n        }\n\n        /* Mobile title in body - hidden on desktop */\n        .mobile-body-title {\n            display: none;\n        }\n\n        @media (max-width: 768px) {\n            .modal-title .desktop-title {\n                display: none;\n            }\n\n            .modal-title .mobile-title {\n                display: inline;\n            }\n\n            /* Hide header title on mobile, show body title */\n            .modal-header .modal-title {\n                display: none;\n            }\n\n            .mobile-body-title {\n                display: flex;\n                margin-bottom: 8px;\n                justify-content: center;\n                text-align: center;\n            }\n        }\n\n\n        .modal-body {\n            padding: 24px 32px 0 32px;\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            position: relative;\n            min-height: 0;\n        }\n\n        .content-wrapper {\n            display: flex;\n            gap: 0;\n            align-items: stretch;\n            flex: 1;\n            min-height: 0;\n        }\n\n        .left-content {\n            width: 442px;\n            flex-shrink: 0;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .description {\n            font-size: 16px;\n            font-weight: 400;\n            color: #222;\n            line-height: 1.42;\n            margin-bottom: 24px;\n            width: 355px;\n        }\n\n        .description .desktop-description {\n            display: inline;\n        }\n\n        .description .mobile-description {\n            display: none;\n        }\n\n        @media (max-width: 768px) {\n            .description .desktop-description {\n                display: none;\n            }\n\n            .description .mobile-description {\n                display: inline;\n            }\n        }\n\n        .description strong {\n            font-weight: 500;\n        }\n\n        .right-content {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            position: relative;\n            overflow: visible; /* Allow video to extend below the fold */\n        }\n\n        .video-container {\n            /* Desktop: 264x443 px proportions, width fills container */\n            width: 264px;\n            aspect-ratio: 264 / 443;\n            //background: #000;\n            border-radius: 28px 28px 0 0;\n            border: 1px solid #C9C9B8;\n            border-bottom: none;\n            overflow: visible;\n            position: absolute;\n            top: 0;\n            right: 32px;\n        }\n\n        /* Clip mask to hide bottom of video content but keep controls visible */\n        .video-clip-mask {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            overflow: hidden;\n            border-radius: 28px 28px 0 0;\n        }\n\n        video {\n            width: 100%;\n            height: 100%;\n            display: block;\n            object-fit: contain;\n            object-position: top center;\n            //background: #000;\n            border-radius: 0;\n        }\n\n        /* Custom controls overlay that stays in visible area */\n        .video-controls-overlay {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            right: 0;\n            height: 44px;\n            background: linear-gradient(transparent, rgba(0,0,0,0.8));\n            display: flex;\n            align-items: center;\n            padding: 0 6px;\n            gap: 2px;\n            z-index: 10;\n        }\n\n        .video-controls-overlay button {\n            background: transparent;\n            border: none;\n            color: white;\n            cursor: pointer;\n            padding: 4px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            flex-shrink: 0;\n        }\n\n        .video-controls-overlay button:hover {\n            opacity: 0.8;\n        }\n\n        .video-controls-overlay button svg {\n            width: 16px;\n            height: 16px;\n        }\n\n        /* Progress bar container */\n        .video-progress-container {\n            flex: 1;\n            display: flex;\n            align-items: center;\n            gap: 4px;\n            min-width: 0;\n            overflow: hidden;\n        }\n\n        .video-progress {\n            flex: 1;\n            height: 4px;\n            background: rgba(255,255,255,0.3);\n            border-radius: 2px;\n            cursor: pointer;\n            position: relative;\n            min-width: 0;\n        }\n\n        .video-progress-bar {\n            height: 100%;\n            background: #fff;\n            border-radius: 2px;\n            width: 0%;\n            transition: width 0.1s linear;\n        }\n\n        .video-progress:hover .video-progress-bar {\n            background: #4a9eff;\n        }\n\n        /* Time display */\n        .video-time {\n            color: white;\n            font-size: 10px;\n            font-family: var(--font_main_family);\n            white-space: nowrap;\n            flex-shrink: 0;\n            text-align: center;\n        }\n\n        /* Volume controls */\n        .volume-container {\n            display: flex;\n            align-items: center;\n            flex-shrink: 0;\n        }\n\n        .volume-slider {\n            display: none;\n        }\n\n        .volume-bar {\n            display: none;\n        }\n\n        /* Download link - shown on desktop only */\n        .download-link {\n            display: inline-block;\n            color: #222;\n            font-size: 16px;\n            font-family: var(--font_main_family);\n            font-weight: 500;\n            text-decoration: underline;\n            text-decoration-skip-ink: none;\n            cursor: pointer;\n            transition: color 0.2s;\n            margin-top: auto;\n            line-height: 1.42;\n            position: absolute;\n            bottom: 32px;\n            left: 32px;\n            background: none;\n            border: none;\n            padding: 0;\n        }\n\n        .download-link:hover {\n            color: #000;\n        }\n\n        @media (max-width: 768px) {\n            .download-link {\n                display: none;\n            }\n        }\n\n        /* Share button - shown on mobile only */\n        .share-button {\n            display: none;\n            padding: 12px 20px;\n            background: #222;\n            color: #fff;\n            font-size: 14px;\n            font-family: var(--font_main_family);\n            font-weight: 500;\n            border: none;\n            border-radius: 8px;\n            cursor: pointer;\n            transition: background-color 0.2s;\n            text-align: center;\n            text-decoration: none;\n            align-items: center;\n            gap: 8px;\n        }\n\n        .share-button:hover {\n            background: #000;\n        }\n\n        .share-button .share-icon {\n            display: none;\n            width: 16px;\n            height: 16px;\n        }\n\n        /* Show appropriate icon based on device (set by JavaScript) */\n        @media (max-width: 768px) {\n            .share-button {\n                display: inline-flex;\n            }\n\n            /* iOS device - show iOS icon */\n            body.is-ios .share-button .share-icon-ios {\n                display: inline-block;\n            }\n\n            /* Android device - show Android icon */\n            body.is-android .share-button .share-icon-android {\n                display: inline-block;\n            }\n\n            /* Fallback: if no device class, show iOS icon (default) */\n            body:not(.is-ios):not(.is-android) .share-button .share-icon-ios {\n                display: inline-block;\n            }\n        }\n\n        .qr-section {\n            display: flex;\n            flex-direction: row;\n            justify-content: flex-start;\n            align-items: flex-end;\n            margin-bottom: 24px;\n        }\n\n        .qr-section.hidden {\n            display: none;\n        }\n\n        @media (max-width: 768px) {\n            .qr-section {\n                display: none;\n            }\n        }\n\n        .qr-code {\n            width: 120px;\n            height: 120px;\n            flex-shrink: 0;\n        }\n\n        .qr-code img {\n            width: 100%;\n            height: 100%;\n            display: block;\n        }\n\n\n        .error {\n            color: #d32f2f;\n            padding: 16px;\n            background: #ffebee;\n            border-radius: 4px;\n            margin-bottom: 16px;\n            font-size: 14px;\n            display: none;\n        }\n\n        .error.visible {\n            display: block;\n        }\n\n        /* Video loading spinner */\n        .video-loader {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            //background: #000;\n            border-radius: 28px 28px 0 0;\n            z-index: 15;\n            transition: opacity 0.3s ease;\n        }\n\n        .video-loader.hidden {\n            opacity: 0;\n            pointer-events: none;\n        }\n\n        .spinner {\n            width: 48px;\n            height: 48px;\n        }\n\n        /* Mobile responsive layout */\n        @media (max-width: 768px) {\n            html, body {\n                height: 100%;\n                overflow: hidden;\n            }\n\n            #app-root {\n                height: 100%;\n                overflow: hidden;\n            }\n\n            .modal {\n                width: 100%;\n                height: 100%;\n                border: none;\n                border-radius: 0;\n                overflow: hidden;\n            }\n\n            .modal-header {\n                padding: 0;\n                min-height: 0;\n            }\n\n            .modal-title {\n                font-size: 22px;\n                font-weight: 500;\n                max-width: 100%;\n                padding: 0;\n            }\n\n            .modal-body {\n                padding: 24px 24px 0 24px;\n                flex: 1;\n                min-height: 0;\n            }\n\n            .content-wrapper {\n                flex-direction: column;\n                gap: 0;\n                height: 100%;\n            }\n\n            .left-content {\n                width: 100%;\n                order: 1;\n                flex-shrink: 0;\n                align-items: center;\n                text-align: center;\n            }\n\n            .right-content {\n                width: 100%;\n                order: 2;\n                position: relative;\n                margin-top: 44px;\n                flex: 1;\n                min-height: 0;\n                overflow: hidden;\n            }\n\n            .description {\n                width: 100%;\n                margin-bottom: 16px;\n                font-size: 16px;\n                line-height: 1.5;\n            }\n\n            .share-button {\n                width: 150px;\n                height: 44px;\n                min-width: auto;\n                max-width: none;\n                margin-bottom: 0;\n                justify-content: center;\n                border-radius: 0;\n                padding: 0;\n            }\n\n            .video-container {\n                position: absolute;\n                top: 0;\n                left: 50%;\n                transform: translateX(-50%);\n                bottom: 0;\n                width: 100%;\n                max-width: 300px;\n                aspect-ratio: unset;\n                border-radius: 28px 28px 0 0;\n                border: 1px solid #C9C9B8;\n                border-bottom: none;\n                box-shadow: none;\n            }\n\n            .video-clip-mask {\n                border-radius: 28px 28px 0 0;\n            }\n\n            .video-loader {\n                bottom: 0;\n                border-radius: 28px 28px 0 0;\n            }\n\n            video {\n                height: 100%;\n                object-fit: contain;\n                object-position: center top;\n                border-radius: 28px 28px 0 0;\n            }\n\n            /* Show custom controls on mobile */\n            .video-controls-overlay {\n                display: flex;\n            }\n\n            /* Video area fits to bottom of screen */\n            .right-content {\n                overflow: visible;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\">\n        <div class=\"modal\">\n            <div class=\"modal-header\">\n                <h1 class=\"modal-title\" id=\"modalTitle\">\n                    <span class=\"desktop-title\" id=\"desktopTitle\"></span>\n                    <span class=\"mobile-title\" id=\"mobileTitle\"></span>\n                </h1>\n            </div>\n\n            <div class=\"modal-body\">\n                <div id=\"errorMessage\" class=\"error\"></div>\n\n                <!-- Mobile title - shown inside body on mobile -->\n                <h1 class=\"modal-title mobile-body-title\" id=\"mobileTitleBody\">\n                    <span class=\"mobile-title\" id=\"mobileTitleInBody\"></span>\n                </h1>\n\n                <div class=\"content-wrapper\">\n                    <div class=\"left-content\">\n                        <p class=\"description\" id=\"description\">\n                            <span class=\"desktop-description\" id=\"desktopDescription\"></span>\n                            <span class=\"mobile-description\" id=\"mobileDescription\"></span>\n                        </p>\n\n                        <div class=\"qr-section hidden\" id=\"qrSection\">\n                            <div class=\"qr-code\">\n                                <img id=\"qrCodeImage\" alt=\"QR Code\">\n                            </div>\n                        </div>\n\n                        <!-- Download link - shown on desktop -->\n                        <button class=\"download-link\" id=\"downloadLink\" type=\"button\"></button>\n\n                        <!-- Share button - shown on mobile only -->\n                        <button class=\"share-button\" id=\"shareButton\" type=\"button\">\n                            <!-- iOS share icon (square with arrow up) -->\n                            <svg class=\"share-icon share-icon-ios\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                <path d=\"M8 1.5V10\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n                                <path d=\"M5 4.5L8 1.5L11 4.5\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M3 8V13C3 13.5523 3.44772 14 4 14H12C12.5523 14 13 13.5523 13 13V8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n                            </svg>\n                            <!-- Android share icon (three connected dots) -->\n                            <svg class=\"share-icon share-icon-android\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                <circle cx=\"12\" cy=\"3\" r=\"2\" stroke=\"currentColor\" stroke-width=\"1.5\"/>\n                                <circle cx=\"12\" cy=\"13\" r=\"2\" stroke=\"currentColor\" stroke-width=\"1.5\"/>\n                                <circle cx=\"4\" cy=\"8\" r=\"2\" stroke=\"currentColor\" stroke-width=\"1.5\"/>\n                                <path d=\"M5.5 7L10.5 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n                                <path d=\"M5.5 9L10.5 12\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n                            </svg>\n                            <span id=\"shareButtonText\"></span>\n                        </button>\n                    </div>\n\n                    <div class=\"right-content\">\n                        <div class=\"video-container\">\n                            <div class=\"video-loader\" id=\"videoLoader\">\n                                <div class=\"spinner\" id=\"lottieSpinner\"></div>\n                            </div>\n                            <div class=\"video-clip-mask\">\n                                <video id=\"videoPlayer\" controlsList=\"nodownload\" autoplay muted playsinline>\n                                    <source id=\"videoSource\" type=\"video/mp4\">\n                                </video>\n                            </div>\n                            <div class=\"video-controls-overlay\" id=\"videoControlsOverlay\">\n                                <!-- Play/Pause button -->\n                                <button class=\"play-pause-btn\" id=\"playPauseBtn\" aria-label=\"Play/Pause\">\n                                    <svg class=\"play-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                                        <path d=\"M8 5v14l11-7z\"/>\n                                    </svg>\n                                    <svg class=\"pause-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\" style=\"display: none;\">\n                                        <path d=\"M6 4h4v16H6V4zm8 0h4v16h-4V4z\"/>\n                                    </svg>\n                                </button>\n\n                                <!-- Progress bar and time -->\n                                <div class=\"video-progress-container\">\n                                    <div class=\"video-progress\" id=\"videoProgress\">\n                                        <div class=\"video-progress-bar\" id=\"videoProgressBar\"></div>\n                                    </div>\n                                    <span class=\"video-time\" id=\"videoTime\">0:00 / 0:00</span>\n                                </div>\n\n                                <!-- Volume controls -->\n                                <div class=\"volume-container\">\n                                    <button class=\"volume-btn\" id=\"volumeBtn\" aria-label=\"Mute/Unmute\">\n                                        <svg class=\"volume-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                                            <path d=\"M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z\"/>\n                                        </svg>\n                                        <svg class=\"mute-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\" style=\"display: none;\">\n                                            <path d=\"M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z\"/>\n                                        </svg>\n                                    </button>\n                                    <div class=\"volume-slider\" id=\"volumeSlider\">\n                                        <div class=\"volume-bar\" id=\"volumeBar\"></div>\n                                    </div>\n                                </div>\n\n                                <!-- Fullscreen button -->\n                                <button class=\"fullscreen-btn\" id=\"fullscreenBtn\" aria-label=\"Fullscreen\">\n                                    <svg class=\"expand-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                                        <path d=\"M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z\"/>\n                                    </svg>\n                                    <svg class=\"compress-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\" style=\"display: none;\">\n                                        <path d=\"M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z\"/>\n                                    </svg>\n                                </button>\n                            </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        // Detect device type and add class to body\n        function detectDevice() {\n            const ua = navigator.userAgent || navigator.vendor || window.opera;\n\n            // Check for iOS devices (iPhone, iPad, iPod)\n            if (/iPad|iPhone|iPod/.test(ua) && !window.MSStream) {\n                document.body.classList.add('is-ios');\n                return 'ios';\n            }\n\n            // Check for Android devices\n            if (/android/i.test(ua)) {\n                document.body.classList.add('is-android');\n                return 'android';\n            }\n\n            // Default fallback (will show iOS icon via CSS)\n            return 'other';\n        }\n\n        // Run device detection immediately\n        detectDevice();\n\n        // Initialize Lottie spinner animation\n        var spinnerAnimation = lottie.loadAnimation({\n            container: document.getElementById('lottieSpinner'),\n            renderer: 'svg',\n            loop: true,\n            autoplay: true,\n            animationData: {\"v\":\"5.10.2\",\"fr\":60,\"ip\":0,\"op\":150,\"w\":48,\"h\":48,\"nm\":\"MASTER-48X48\",\"ddd\":0,\"assets\":[],\"layers\":[{\"ddd\":0,\"ind\":1,\"ty\":3,\"nm\":\"CONTROLLER\",\"sr\":1,\"ks\":{\"o\":{\"a\":0,\"k\":0,\"ix\":11},\"r\":{\"a\":1,\"k\":[{\"i\":{\"x\":[0.833],\"y\":[0.833]},\"o\":{\"x\":[0.167],\"y\":[0.167]},\"t\":0,\"s\":[-26]},{\"t\":149,\"s\":[345]}],\"ix\":10},\"p\":{\"a\":0,\"k\":[24,24,0],\"ix\":2,\"l\":2},\"a\":{\"a\":0,\"k\":[0,0,0],\"ix\":1,\"l\":2},\"s\":{\"a\":0,\"k\":[92,92,100],\"ix\":6,\"l\":2}},\"ao\":0,\"ip\":1,\"op\":150,\"st\":1,\"bm\":0},{\"ddd\":0,\"ind\":2,\"ty\":4,\"nm\":\"STROKE2\",\"parent\":1,\"sr\":1,\"ks\":{\"o\":{\"a\":0,\"k\":100,\"ix\":11},\"r\":{\"a\":0,\"k\":26.848,\"ix\":10},\"p\":{\"a\":0,\"k\":[0,0,0],\"ix\":2,\"l\":2},\"a\":{\"a\":0,\"k\":[0,0,0],\"ix\":1,\"l\":2},\"s\":{\"a\":0,\"k\":[100,100,100],\"ix\":6,\"l\":2}},\"ao\":0,\"shapes\":[{\"ty\":\"gr\",\"it\":[{\"d\":1,\"ty\":\"el\",\"s\":{\"a\":0,\"k\":[48,48],\"ix\":2},\"p\":{\"a\":0,\"k\":[0,0],\"ix\":3},\"nm\":\"Ellipse Path 1\",\"mn\":\"ADBE Vector Shape - Ellipse\",\"hd\":false},{\"ty\":\"st\",\"c\":{\"a\":0,\"k\":[0.6,0.6,0.6,1],\"ix\":3},\"o\":{\"a\":0,\"k\":100,\"ix\":4},\"w\":{\"a\":0,\"k\":4,\"ix\":5},\"lc\":2,\"lj\":1,\"ml\":4,\"bm\":0,\"nm\":\"Stroke 1\",\"cl\":\"pt-loader__stroke\",\"mn\":\"ADBE Vector Graphic - Stroke\",\"hd\":false},{\"ty\":\"tr\",\"p\":{\"a\":0,\"k\":[0,0],\"ix\":2},\"a\":{\"a\":0,\"k\":[0,0],\"ix\":1},\"s\":{\"a\":0,\"k\":[100,100],\"ix\":3},\"r\":{\"a\":0,\"k\":0,\"ix\":6},\"o\":{\"a\":0,\"k\":100,\"ix\":7},\"sk\":{\"a\":0,\"k\":0,\"ix\":4},\"sa\":{\"a\":0,\"k\":0,\"ix\":5},\"nm\":\"Transform\"}],\"nm\":\"Ellipse 1\",\"np\":3,\"cix\":2,\"bm\":0,\"ix\":1,\"mn\":\"ADBE Vector Group\",\"hd\":false},{\"ty\":\"tm\",\"s\":{\"a\":1,\"k\":[{\"i\":{\"x\":[0.405],\"y\":[1]},\"o\":{\"x\":[0.58],\"y\":[0]},\"t\":66,\"s\":[3]},{\"t\":126.654296875,\"s\":[100]}],\"ix\":1},\"e\":{\"a\":1,\"k\":[{\"i\":{\"x\":[0.374],\"y\":[1]},\"o\":{\"x\":[0.614],\"y\":[0]},\"t\":77,\"s\":[0]},{\"t\":149,\"s\":[97]}],\"ix\":2},\"o\":{\"a\":0,\"k\":0,\"ix\":3},\"m\":1,\"ix\":2,\"nm\":\"Trim Paths 1\",\"mn\":\"ADBE Vector Filter - Trim\",\"hd\":false}],\"ip\":66,\"op\":152,\"st\":66,\"ct\":1,\"bm\":0},{\"ddd\":0,\"ind\":3,\"ty\":4,\"nm\":\"STROKE1\",\"parent\":1,\"sr\":1,\"ks\":{\"o\":{\"a\":0,\"k\":100,\"ix\":11},\"r\":{\"a\":0,\"k\":26.848,\"ix\":10},\"p\":{\"a\":0,\"k\":[0,0,0],\"ix\":2,\"l\":2},\"a\":{\"a\":0,\"k\":[0,0,0],\"ix\":1,\"l\":2},\"s\":{\"a\":0,\"k\":[100,100,100],\"ix\":6,\"l\":2}},\"ao\":0,\"shapes\":[{\"ty\":\"gr\",\"it\":[{\"d\":1,\"ty\":\"el\",\"s\":{\"a\":0,\"k\":[48,48],\"ix\":2},\"p\":{\"a\":0,\"k\":[0,0],\"ix\":3},\"nm\":\"Ellipse Path 1\",\"mn\":\"ADBE Vector Shape - Ellipse\",\"hd\":false},{\"ty\":\"st\",\"c\":{\"a\":0,\"k\":[0.6,0.6,0.6,1],\"ix\":3},\"o\":{\"a\":0,\"k\":100,\"ix\":4},\"w\":{\"a\":0,\"k\":4,\"ix\":5},\"lc\":2,\"lj\":1,\"ml\":4,\"bm\":0,\"nm\":\"Stroke 1\",\"cl\":\"pt-loader__stroke\",\"mn\":\"ADBE Vector Graphic - Stroke\",\"hd\":false},{\"ty\":\"tr\",\"p\":{\"a\":0,\"k\":[0,0],\"ix\":2},\"a\":{\"a\":0,\"k\":[0,0],\"ix\":1},\"s\":{\"a\":0,\"k\":[100,100],\"ix\":3},\"r\":{\"a\":0,\"k\":0,\"ix\":6},\"o\":{\"a\":0,\"k\":100,\"ix\":7},\"sk\":{\"a\":0,\"k\":0,\"ix\":4},\"sa\":{\"a\":0,\"k\":0,\"ix\":5},\"nm\":\"Transform\"}],\"nm\":\"Ellipse 1\",\"np\":3,\"cix\":2,\"bm\":0,\"ix\":1,\"mn\":\"ADBE Vector Group\",\"hd\":false},{\"ty\":\"tm\",\"s\":{\"a\":1,\"k\":[{\"i\":{\"x\":[0.405],\"y\":[1]},\"o\":{\"x\":[0.58],\"y\":[0]},\"t\":0,\"s\":[3]},{\"t\":60.654296875,\"s\":[100]}],\"ix\":1},\"e\":{\"a\":1,\"k\":[{\"i\":{\"x\":[0.374],\"y\":[1]},\"o\":{\"x\":[0.614],\"y\":[0]},\"t\":11,\"s\":[0]},{\"t\":86.861328125,\"s\":[97]}],\"ix\":2},\"o\":{\"a\":0,\"k\":0,\"ix\":3},\"m\":1,\"ix\":2,\"nm\":\"Trim Paths 1\",\"mn\":\"ADBE Vector Filter - Trim\",\"hd\":false}],\"ip\":0,\"op\":86,\"st\":0,\"ct\":1,\"bm\":0}],\"markers\":[]}\n        });\n\n        // Private state\n        let currentState = null;\n        const loadedFonts = new Set();\n\n        // DOM references (cached after first render)\n        const elements = {\n            appRoot: document.getElementById('app-root'),\n            modalTitle: document.getElementById('modalTitle'),\n            desktopTitle: document.getElementById('desktopTitle'),\n            mobileTitle: document.getElementById('mobileTitle'),\n            mobileTitleInBody: document.getElementById('mobileTitleInBody'),\n            description: document.getElementById('description'),\n            desktopDescription: document.getElementById('desktopDescription'),\n            mobileDescription: document.getElementById('mobileDescription'),\n            videoPlayer: document.getElementById('videoPlayer'),\n            videoSource: document.getElementById('videoSource'),\n            downloadLink: document.getElementById('downloadLink'),\n            qrSection: document.getElementById('qrSection'),\n            qrCodeImage: document.getElementById('qrCodeImage'),\n            errorMessage: document.getElementById('errorMessage'),\n            videoLoader: document.getElementById('videoLoader'),\n            shareButton: document.getElementById('shareButton'),\n            shareButtonText: document.getElementById('shareButtonText'),\n            playPauseBtn: document.getElementById('playPauseBtn'),\n            playIcon: document.querySelector('.play-icon'),\n            pauseIcon: document.querySelector('.pause-icon'),\n            videoProgress: document.getElementById('videoProgress'),\n            videoProgressBar: document.getElementById('videoProgressBar'),\n            videoTime: document.getElementById('videoTime'),\n            volumeBtn: document.getElementById('volumeBtn'),\n            volumeIcon: document.querySelector('.volume-icon'),\n            muteIcon: document.querySelector('.mute-icon'),\n            volumeSlider: document.getElementById('volumeSlider'),\n            volumeBar: document.getElementById('volumeBar'),\n            fullscreenBtn: document.getElementById('fullscreenBtn'),\n            expandIcon: document.querySelector('.expand-icon'),\n            compressIcon: document.querySelector('.compress-icon'),\n            videoContainer: document.querySelector('.video-container')\n        };\n\n        // Load fonts and set CSS variables\n        function loadFonts(fonts) {\n            if (!fonts || !Array.isArray(fonts)) return;\n\n            const root = document.documentElement;\n\n            fonts.forEach(function(font) {\n                // Load font CSS if not already loaded\n                if (font.url && !loadedFonts.has(font.url)) {\n                    const link = document.createElement('link');\n                    link.rel = 'stylesheet';\n                    link.href = font.url;\n                    document.head.appendChild(link);\n                    loadedFonts.add(font.url);\n                }\n\n                // Set CSS variables for this font\n                const varPrefix = '--font_' + font.id;\n                root.style.setProperty(varPrefix + '_family', font.family);\n\n                if (font.weight !== undefined) {\n                    root.style.setProperty(varPrefix + '_weight', font.weight);\n                }\n\n                if (font.style !== undefined) {\n                    root.style.setProperty(varPrefix + '_style', font.style);\n                }\n            });\n        }\n\n        // Render function\n        function render(data) {\n            currentState = data;\n\n            // Load fonts from config\n            loadFonts(data.fonts);\n\n            // Set text content from lang DTO\n            // Use returning text for desktop if download count > 2\n            if (data.downloadCount > 2) {\n                elements.desktopTitle.textContent = data.lang.titleReturning;\n                elements.desktopDescription.innerHTML = data.lang.descriptionReturning;\n            } else {\n                elements.desktopTitle.textContent = data.lang.title;\n                elements.desktopDescription.innerHTML = data.lang.description;\n            }\n            elements.mobileTitle.textContent = data.lang.mobileTitle;\n            elements.mobileTitleInBody.textContent = data.lang.mobileTitle;\n            elements.mobileDescription.innerHTML = data.lang.mobileDescription;\n            elements.downloadLink.textContent = data.lang.downloadLink;\n\n            // Store video URL for download handler\n            elements.downloadLink.dataset.videoUrl = data.videoUrl;\n\n            // Set share button (mobile)\n            elements.shareButtonText.textContent = data.lang.shareButtonLabel;\n\n            // Set video source and show loader\n            elements.videoLoader.classList.remove('hidden');\n            elements.videoSource.src = data.videoUrl;\n            elements.videoPlayer.load();\n\n            // Show QR section if provided\n            if (data.qrCodeUrl) {\n                elements.qrSection.classList.remove('hidden');\n                elements.qrCodeImage.src = data.qrCodeUrl;\n            } else {\n                elements.qrSection.classList.add('hidden');\n            }\n\n            // Clear any previous errors\n            elements.errorMessage.classList.remove('visible');\n        }\n\n        // Show error\n        function showError(message) {\n            elements.errorMessage.textContent = message;\n            elements.errorMessage.classList.add('visible');\n        }\n\n        // Event handlers - download link\n        elements.downloadLink.addEventListener('click', function() {\n            if (currentState) {\n                window.myop_cta_handler('download-clicked', {\n                    videoUrl: currentState.videoUrl\n                });\n            }\n        });\n\n        // Event handlers - share button (mobile)\n        elements.shareButton.addEventListener('click', function() {\n            if (currentState) {\n                window.myop_cta_handler('share-clicked', {\n                    videoUrl: currentState.videoUrl\n                });\n            }\n        });\n\n\n        // Hide loader when video can play\n        elements.videoPlayer.addEventListener('canplay', function() {\n            elements.videoLoader.classList.add('hidden');\n        });\n\n        // Custom play/pause button handler\n        function updatePlayPauseIcon() {\n            if (elements.videoPlayer.paused) {\n                elements.playIcon.style.display = 'block';\n                elements.pauseIcon.style.display = 'none';\n            } else {\n                elements.playIcon.style.display = 'none';\n                elements.pauseIcon.style.display = 'block';\n            }\n        }\n\n        elements.playPauseBtn.addEventListener('click', function() {\n            if (elements.videoPlayer.paused) {\n                elements.videoPlayer.play();\n            } else {\n                elements.videoPlayer.pause();\n            }\n        });\n\n        elements.videoPlayer.addEventListener('play', updatePlayPauseIcon);\n        elements.videoPlayer.addEventListener('pause', updatePlayPauseIcon);\n\n        // Format time helper\n        function formatTime(seconds) {\n            var mins = Math.floor(seconds / 60);\n            var secs = Math.floor(seconds % 60);\n            return mins + ':' + (secs < 10 ? '0' : '') + secs;\n        }\n\n        // Progress bar update\n        elements.videoPlayer.addEventListener('timeupdate', function() {\n            var current = elements.videoPlayer.currentTime;\n            var duration = elements.videoPlayer.duration || 0;\n            var percent = duration ? (current / duration) * 100 : 0;\n            elements.videoProgressBar.style.width = percent + '%';\n            elements.videoTime.textContent = formatTime(current) + ' / ' + formatTime(duration);\n        });\n\n        elements.videoPlayer.addEventListener('loadedmetadata', function() {\n            var duration = elements.videoPlayer.duration || 0;\n            elements.videoTime.textContent = '0:00 / ' + formatTime(duration);\n        });\n\n        // Progress bar click to seek\n        elements.videoProgress.addEventListener('click', function(e) {\n            var rect = elements.videoProgress.getBoundingClientRect();\n            var percent = (e.clientX - rect.left) / rect.width;\n            elements.videoPlayer.currentTime = percent * elements.videoPlayer.duration;\n        });\n\n        // Volume button (mute/unmute)\n        function updateVolumeIcon() {\n            if (elements.videoPlayer.muted || elements.videoPlayer.volume === 0) {\n                elements.volumeIcon.style.display = 'none';\n                elements.muteIcon.style.display = 'block';\n                elements.volumeBar.style.width = '0%';\n            } else {\n                elements.volumeIcon.style.display = 'block';\n                elements.muteIcon.style.display = 'none';\n                elements.volumeBar.style.width = (elements.videoPlayer.volume * 100) + '%';\n            }\n        }\n\n        elements.volumeBtn.addEventListener('click', function() {\n            elements.videoPlayer.muted = !elements.videoPlayer.muted;\n            updateVolumeIcon();\n        });\n\n        // Volume slider\n        elements.volumeSlider.addEventListener('click', function(e) {\n            var rect = elements.volumeSlider.getBoundingClientRect();\n            var percent = (e.clientX - rect.left) / rect.width;\n            percent = Math.max(0, Math.min(1, percent));\n            elements.videoPlayer.volume = percent;\n            elements.videoPlayer.muted = false;\n            updateVolumeIcon();\n        });\n\n        elements.videoPlayer.addEventListener('volumechange', updateVolumeIcon);\n\n        // Fullscreen button\n        function updateFullscreenIcon() {\n            var isFullscreen = document.fullscreenElement || document.webkitFullscreenElement;\n            if (isFullscreen) {\n                elements.expandIcon.style.display = 'none';\n                elements.compressIcon.style.display = 'block';\n            } else {\n                elements.expandIcon.style.display = 'block';\n                elements.compressIcon.style.display = 'none';\n            }\n        }\n\n        elements.fullscreenBtn.addEventListener('click', function() {\n            if (document.fullscreenElement || document.webkitFullscreenElement) {\n                if (document.exitFullscreen) {\n                    document.exitFullscreen();\n                } else if (document.webkitExitFullscreen) {\n                    document.webkitExitFullscreen();\n                }\n            } else {\n                var container = elements.videoContainer;\n                if (container.requestFullscreen) {\n                    container.requestFullscreen();\n                } else if (container.webkitRequestFullscreen) {\n                    container.webkitRequestFullscreen();\n                }\n            }\n        });\n\n        document.addEventListener('fullscreenchange', updateFullscreenIcon);\n        document.addEventListener('webkitfullscreenchange', updateFullscreenIcon);\n\n        // Initialize volume icon state\n        updateVolumeIcon();\n\n        elements.videoPlayer.addEventListener('error', function() {\n            elements.videoLoader.classList.add('hidden');\n            if (currentState && currentState.lang.videoError) {\n                showError(currentState.lang.videoError);\n            }\n        });\n\n        // Keyboard accessibility\n        document.addEventListener('keydown', function(e) {\n            if (e.key === 'Escape') {\n                window.myop_cta_handler('close-requested', undefined);\n            }\n        });\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n            console.log('CTA Handler:', action_id, payload);\n        };\n    })();\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            videoUrl: 'https://www.w3schools.com/html/mov_bbb.mp4',\n            qrCodeUrl: 'https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=https://example.com/download-video',\n            downloadCount: 0,\n            videoCreationDate: '2024-01-15T14:30:00Z',\n            fonts: [\n                {\n                    id: 'main',\n                    family: 'TT Norms Pro',\n                    style: 'normal',\n                    weight: 400,\n                    url: 'https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css'\n                }\n            ],\n            lang: {\n                title: 'Time to show off!',\n                titleReturning: 'Share gallery preview',\n                mobileTitle: 'Gallery Preview Video',\n                description: 'We\\'ve made a <strong>scroll-through video of your gallery</strong> to post on social media. Scan the QR&nbsp;code to download the video to your mobile device.',\n                descriptionReturning: 'Your gallery preview video is ready to post on social media.',\n                mobileDescription: 'The scroll-through video of your gallery is ready to post.',\n                downloadLink: 'Download video',\n                shareButtonLabel: 'Share',\n                closeConfirm: 'Are you sure you want to close?',\n                videoError: 'Unable to load video. Please try again later.'\n            }\n        });\n    </script>\n</body>\n</html>\n"
        }
      }
