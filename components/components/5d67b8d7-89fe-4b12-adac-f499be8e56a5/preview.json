        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <title>Upload Loading</title>\n\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    interface MyopFont {\n        /** Font identifier used for CSS variable naming, e.g. \"main\" → --font_main */\n        id: string;\n        /** Font family name */\n        family: string;\n        /** Optional font style (e.g. \"normal\", \"italic\") */\n        style?: string;\n        /** Optional font weight (e.g. 400, 700) */\n        weight?: number;\n        /** URL to the font CSS file to load */\n        url: string;\n    }\n\n    interface MyopConfig {\n        fonts: MyopFont[];\n    }\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n        config?: MyopConfig;\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n        // No actions - this is a passive loading indicator\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        html, body {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n        }\n\n        body {\n            background: white;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .loading-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 32px;\n        }\n\n        .gentle-loader {\n            width: 24px;\n            height: 24px;\n            border: 2px solid #444444;\n            border-top: 2px solid #ffffff;\n            border-radius: 50%;\n            animation: ring-rotate 1.5s linear infinite;\n        }\n\n        .loading-text {\n            font-family: var(--font_main, sans-serif);\n            font-size: 16px;\n            font-style: var(--font_main_style, normal);\n            font-weight: var(--font_main_weight, normal);\n            line-height: 150%;\n            color: #444;\n            text-align: center;\n            letter-spacing: 0.2px;\n        }\n\n        .loading-text p {\n            margin-bottom: 0;\n        }\n\n        @keyframes ring-rotate {\n            0% { transform: rotate(0deg); }\n            100% { transform: rotate(360deg); }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\">\n        <div class=\"loading-container\">\n            <div class=\"gentle-loader\"></div>\n\n            <div class=\"loading-text\">\n                <p>Items uploading...</p>\n                <p>Preparing gallery preview</p>\n            </div>\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        var currentState = {};\n        var loadedFontUrls = {};\n\n        function applyFonts(fonts) {\n            if (!fonts || !fonts.length) return;\n            var root = document.documentElement;\n            fonts.forEach(function(font) {\n                var varPrefix = '--font_' + font.id;\n                root.style.setProperty(varPrefix, font.family);\n                if (font.style) {\n                    root.style.setProperty(varPrefix + '_style', font.style);\n                }\n                if (font.weight != null) {\n                    root.style.setProperty(varPrefix + '_weight', String(font.weight));\n                }\n                // Load font CSS if not already loaded\n                if (font.url && !loadedFontUrls[font.url]) {\n                    loadedFontUrls[font.url] = true;\n                    var link = document.createElement('link');\n                    link.rel = 'stylesheet';\n                    link.href = font.url;\n                    document.head.appendChild(link);\n                }\n            });\n        }\n\n        // Public API exposed to window\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            currentState = data;\n            if (data.config && data.config.fonts) {\n                applyFonts(data.config.fonts);\n            }\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n        };\n    })();\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            config: {\n                fonts: [\n                    {\n                        id: \"main\",\n                        family: \"tt_norms_pro\",\n                        style: \"normal\",\n                        weight: 400,\n                        url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n                    }\n                ]\n            }\n        });\n    </script>\n</body>\n</html>"
        }
      }
    ]
