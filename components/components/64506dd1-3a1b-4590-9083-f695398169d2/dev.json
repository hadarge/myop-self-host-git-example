          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n<title>Pic-Time 2.0 Feature Slide</title>\n\n<script type=\"myop/types\">\ninterface MyopInitData {\n  videoSrc?: string;\n}\ninterface MyopCtaPayloads {\n  'close_screenTakeover': void;\n}\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(action: K, payload: MyopCtaPayloads[K]): void;\n</script>\n\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --font-main: 'TT Norms Pro', 'Helvetica Neue', Arial, sans-serif;\n    --color-lavender: #e5e0ed;\n    --color-text-dark: #210036;\n    --color-text: #2d2d2d;\n  }\n\n  html, body {\n    width: 100%;\n    height: 100%;\n    margin: 0;\n    overflow: hidden;\n    background: var(--color-lavender);\n    font-family: var(--font-main);\n  }\n\n  #app-root {\n    position: relative;\n    width: 100%;\n    height: 100%;\n  }\n\n  .slide-content {\n    position: relative;\n    width: 100%;\n    height: 100%;\n  }\n\n  /* ── Text Content ── */\n  .feature-header {\n    position: absolute;\n    top: 104px;\n    left: 120px;\n    right: 120px;\n  }\n\n  .feature-title {\n    font-weight: 300;\n    font-size: clamp(28px, 4.17vw, 60px);\n    line-height: 1.3;\n    color: var(--color-text-dark);\n    margin-bottom: 0.3em;\n  }\n\n  .feature-subtitle {\n    font-weight: 300;\n    font-size: clamp(16px, 2.22vw, 32px);\n    line-height: 1.3;\n    color: var(--color-text-dark);\n  }\n\n  /* ── Video/Image Frame ── */\n  .video-frame {\n    position: absolute;\n    left: 50%;\n    transform: translateX(-50%);\n    top: 32.6%;\n    bottom: 255px;\n    width: 57.8%;\n    overflow: hidden;\n    border-radius: 2px;\n    background: #d8d3e3;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .video-frame video {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  /* ── Arrow ── */\n  .arrow-wrap {\n    position: absolute;\n    right: 120px;\n    bottom: 120px;\n    display: inline-flex;\n    cursor: pointer;\n    padding: 20px 0 20px 20px;\n  }\n\n  .arrow-svg {\n    display: block;\n    width: 236.5px;\n    height: 22.1px;\n    clip-path: inset(0 0 0 96.5px);\n    transition: clip-path 0.45s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .arrow-wrap:hover .arrow-svg {\n    clip-path: inset(0 0 0 0px);\n  }\n</style>\n</head>\n<body>\n\n<div id=\"app-root\">\n  <div class=\"slide-content\">\n    <div class=\"feature-header\">\n      <h2 class=\"feature-title\">Limitless creative control</h2>\n      <p class=\"feature-subtitle\">Customize every detail of your gallery – your way.</p>\n    </div>\n\n    <div class=\"video-frame\">\n      <video id=\"slide-video\" autoplay muted loop playsinline>\n        <source src=\"./uploads/Design_MP4.mp4\" type=\"video/mp4\">\n      </video>\n    </div>\n\n    <div class=\"arrow-wrap\" role=\"button\" tabindex=\"0\" aria-label=\"Next slide\" id=\"arrow-btn\">\n      <svg class=\"arrow-svg\" viewBox=\"0 0 237 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <line x1=\"0\" y1=\"12\" x2=\"224\" y2=\"12\" stroke=\"#2d2d2d\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n        <polyline points=\"214,2 225,12 214,22\" stroke=\"#2d2d2d\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/>\n      </svg>\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  var currentState = {};\n\n  function handleNextSlide() {\n    console.log('[myop] close_screenTakeover');\n    window.myop_cta_handler('close_screenTakeover', undefined);\n  }\n\n  var arrowBtn = document.getElementById('arrow-btn');\n  arrowBtn.addEventListener('click', handleNextSlide);\n  arrowBtn.addEventListener('keydown', function(e) {\n    if (e.key === 'Enter' || e.key === ' ') {\n      e.preventDefault();\n      handleNextSlide();\n    }\n  });\n\n  window.myop_init_interface = function(data) {\n    if (!data) return currentState;\n    currentState = data;\n    if (data.videoSrc) {\n      var video = document.getElementById('slide-video');\n      video.src = data.videoSrc;\n    }\n  };\n\n  window.myop_cta_handler = function(action_id, payload) {\n    // overridden by host\n  };\n})();\n</script>\n\n<script id=\"myop_preview\">\n  window.myop_init_interface({});\n</script>\n\n</body>\n</html>\n"
