4C1.96832 4.75618 1.96832 5.46882 2.40766 5.90816L2.88496 5.43086ZM2.88496 4.79414L3.36226 5.27144L5.27144 3.36226L4.79414 2.88496L4.31684 2.40766L2.40766 4.31684L2.88496 4.79414ZM4.79414 2.88496L5.27121 3.36248C5.18363 3.44998 5.0417 3.4504 4.95356 3.36226L5.43086 2.88496L5.90816 2.40766C5.46864 1.96815 4.75615 1.96878 4.31707 2.40744L4.79414 2.88496ZM5.43086 2.88496L4.95356 3.36226L6.68696 5.09566L7.16426 4.61836L7.64156 4.14106L5.90816 2.40766L5.43086 2.88496ZM7.16426 4.61836L7.52422 5.18937C8.2217 4.74967 8.99705 4.42374 9.82548 4.23558L9.67598 3.57734L9.52647 2.91911C8.5466 3.14167 7.6292 3.52732 6.80429 4.04735L7.16426 4.61836ZM9.67598 3.57734H10.351V1.1252H9.67598H9.00098V3.57734H9.67598ZM9.67598 1.1252H10.351C10.351 1.24946 10.2504 1.35 10.1262 1.35V0.675V0C9.50485 0 9.00098 0.503875 9.00098 1.1252H9.67598ZM10.1262 0.675V1.35H12.8264V0.675V0H10.1262V0.675Z\"\n                                fill=\"#222222\" />\n                            <circle cx=\"11.4756\" cy=\"11.4727\" r=\"2.7\" stroke=\"#222222\" stroke-linecap=\"round\"\n                                stroke-width=\"1.35\" />\n                        </g>\n                    </svg>\n                </div>\n                <span class=\"menu-text\" data-lang-key=\"settingsLogo\">Settings</span>\n                <span class=\"tooltip-text\" data-tooltip-key=\"settingsTooltip\">Settings</span>\n            </a>\n        </div>\n\n        <!-- Bottom navigation items -->\n        <div class=\"sidebar-bottom\">\n\n            <!-- Menu Item: Help Center -->\n            <a href=\"#\" class=\"menu-item\" data-action=\"help\" data-lang-key=\"helpLogo\" data-tooltip-key=\"helpTooltip\">\n                <div class=\"menu-icon icon-composite\">\n                    <!-- Circle SVG - UPDATED -->\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" fill=\"none\"\n                        preserveAspectRatio=\"xMidYMid meet\">\n                        <circle cx=\"18\" cy=\"18\" r=\"17.1\" stroke=\"black\" stroke-width=\"1.8\" />\n                    </svg>\n                    <!-- Question mark text overlay -->\n                    <span class=\"icon-overlay-text question\">?</span>\n                </div>\n                <span class=\"menu-text\" data-lang-key=\"helpLogo\">Help center</span>\n                <span class=\"tooltip-text\" data-tooltip-key=\"helpTooltip\">Help center</span>\n            </a>\n\n            <!-- Menu Item: My Account -->\n            <a href=\"#\" class=\"menu-item\" data-action=\"myAccount\" data-lang-key=\"profileLogo\"\n                data-tooltip-key=\"profileTooltip\">\n                <div class=\"menu-icon icon-composite\">\n                    <!-- Circle SVG - UPDATED -->\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" fill=\"none\"\n                        preserveAspectRatio=\"xMidYMid meet\">\n                        <circle cx=\"18\" cy=\"18\" r=\"17.1\" fill=\"black\" stroke=\"black\" stroke-width=\"1.8\" />\n                    </svg>\n                    <!-- Initials text overlay -->\n                    <span class=\"icon-overlay-text initials\" id=\"profile-initials\">RM</span>\n                </div>\n                <span class=\"menu-text\" data-lang-key=\"profileLogo\">My Profile</span>\n                <span class=\"tooltip-text\" data-tooltip-key=\"profileTooltip\">My Profile</span>\n            </a>\n\n        </div>\n    </nav>\n\n    <script>\n        /**\n     * 1. PRIVATE: Main population logic\n     * This function takes the configuration and applies it to the HTML.\n     * @param {object} config - The configuration object from myop_init_interface.\n     */\n    function populateSidebar(config) {\n\n      // --- Get Elements ---\n      const logoIconContainer = document.getElementById('logo-icon-container');\n      const logoTextContainer = document.getElementById('logo-text-container');\n      const logoTooltipText = document.getElementById('logo-tooltip-text');\n      const profileInitials = document.getElementById('profile-initials');\n\n      // --- Apply Dynamic Values ---\n\n      // 1. Set Logo based on app - Read from config.Data\n      if (config.Data && config.Data.svgLogo) {\n        logoIconContainer.innerHTML = config.Data.svgLogo;\n      }\n\n      // 2. Set Brand Text - Read from config.Data\n      let appName = (config.Data && config.Data.appName) ? config.Data.appName : '';\n      let logoTextHTML = `<span class=\"app-line\">${appName}</span>`;\n\n      if (config.Data && config.Data.brand && config.Data.brandName) {\n        const brandName = config.Data.brandName;\n        logoTextHTML += `<span class=\"brand-line\">${brandName}</span>`;\n      }\n      logoTextContainer.innerHTML = logoTextHTML;\n\n      // 3. Set Logo Tooltip - Always \"Home\"\n      // Use lang file if available, otherwise default to \"Home\"\n      logoTooltipText.textContent = (config.lang && config.lang.homeTooltip) ? config.lang.homeTooltip : \"Home\";\n\n      // 4. Set Profile Initials - Read from config.Data\n      profileInitials.textContent = (config.Data && config.Data.initials) ? config.Data.initials : '??';\n\n      // 5. Populate all text/tooltips from config.lang\n      const allMenuItems = document.querySelectorAll('.menu-item');\n      allMenuItems.forEach(item => {\n        // Find the text and tooltip elements within this item\n        const textEl = item.querySelector('.menu-text');\n        const tooltipEl = item.querySelector('.tooltip-text');\n\n        // Get the keys from data attributes\n        const textKey = textEl ? textEl.getAttribute('data-lang-key') : null;\n        const tooltipKey = tooltipEl ? tooltipEl.getAttribute('data-tooltip-key') : null;\n\n        // Populate text from lang file\n        if (textEl && textKey && config.lang && config.lang[textKey]) {\n          textEl.textContent = config.lang[textKey];\n        } else if (textEl && textKey) {\n          textEl.textContent = textKey; // Fallback to key if not in lang\n        }\n\n        // Populate tooltip from lang file\n        if (tooltipEl && tooltipKey && config.lang && config.lang[tooltipKey]) {\n          tooltipEl.textContent = config.lang[tooltipKey];\n        } else if (tooltipEl && tooltipKey) {\n          tooltipEl.textContent = tooltipKey; // Fallback to key if not in lang\n        }\n      });\n\n      // --- 6. Add Click Listeners & Tooltip Positioning ---\n\n      // --- Click Listener ---\n      const menuItems = document.querySelectorAll('.menu-item[data-action]');\n      menuItems.forEach(item => {\n        // Check for a flag to prevent adding listeners multiple times if init is called again\n        if (!item.hasClickListener) {\n          item.addEventListener('click', (e) => {\n            e.preventDefault(); // Prevent default link behavior\n\n            // Get the stable 'data-action' attribute as the payload\n            const buttonId = item.getAttribute('data-action');\n\n            if (buttonId) {\n              // --- MODIFICATION 1: Send payload as an object ---\n              window.myop_cta_handler('navigation_item', { target: buttonId });\n            }\n          });\n          item.hasClickListener = true; // Set the flag\n        }\n      });\n\n      // --- Narrow Mode Detection ---\n      const sidebar = document.getElementById('sidebar');\n\n      function checkNarrowMode() {\n        if (sidebar) {\n          const sidebarWidth = sidebar.offsetWidth;\n          if (sidebarWidth < 100) {\n            sidebar.classList.add('narrow-mode');\n          } else {\n            sidebar.classList.remove('narrow-mode');\n          }\n        }\n      }\n\n      // Check on init and on resize\n      checkNarrowMode();\n      if (!window.hasNarrowModeListener) {\n        window.addEventListener('resize', checkNarrowMode);\n        window.hasNarrowModeListener = true;\n      }\n\n      // --- Tooltip Positioning (Efficient Delegated Listener) ---\n      // This single listener on the sidebar handles all tooltips in narrow mode.\n      if (sidebar && !sidebar.hasTooltipListener) {\n        sidebar.addEventListener('mouseover', (e) => {\n          // Only run this logic if in narrow mode\n          if (sidebar.classList.contains('narrow-mode')) {\n            const item = e.target.closest('.menu-item');\n            if (item) {\n              const tooltip = item.querySelector('.tooltip-text');\n              if (tooltip) {\n                const itemRect = item.getBoundingClientRect();\n                const sidebarRect = sidebar.getBoundingClientRect();\n\n                // Position tooltip to the right of the sidebar, vertically centered on the item\n                tooltip.style.left = `${sidebarRect.right + 12}px`;\n                tooltip.style.top = `${itemRect.top + itemRect.height / 2}px`;\n                tooltip.style.transform = 'translateY(-50%)';\n              }\n            }\n          }\n        });\n        sidebar.hasTooltipListener = true; // Set flag\n      }\n    }\n\n    /**\n     * 2. PUBLIC API: CTA Handler\n     * Receives all actions from the component.\n     * This function is designed to be defined by the consuming application.\n     * @param {string} action_id - The type of action (e.g., \"menuClicked\").\n     * @param {object} payload - The specific data for the action (e.g., { target: \"home\" }).\n     */\n    window.myop_cta_handler = function(action_id, payload) {\n      // This is a placeholder. The application using this component\n      // should overwrite this function.\n      console.log(`[myop_cta_handler] Action ID: ${action_id}, Payload:`, payload);\n    };\n\n    /**\n     * 3. PUBLIC API: Initialize Interface\n     * Receives the configuration object and populates the sidebar.\n     * This is the main entry point for the component.\n     * @param {object} config - The configuration object.\n     */\n    window.myop_init_interface = function(config) {\n      populateSidebar(config);\n    };\n\n\n    // --- 4. EXAMPLE USAGE (for testing) ---\n    // You can uncomment this block to test the component\n    // The real application would call myop_init_interface directly.\n\n    document.addEventListener('DOMContentLoaded', function() {\n      // This is the main configuration object.\n      var exampleConfig = {\n        lang: {\n          \"homeTooltip\": \"Home\", // Tooltip for the logo/home button\n          \"clientGalleriesLogo\": \"Client Galleries\",\n          \"clientGalleriesTooltip\": \"View Client Galleries\",\n          \"artGalleriesLogo\": \"Art Galleries\",\n          \"artGalleriesTooltip\": \"View Art Galleries\",\n          \"salesLogo\": \"Sales & Automation\",\n          \"salesTooltip\": \"Manage Sales\",\n          \"settingsLogo\": \"Settings\",\n          \"settingsTooltip\": \"Account Settings\",\n          \"helpLogo\": \"Help Center\",\n          \"helpTooltip\": \"Get Help\",\n          \"profileLogo\": \"My Profile\",\n          \"profileTooltip\": \"View My Profile\"\n        },\n        Data: {\n          \"initials\": \"RM\",\n          \"appName\": \"Pic-Time\", // <-- App name string\n          // <-- SVG logo string\n          \"svgLogo\": `<svg style=\"display: block; width: 100%; height: 100%;\" fill=\"none\" preserveAspectRatio=\"xMidYMid meet\" viewBox=\"0 0 40 31\">\n                          <g>\n                            <path d=\"M13.5511 2.02475C20.9623 2.02493 26.9789 8.3468 26.9789 16.098C26.9787 23.8491 20.9622 30.1701 13.5511 30.1703C6.13994 30.1703 0.122542 23.8537 0.122411 16.098C0.122411 8.34218 6.13985 2.02475 13.5511 2.02475ZM13.5511 3.16831C6.75747 3.16831 1.22495 8.96517 1.22495 16.098C1.22508 23.2307 6.76181 29.0267 13.5511 29.0267C20.3403 29.0265 25.8762 23.2306 25.8763 16.098C25.8763 8.96084 20.3404 3.16848 13.5511 3.16831Z\" fill=\"black\" stroke=\"black\" stroke-width=\"0.245458\"/>\n                            <path d=\"M39.1683 0.122411V6.2562H28.4613V0.122411H39.1683ZM29.4779 5.20249H38.1517V1.1771H29.4779V5.20249Z\" fill=\"black\" stroke=\"black\" stroke-width=\"0.245458\"/>\n                          </g>\n                        </svg>`,\n          \"brand\": true,     // true or false\n          \"brandName\": \"x QT Albums\" // <-- Brand name string\n        }\n      };\n\n      // Call the new init function\n      window.myop_init_interface(exampleConfig);\n\n      // --- Example of overwriting the CTA handler ---\n      // window.myop_cta_handler = function(action_id, payload) {\n      //   console.log(\"--- CUSTOM HANDLER ---\");\n      //   console.log(`Action: ${action_id}`);\n      //   console.log(`Payload:`, payload);\n      //\n      //   if (payload.target === 'clientGalleries') {\n      //     console.log(\"Navigating to Client Galleries!\");\n      //   }\n      // };\n\n    });\n\n    </script>\n</body>\n\n</html>"
        }
      }
    ]
