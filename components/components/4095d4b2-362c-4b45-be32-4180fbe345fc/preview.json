      {
        "id": "1f4ebcce-199d-403e-94b5-cfc48cdd66cb",
        "name": "Version 3",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Sidebar Menu</title>\n    <style>\n        /* --- Base & Reset --- */\n        :root {\n            /* Width is 20vw, with a max of 384px */\n            --sidebar-width-expanded: 20vw;\n            --sidebar-max-width-expanded: 384px;\n            /* --sidebar-width-collapsed: 100%; (No longer used) */\n            --sidebar-bg: #f3f2ee;\n            --sidebar-hover-bg: #e9e7e1;\n            --text-color-primary: #050505;\n            --text-color-secondary: #555;\n            --icon-color: #222222;\n            --tooltip-bg: #222;\n            --tooltip-text: white;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        /*\n     * 1. Set body to transparent (no main content area).\n     * 2. Position content at top-left corner.\n     */\n        body,\n        html {\n            width: 100%;\n            height: 100%;\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            background: transparent;\n            margin: 0;\n            padding: 0;\n        }\n\n        /* --- Main Layout --- */\n        /* The sidebar is positioned at top-left, full height, full width */\n        .sidebar {\n            position: fixed;\n            top: 0;\n            left: 0;\n            background: var(--sidebar-bg);\n            height: 100vh;\n            border-radius: 0;\n            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);\n\n            /* Width spans full container - no max-width constraint */\n            width: 100%;\n\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n            padding: 24px 16px;\n            transition: padding 0.3s ease;\n            overflow: hidden;\n        }\n\n        /* Narrow mode: when width < 100px */\n        .sidebar.narrow-mode {\n            padding: 24px 8px;\n        }\n\n        .sidebar.narrow-mode .menu-text,\n        .sidebar.narrow-mode .logo-text-container {\n            display: none;\n        }\n\n        .sidebar.narrow-mode .menu-item {\n            justify-content: center;\n            padding: 12px 8px;\n        }\n\n        .sidebar.narrow-mode .menu-item:hover .tooltip-text {\n            opacity: 1;\n        }\n\n        .sidebar-top {\n            display: flex;\n            flex-direction: column;\n            gap: 16px;\n        }\n\n        .sidebar-bottom {\n            display: flex;\n            flex-direction: column;\n            gap: 16px;\n        }\n\n        /* --- Menu Item --- */\n        .menu-item {\n            display: flex;\n            align-items: center;\n            gap: 20px;\n            padding: 12px;\n            border-radius: 8px;\n            text-decoration: none;\n            color: var(--text-color-primary);\n            height: 60px;\n            position: relative;\n            overflow: hidden;\n            white-space: nowrap;\n        }\n\n        .menu-item:hover {\n            background: var(--sidebar-hover-bg);\n        }\n\n        /* --- Icons --- */\n        .menu-icon {\n            flex-shrink: 0;\n            width: 36px;\n            height: 36px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .menu-icon svg {\n            display: block;\n            /* Fix for SVG scaling */\n            width: 100%;\n            height: 100%;\n        }\n\n        /* Composite icon (for Help/Profile) */\n        .icon-composite {\n            position: relative;\n        }\n\n        .icon-overlay-text {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            pointer-events: none;\n            font-size: 14px;\n            font-weight: 500;\n            line-height: 1;\n        }\n\n        .icon-overlay-text.question {\n            color: var(--text-color-primary);\n        }\n\n        .icon-overlay-text.initials {\n            color: white;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        /* --- Text & Brand --- */\n        .menu-text {\n            font-size: 16px;\n            font-weight: 400;\n            line-height: 1.4;\n            /* --- MODIFICATION 2: Always visible --- */\n            opacity: 1;\n            transition: opacity 0.2s ease;\n        }\n\n        .logo-text-container {\n            /* --- MODIFICATION 2: Always visible --- */\n            display: flex;\n            flex-direction: column;\n            line-height: 1.3;\n        }\n\n        .logo-text-container .app-line {\n            font-size: 16px;\n            font-weight: 500;\n            color: var(--text-color-primary);\n        }\n\n        .logo-text-container .brand-line {\n            font-size: 14px;\n            font-weight: 400;\n            color: var(--text-color-secondary);\n        }\n\n        /* --- MODIFICATION 2: Removed responsive media query --- */\n        /* @media (max-width: 1599px) { ... } block removed */\n\n        /* --- Tooltip (Only visible when collapsed) --- */\n        .tooltip-text {\n            position: fixed;\n            /* --- MODIFICATION 3: Removed 'left' property, will be set by JS --- */\n            top: 0;\n            background: var(--tooltip-bg);\n            color: var(--tooltip-text);\n            font-size: 12px;\n            font-weight: 500;\n            white-space: nowrap;\n            pointer-events: none;\n            /* --- MODIFICATION 3: Default state is hidden --- */\n            opacity: 0;\n            transition: opacity 0.15s;\n            z-index: 1000;\n            transform: translateY(-50%);\n            /* Start centered */\n\n            /* New styles */\n            width: auto;\n            /* Expand to fit content */\n            min-width: 100px;\n            /* Set minimum width */\n            padding: 6px 8px;\n            /* 6px top/bottom, 8px left/right */\n            flex-shrink: 0;\n            border-radius: 4px;\n\n            /* Added to center text in fixed-size box */\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        /* Tooltip arrow - REMOVED */\n        .tooltip-text::before {\n            display: none;\n            /* Hide the arrow */\n        }\n\n        /* Tooltips are shown via JS in narrow mode */\n    </style>\n</head>\n\n<body>\n\n    <nav class=\"sidebar\" id=\"sidebar\">\n\n        <!-- Top navigation items -->\n        <div class=\"sidebar-top\">\n\n            <!-- Menu Item: Logo -->\n            <a href=\"#\" class=\"menu-item\" data-action=\"home\" data-tooltip-key=\"homeTooltip\">\n                <div class=\"menu-icon\" id=\"logo-icon-container\">\n                    <!-- Logo SVG is injected here by JavaScript -->\n                </div>\n                <!-- Container for App Name and Brand -->\n                <div class=\"logo-text-container\" id=\"logo-text-container\">\n                    <!-- Content is injected by JS -->\n                </div>\n                <span class=\"tooltip-text\" id=\"logo-tooltip-text\" data-tooltip-key=\"homeTooltip\">Home</span>\n            </a>\n\n            <!-- Menu Item: Client Galleries -->\n            <a href=\"#\" class=\"menu-item\" data-action=\"clientGalleries\" data-lang-key=\"clientGalleriesLogo\"\n                data-tooltip-key=\"clientGalleriesTooltip\">\n                <div class=\"menu-icon\">\n                    <svg style=\"display: block; width: 100%; height: 100%;\" fill=\"none\"\n                        preserveAspectRatio=\"xMidYMid meet\" viewBox=\"0 0 28 28\">\n                        <g>\n                            <rect height=\"19.3916\" stroke=\"#222222\"