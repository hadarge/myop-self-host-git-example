{
  "version": "0.2.10",
  "item": {
    "name": "PHDash_search",
    "id": "1f79f62f-84a4-4ef2-b25d-d9b1fcbed47c",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "155aa8ef-1466-4c90-a02d-b6fc121bef02",
        "name": "Version 39",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":300}'>\n  <title>Gallery Search Dashboard</title>\n  <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Font configuration for CSS variable injection\n */\ninterface FontConfig {\n  /** Used to create CSS variable --font_{id} */\n  id: string;\n  /** Font family name */\n  family: string;\n  /** Optional font style (e.g., \"normal\", \"italic\") */\n  style?: string;\n  /** Optional font weight (e.g., 400, 500, 700) */\n  weight?: number;\n  /** Optional URL to load external font CSS */\n  url?: string;\n}\n\n/**\n * Gallery item data\n */\ninterface GalleryItem {\n  id: number;\n  imageUrl: string | null;\n  altText: string;\n  name: string;\n  date: string;\n}\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n  fonts?: FontConfig[];\n  lang: {\n    welcomeGreeting: string;\n    welcomeGreetingNoName: string;\n    searchInputPlaceholder: string;\n    dropdownTitleRecent: string;\n    dropdownTitleSearch: string;\n    newGalleryButton: string;\n    noResults: string;\n  };\n  Data: {\n    userName?: string;\n    header2: string;\n    recentGalleries: GalleryItem[];\n    allGalleries: GalleryItem[];\n  };\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'navigation_item': { target: string; projectid: number };\n  'new_gallery_clicked': null;\n  'size-requested': {\n    width?: number | null;\n    height?: number | null;\n    minWidth?: number | null;\n    maxWidth?: number | null;\n    minHeight?: number | null;\n    maxHeight?: number | null;\n    required?: boolean;\n  };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n  </script>\n  <style>\n    :root {\n      /* Using CSS variables for easier theme management */\n      --color-background: transparent; /* Page background set to transparent */\n      --color-component-bg: #FFFFFF; /* Component background */\n      --color-dropdown-bg: #FFFFFF; /* Dropdown background */\n      --color-search-bg: #FFFFFF; /* Search input background */\n      --color-text-primary: #050505;\n      --color-text-secondary: #222222;\n      --color-text-placeholder: #6b6b6b;\n      --color-text-muted: #aeaeae;\n      --color-border: #6b6b6b;\n      --color-border-focus: #222222;\n      --color-button-primary-bg: #222222;\n      --color-button-primary-text: #FFFFFF;\n      --color-button-primary-hover: #000000;\n\n      /* Font CSS variables - set dynamically from config */\n      --font_main: sans-serif;\n      --font_main_style: normal;\n      --font_main_weight: 400;\n    }\n\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    html, body {\n      width: 100%;\n      margin: 0;\n      padding: 0;\n    }\n\n    body {\n      font-family: var(--font_main);\n      font-style: var(--font_main_style);\n      font-weight: var(--font_main_weight);\n      background: var(--color-background);\n      color: var(--color-text-primary);\n      /* Added for smooth visual transitions */\n      transition: background-color 0.3s;\n\n      /* No padding for iframe embedding - only left padding */\n      padding: 0 0 0 0;\n    }\n\n    #app-root {\n      width: 100%;\n    }\n\n    .dashboard-container {\n      width: 100%;\n      position: relative;\n    }\n\n    .header {\n      margin-bottom: 32px;\n    }\n\n    .header-row {\n      display: flex;\n      justify-content: flex-start;\n      align-items: center;\n      margin-bottom: 12px;\n    }\n\n    .header h1 {\n      margin-bottom: 0;\n      color: var(--color-text-primary, #222);\n      font-feature-settings: 'liga' off, 'clig' off;\n      font-family: var(--font_main);\n      font-size: 28px;\n      font-style: normal;\n      font-weight: 400;\n      line-height: 128%; /* 35.84px */\n    }\n\n    .header p {\n      color: #6B6B6B;\n      text-align: left;\n      font-kerning: none;\n      font-feature-settings: 'liga' off, 'calt' off;\n      font-family: var(--font_main);\n      font-size: 16px;\n      font-style: normal;\n      font-weight: 400;\n      line-height: normal;\n      max-width: 505px;\n    }\n\n    .search-section {\n      display: flex;\n      gap: 24px;\n      align-items: flex-start;\n      position: relative;\n      width: calc(100% - 380px);\n    }\n\n    .search-section .new-gallery-button {\n      margin-top: 0;\n    }\n\n    .search-container {\n      position: relative;\n      flex: 1;\n      min-width: 0;\n    }\n\n    .search-input-wrapper {\n      position: relative;\n      z-index: 10;\n    }\n\n    .search-input {\n      display: flex;\n      width: 100%;\n      height: 40px;\n      padding: 6px 14px 6px 40px;\n      align-items: center;\n      gap: 163px;\n      align-self: stretch;\n      border-radius: 2px;\n      border: 1px solid #DDDDD1;\n      color: #222;\n      font-feature-settings: 'liga' off, 'clig' off;\n      font-family: var(--font_main);\n      font-size: 16px;\n      font-style: normal;\n      font-weight: 400;\n      line-height: 142%;\n      background: var(--color-search-bg);\n      outline: none;\n      transition: border-color 0.2s;\n    }\n\n    .search-input::placeholder {\n      color: var(--color-text-placeholder);\n    }\n\n    .search-input:focus {\n      border-color: var(--color-border-focus);\n    }\n\n    .search-icon {\n      position: absolute;\n      left: 14px;\n      top: 50%;\n      transform: translateY(-50%);\n      width: 16px;\n      height: 16px;\n      pointer-events: none;\n    }\n\n    /* Styling for the search icon's stroke to match focus color */\n    .search-icon circle,\n    .search-icon path {\n      stroke: var(--color-border);\n      transition: stroke 0.2s;\n    }\n\n    .search-input:focus ~ .search-icon circle,\n    .search-input:focus ~ .search-icon path {\n        stroke: var(--color-border-focus);\n    }\n\n\n    .clear-button {\n      position: absolute;\n      right: 14px;\n      top: 50%;\n      transform: translateY(-50%);\n      width: 20px;\n      height: 20px;\n      border: none;\n      background: transparent;\n      cursor: pointer;\n      padding: 0;\n      display: none;\n      align-items: center;\n      justify-content: center;\n      opacity: 0.6;\n      transition: opacity 0.2s;\n    }\n\n    .clear-button:hover {\n      opacity: 1;\n    }\n\n    .clear-button.visible {\n      display: flex;\n    }\n\n    .dropdown {\n      position: static;\n      width: 100%;\n      background: var(--color-dropdown-bg);\n      border-radius: 2px;\n      border: none;\n      box-shadow: 0px 3px 8px 0px rgba(34, 34, 34, 0.16);\n      padding: 0;\n      margin-top: 8px;\n      max-height: 0;\n      opacity: 0;\n      overflow: hidden;\n      transition: max-height 0.3s ease-out, opacity 0.2s ease-out, padding 0.3s ease-out;\n    }\n\n    .dropdown.visible {\n      max-height: 400px;\n      opacity: 1;\n      padding: 12px 16px;\n    }\n\n    .dropdown-title {\n      font-size: 16px;\n      font-weight: 500;\n      font-family: var(--font_main);\n      color: #222;\n      line-height: 24px;\n      padding: 8px 0;\n      margin-bottom: 8px;\n    }\n\n    .gallery-list {\n      display: flex;\n      flex-direction: column;\n      gap: 0;\n      max-height: 300px;\n      overflow-y: auto;\n      padding-right: 8px;\n    }\n\n    /* Custom scrollbar - Webkit (Chrome, Safari, Edge) */\n    .gallery-list::-webkit-scrollbar {\n      width: 8px;\n    }\n\n    .gallery-list::-webkit-scrollbar-track {\n      background: transparent;\n      padding: 4px 0;\n    }\n\n    .gallery-list::-webkit-scrollbar-thumb {\n      background-color: #E1E1E1;\n      border-radius: 4px;\n      min-height: 30px;\n    }\n\n    .gallery-list::-webkit-scrollbar-thumb:hover {\n      background-color: #C8C8C8;\n    }\n\n    /* Custom scrollbar - Firefox */\n    .gallery-list {\n      scrollbar-width: thin;\n      scrollbar-color: #E1E1E1 transparent;\n    }\n\n    .gallery-item {\n      display: flex;\n      align-items: center;\n      gap: 10px;\n      height: 64px;\n      padding: 8px;\n      margin: 0;\n      cursor: pointer;\n      transition: background-color 0.15s;\n    }\n\n    .gallery-item + .gallery-item {\n      margin-top: 8px;\n    }\n\n    .gallery-item:hover,\n    .gallery-item.highlighted {\n      background-color: #FAFAF8;\n    }\n\n    .gallery-thumbnail {\n      width: 66px;\n      height: 48px;\n      border-radius: 0;\n      object-fit: cover;\n      flex-shrink: 0;\n      background-color: #d3d3d3;\n      overflow: hidden;\n    }\n\n    /* Handle missing images */\n    .gallery-thumbnail[src=\"\"],\n    .gallery-thumbnail:not([src]) {\n      content: '';\n      display: block;\n    }\n\n    .gallery-info {\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n      gap: 2px;\n    }\n\n    .gallery-name {\n      font-size: 16px;\n      font-weight: 500;\n      font-family: var(--font_main);\n      color: #222;\n      line-height: 24px;\n    }\n\n    .gallery-date {\n      font-size: 14px;\n      font-weight: 400;\n      font-family: var(--font_main);\n      color: #999;\n      line-height: 1.42;\n    }\n\n    .no-results {\n      display: flex;\n      align-items: center;\n      height: 40px;\n      font-size: 16px;\n      font-weight: 400;\n      font-family: var(--font_main);\n      color: #222;\n      line-height: 24px;\n    }\n\n    .new-gallery-button {\n      display: flex;\n      width: 151px;\n      height: 40px;\n      padding: 5px 12px;\n      justify-content: center;\n      align-items: center;\n      gap: 8px;\n      border-radius: 2px;\n      background: var(--C9, #1C1C1C);\n      color: var(--C1, #FFF);\n      border: 1px solid var(--C9, #1C1C1C);\n      outline: none;\n      font-feature-settings: 'liga' off, 'clig' off;\n      font-family: var(--font_main);\n      font-size: 16px;\n      font-style: normal;\n      font-weight: 400;\n      line-height: 125%;\n      cursor: pointer;\n      white-space: nowrap;\n      transition: background 0.2s, transform 0.1s ease-out;\n      flex-shrink: 0;\n      box-sizing: border-box;\n    }\n\n    .new-gallery-button svg {\n      flex-shrink: 0;\n      width: 15.214px;\n      height: 15.214px;\n    }\n\n    .new-gallery-button:hover {\n      background: var(--C9, #1C1C1C);\n      opacity: 0.85;\n    }\n\n    .new-gallery-button:active {\n      transform: scale(0.98);\n    }\n\n    /* Hide mobile button by default (desktop) */\n    .header .mobile-button {\n      display: none;\n    }\n\n    /* Responsive Styles - Mobile only (smaller breakpoint) */\n    @media (max-width: 480px) {\n      body {\n        padding: 16px;\n      }\n\n      .header-row {\n        flex-direction: column;\n        align-items: flex-start;\n        gap: 0;\n      }\n\n      .search-section > .new-gallery-button {\n        display: none !important; /* Hide button in search-section on mobile */\n      }\n\n      .header .mobile-button {\n        display: inline-flex !important; /* Show mobile button after header2 */\n        margin-top: 16px;\n        width: 100%;\n      }\n\n      .header h1 {\n        font-size: 28px;\n      }\n\n      .header p {\n        font-size: 16px;\n      }\n\n      .search-section {\n        flex-direction: column;\n        align-items: stretch;\n        gap: 16px;\n      }\n\n      .search-container {\n        width: 100% !important;\n      }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"dashboard-container\">\n    <div class=\"header\">\n      <!-- Content populated by JS -->\n      <div class=\"header-row\">\n        <h1></h1>\n      </div>\n      <p></p>\n      <!-- Mobile button (shown below header2 on mobile only) -->\n      <button class=\"new-gallery-button mobile-button\" id=\"newGalleryButtonMobile\"></button>\n    </div>\n\n    <div class=\"search-section\">\n      <div class=\"search-container\" id=\"searchContainer\">\n        <div class=\"search-input-wrapper\">\n          <svg class=\"search-icon\" fill=\"none\" viewBox=\"0 0 16 16\">\n            <circle cx=\"7\" cy=\"7\" r=\"6.25\" stroke=\"#222222\" stroke-width=\"1.5\" fill=\"none\"/>\n            <path d=\"M11.5 11.5L14.5 14.5\" stroke=\"#222222\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n          </svg>\n          <input\n            type=\"text\"\n            class=\"search-input\"\n            placeholder=\"\"\n            id=\"searchInput\"\n            autocomplete=\"off\"\n          />\n          <!-- placeholder populated by JS -->\n          <button class=\"clear-button\" id=\"clearButton\">\n            <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\">\n              <line x1=\"1\" y1=\"1\" x2=\"11\" y2=\"11\" stroke=\"#8D8D8D\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n              <line x1=\"11\" y1=\"1\" x2=\"1\" y2=\"11\" stroke=\"#8D8D8D\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n            </svg>\n          </button>\n        </div>\n\n        <div class=\"dropdown\" id=\"dropdown\">\n          <!-- Title populated by JS -->\n          <div class=\"dropdown-title\"></div>\n          <!-- List populated by JS -->\n          <div class=\"gallery-list\" id=\"galleryList\">\n            <!-- Gallery items will be dynamically inserted here -->\n          </div>\n        </div>\n      </div>\n      <!-- Button next to search -->\n      <button class=\"new-gallery-button\" id=\"newGalleryButton\"></button>\n    </div>\n  </div>\n\n  <script>\n    (function() {\n      // --- Internal Component State & Variables ---\n      var appConfig = null;\n      var galleryItems = [];\n      var highlightedIndex = -1;\n\n      /**\n       * Populates the page with content from the config object.\n       * @param {object} config The searchConfig object.\n       */\n      function populateSearchComponent(config) {\n        if (!config) {\n          console.error(\"Configuration object is missing.\");\n          return;\n        }\n\n        var lang = config.lang;\n        var Data = config.Data;\n\n        // Element Selectors\n        var searchInput = document.getElementById('searchInput');\n        var newGalleryButton = document.getElementById('newGalleryButton');\n        var newGalleryButtonMobile = document.getElementById('newGalleryButtonMobile');\n        var headerH1 = document.querySelector('.header h1');\n        var headerP = document.querySelector('.header p');\n\n        // 1. Populate Language Strings & Data Headers\n        if (headerH1) {\n          if (Data.userName) {\n            headerH1.textContent = lang.welcomeGreeting.replace('{name}', Data.userName);\n          } else {\n            headerH1.textContent = lang.welcomeGreetingNoName || \"Welcome!\";\n          }\n        }\n\n        if (headerP) {\n          headerP.textContent = lang.header2;\n        }\n\n        if (searchInput) {\n          searchInput.placeholder = lang.searchInputPlaceholder;\n        }\n\n        var buttonIconSVG = '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M7.60742 0C8.02164 0 8.35742 0.335787 8.35742 0.75V6.85645H14.4639C14.8781 6.85645 15.2139 7.19223 15.2139 7.60645C15.2138 8.02064 14.8781 8.35645 14.4639 8.35645H8.35742V14.4639C8.35725 14.8779 8.02153 15.2139 7.60742 15.2139C7.19333 15.2139 6.8576 14.8779 6.85742 14.4639V8.35645H0.75C0.335941 8.35628 2.49801e-05 8.02054 0 7.60645C0 7.19233 0.335925 6.85661 0.75 6.85645H6.85742V0.75C6.85742 0.335795 7.19322 1.26325e-05 7.60742 0Z\" fill=\"currentColor\"/></svg>';\n        var buttonHTML = buttonIconSVG + '<span>' + lang.newGalleryButton + '</span>';\n\n        if (newGalleryButton) {\n          newGalleryButton.innerHTML = buttonHTML;\n        }\n\n        if (newGalleryButtonMobile) {\n          newGalleryButtonMobile.innerHTML = buttonHTML;\n        }\n\n        // 2. Populate initial gallery list (recent)\n        renderGalleryList(Data.recentGalleries, lang.dropdownTitleRecent);\n      }\n\n      /**\n       * Formats a date string to \"Aug 2, 2006\" format\n       */\n      function formatDate(dateStr) {\n        var date = new Date(dateStr);\n        if (isNaN(date.getTime())) return dateStr; // Return original if invalid\n\n        var months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];\n        var month = months[date.getMonth()];\n        var day = date.getDate();\n        var year = date.getFullYear();\n\n        return month + ' ' + day + ', ' + year;\n      }\n\n      /**\n       * Renders a list of galleries in the dropdown.\n       */\n      function renderGalleryList(galleryList, title) {\n        var galleryListContainer = document.getElementById('galleryList');\n        var dropdownTitle = document.querySelector('.dropdown-title');\n        var dropdown = document.getElementById('dropdown');\n        var searchInput = document.getElementById('searchInput');\n        var searchContainer = document.getElementById('searchContainer');\n\n        if (!galleryListContainer || !dropdownTitle || !appConfig) return;\n\n        var lang = appConfig.lang;\n\n        // 1. Set Title\n        dropdownTitle.textContent = title;\n\n        // 2. Clear existing list\n        galleryListContainer.innerHTML = '';\n\n        // 3. Render list\n        if (galleryList.length === 0) {\n          galleryListContainer.innerHTML = '<div class=\"no-results\">' + lang.noResults + '</div>';\n          return;\n        }\n\n        galleryList.forEach(function(gallery) {\n          var imageUrl = gallery.imageUrl || '';\n          var hasImage = imageUrl.trim() !== '';\n\n          var thumbnailHTML = hasImage\n            ? '<img src=\"' + imageUrl + '\" alt=\"' + (gallery.altText || '') + '\" class=\"gallery-thumbnail\" onerror=\"this.outerHTML=\\'<div class=\\\\\\'gallery-thumbnail\\\\\\'></div>\\';\" />'\n            : '<div class=\"gallery-thumbnail\"></div>';\n\n          var formattedDate = formatDate(gallery.date);\n\n          var itemHTML =\n            '<div class=\"gallery-item\" data-gallery=\"' + gallery.id + '\">' +\n              thumbnailHTML +\n              '<div class=\"gallery-info\">' +\n                '<div class=\"gallery-name\">' + gallery.name + '</div>' +\n                '<div class=\"gallery-date\">Created ' + formattedDate + '</div>' +\n              '</div>' +\n            '</div>';\n          galleryListContainer.insertAdjacentHTML('beforeend', itemHTML);\n        });\n\n        // 4. Re-select gallery items and attach listeners\n        galleryItems = galleryListContainer.querySelectorAll('.gallery-item');\n\n        galleryItems.forEach(function(item) {\n          item.addEventListener('click', function() {\n            var galleryId = parseInt(item.dataset.gallery, 10);\n\n            if (window.myop_cta_handler) {\n              window.myop_cta_handler(\"navigation_item\", {\n                target: \"gallery\",\n                projectid: galleryId\n              });\n            }\n\n            // Close dropdown and collapse search\n            if (dropdown) {\n              dropdown.classList.remove('visible');\n            }\n            if (searchInput) {\n              searchInput.value = '';\n              searchInput.blur();\n            }\n            if (searchContainer) {\n              searchContainer.classList.remove('expanded');\n            }\n            requestFitHeight(50);\n            var clearBtn = document.getElementById('clearButton');\n            if (clearBtn) {\n              clearBtn.classList.remove('visible');\n            }\n          });\n        });\n      }\n\n      /**\n       * Filters the visible gallery list based on a search term.\n       */\n      function filterGalleryList(searchTerm) {\n        if (!appConfig) return;\n\n        var term = searchTerm.toLowerCase();\n        var lang = appConfig.lang;\n        var Data = appConfig.Data;\n\n        if (term.length > 0) {\n          var searchResults = Data.allGalleries.filter(function(gallery) {\n            return gallery.name.toLowerCase().includes(term);\n          });\n          renderGalleryList(searchResults, lang.dropdownTitleSearch);\n        } else {\n          renderGalleryList(Data.recentGalleries, lang.dropdownTitleRecent);\n        }\n\n        highlightedIndex = -1;\n      }\n\n      /**\n       * Updates the visual highlight on gallery items.\n       */\n      function updateHighlight() {\n        galleryItems.forEach(function(item) { item.classList.remove('highlighted'); });\n\n        if (highlightedIndex >= 0 && highlightedIndex < galleryItems.length) {\n          var highlightedItem = galleryItems[highlightedIndex];\n          highlightedItem.classList.add('highlighted');\n          highlightedItem.scrollIntoView({ block: 'nearest', behavior: 'smooth' });\n        }\n      }\n\n      /**\n       * Selects the currently highlighted gallery item.\n       */\n      function selectHighlightedItem() {\n        if (highlightedIndex >= 0 && highlightedIndex < galleryItems.length) {\n          var item = galleryItems[highlightedIndex];\n          var galleryId = parseInt(item.dataset.gallery, 10);\n\n          if (window.myop_cta_handler) {\n            window.myop_cta_handler(\"navigation_item\", {\n              target: \"gallery\",\n              projectid: galleryId\n            });\n          }\n\n          var dropdown = document.getElementById('dropdown');\n          var searchInput = document.getElementById('searchInput');\n          var searchContainer = document.getElementById('searchContainer');\n\n          if (dropdown) dropdown.classList.remove('visible');\n          if (searchInput) {\n            searchInput.value = '';\n            searchInput.blur();\n          }\n          if (searchContainer) searchContainer.classList.remove('expanded');\n          requestFitHeight(50);\n          var clearBtn = document.getElementById('clearButton');\n          if (clearBtn) clearBtn.classList.remove('visible');\n\n          highlightedIndex = -1;\n        }\n      }\n\n      /** Track if listeners have been attached to prevent duplicates */\n      var listenersAttached = false;\n\n      var lastReportedHeight = 0;\n\n      /**\n       * Measures the actual content height and notifies Myop if it changed.\n       */\n      function notifyHeight() {\n        var container = document.querySelector('.dashboard-container');\n        if (!container) return;\n        var bodyStyle = window.getComputedStyle(document.body);\n        var verticalPadding = (parseFloat(bodyStyle.paddingTop) || 0) + (parseFloat(bodyStyle.paddingBottom) || 0);\n        var contentHeight = container.offsetHeight + verticalPadding;\n        if (contentHeight !== lastReportedHeight) {\n          lastReportedHeight = contentHeight;\n          if (window.myop_cta_handler) {\n            window.myop_cta_handler('size-requested', { height: contentHeight });\n          }\n        }\n      }\n\n      /**\n       * Measures the actual content height and requests that size from the host.\n       * Uses a small delay to allow DOM to update (e.g., dropdown animation).\n       */\n      function requestFitHeight(delay) {\n        setTimeout(notifyHeight, delay || 0);\n      }\n\n      /**\n       * Sets up a ResizeObserver on the body to automatically notify Myop\n       * whenever the content height changes (e.g., window resize, reflow).\n       */\n      function setupResizeObserver() {\n        if (typeof ResizeObserver === 'undefined') return;\n        var container = document.querySelector('.dashboard-container');\n        if (!container) return;\n        var ro = new ResizeObserver(function() {\n          notifyHeight();\n        });\n        ro.observe(container);\n      }\n\n      /**\n       * Attach all event listeners. Called after DOM is ready.\n       */\n      function attachListeners() {\n        if (listenersAttached) return;\n        listenersAttached = true;\n\n        var searchInput = document.getElementById('searchInput');\n        var dropdown = document.getElementById('dropdown');\n        var clearButton = document.getElementById('clearButton');\n        var newGalleryButton = document.getElementById('newGalleryButton');\n        var newGalleryButtonMobile = document.getElementById('newGalleryButtonMobile');\n        var searchContainer = document.getElementById('searchContainer');\n\n        if (searchInput) {\n          searchInput.addEventListener('focus', function() {\n            if (dropdown) dropdown.classList.add('visible');\n            if (searchContainer) searchContainer.classList.add('expanded');\n            requestFitHeight(350);\n            filterGalleryList(searchInput.value);\n          });\n\n          searchInput.addEventListener('input', function(e) {\n            var searchTerm = e.target.value;\n            if (clearButton) {\n              clearButton.classList.toggle('visible', searchTerm.length > 0);\n            }\n            filterGalleryList(searchTerm);\n          });\n\n          searchInput.addEventListener('keydown', function(e) {\n            if (!dropdown || !dropdown.classList.contains('visible')) return;\n\n            switch (e.key) {\n              case 'ArrowDown':\n                e.preventDefault();\n                if (galleryItems.length > 0) {\n                  highlightedIndex = (highlightedIndex + 1) % galleryItems.length;\n                  updateHighlight();\n                }\n                break;\n              case 'ArrowUp':\n                e.preventDefault();\n                if (galleryItems.length > 0) {\n                  highlightedIndex = highlightedIndex <= 0\n                    ? galleryItems.length - 1\n                    : highlightedIndex - 1;\n                  updateHighlight();\n                }\n                break;\n              case 'Enter':\n                e.preventDefault();\n                if (highlightedIndex >= 0) {\n                  selectHighlightedItem();\n                }\n                break;\n              case 'Escape':\n                dropdown.classList.remove('visible');\n                searchInput.blur();\n                highlightedIndex = -1;\n                requestFitHeight(50);\n                // Collapse search if empty\n                if (searchInput.value.trim() === '' && searchContainer) {\n                  searchContainer.classList.remove('expanded');\n                }\n                break;\n            }\n          });\n        }\n\n        // Hide dropdown when clicking outside the entire search container\n        document.addEventListener('click', function(e) {\n          if (!searchContainer || !dropdown) return;\n          // If click is inside the search container (input, clear button, dropdown), do nothing\n          if (searchContainer.contains(e.target)) return;\n\n          dropdown.classList.remove('visible');\n          requestFitHeight(50);\n          // Collapse search if empty\n          if (searchInput && searchInput.value.trim() === '') {\n            searchContainer.classList.remove('expanded');\n          }\n        });\n\n        if (clearButton) {\n          clearButton.addEventListener('click', function() {\n            if (searchInput) {\n              searchInput.value = '';\n              searchInput.focus();\n            }\n            clearButton.classList.remove('visible');\n            filterGalleryList('');\n          });\n        }\n\n        if (newGalleryButton) {\n          newGalleryButton.addEventListener('click', function() {\n            if (window.myop_cta_handler) {\n              window.myop_cta_handler(\"new_gallery_clicked\", null);\n            }\n          });\n        }\n\n        if (newGalleryButtonMobile) {\n          newGalleryButtonMobile.addEventListener('click', function() {\n            if (window.myop_cta_handler) {\n              window.myop_cta_handler(\"new_gallery_clicked\", null);\n            }\n          });\n        }\n      }\n\n      // --- PUBLIC GLOBAL FUNCTIONS (defined at top-level as required) ---\n\n      window.myop_init_interface = function(config) {\n        if (!config) return appConfig;\n\n        if (!config.lang || !config.Data) {\n          console.error(\"Initialization Error: Invalid config object provided.\", config);\n          return;\n        }\n\n        // Store the config for internal use\n        appConfig = config;\n\n        // Load fonts and set CSS variables\n        if (config.fonts && Array.isArray(config.fonts)) {\n          config.fonts.forEach(function(font) {\n            if (font.url) {\n              var linkEl = document.createElement('link');\n              linkEl.rel = 'stylesheet';\n              linkEl.href = font.url;\n              document.head.appendChild(linkEl);\n            }\n\n            var root = document.documentElement;\n            root.style.setProperty('--font_' + font.id, font.family);\n            if (font.style) {\n              root.style.setProperty('--font_' + font.id + '_style', font.style);\n            }\n            if (font.weight) {\n              root.style.setProperty('--font_' + font.id + '_weight', font.weight);\n            }\n          });\n        }\n\n        // If DOM is ready, populate immediately; otherwise wait\n        if (document.readyState === 'loading') {\n          document.addEventListener('DOMContentLoaded', function() {\n            attachListeners();\n            populateSearchComponent(appConfig);\n            setupResizeObserver();\n            requestFitHeight(50);\n          });\n        } else {\n          attachListeners();\n          populateSearchComponent(appConfig);\n          setupResizeObserver();\n          requestFitHeight(50);\n        }\n      };\n\n      window.myop_cta_handler = function(action_id, payload) {\n        var update = {\n          \"action\": action_id,\n          \"payload\": payload\n        };\n        console.log('CTA HANDLER:', update);\n      };\n\n    })();\n  </script>\n\n  <!-- Preview script - replaced in production -->\n  <script id=\"myop_preview\">\n    window.myop_init_interface({\n      fonts: [\n        {\n          id: \"main\",\n          family: \"TT Norms Pro\",\n          style: \"normal\",\n          weight: 400,\n          url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n        }\n      ],\n      lang: {\n        welcomeGreeting: \"Welcome, {name}\",\n        welcomeGreetingNoName: \"Welcome!\",\n        header2: \"Time to create something beautiful\",\n        searchInputPlaceholder: \"Search galleries\",\n        dropdownTitleRecent: \"Recent galleries\",\n        dropdownTitleSearch: \"Search results\",\n        newGalleryButton: \"Create gallery\",\n        noResults: \"No results. Try a different search term\"\n      },\n      Data: {\n        userName: \"Roee\",\n        recentGalleries: [\n          {\n            id: 1001,\n            imageUrl: \"https://images.unsplash.com/photo-1519741497674-611481863552?w=200&h=150&fit-crop\",\n            altText: \"Hanna & Stephen\",\n            name: \"Hanna & Stephen\",\n            date: \"June 6, 2025\"\n          },\n          {\n            id: 1002,\n            imageUrl: