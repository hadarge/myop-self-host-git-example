{
  "version": "0.2.10",
  "item": {
    "name": "PHDash_search",
    "id": "1f79f62f-84a4-4ef2-b25d-d9b1fcbed47c",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "bb008b7d-546c-473c-979e-96c7aa2301c1",
        "name": "V0",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Gallery Search Dashboard</title>\n  <style>\n    :root {\n      /* Using CSS variables for easier theme management */\n      --color-background: transparent; /* Page background set to transparent */\n      --color-component-bg: #FFFFFF; /* Component background */\n      --color-dropdown-bg: #FFFFFF; /* Dropdown background */\n      --color-search-bg: #FFFFFF; /* Search input background */\n      --color-text-primary: #050505;\n      --color-text-secondary: #222222;\n      --color-text-placeholder: #6b6b6b;\n      --color-text-muted: #aeaeae;\n      --color-border: #6b6b6b;\n      --color-border-focus: #222222;\n      --color-button-primary-bg: #222222;\n      --color-button-primary-text: #FFFFFF;\n      --color-button-primary-hover: #000000;\n    }\n\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;\n      background: var(--color-background);\n      color: var(--color-text-primary);\n      /* Added for smooth visual transitions */\n      transition: background-color 0.3s;\n      \n      /* Position component at top-left with a margin */\n      padding: 20px;\n    }\n\n    .dashboard-container {\n      max-width: 730px;\n      width: 100%; /* Make it responsive */\n      position: relative;\n      \n      /* --- Height & Standalone Styling --- */\n      transition: height 0.3s ease-out;\n      overflow: visible; /* Changed from hidden to allow dropdown to show */\n    }\n\n    .dashboard-container.open {\n      /* height: 480px; */ /* Removed fixed open height */\n    }\n\n    .header {\n      margin-bottom: 30px;\n    }\n\n    .header h1 {\n      font-size: 32px;\n      font-weight: 500;\n      margin-bottom: 8px;\n      color: var(--color-text-primary);\n    }\n\n    .header p {\n      font-size: 18px;\n      font-weight: 400;\n      color: var(--color-text-primary);\n      max-width: 505px;\n    }\n\n    .search-section {\n      display: flex;\n      gap: 24px;\n      align-items: flex-start;\n      position: relative;\n    }\n\n    .search-container {\n      position: relative;\n      flex: 1;\n      max-width: 472px;\n    }\n\n    .search-input-wrapper {\n      position: relative;\n      z-index: 10;\n    }\n\n    .search-input {\n      width: 100%;\n      height: 40px;\n      padding: 0 40px 0 40px;\n      border: 1px solid var(--color-border);\n      border-radius: 50px;\n      font-size: 14px;\n      font-weight: 400;\n      color: var(--color-text-secondary);\n      background: var(--color-search-bg); /* Use specific bg color */\n      outline: none;\n      transition: border-color 0.2s;\n    }\n\n    .search-input::placeholder {\n      color: var(--color-text-placeholder);\n    }\n\n    .search-input:focus {\n      border-color: var(--color-border-focus);\n    }\n\n    .search-icon {\n      position: absolute;\n      left: 14px;\n      top: 50%;\n      transform: translateY(-50%);\n      width: 16px;\n      height: 16px;\n      pointer-events: none;\n    }\n    \n    /* Styling for the search icon's stroke to match focus color */\n    .search-icon circle,\n    .search-icon path {\n      stroke: var(--color-border);\n      transition: stroke 0.2s;\n    }\n\n    .search-input:focus ~ .search-icon circle,\n    .search-input:focus ~ .search-icon path {\n        stroke: var(--color-border-focus);\n    }\n\n\n    .clear-button {\n      position: absolute;\n      right: 14px;\n      top: 50%;\n      transform: translateY(-50%);\n      width: 20px;\n      height: 20px;\n      border: none;\n      background: transparent;\n      cursor: pointer;\n      padding: 0;\n      display: none;\n      align-items: center;\n      justify-content: center;\n      opacity: 0.6;\n      transition: opacity 0.2s;\n    }\n\n    .clear-button:hover {\n      opacity: 1;\n    }\n\n    .clear-button.visible {\n      display: flex;\n    }\n\n    .dropdown {\n      position: absolute;\n      top: 58px;\n      left: 0;\n      /* Changed from fixed width to 100% to be responsive */\n      width: 100%;\n      background: var(--color-dropdown-bg); /* Use specific bg color */\n      border-radius: 20px; /* Applied to all corners for when it's visible */\n      box-shadow: 0px 8px 20px 0px rgba(0, 0, 0, 0.1);\n      padding: 20px 17px;\n      display: none;\n      z-index: 5;\n      /* Added for smoother appearance */\n      opacity: 0;\n      transform: translateY(-10px);\n      transition: opacity 0.2s ease-out, transform 0.2s ease-out;\n      overflow: hidden; /* Ensures content respects border radius */\n    }\n\n    /* When visible, change styles for animation */\n    .dropdown.visible {\n      display: block;\n      opacity: 1;\n      transform: translateY(0);\n    }\n    \n    .dropdown-title {\n      font-size: 14px;\n      font-weight: 500;\n      color: #000000;\n      margin-bottom: 24px;\n    }\n\n    .gallery-list {\n      display: flex;\n      flex-direction: column;\n      gap: 22px;\n    }\n\n    .gallery-item {\n      display: flex;\n      gap: 20px;\n      cursor: pointer;\n      transition: opacity 0.2s;\n    }\n\n    .gallery-item:hover {\n      opacity: 0.8;\n    }\n\n    .gallery-thumbnail {\n      width: 96px;\n      height: 64px;\n      border-radius: 4px;\n      object-fit: cover;\n      flex-shrink: 0;\n      background-color: #eee; /* Placeholder bg */\n    }\n\n    .gallery-info {\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n      gap: 8px;\n    }\n\n    .gallery-name {\n      font-size: 16px;\n      font-weight: 400;\n      color: var(--color-text-secondary);\n      line-height: 1.25;\n    }\n\n    .gallery-date {\n      font-size: 12px;\n      font-weight: 400;\n      color: var(--color-text-muted);\n      line-height: 1.25;\n    }\n\n    .new-gallery-button {\n      height: 40px;\n      padding: 0 32px;\n      background: var(--color-button-primary-bg);\n      color: var(--color-button-primary-text);\n      border: none;\n      border-radius: 50px;\n      font-size: 16px;\n      font-weight: 500;\n      cursor: pointer;\n      white-space: nowrap;\n      transition: background 0.2s, transform 0.1s ease-out;\n    }\n\n    .new-gallery-button:hover {\n      background: var(--color-button-primary-hover);\n    }\n\n    .new-gallery-button:active {\n      transform: scale(0.98);\n    }\n\n    /* Responsive Styles */\n    @media (max-width: 600px) {\n      body {\n        padding: 16px;\n      }\n      \n      .header h1 {\n        font-size: 28px;\n      }\n\n      .header p {\n        font-size: 16px;\n      }\n\n      .search-section {\n        flex-direction: column;\n        align-items: stretch; /* Make children full-width */\n        gap: 16px;\n      }\n\n      .search-container {\n        max-width: 100%;\n      }\n\n      .new-gallery-button {\n        /* Full width button on mobile */\n        width: 100%; \n      }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"dashboard-container\">\n    <div class=\"header\">\n      <!-- Content populated by JS -->\n      <h1></h1>\n      <p></p>\n    </div>\n\n    <div class=\"search-section\">\n      <div class=\"search-container\">\n        <div class=\"search-input-wrapper\">\n          <svg class=\"search-icon\" fill=\"none\" viewBox=\"0 0 16 16\">\n            <circle cx=\"7\" cy=\"7\" r=\"6.25\" stroke=\"#222222\" stroke-width=\"1.5\" fill=\"none\"/>\n            <path d=\"M11.5 11.5L14.5 14.5\" stroke=\"#222222\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n          </svg>\n          <input \n            type=\"text\" \n            class=\"search-input\" \n            placeholder=\"\"\n            id=\"searchInput\"\n          />\n          <!-- placeholder populated by JS -->\n          <button class=\"clear-button\" id=\"clearButton\">\n            <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\">\n              <line x1=\"1\" y1=\"1\" x2=\"11\" y2=\"11\" stroke=\"#8D8D8D\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n              <line x1=\"11\" y1=\"1\" x2=\"1\" y2=\"11\" stroke=\"#8D8D8D\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n            </svg>\n          </button>\n        </div>\n\n        <div class=\"dropdown\" id=\"dropdown\">\n          <!-- Title populated by JS -->\n          <div class=\"dropdown-title\"></div>\n          <!-- List populated by JS -->\n          <div class=\"gallery-list\" id=\"galleryList\">\n            <!-- Gallery items will be dynamically inserted here -->\n          </div>\n        </div>\n      </div>\n\n      <!-- Button text populated by JS -->\n      <button class=\"new-gallery-button\" id=\"newGalleryButton\"></button>\n    </div>\n  </div>\n\n  <script>\n    /**\n     * This script wraps all component logic in a DOMContentLoaded event.\n     * It exposes two global functions:\n     * 1. window.myop_init_interface(config): To initialize the component.\n     * 2. window.myop_cta_handler(action_id, payload): To handle all outbound actions.\n     */\n    document.addEventListener('DOMContentLoaded', () => {\n\n      // --- Internal Component State & Variables ---\n      let appConfig = null; // This will hold the config object\n      let galleryItems = []; // This will hold the DOM nodes\n      \n      // --- Element Selectors (Static) ---\n      const searchInput = document.getElementById('searchInput');\n      const dropdown = document.getElementById('dropdown');\n      const clearButton = document.getElementById('clearButton');\n      const newGalleryButton = document.getElementById('newGalleryButton');\n      const dropdownTitle = document.querySelector('.dropdown-title');\n      const galleryListContainer = document.getElementById('galleryList');\n      const headerH1 = document.querySelector('.header h1');\n      const headerP = document.querySelector('.header p');\n\n      /**\n       * Populates the page with content from the config object.\n       * This runs once when myop_init_interface is called.\n       * @param {object} config The searchConfig object.\n       */\n      function populateSearchComponent(config) { \n        if (!config) {\n          console.error(\"Configuration object is missing.\");\n          return;\n        }\n        \n        const { lang, Data } = config;\n\n        // 1. Populate Language Strings & Data Headers\n        if (headerH1) {\n          headerH1.textContent = Data.header1;\n        } else {\n          console.error(\"Header H1 not found\");\n        }\n        \n        if (headerP) {\n          headerP.textContent = Data.header2;\n        } else {\n            console.error(\"Header P not found\");\n        }\n        \n        if (searchInput) {\n          searchInput.placeholder = lang.searchInputPlaceholder;\n        } else {\n            console.error(\"Search Input not found\");\n        }\n        \n        if (newGalleryButton) {\n          newGalleryButton.textContent = lang.newGalleryButton;\n        } else {\n            console.error(\"New Gallery Button not found\");\n        }\n\n        // 2. Populate initial gallery list (recent)\n        renderGalleryList(Data.recentGalleries, lang.dropdownTitleRecent);\n      }\n\n      /**\n       * Renders a list of galleries in the dropdown.\n       * @param {Array} galleryList - The array of gallery objects to render.\n       * @param {string} title - The title to display (e.g., \"Recent galleries\").\n       */\n      function renderGalleryList(galleryList, title) {\n        if (!galleryListContainer || !dropdownTitle || !appConfig) return;\n        \n        const { lang } = appConfig;\n        \n        // 1. Set Title\n        dropdownTitle.textContent = title;\n        \n        // 2. Clear existing list\n        galleryListContainer.innerHTML = ''; \n\n        // 3. Render list\n        if (galleryList.length === 0) {\n            galleryListContainer.innerHTML = `<div class=\"gallery-name\" style=\"padding: 0 5px;\">${lang.noResults}</div>`;\n            return;\n        }\n        \n        galleryList.forEach(gallery => {\n          const itemHTML = `\n            <div class=\"gallery-item\" data-gallery=\"${gallery.id}\">\n              <img \n                src=\"${gallery.imageUrl}\" \n                alt=\"${gallery.altText}\"\n                class=\"gallery-thumbnail\"\n              />\n              <div class=\"gallery-info\">\n                <div class=\"gallery-name\">${gallery.name}</div>\n                <div class=\"gallery-date\">${gallery.date}</div>\n              </div>\n            </div>\n          `;\n          galleryListContainer.insertAdjacentHTML('beforeend', itemHTML);\n        });\n\n        // 4. Re-select gallery items and attach listeners\n        galleryItems = galleryListContainer.querySelectorAll('.gallery-item');\n        \n        galleryItems.forEach(item => {\n          item.addEventListener('click', () => {\n            // Get the ID (as a string from data-*) and convert to a number\n            const galleryId = parseInt(item.dataset.gallery, 10);\n\n            // Send to server (NEW FORMAT)\n            // Use the global CTA handler\n            if (window.myop_cta_handler) {\n              window.myop_cta_handler(\"navigation_item\", { \n                target: \"gallery\",\n                projectid: galleryId // Pass the numeric ID\n              });\n            }\n\n            // Close dropdown\n            if (dropdown) {\n              dropdown.classList.remove('visible');\n            }\n            if (searchInput) {\n              searchInput.blur();\n            }\n          });\n        });\n      }\n      \n      /**\n       * Filters the visible gallery list based on a search term.\n       * This is the core logic for switching between \"Recent\" and \"Search\".\n       * @param {string} searchTerm The term to filter by.\n       */\n      function filterGalleryList(searchTerm) {\n        // Ensure config is loaded before trying to filter\n        if (!appConfig) {\n          console.error(\"Cannot filter: appConfig is not initialized.\");\n          return;\n        }\n\n        const term = searchTerm.toLowerCase();\n        const { lang, Data } = appConfig;\n        \n        if (term.length > 0) {\n          // Search mode: Filter allGalleries\n          const searchResults = Data.allGalleries.filter(gallery => \n            gallery.name.toLowerCase().includes(term)\n          );\n          renderGalleryList(searchResults, lang.dropdownTitleSearch);\n        } else {\n          // Recent mode: Show recentGalleries\n          renderGalleryList(Data.recentGalleries, lang.dropdownTitleRecent);\n        }\n      }\n\n      // --- Event Listeners (Static) ---\n      \n      // We check if elements exist before adding listeners.\n      // This is a robust way to prevent \"cannot read properties of null\" errors.\n      if (searchInput) {\n        searchInput.addEventListener('focus', () => {\n          if (dropdown) {\n            dropdown.classList.add('visible');\n          }\n          filterGalleryList(searchInput.value); // Re-filter on focus\n        });\n\n        searchInput.addEventListener('input', (e) => {\n          const searchTerm = e.target.value;\n          \n          if (clearButton) {\n            clearButton.classList.toggle('visible', searchTerm.length > 0);\n          }\n          \n          filterGalleryList(searchTerm);\n        });\n      } // end if(searchInput)\n\n      // Hide dropdown when clicking outside\n      document.addEventListener('click', (e) => {\n        if (searchInput && dropdown && !searchInput.contains(e.target) && !dropdown.contains(e.target)) {\n          dropdown.classList.remove('visible');\n\n        }\n      });\n      \n      if (clearButton) {\n        clearButton.addEventListener('click', () => {\n          if (searchInput) {\n            searchInput.value = '';\n            searchInput.focus();\n          }\n          clearButton.classList.remove('visible');\n          filterGalleryList(''); // Reset filter to show \"Recent\"\n        });\n      } // end if(clearButton)\n\n      if (newGalleryButton) {\n        newGalleryButton.addEventListener('click', () => {\n          // Use the global CTA handler\n          if (window.myop_cta_handler) {\n            window.myop_cta_handler(\"new_gallery_clicked\", null);\n          }\n        });\n      } // end if(newGalleryButton)\n      \n\n      // --- (1) PUBLIC GLOBAL FUNCTION: myop_init_interface ---\n      /**\n       * Initializes the search component with data.\n       * This is the entry point for loading the component.\n       * @param {object} config The full configuration object.\n       */\n      window.myop_init_interface = (config) => {\n        if (!config || !config.lang || !config.Data) {\n          console.error(\"Initialization Error: Invalid config object provided.\", config);\n          return;\n        }\n        \n        // Store the config for internal use\n        appConfig = config;\n        \n        // Check for critical elements before trying to populate the page.\n        if (searchInput && galleryListContainer && newGalleryButton && headerH1 && headerP) {\n          populateSearchComponent(appConfig);\n        } else {\n          console.error(\"Critical elements missing, could not populate component.\");\n        }\n      };\n\n      // --- (2) PUBLIC GLOBAL FUNCTION: myop_cta_handler ---\n      /**\n       * Handles all component actions (e.g., clicks) and reports them.\n       * @param {string} action_id The action performed.\n       * @param {object | null} payload The data associated with the action.\n       */\n      window.myop_cta_handler = (action_id, payload) => {\n        const update = {\n          \"action\": action_id,\n          \"payload\": payload\n        };\n        \n        // Log in the exact format requested\n        console.log('CTA HANDLER:', update);\n      };\n\n      \n      // --- Example on how to test this from the console ---\n      \n      // 1. Copy the object below\n      const testConfig = { \n        lang: {\n          searchInputPlaceholder: \"Search galleries\",\n          dropdownTitleRecent: \"Recent galleries\",\n          dropdownTitleSearch: \"Search results\",\n          newGalleryButton: \"+ New gallery\",\n          noResults: \"No galleries found\"\n        },\n        Data: {\n          header1: \"Good evening, Sam\",\n          header2: \"You made your first sale! Here's to many more ahead.\",\n          recentGalleries: [\n            {\n              id: 1001,\n              imageUrl: \"https://images.unsplash.com/photo-1519741497674-611481863552?w=200&h=150&fit-crop\",\n              altText: \"Hanna & Stephen\",\n              name: \"Hanna & Stephen\",\n              date: \"June 6, 2025\"\n            },\n            {\n              id: 1002,\n              imageUrl: \"https://images.unsplash.com/photo-1606800052052-a08af7148866?w=200&h=150&fit-crop\",\n              altText: \"Hadar & David\",\n              name: \"Hadar & David\",\n              date: \"May 6, 2024\"\n            }\n          ],\n          allGalleries: [\n             {\n              id: 1001,\n              imageUrl: \"https://images.unsplash.com/photo-1519741497674-611481863552?w=200&h=150&fit-crop\",\n              altText: \"Hanna & Stephen\",\n              name: \"Hanna & Stephen\",\n              date: \"June 6, 2025\"\n            },\n            {\n              id: 1002,\n              imageUrl: \"https://images.unsplash.com/photo-1606800052052-a08af7148866?w=200&h=150&fit-crop\",\n              altText: \"Hadar & David\",\n              name: \"Hadar & David\",\n              date: \"May 6, 2024\"\n            },\n            {\n              id: 1003,\n              imageUrl: \"https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=200&h=150&fit-crop\",\n              altText: \"Hall of Fame\",\n              name: \"Hall of Fame\",\n              date: \"Jan 1, 2024\"\n            },\n            {\n              id: 2001,\n              imageUrl: \"https://images.unsplash.com/photo-1520854221256-14e5d225d9c8?w=200&h=150&fit-crop\",\n              altText: \"Jessica & Mike\",\n              name: \"Jessica & Mike's Wedding\",\n              date: \"Oct 12, 2023\"\n            }\n          ]\n        }\n      };\n\n      // 2. Paste it into your console and then run this command:\n      // window.myop_init_interface(testConfig);\n      \n      // 3. The component will now be populated and fully interactive.\n      \n      \n      // --- AUTOMATIC MOCK DATA CALL FOR TESTING ---\n      // We'll call the init function automatically so the component isn't blank on load.\n      if (window.myop_init_interface) {\n        window.myop_init_interface(testConfig);\n      }\n    \n    }); // End of DOMContentLoaded\n  </script>\n</body>\n</html>"
        }
      }
    ]
  }
}