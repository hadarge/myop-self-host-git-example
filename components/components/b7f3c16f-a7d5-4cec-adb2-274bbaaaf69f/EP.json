{
  "version": "0.2.10",
  "item": {
    "name": "Vendors - Galleries list",
    "id": "b7f3c16f-a7d5-4cec-adb2-274bbaaaf69f",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "a60b9722-9a2c-4690-83f5-639aa2e82188",
        "name": "Version 3",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":600,\"height\":800,\"minWidth\":320,\"minHeight\":400}'>\n    <title>Choose Gallery</title>\n\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n  profile_id?: string;\n  page_title?: string;\n  galleries: Array<{\n    id: string;\n    image_url: string;\n    couple_name: string;\n    photographer_name: string;\n  }>;\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'navigate_back': { profile_id?: string };\n  'search_focus': void;\n  'search_input': { query: string };\n  'search_submit': { query: string };\n  'select_gallery': { gallery_id: string };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n\n    <style>\n        /* --- Fonts --- */\n        @font-face {\n            font-family: 'TT Norms Pro';\n            src: url('https://fonts.cdnfonts.com/s/29009/TTNormsPro-Regular.woff') format('woff');\n            font-weight: 400;\n            font-style: normal;\n            font-display: swap;\n        }\n\n        @font-face {\n            font-family: 'TT Norms Pro';\n            src: url('https://fonts.cdnfonts.com/s/29009/TTNormsPro-Medium.woff') format('woff');\n            font-weight: 500;\n            font-style: normal;\n            font-display: swap;\n        }\n\n        /* --- Reset & Base --- */\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n        }\n\n        body {\n            font-family: 'TT Norms Pro', sans-serif;\n            background-color: #f9f9f9;\n            color: #222;\n            display: flex;\n            justify-content: center;\n        }\n\n        /* --- Main Container --- */\n        .app-container {\n            width: 100%;\n            max-width: 600px; \n            background: white;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            box-shadow: 0 0 20px rgba(0,0,0,0.05);\n            position: relative;\n        }\n\n        /* --- Header Section --- */\n        .header {\n            display: flex;\n            align-items: center;\n            padding: 24px 20px 0 20px; \n            margin-bottom: 24px;\n            flex-shrink: 0;\n        }\n\n        .back-button {\n            background: none;\n            border: none;\n            cursor: pointer;\n            padding: 10px; \n            margin-left: -10px; \n            display: flex;\n            align-items: center;\n            justify-content: center;\n            border-radius: 50%;\n        }\n        \n        /* Focus styles for accessibility */\n        .back-button:focus-visible {\n            outline: 2px solid #222;\n            background-color: rgba(0,0,0,0.05);\n        }\n\n        .back-button svg {\n            width: 9px;\n            height: 16px;\n        }\n\n        .page-title {\n            font-size: 26px;\n            font-weight: 500;\n            color: #222;\n            margin-left: 20px;\n            text-transform: capitalize;\n        }\n\n        /* --- Search Section --- */\n        .search-container {\n            position: relative;\n            margin-bottom: 24px;\n            padding: 0 20px;\n            width: 100%;\n            flex-shrink: 0;\n        }\n\n        .search-input {\n            width: 100%;\n            height: 48px;\n            border: 1px solid #8A8A8A;\n            border-radius: 8px;\n            padding: 0 16px 0 48px;\n            font-family: inherit;\n            font-size: 16px;\n            outline: none;\n            transition: border-color 0.2s;\n            background: transparent;\n            -webkit-appearance: none;\n            appearance: none;\n        }\n\n        .search-input:focus {\n            border-color: #222;\n        }\n\n        .search-icon {\n            position: absolute;\n            left: 36px;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 18px;\n            height: 18px;\n            pointer-events: none;\n        }\n\n        /* --- Gallery List --- */\n        .gallery-list {\n            display: flex;\n            flex-direction: column;\n            overflow-y: auto;\n            flex: 1;\n            min-height: 0;\n            padding: 0 20px 40px 20px;\n            /* Performance: Isolated layout containment for scrolling lists */\n            contain: content;\n            -webkit-overflow-scrolling: touch;\n        }\n\n        /* Wrapper to separate items from 'No Results' msg */\n        .gallery-items-wrapper {\n            display: flex;\n            flex-direction: column;\n            gap: 24px;\n        }\n\n        /* Scrollbar Styling */\n        .gallery-list::-webkit-scrollbar {\n            width: 6px;\n        }\n        .gallery-list::-webkit-scrollbar-track {\n            background: transparent;\n        }\n        .gallery-list::-webkit-scrollbar-thumb {\n            background-color: rgba(0,0,0,0.1);\n            border-radius: 3px;\n        }\n\n        .gallery-item {\n            display: flex;\n            align-items: flex-start;\n            gap: 19px;\n            text-decoration: none; \n            transition: opacity 0.2s, background-color 0.2s;\n            cursor: pointer;\n            flex-shrink: 0;\n            position: relative;\n            outline: none; /* Focus handled by focus-visible */\n        }\n\n        .gallery-item:hover {\n            opacity: 0.8;\n        }\n\n        /* Keyboard focus state */\n        .gallery-item:focus-visible {\n            opacity: 1;\n            outline: 2px solid #222;\n            outline-offset: 4px;\n            border-radius: 4px;\n        }\n\n        .gallery-image {\n            width: 68px;\n            height: 68px;\n            border-radius: 4px;\n            overflow: hidden;\n            flex-shrink: 0;\n            background-color: #eee;\n        }\n\n        .gallery-image img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n        }\n\n        .gallery-info {\n            padding-top: 8px;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .couple-name {\n            font-size: 16px;\n            font-weight: 500;\n            color: #1c1c1c;\n            margin-bottom: 4px;\n            line-height: 1.3;\n        }\n\n        .photographer-name {\n            font-size: 14px;\n            font-weight: 400;\n            color: #666;\n            line-height: 1.4;\n        }\n\n        /* No Results State */\n        .no-results {\n            display: none;\n            text-align: center;\n            color: #666;\n            margin-top: 20px;\n            font-size: 15px;\n            width: 100%;\n        }\n\n        @media (max-width: 480px) {\n            .app-container {\n                box-shadow: none;\n                max-width: 100%;\n            }\n            .header {\n                margin-top: 12px; \n            }\n        }\n    </style>\n</head>\n<body>\n\n    <div class=\"app-container\">\n        <header class=\"header\">\n            <button id=\"backButton\" class=\"back-button\" aria-label=\"Go back\">\n                <svg viewBox=\"0 0 9 17\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M7.81606 1L1.13447 8.15885C0.955175 8.35095 0.955176 8.64906 1.13447 8.84116L7.81606 16\" stroke=\"#222222\" stroke-linecap=\"round\" stroke-width=\"2\" />\n                </svg>\n            </button>\n            <h1 class=\"page-title\">Choose gallery</h1>\n        </header>\n\n        <div class=\"search-container\">\n            <div class=\"search-icon\">\n                <svg viewBox=\"0 0 21 21\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <circle cx=\"9.5\" cy=\"9.5\" r=\"7.5\" stroke=\"#222222\" stroke-width=\"2\"/>\n                    <path d=\"M14.5 14.5L19 19\" stroke=\"#222222\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            <input \n                type=\"search\" \n                id=\"searchInput\" \n                class=\"search-input\" \n                placeholder=\"Search galleries...\"\n                aria-label=\"Search galleries\"\n                inputmode=\"search\" \n                enterkeyhint=\"search\"\n            >\n        </div>\n\n        <div id=\"galleryList\" class=\"gallery-list\">\n            <!-- Wrapper for items to separate from 'No Results' message -->\n            <div id=\"galleryItemsWrapper\" class=\"gallery-items-wrapper\"></div>\n            <div id=\"noResultsMessage\" class=\"no-results\">No galleries found</div>\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        'use strict';\n\n        // State & DOM Caching\n        let appConfig = {};\n\n        // Performance: Cache searchable text in memory to avoid DOM reads during filter\n        // Structure: [ { element: DOMNode, text: \"string\" }, ... ]\n        let searchCache = [];\n        let searchDebounceTimer = null;\n\n        const elements = {\n            galleryList: document.getElementById('galleryList'),\n            galleryItemsWrapper: document.getElementById('galleryItemsWrapper'),\n            backButton: document.getElementById('backButton'),\n            searchInput: document.getElementById('searchInput'),\n            pageTitle: document.querySelector('.page-title'),\n            noResultsMsg: document.getElementById('noResultsMessage')\n        };\n\n        // --- Interface Initialization ---\n        window.myop_init_interface = function(config) {\n            if (!config) return appConfig;\n\n            appConfig = config || {};\n\n            if (config.page_title && elements.pageTitle) {\n                elements.pageTitle.textContent = config.page_title;\n            }\n\n            // Clear previous state\n            elements.noResultsMsg.style.display = 'none';\n            elements.galleryItemsWrapper.innerHTML = '';\n            searchCache = [];\n\n            if (config.galleries && Array.isArray(config.galleries) && config.galleries.length > 0) {\n                const items = config.galleries.map(gallery => {\n                    // Create searchable string\n                    const searchText = (gallery.couple_name + ' ' + gallery.photographer_name).toLowerCase();\n\n                    return {\n                        html: `\n                            <div class=\"gallery-item\" data-id=\"${gallery.id}\" role=\"button\" tabindex=\"0\" aria-label=\"Select gallery for ${gallery.couple_name}\">\n                                <div class=\"gallery-image\">\n                                    <img src=\"${gallery.image_url}\" alt=\"\" loading=\"lazy\" decoding=\"async\">\n                                </div>\n                                <div class=\"gallery-info\">\n                                    <p class=\"couple-name\">${gallery.couple_name}</p>\n                                    <p class=\"photographer-name\">${gallery.photographer_name}</p>\n                                </div>\n                            </div>\n                        `,\n                        searchText: searchText\n                    };\n                });\n\n                elements.galleryItemsWrapper.innerHTML = items.map(item => item.html).join('');\n\n                // Build search cache after DOM insertion\n                const itemElements = elements.galleryItemsWrapper.querySelectorAll('.gallery-item');\n                searchCache = Array.from(itemElements).map((element, index) => ({\n                    element: element,\n                    text: items[index].searchText\n                }));\n            } else {\n                // Show 'No Results' if no galleries provided\n                elements.noResultsMsg.style.display = 'block';\n            }\n        };\n\n        // --- Local Filter Logic (Optimized) ---\n        function filterGalleries(query) {\n            const normalizedQuery = query.toLowerCase().trim();\n            let hasVisibleItems = false;\n\n            // Use memory cache instead of DOM querying\n            searchCache.forEach(itemObj => {\n                if (itemObj.text.includes(normalizedQuery)) {\n                    itemObj.element.style.display = ''; // Show\n                    hasVisibleItems = true;\n                } else {\n                    itemObj.element.style.display = 'none'; // Hide\n                }\n            });\n\n            // Toggle No Results Message\n            elements.noResultsMsg.style.display = hasVisibleItems ? 'none' : 'block';\n        }\n\n        // --- CTA Handler ---\n        window.myop_cta_handler = function(action_id, payload) {\n            console.log(`[CTA Handler] Action: ${action_id}`, payload);\n        };\n\n        // --- Event Listeners ---\n\n        // 1. Navigation Logic (Click & Keyboard)\n        function handleSelection(target) {\n            const item = target.closest('.gallery-item');\n            if (!item) return;\n\n            const galleryId = item.dataset.id;\n            if (galleryId) {\n                window.myop_cta_handler('select_gallery', {\n                    gallery_id: galleryId\n                });\n            }\n        }\n\n        elements.galleryList.addEventListener('click', function(e) {\n            handleSelection(e.target);\n        });\n\n        // Accessibility: Allow keyboard selection (Enter or Space)\n        elements.galleryList.addEventListener('keydown', function(e) {\n            if (e.key === 'Enter' || e.key === ' ') {\n                e.preventDefault(); // Prevent scrolling for space\n                handleSelection(e.target);\n            }\n        });\n\n        // 2. Back Navigation\n        elements.backButton.addEventListener('click', function() {\n            window.myop_cta_handler('navigate_back', {\n                profile_id: appConfig.profile_id\n            });\n        });\n\n        // 3. Search (Local Filter + Debounced Analytics)\n        elements.searchInput.addEventListener('input', function(e) {\n            const query = e.target.value;\n            \n            // 1. Filter UI immediately (Fast)\n            filterGalleries(query);\n\n            // 2. Report to Host (Debounced)\n            // We debounce analytics to avoid flooding the host bridge\n            clearTimeout(searchDebounceTimer);\n            searchDebounceTimer = setTimeout(() => {\n                 window.myop_cta_handler('search_input', { query: query });\n            }, 300);\n        });\n        \n        elements.searchInput.addEventListener('keydown', function(e) {\n            if (e.key === 'Enter') {\n                e.preventDefault(); \n                elements.searchInput.blur(); \n                window.myop_cta_handler('search_submit', { query: e.target.value });\n            }\n        });\n        \n        elements.searchInput.addEventListener('focus', function() {\n            window.myop_cta_handler('search_focus', undefined);\n        });\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        // --- Mock Data (Dev Only) ---\n        const generateMockGalleries = (count) => {\n            const baseGalleries = [\n                { img: \"https://images.unsplash.com/photo-1606800052052-a08af7148866?w=400\", names: [\"John & Jessica\", \"Alex & Sam\", \"Jordan & Taylor\"] },\n                { img: \"https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=400\", names: [\"Emma & Liam\", \"Olivia & Noah\", \"Sophia & Elijah\"] },\n                { img: \"https://images.unsplash.com/photo-1520763185298-1b434c919102?w=400\", names: [\"Sophia & Noah\", \"Isabella & James\", \"Mia & Benjamin\"] },\n                { img: \"https://images.unsplash.com/photo-1487530811176-3780de880c2d?w=400\", names: [\"Ava & Ethan\", \"Charlotte & Lucas\", \"Amelia & Henry\"] }\n            ];\n\n            let result = [];\n            for (let i = 0; i < count; i++) {\n                const base = baseGalleries[i % baseGalleries.length];\n                result.push({\n                    id: `g${i}`,\n                    image_url: base.img,\n                    couple_name: base.names[i % base.names.length] + ` (${i + 1})`,\n                    photographer_name: \"Mock Photography Studio\"\n                });\n            }\n            return result;\n        };\n\n        window.myop_init_interface({\n            profile_id: \"user_12345\",\n            page_title: \"Choose gallery\",\n            galleries: generateMockGalleries(15)\n        });\n    </script>\n</body>\n</html>"
        }
      }
    ]
  }
}