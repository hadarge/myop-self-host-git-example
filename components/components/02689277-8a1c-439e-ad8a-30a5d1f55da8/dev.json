        "id": "3a777823-0fd0-4eb3-9a3e-1c3a7e1058ac",
        "name": "Your variant",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\ninterface FontConfig {\n    id: string;\n    family: string;\n    style?: string;\n    weight?: number;\n    url: string;\n}\n\ninterface LangStrings {\n    welcomeLabel: string;\n    headline: string;\n}\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n    fonts: FontConfig[];\n    lang: LangStrings;\n    videoUrl: string;\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n    'video-error': { error: string };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n    action: K,\n    payload: MyopCtaPayloads[K]\n): void;\n    </script>\n\n    <style>\n        * { box-sizing: border-box; margin: 0; padding: 0; }\n        html, body {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            margin: 0;\n            padding: 0;\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            position: relative;\n            background-color: #F5F3EF;\n            font-family: var(--font_main), serif;\n        }\n\n        /* Video Background */\n        .video-container {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            right: 0;\n            height: 72%;\n            overflow: hidden;\n            z-index: 0;\n        }\n\n        .video-container video {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            object-position: center top;\n        }\n\n        /* Content Overlay */\n        .content {\n            position: relative;\n            z-index: 1;\n            padding: 32px 24px;\n            display: flex;\n            flex-direction: column;\n        }\n\n        /* Logo */\n        .logo {\n            width: 41px;\n            height: 31px;\n            margin-bottom: 61px;\n        }\n\n        .logo svg {\n            width: 100%;\n            height: 100%;\n        }\n\n        /* Text Content */\n        .text-content {\n            display: flex;\n            flex-direction: column;\n            gap: 24px;\n        }\n\n        .welcome-label {\n            font-family: var(--font_main), sans-serif;\n            font-size: 14px;\n            font-weight: 500;\n            font-style: normal;\n            line-height: 130%;\n            letter-spacing: 1.12px;\n            text-transform: uppercase;\n            text-align: center;\n            color: #98452A;\n        }\n\n        .headline {\n            font-family: var(--font_main), serif;\n            font-size: 26px;\n            font-weight: 400;\n            font-style: normal;\n            line-height: 120%;\n            text-align: center;\n            font-feature-settings: 'liga' off;\n            color: #232323;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\"></div>\n\n    <script>\n    (function() {\n        let currentState = null;\n        let fontsLoaded = new Set();\n\n        function loadFont(font) {\n            if (fontsLoaded.has(font.id)) return;\n\n            if (font.url) {\n                const link = document.createElement('link');\n                link.rel = 'stylesheet';\n                link.href = font.url;\n                document.head.appendChild(link);\n            }\n\n            // Set CSS variables for this font\n            document.documentElement.style.setProperty(`--font_${font.id}`, font.family);\n            if (font.weight) {\n                document.documentElement.style.setProperty(`--font_${font.id}_weight`, font.weight);\n            }\n            if (font.style) {\n                document.documentElement.style.setProperty(`--font_${font.id}_style`, font.style);\n            }\n\n            fontsLoaded.add(font.id);\n        }\n\n        function render(data) {\n            const container = document.getElementById('app-root');\n\n            // Load fonts\n            if (data.fonts && Array.isArray(data.fonts)) {\n                data.fonts.forEach(font => loadFont(font));\n            }\n\n            container.innerHTML = `\n                <div class=\"video-container\">\n                    <video autoplay loop muted playsinline>\n                        <source src=\"${data.videoUrl}\" type=\"video/webm\">\n                    </video>\n                </div>\n\n                <div class=\"content\">\n                    <div class=\"logo\">\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"41\" height=\"31\" viewBox=\"0 0 41 31\" fill=\"none\">\n                            <path d=\"M14.1631 2.18628C21.9063 2.18628 28.2031 8.48786 28.2031 16.2263C28.2029 23.9646 21.9062 30.2654 14.1631 30.2654C6.42004 30.2654 0.123272 23.9691 0.123047 16.2263C0.123047 8.48336 6.4199 2.18629 14.1631 2.18628ZM14.1631 3.32788C7.04836 3.32789 1.26465 9.11625 1.26465 16.2263C1.26487 23.3362 7.05295 29.1238 14.1631 29.1238C21.2732 29.1238 27.0613 23.3362 27.0615 16.2263C27.0615 9.11182 21.2734 3.32788 14.1631 3.32788Z\" fill=\"black\" stroke=\"black\" stroke-width=\"0.245458\"/>\n                            <path d=\"M40.3701 0.122437V6.43787H29.3398V0.122437H40.3701ZM30.3809 5.35876H39.3291V1.20154H30.3809V5.35876Z\" fill=\"black\" stroke=\"black\" stroke-width=\"0.245458\"/>\n                        </svg>\n                    </div>\n\n                    <div class=\"text-content\">\n                        <p class=\"welcome-label\">${data.lang.welcomeLabel}</p>\n                        <h1 class=\"headline\">${data.lang.headline}</h1>\n                    </div>\n                </div>\n            `;\n\n            // Handle video errors\n            const video = container.querySelector('video');\n            if (video) {\n                video.addEventListener('error', function(e) {\n                    window.myop_cta_handler('video-error', { error: 'Video failed to load' });\n                });\n            }\n        }\n\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            currentState = data;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            fonts: [\n                {\n                    id: \"main\",\n                    family: \"TT Norms Pro\",\n                    style: \"normal\",\n                    weight: 400,\n                    url: \"https://pictimecloudaf.blob.core.windows.net/pictures/fonts/tt_norms_pro.css\"\n                }\n            ],\n            lang: {\n                welcomeLabel: \"Welcome to pic-time\",\n                headline: \"Continue on desktop to create your first gallery\"\n            },\n            videoUrl: \"https://user-components-assets.s3.eu-south-1.amazonaws.com/02689277-8a1c-439e-ad8a-30a5d1f55da8/mob1.webm\"\n        });\n    </script>\n</body>\n</html>\n"
        }
