{
  "version": "0.2.10",
  "item": {
    "name": "Public Vendor profile (complete)",
    "id": "dec3b94e-749e-41d8-9fd1-d1405c1dc843",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "name": "Version 16",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":450,\"height\":850,\"minWidth\":320,\"maxWidth\":450}'>\n    <title>Vendor Portfolio</title>\n\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Font definition from the host app\n */\ninterface MyopFont {\n  id: string;\n  family: string;\n  url: string;\n}\n\n/**\n * Social links object (one entry in the socialLinks array)\n */\ninterface MyopSocialLinks {\n  website?: string | null;\n  facebook?: string | null;\n  instagram?: string | null;\n  twitter?: string | null;\n  tiktok?: string | null;\n}\n\n/**\n * Data structure passed to myop_init_interface(data) — matches host app DTO\n */\ninterface MyopInitData {\n  fonts?: MyopFont[];\n  vendorAccountId: number;\n  storeId?: number;\n  createDate?: string;\n  vendorName: string;\n  types: string[];\n  hasLogo: boolean;\n  businessEmail?: string;\n  description?: string;\n  socialLinks: MyopSocialLinks[];\n  profileMedia: string[];\n  profileAvatar?: string | null;\n  colorIndex: number;\n  mobileMode?: boolean;\n  mobileApp?: boolean;\n  /** CDN base URL for resolving profileMedia and profileAvatar filenames */\n  mediaBaseUrl?: string;\n  /** When true, renders the no-internet empty state */\n  no_internet?: boolean;\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'navigate_back': void;\n  'reload-requested': void;\n  'share_profile': { profile_id: number };\n  'email': { value: string };\n  'facebook': { value: string };\n  'instagram': { value: string };\n  'tiktok': { value: string };\n  'twitter': { value: string };\n  'website': { value: string };\n  'view_photo': { photo_id: string };\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap');\n\n        * {\n            box-sizing: border-box;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            font-family: var(--font-main, 'Inter', -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif);\n            background-color: #f3f4f6;\n            color: #222;\n        }\n\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n        .app-container {\n            width: 100%;\n            height: 100%;\n            max-width: 450px;\n            background-color: white;\n            display: flex;\n            flex-direction: column;\n            position: relative;\n            margin: 0 auto;\n        }\n\n        @media (min-width: 640px) {\n            .app-container {\n                border-radius: 40px;\n                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);\n                border: 1px solid #f3f4f6;\n            }\n        }\n\n        /* Animations */\n        .fade-in { animation: fadeIn 0.3s ease-out; }\n        .slide-up { animation: slideUp 0.4s ease-out; }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes slideUp {\n            from { transform: translateY(100%); }\n            to { transform: translateY(0); }\n        }\n\n        /* No Internet Empty State */\n        .no-internet-state {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100%;\n            padding: 48px 32px;\n            text-align: center;\n            gap: 16px;\n        }\n\n        .no-internet-icon {\n            width: 64px;\n            height: 64px;\n            color: #9ca3af;\n            margin-bottom: 8px;\n        }\n\n        .no-internet-title {\n            font-size: 16px;\n            font-weight: 500;\n            color: #374151;\n            line-height: 1.4;\n            margin: 0;\n        }\n\n        .no-internet-retry {\n            margin-top: 8px;\n            padding: 12px 28px;\n            background-color: #111827;\n            color: white;\n            border: none;\n            border-radius: 999px;\n            font-size: 14px;\n            font-weight: 500;\n            cursor: pointer;\n            transition: background-color 0.2s, transform 0.1s;\n            font-family: inherit;\n        }\n\n        .no-internet-retry:hover { background-color: #374151; }\n        .no-internet-retry:active { transform: scale(0.97); }\n\n        .photo-item {\n            aspect-ratio: 1 / 1;\n            background-color: #f3f4f6;\n            overflow: hidden;\n            position: relative;\n            cursor: pointer;\n        }\n\n        .photo-item img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            transition: transform 0.5s ease;\n        }\n\n        .photo-item:hover img {\n            transform: scale(1.1);\n        }\n    </style>\n</head>\n<body>\n\n    <div id=\"app-root\" class=\"app-container no-scrollbar overflow-y-auto\">\n        <!-- Header -->\n        <header class=\"px-6 pt-10 pb-4 flex justify-between items-center sticky top-0 bg-white/80 backdrop-blur-md z-20\">\n            <button onclick=\"myop_cta_handler('navigate_back', {})\" class=\"p-2 hover:bg-gray-50 rounded-full transition-colors group\" aria-label=\"Go back\">\n                <svg width=\"10\" height=\"19\" viewBox=\"0 0 10 19\" fill=\"none\" stroke=\"#222222\" stroke-width=\"2\" stroke-linecap=\"round\">\n                    <path d=\"M8.66944 1L1.13949 8.83536C0.953503 9.02889 0.953503 9.33475 1.13949 9.52828L8.66944 17.3636\"/>\n                </svg>\n            </button>\n\n            <button onclick=\"myop_cta_handler('share_profile', { profile_id: window.currentProfileId })\" id=\"share-btn\" class=\"flex items-center gap-2 px-4 py-2 rounded-full transition-all active:scale-95 hover:bg-gray-50\">\n                <div style=\"width: 18px; height: 23px;\">\n                    <svg viewBox=\"0 0 18 23\" fill=\"none\" style=\"width:100%; height:100%;\">\n                        <path d=\"M10.0002 3.41905V7.0002H16.005C17.1066 7.0002 18 7.89455 18 8.9942V21.006C18 22.1066 17.1075 23 16.005 23H1.995C0.893448 23 0 22.1056 0 21.006V8.9942C0 7.89268 0.892512 7.0002 1.995 7.0002H7.9998V3.41617L6.87106 4.54487C6.48386 4.93205 5.85574 4.93205 5.46293 4.53831C5.07199 4.14832 5.0748 3.51273 5.45637 3.13117L8.29797 0.28967C8.49015 0.0974893 8.74235 0.000935967 8.99545 0L9.00295 0.00374987C9.25702 0.00374987 9.50921 0.0993721 9.69951 0.289676L12.5401 3.13117C12.9273 3.51835 12.9273 4.14552 12.5345 4.53832C12.1436 4.92924 11.508 4.92643 11.1264 4.54488L10.0002 3.41905ZM7.99958 8.99981H1.99958V20.9994H16.0002V8.99981H10.0002V13.0019C10.0002 13.5531 9.55584 14.0003 8.9999 14.0003C8.44771 14.0003 7.99958 13.5522 7.99958 13.0019V8.99981ZM4.99958 7.0002V8.99981H13.0002V7.0002H4.99958ZM7.9998 7.0002H10.0002L10.0002 8.99981H7.99958L7.9998 7.0002Z\" fill=\"black\" />\n                    </svg>\n                </div>\n                <span class=\"text-sm font-medium\" id=\"share-text\">Share</span>\n            </button>\n        </header>\n\n        <!-- Profile Section -->\n        <main class=\"flex-1\">\n            <section class=\"px-8 mt-6\">\n                <div class=\"flex items-center gap-6 mb-6\">\n                    <div id=\"avatar-container\" class=\"w-[86px] h-[86px] rounded-full flex-shrink-0 flex items-center justify-center text-white text-[32px] font-normal tracking-wide overflow-hidden bg-[#749BA7]\">\n                        <span id=\"profile-initials\">VN</span>\n                        <img id=\"profile-img\" class=\"hidden w-full h-full object-cover\" src=\"\" alt=\"Profile\">\n                    </div>\n                    <div class=\"flex flex-col\">\n                        <h1 id=\"profile-name\" class=\"text-[26px] font-medium tracking-tight text-[#222] leading-[1.3]\">Vivian Ng</h1>\n                        <p id=\"profile-type\" class=\"text-base text-[#222] mt-1 leading-[1.25]\">Hair Stylist, Makeup Artist</p>\n                    </div>\n                </div>\n\n                <p id=\"profile-description\" class=\"text-base text-[#222] leading-[1.4] mb-8 pr-4\">\n                    Blending contemporary and classic styles, wild textures, and timeless elegance, this Portland-based hair stylist and makeup artist brings your perfect day to life.\n                </p>\n\n                <!-- Social Links -->\n                <div class=\"flex items-center gap-8 mb-10\" id=\"social-container\">\n                    <!-- Dynamic Social Buttons -->\n                </div>\n            </section>\n\n            <!-- Photo Grid -->\n            <section class=\"mt-auto\">\n                <div class=\"px-6 mb-4\">\n                    <h2 class=\"text-base font-normal text-[#222]\">Photos of my work</h2>\n                </div>\n                <div id=\"photo-grid\" class=\"grid grid-cols-3 gap-[2px]\">\n                    <!-- Grid items -->\n                </div>\n            </section>\n        </main>\n\n        <!-- Detail Modal (hidden by default) -->\n        <div id=\"photo-modal\" onclick=\"closeModal(event)\" class=\"hidden fixed sm:absolute inset-0 z-50 bg-black/95 flex flex-col fade-in cursor-pointer\">\n            <div class=\"p-6 flex justify-between items-center text-white\">\n                <div class=\"flex items-center gap-3\">\n                    <div id=\"modal-mini-avatar\" class=\"w-8 h-8 rounded-full flex items-center justify-center text-[10px] font-bold\">VN</div>\n                    <span class=\"text-sm font-medium tracking-wide\">Work by <span id=\"modal-author\">Vivian</span></span>\n                </div>\n                <button onclick=\"closeModal(event, true)\" class=\"p-2 bg-white/10 hover:bg-white/20 rounded-full backdrop-blur-sm transition-colors\" aria-label=\"Close modal\">\n                    <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M6 18L18 6M6 6l12 12\"></path></svg>\n                </button>\n            </div>\n\n            <div class=\"flex-1 flex items-center justify-center p-4 overflow-hidden\" onclick=\"event.stopPropagation()\">\n                <img id=\"modal-img\" src=\"\" alt=\"Enlarged view\" class=\"max-w-full max-h-[60vh] object-contain rounded-lg shadow-2xl cursor-default\">\n            </div>\n\n            <div class=\"bg-white p-8 rounded-t-[32px] slide-up cursor-default\" onclick=\"event.stopPropagation()\">\n                <div class=\"flex items-start justify-between mb-4\">\n                    <h3 class=\"text-lg font-semibold text-gray-900\">Project Details</h3>\n                </div>\n\n                <div class=\"space-y-4\">\n                    <div>\n                        <label class=\"text-xs font-bold text-gray-400 uppercase tracking-tighter block mb-2\">Tagged Collaborators</label>\n                        <div id=\"modal-tags\" class=\"flex flex-wrap gap-2\">\n                            <!-- Tags populated here -->\n                        </div>\n                    </div>\n\n                    <div class=\"pt-4\">\n                        <button id=\"modal-cta\" class=\"w-full py-4 bg-gray-900 text-white rounded-2xl font-bold text-sm flex items-center justify-center gap-2 hover:bg-gray-800 transition-colors\">\n                            Book a Service\n                        </button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n    (function() {\n        // --- Private Scope - All Implementation Details ---\n\n        // Color palette indexed by colorIndex\n        const COLOR_PALETTE = [\n            '#749BA7', '#E8A87C', '#85C1AE', '#C39BD3',\n            '#F1948A', '#7FB3D3', '#82E0AA', '#F7DC6F',\n            '#A9CCE3', '#D2B4DE'\n        ];\n\n        // Social Icons Definitions (supports all host app social types)\n        const SOCIAL_ICONS = {\n            instagram: `<svg viewBox=\"0 0 25 25\" fill=\"none\" class=\"w-full h-full\"><path d=\"M12.5 7.292C9.628 7.292 7.292 9.62893 7.292 12.5C7.292 15.372 9.62892 17.708 12.5 17.708C15.372 17.708 17.708 15.3711 17.708 12.5C17.708 9.628 15.372 7.292 12.5 7.292ZM12.5 15.625C10.7764 15.625 9.375 14.2236 9.375 12.5C9.375 10.7764 10.7764 9.375 12.5 9.375C14.2236 9.375 15.625 10.7764 15.625 12.5C15.625 14.2236 14.2236 15.625 12.5 15.625ZM19.792 2.083H5.208C3.48535 2.083 2.083 3.48535 2.083 5.208V19.791C2.083 21.5146 3.48438 22.916 5.208 22.916H19.791C21.5146 22.916 22.916 21.5146 22.916 19.791L22.917 5.208C22.917 3.48535 21.5146 2.083 19.792 2.083ZM20.833 19.792C20.833 20.3672 20.3662 20.834 19.791 20.834L5.20802 20.833C4.6338 20.833 4.16602 20.3662 4.16602 19.791L4.167 5.20802C4.167 4.6338 4.63478 4.16602 5.209 4.16602H19.792C20.3672 4.16602 20.834 4.6338 20.834 5.20802L20.833 19.792ZM18.4482 6.55175C18.6348 6.74999 18.75 7.0205 18.75 7.29198C18.75 7.56248 18.6348 7.83398 18.4482 8.03123C18.3955 8.07322 18.3428 8.11423 18.291 8.15623C18.2295 8.19724 18.166 8.22947 18.1045 8.24998C18.041 8.28123 17.9795 8.30173 17.917 8.31248C17.8438 8.32224 17.7803 8.33298 17.708 8.33298C17.4375 8.33298 17.166 8.21775 16.9688 8.03123C16.7803 7.83299 16.667 7.56248 16.667 7.29198C16.667 7.02051 16.7813 6.74998 16.9688 6.55273C17.0205 6.51074 17.0723 6.46875 17.124 6.42676C17.1875 6.38574 17.25 6.35351 17.3125 6.33301C17.375 6.30176 17.4375 6.28125 17.5 6.27051C17.6455 6.23926 17.7803 6.23926 17.917 6.27051C17.9795 6.28027 18.041 6.30175 18.1045 6.33301C18.166 6.35351 18.2295 6.38574 18.291 6.42676C18.3428 6.46875 18.3955 6.51074 18.4482 6.55175Z\" fill=\"black\" /></svg>`,\n            email: `<svg viewBox=\"0 0 28 28\" fill=\"none\" class=\"w-full h-full\"><path d=\"M2.24 5.6C1.77626 5.6 1.4 5.97626 1.4 6.44V21.56C1.4 22.0237 1.77626 22.4 2.24 22.4H25.76C26.2237 22.4 26.6 22.0237 26.6 21.56V6.44C26.6 5.97626 26.2237 5.6 25.76 5.6H2.24ZM4.6725 7.28H23.3275L14.0001 14.6126L4.6725 7.28ZM3.08 8.16374L13.4837 16.3364C13.7877 16.5726 14.2121 16.5726 14.5162 16.3364L24.9199 8.16374V20.7201H3.07986L3.08 8.16374Z\" fill=\"black\" /></svg>`,\n            website: `<svg viewBox=\"0 0 22 22\" fill=\"none\" class=\"w-full h-full\"><path d=\"M11 22C8.08236 22 5.2844 20.8407 3.2219 18.7781C1.1594 16.7155 0 13.9174 0 11C0 8.08258 1.15929 5.2844 3.2219 3.2219C5.28451 1.1594 8.08258 0 11 0C13.9174 0 16.7156 1.15929 18.7781 3.2219C20.8406 5.28451 22 8.08258 22 11C21.9966 13.9168 20.8364 16.7123 18.7748 18.7748C16.7123 20.8364 13.9168 21.9967 11 22ZM11 1.69202C8.53182 1.69202 6.1644 2.67256 4.41804 4.41804C2.67265 6.16429 1.69202 8.53182 1.69202 11C1.69202 13.4682 2.67256 15.8356 4.41804 17.582C6.16429 19.3274 8.53182 20.308 11 20.308C13.4682 20.308 15.8356 19.3274 17.582 17.582C19.3274 15.8357 20.308 13.4682 20.308 11C20.3045 8.5327 19.3231 6.16682 17.5787 4.42156C15.8333 2.67703 13.4673 1.69554 11.0002 1.69224L11 1.69202Z\" fill=\"black\" /><path d=\"M11 22C8.10656 22 5.92284 17.2709 5.92284 11C5.92284 4.72912 8.10652 -3.27826e-07 11 -3.27826e-07C13.8935 -3.27826e-07 16.0772 4.72912 16.0772 11C16.0772 17.2709 13.8935 22 11 22ZM11 1.69202C9.40243 1.69202 7.61574 5.66918 7.61574 11C7.61574 16.3308 9.40324 20.308 11 20.308C12.5976 20.308 14.3843 16.3308 14.3843 11C14.3843 5.66918 12.5976 1.69202 11 1.69202Z\" fill=\"black\" /><path d=\"M11 8.46142C7.43006 8.46142 4.0854 7.55821 2.0504 6.04318C1.70837 5.75443 1.64993 5.24911 1.91806 4.89075C2.18531 4.53154 2.68634 4.44389 3.06016 4.68966C4.81242 5.99076 7.78423 6.76934 11 6.76934C14.2157 6.76934 17.1875 5.99074 18.9398 4.68621C19.1177 4.53582 19.3497 4.46535 19.5817 4.49199C19.8138 4.51863 20.0243 4.6398 20.1635 4.82628C20.3027 5.01362 20.3595 5.24995 20.3182 5.47941C20.2778 5.70887 20.1446 5.91167 19.9495 6.03973C17.9145 7.55824 14.5699 8.46142 11 8.46142Z\" fill=\"black\" /><path d=\"M19.4434 17.4814C19.2603 17.4823 19.0825 17.423 18.9363 17.3121C17.1875 16.0093 14.2158 15.2307 11.0001 15.2307C7.78433 15.2307 4.81257 16.0093 3.06027 17.3139C2.88238 17.4643 2.65034 17.5347 2.41831 17.5081C2.18627 17.4814 1.97573 17.3603 1.83652 17.1738C1.6973 16.9864 1.64058 16.7501 1.68183 16.5207C1.72222 16.2912 1.85542 16.0884 2.05051 15.9603C4.08551 14.4418 7.43017 13.5386 11.0001 13.5386C14.57 13.5386 17.9147 14.4426 19.9497 15.9568C20.241 16.1751 20.3605 16.5558 20.2453 16.9013C20.1302 17.2467 19.8062 17.4796 19.4427 17.4796L19.4434 17.4814Z\" fill=\"black\" /></svg>`,\n            facebook: `<svg viewBox=\"0 0 24 24\" fill=\"none\" class=\"w-full h-full\"><path d=\"M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.791-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.268h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z\" fill=\"black\"/></svg>`,\n            twitter: `<svg viewBox=\"0 0 24 24\" fill=\"none\" class=\"w-full h-full\"><path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\" fill=\"black\"/></svg>`,\n            tiktok: `<svg viewBox=\"0 0 24 24\" fill=\"none\" class=\"w-full h-full\"><path d=\"M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.75a8.18 8.18 0 004.78 1.52V6.82a4.85 4.85 0 01-1.01-.13z\" fill=\"black\"/></svg>`\n        };\n\n        const ICON_SIZES = {\n            instagram: 'w-[25px]',\n            email: 'w-[28px]',\n            website: 'w-[22px]',\n            facebook: 'w-[22px]',\n            twitter: 'w-[22px]',\n            tiktok: 'w-[22px]'\n        };\n\n        let currentConfig = null;\n        let currentNormalized = null;\n\n        // --- Data Normalization ---\n\n        /**\n         * Derives initials from a vendor name (up to 2 letters)\n         */\n        function deriveInitials(name) {\n            if (!name) return '??';\n            const parts = name.trim().split(/\\s+/).filter(Boolean);\n            if (parts.length === 1) return parts[0].substring(0, 2).toUpperCase();\n            return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();\n        }\n\n        /**\n         * Normalizes the host app DTO into the shape the render functions expect.\n         * Also handles the legacy flat shape (id, business_name, etc.) for backwards compat.\n         */\n        function normalizeData(data) {\n            // Already normalized (legacy flat shape)\n            if (data.business_name !== undefined) return data;\n\n            const mediaBaseUrl = data.mediaBaseUrl || '';\n\n            // Resolve color from palette index\n            const colourCode = COLOR_PALETTE[data.colorIndex % COLOR_PALETTE.length] || COLOR_PALETTE[0];\n\n            // Flatten socialLinks array (host sends an array with one object)\n            const rawSocial = (data.socialLinks && data.socialLinks[0]) || {};\n            const social_links = {};\n            if (rawSocial.instagram) social_links.instagram = rawSocial.instagram;\n            if (rawSocial.website)   social_links.website   = rawSocial.website;\n            if (rawSocial.facebook)  social_links.facebook  = rawSocial.facebook;\n            if (rawSocial.twitter)   social_links.twitter   = rawSocial.twitter;\n            if (rawSocial.tiktok)    social_links.tiktok    = rawSocial.tiktok;\n            // businessEmail maps to email social link\n            if (data.businessEmail)  social_links.email     = data.businessEmail;\n\n            // profileMedia filenames → image objects\n            const images = (data.profileMedia || []).map((filename, index) => ({\n                id: filename,\n                order: index + 1,\n                url: mediaBaseUrl ? `${mediaBaseUrl}/${filename}` : filename,\n                tagged_vendors: []\n            }));\n\n            // profileAvatar filename → URL\n            const profile_image = data.profileAvatar\n                ? (mediaBaseUrl ? `${mediaBaseUrl}/${data.profileAvatar}` : data.profileAvatar)\n                : null;\n\n            // Types array → comma-separated readable string\n            const typeLabels = {\n                videographer: 'Videographer',\n                weddingdress: 'Wedding Dress',\n                makeup: 'Makeup Artist',\n                hairstylist: 'Hair Stylist',\n                photographer: 'Photographer',\n                florist: 'Florist',\n                venue: 'Venue',\n                catering: 'Catering',\n                dj: 'DJ',\n                band: 'Band'\n            };\n            const typeStr = (data.types || [])\n                .map(t => typeLabels[t] || t)\n                .join(', ');\n\n            return {\n                id: data.vendorAccountId,\n                business_name: (data.vendorName || '').trim(),\n                type: typeStr,\n                initials: deriveInitials(data.vendorName),\n                colour_code: colourCode,\n                description: data.description || '',\n                profile_image,\n                social_links,\n                images,\n                no_internet: data.no_internet,\n                fonts: data.fonts\n            };\n        }\n\n        /**\n         * Loads custom fonts from the fonts array (injects <link> tags).\n         */\n        function loadFonts(fonts) {\n            if (!fonts || !fonts.length) return;\n            fonts.forEach(font => {\n                if (!font.url) return;\n                // Avoid duplicate loads\n                if (document.querySelector(`link[data-font-id=\"${font.id}\"]`)) return;\n                const link = document.createElement('link');\n                link.rel = 'stylesheet';\n                link.href = font.url;\n                link.setAttribute('data-font-id', font.id);\n                document.head.appendChild(link);\n                // Apply as CSS variable if id is \"main\"\n                if (font.id === 'main' && font.family) {\n                    document.documentElement.style.setProperty('--font-main', `'${font.family}', 'Inter', sans-serif`);\n                }\n            });\n        }\n\n        // --- Public API ---\n\n        window.myop_cta_handler = function(action_id, payload) {\n            console.log(\"Action Triggered:\", action_id, payload);\n\n            if (action_id === 'navigate_back') {\n                window.history.back();\n            }\n\n            if (action_id === 'share_profile') {\n                const name = currentNormalized ? currentNormalized.business_name : '';\n                const shareData = {\n                    title: name,\n                    text: `Check out ${name}'s portfolio!`,\n                    url: window.location.href\n                };\n\n                if (navigator.share) {\n                    navigator.share(shareData)\n                        .then(() => console.log('Shared successfully'))\n                        .catch((err) => console.log('Error sharing:', err));\n                } else {\n                    const btnText = document.getElementById('share-text');\n                    const originalText = btnText.innerText;\n\n                    const textArea = document.createElement(\"textarea\");\n                    textArea.value = window.location.href;\n                    document.body.appendChild(textArea);\n                    textArea.select();\n                    try {\n                        document.execCommand(\"copy\");\n                        btnText.innerText = \"Copied!\";\n                    } catch (err) {\n                        console.error(\"Copy failed\", err);\n                    }\n                    document.body.removeChild(textArea);\n\n                    setTimeout(() => btnText.innerText = originalText, 2000);\n                }\n            }\n\n            if (action_id === 'view_photo') {\n                openModal(payload.photo_id);\n            }\n\n            if (action_id === 'reload-requested') {\n                window.location.reload();\n                return;\n            }\n\n            if (['instagram','email','website','facebook','tiktok','twitter'].includes(action_id)) {\n                // Host app handles social navigation natively\n                return;\n            }\n        };\n\n        window.myop_init_interface = function(data) {\n            if (!data) return currentConfig;\n            currentConfig = data;\n\n            // Normalize host DTO → internal shape\n            const config = normalizeData(data);\n            currentNormalized = config;\n            window.currentProfileId = config.id;\n\n            // Load custom fonts\n            if (config.fonts) loadFonts(config.fonts);\n\n            // No internet empty state\n            if (config.no_internet) {\n                document.getElementById('app-root').innerHTML = `\n                    <div class=\"no-internet-state fade-in\">\n                        <svg class=\"no-internet-icon\" viewBox=\"0 0 64 64\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                            <!-- Outer arc (faint / broken) -->\n                            <path d=\"M6 22 Q32 2 58 22\" stroke-dasharray=\"6 5\" opacity=\"0.35\"/>\n                            <!-- Mid arc -->\n                            <path d=\"M14 31 Q32 14 50 31\"/>\n                            <!-- Inner arc -->\n                            <path d=\"M22 40 Q32 30 42 40\"/>\n                            <!-- Dot -->\n                            <circle cx=\"32\" cy=\"50\" r=\"2.5\" fill=\"currentColor\" stroke=\"none\"/>\n                            <!-- Slash -->\n                            <line x1=\"10\" y1=\"10\" x2=\"54\" y2=\"54\" stroke-width=\"3.5\" stroke=\"#ef4444\"/>\n                        </svg>\n                        <p class=\"no-internet-title\">Looks like you have no internet access,<br>click to reload</p>\n                        <button class=\"no-internet-retry\" onclick=\"myop_cta_handler('reload-requested', undefined)\">Retry</button>\n                    </div>\n                `;\n                return;\n            }\n\n            // Update Text Content\n            const elements = {\n                'profile-name': config.business_name,\n                'profile-type': config.type,\n                'profile-initials': config.initials\n            };\n\n            for (const [id, value] of Object.entries(elements)) {\n                const el = document.getElementById(id);\n                if (el) el.innerText = value || \"\";\n            }\n\n            // Update Colors & Avatar\n            const avatar = document.getElementById('avatar-container');\n            if (avatar) avatar.style.backgroundColor = config.colour_code || \"#749BA7\";\n\n            // Update Description\n            const desc = document.getElementById('profile-description');\n            if (desc) {\n                if (config.description) {\n                    desc.innerText = config.description;\n                    desc.classList.remove('hidden');\n                } else {\n                    desc.classList.add('hidden');\n                }\n            }\n\n            // Update Profile Image\n            const profileImg = document.getElementById('profile-img');\n            const initialSpan = document.getElementById('profile-initials');\n            if (config.profile_image) {\n                profileImg.src = config.profile_image;\n                profileImg.classList.remove('hidden');\n                initialSpan.classList.add('hidden');\n            } else {\n                profileImg.classList.add('hidden');\n                initialSpan.classList.remove('hidden');\n            }\n\n            // Render Social Links\n            const socialContainer = document.getElementById('social-container');\n            if (socialContainer) {\n                socialContainer.innerHTML = '';\n                Object.keys(config.social_links).forEach(key => {\n                    if (config.social_links[key] && SOCIAL_ICONS[key]) {\n                        const btn = document.createElement('button');\n                        btn.className = `${ICON_SIZES[key] || 'w-[24px]'} aspect-square hover:scale-110 transition-transform`;\n                        btn.innerHTML = SOCIAL_ICONS[key];\n                        btn.setAttribute('aria-label', `Visit ${key}`);\n                        btn.onclick = () => myop_cta_handler(key, { value: config.social_links[key] });\n                        socialContainer.appendChild(btn);\n                    }\n                });\n            }\n\n            // Render Photo Grid\n            const grid = document.getElementById('photo-grid');\n            if (grid) {\n                grid.innerHTML = '';\n                const images = [...config.images].sort((a, b) => (a.order || 999) - (b.order || 999));\n\n                images.forEach(photo => {\n                    const item = document.createElement('div');\n                    item.className = 'photo-item';\n                    item.onclick = () => myop_cta_handler('view_photo', { photo_id: photo.id });\n\n                    const img = document.createElement('img');\n                    img.src = photo.url;\n                    img.alt = \"Portfolio image\";\n                    img.loading = 'lazy';\n\n                    item.appendChild(img);\n                    grid.appendChild(item);\n                });\n            }\n        };\n\n        // --- Modal Logic ---\n\n        function openModal(photoId) {\n            const photo = currentNormalized.images.find(img => img.id === photoId);\n            if (!photo) return;\n\n            const modal = document.getElementById('photo-modal');\n            const modalImg = document.getElementById('modal-img');\n            const miniAvatar = document.getElementById('modal-mini-avatar');\n            const author = document.getElementById('modal-author');\n            const tagsCont = document.getElementById('modal-tags');\n\n            modalImg.src = photo.url;\n            miniAvatar.innerText = currentNormalized.initials;\n            miniAvatar.style.backgroundColor = currentNormalized.colour_code;\n            author.innerText = currentNormalized.business_name;\n\n            // Render Tags\n            tagsCont.innerHTML = '';\n            if (photo.tagged_vendors && photo.tagged_vendors.length > 0) {\n                photo.tagged_vendors.forEach(tag => {\n                    const span = document.createElement('span');\n                    span.className = 'px-3 py-1.5 bg-gray-50 text-gray-700 text-xs rounded-lg flex items-center gap-2 border border-gray-100';\n                    span.innerHTML = `<svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z\"></path></svg> ${tag}`;\n                    tagsCont.appendChild(span);\n                });\n            } else {\n                tagsCont.innerHTML = '<span class=\"text-xs text-gray-400 italic\">No tags listed</span>';\n            }\n\n            // CTA Button Logic\n            document.getElementById('modal-cta').onclick = () => myop_cta_handler('website', { value: currentNormalized.social_links.website });\n\n            // Show Modal\n            modal.classList.remove('hidden');\n            document.body.style.overflow = 'hidden';\n        }\n\n        function closeModal(event, force = false) {\n            if (force || (event && event.target.id === 'photo-modal')) {\n                const modal = document.getElementById('photo-modal');\n                modal.classList.add('hidden');\n                document.body.style.overflow = '';\n            }\n        }\n\n        // Close modal on Escape key\n        document.addEventListener('keydown', function(event) {\n            if (event.key === \"Escape\") {\n                const modal = document.getElementById('photo-modal');\n                if (!modal.classList.contains('hidden')) {\n                    closeModal(null, true);\n                }\n            }\n        });\n    })();\n    </script>\n\n    <!-- Preview script - replaced in production -->\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            fonts: [\n                {\n                    id: \"main\",\n                    family: \"tt_norms_pro\",\n                    url: \"https://pictimecloudaf-pub-g3csanfebyefg3dm.a02.azurefd.net/pictures/fonts/tt_norms_pro.css\"\n                }\n            ],\n            vendorAccountId: 530744,\n            storeId: 4,\n            createDate: \"2026-02-10T09:50:15.705Z\",\n            vendorName: \"Wedding dresses\",\n            types: [\"videographer\", \"weddingdress\", \"makeup\", \"hairstylist\"],\n            hasLogo: false,\n            businessEmail: \"amir@test.com\",\n            description: \"Personally curated. Hand crafted. Timeless.\\nUnique.\",\n            socialLinks: [\n                {\n                    website: \"test.com\",\n                    facebook: null,\n                    instagram: \"@instacake\",\n                    twitter: null,\n                    tiktok: null\n                }\n            ],\n            profileMedia: [\n                \"https://images.unsplash.com/photo-1522337660859-02fbefca4702?w=800&q=80\",\n                \"https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=800&q=80\",\n                \"https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=800&q=80\",\n                \"https://images.unsplash.com/photo-1519741497674-611481863552?w=800&q=80\",\n                \"https://images.unsplash.com/photo-1595476108010-b4d1f102b1b1?w=800&q=80\",\n                \"https://images.unsplash.com/photo-1520854221256-17451cc331bf?w=800&q=80\",\n                \"https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=800&q=80\",\n                \"https://images.unsplash.com/photo-1515934751635-c81c6bc9a2d8?w=800&q=80\",\n                \"https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=800&q=80\"\n            ],\n            profileAvatar: null,\n            colorIndex: 6,\n            mobileMode: false,\n            mobileApp: false\n        });\n    </script>\n</body>\n</html>\n"
        },
