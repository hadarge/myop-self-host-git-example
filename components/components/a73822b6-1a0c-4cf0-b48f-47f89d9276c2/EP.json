\n                    \"https://pictime7eus1public-pub-hdf3hecqdpaqeuev.a02.azurefd.net/pictures/48/11/48011536/408uz1pkolvonbyrrq/smallres/11433723121.jpg\",\n                    \"https://pictime7eus1public-pub-hdf3hecqdpaqeuev.a02.azurefd.net/pictures/43/459/43459713/dn2ip38beqhn7lj2ao/smallres/10445094658.jpg\",\n                    \"https://pictime7eus1public-pub-hdf3hecqdpaqeuev.a02.azurefd.net/pictures/44/251/44251356/zvnksy8st8rsrqk7uj/smallres/10444753740.jpg\"\n                ]\n            },\n            \"accountDarkLogo\": \"https://pictime1eus1public-pub-ese2a2hyhubtebgg.a02.azurefd.net/pictures/accountdata/6/6677/accountlogo/logo_6297.png?rev=2\",\n            \"accountBrightLogo\": \"https://pictime1eus1public-pub-ese2a2hyhubtebgg.a02.azurefd.net/pictures/accountdata/6/6677/accountlogo/logo2_6297.png?rev=2\",\n            \"aboutText\": \"Your wedding is not a performance; it is a profound narrative waiting to be told with honesty and grace. I move beyond the expected poses to curate the quiet, fleeting instances that truly define the spirit of your celebration—the nervous anticipation, the unscripted laughter, and the deeply personal connection between you and your loved ones.\",\n            \"myPhotographyPrinciples\": \"I believe that exceptional wedding photography requires a delicate balance of artistic intent and emotional intuition. Visually, I am relentless in the pursuit of clean composition and flattering, directional light, often quietly curating the environment to ensure your connection shines without distraction.\"\n        });\n    </script>\n</body>\n</html>\n"
