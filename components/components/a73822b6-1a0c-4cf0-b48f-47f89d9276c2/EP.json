{
  "version": "0.2.10",
  "item": {
    "name": "WWW landing test 2",
    "id": "a73822b6-1a0c-4cf0-b48f-47f89d9276c2",
    "organizationId": "b1aed0f0-1e47-40f6-9ea4-a539c7fb3453",
    "consume_variant": [
      {
        "id": "ecfd73d3-32d2-4e42-be7b-c0dcc95d5642",
        "name": "Version 1",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <title>Photographer Portfolio</title>\n\n    <script type=\"myop/types\">\n    // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    interface SocialHandle {\n        ig?: string;\n        facebook?: string;\n        x?: string;\n        www?: string;\n    }\n\n    interface MyopInitData {\n        brandName: string;\n        accountName: string;\n        country: string;\n        serviceEmail: string;\n        socialHandle: SocialHandle;\n        brandLeadingMedia: string[];\n        leadingMedia_ByPhotographyCategory: Record<string, string[]>;\n        accountDarkLogo?: string;\n        accountBrightLogo?: string;\n        aboutText?: string;\n        myPhotographyPrinciples?: string;\n    }\n\n    interface MyopCtaPayloads {\n        'contact-clicked': { email: string };\n        'gallery-image-clicked': { imageUrl: string; index: number };\n        'category-selected': { category: string };\n        'social-link-clicked': { platform: string; url: string };\n        'size-requested': {\n            width?: number | null;\n            height?: number | null;\n            minWidth?: number | null;\n            maxWidth?: number | null;\n            minHeight?: number | null;\n            maxHeight?: number | null;\n            required?: boolean;\n        };\n    }\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Space+Mono:wght@400;700&family=Italiana&display=swap\" rel=\"stylesheet\">\n\n    <style>\n        :root {\n            --cream: #f5f0e8;\n            --charcoal: #1a1a1a;\n            --gold: #c9a962;\n            --muted: #8a8a8a;\n        }\n\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n\n        html, body {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            font-family: 'Space Mono', monospace;\n            background: var(--cream);\n            color: var(--charcoal);\n        }\n\n        #app-root {\n            width: 100%;\n            height: 100%;\n            overflow-y: auto;\n            overflow-x: hidden;\n        }\n\n        /* Horizontal scrolling hero */\n        .hero {\n            height: 100vh;\n            min-height: 700px;\n            display: flex;\n            flex-direction: column;\n            position: relative;\n            background: var(--charcoal);\n            overflow: hidden;\n        }\n\n        .hero-top {\n            padding: 30px 50px;\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-start;\n            position: relative;\n            z-index: 10;\n        }\n\n        .logo {\n            font-family: 'Italiana', serif;\n            font-size: 14px;\n            letter-spacing: 4px;\n            color: var(--cream);\n            text-transform: uppercase;\n        }\n\n        .nav-minimal {\n            display: flex;\n            gap: 30px;\n        }\n\n        .nav-minimal a {\n            color: var(--cream);\n            text-decoration: none;\n            font-size: 11px;\n            letter-spacing: 2px;\n            opacity: 0.6;\n            transition: opacity 0.3s;\n        }\n\n        .nav-minimal a:hover {\n            opacity: 1;\n        }\n\n        .hero-center {\n            flex: 1;\n            display: flex;\n            align-items: center;\n            position: relative;\n        }\n\n        .hero-text {\n            position: absolute;\n            left: 50px;\n            z-index: 10;\n            mix-blend-mode: difference;\n        }\n\n        .hero-title {\n            font-family: 'Playfair Display', serif;\n            font-size: clamp(60px, 12vw, 180px);\n            font-weight: 400;\n            color: var(--cream);\n            line-height: 0.85;\n            letter-spacing: -4px;\n        }\n\n        .hero-title span {\n            display: block;\n            font-style: italic;\n            font-weight: 400;\n        }\n\n        .hero-images {\n            position: absolute;\n            right: 0;\n            top: 50%;\n            transform: translateY(-50%);\n            display: flex;\n            gap: 20px;\n            padding-right: 50px;\n        }\n\n        .hero-img {\n            width: 280px;\n            height: 380px;\n            object-fit: cover;\n            filter: grayscale(30%);\n            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .hero-img:nth-child(2) {\n            margin-top: 60px;\n        }\n\n        .hero-img:nth-child(3) {\n            margin-top: -40px;\n        }\n\n        .hero-img:hover {\n            filter: grayscale(0%);\n            transform: scale(1.02);\n        }\n\n        .hero-bottom {\n            padding: 30px 50px;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            color: var(--cream);\n        }\n\n        .hero-scroll {\n            font-size: 10px;\n            letter-spacing: 3px;\n            opacity: 0.5;\n            display: flex;\n            align-items: center;\n            gap: 15px;\n        }\n\n        .scroll-line {\n            width: 60px;\n            height: 1px;\n            background: var(--cream);\n            opacity: 0.3;\n        }\n\n        .hero-tagline {\n            font-size: 11px;\n            letter-spacing: 2px;\n            opacity: 0.6;\n            max-width: 300px;\n            text-align: right;\n            line-height: 1.8;\n        }\n\n        /* About Section - Editorial Layout */\n        .about {\n            padding: 150px 50px;\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 100px;\n            max-width: 1400px;\n            margin: 0 auto;\n        }\n\n        .about-left {\n            position: relative;\n        }\n\n        .about-number {\n            font-family: 'Playfair Display', serif;\n            font-size: 200px;\n            font-weight: 400;\n            color: transparent;\n            -webkit-text-stroke: 1px var(--muted);\n            opacity: 0.3;\n            position: absolute;\n            top: -80px;\n            left: -30px;\n            line-height: 1;\n        }\n\n        .about-label {\n            font-size: 10px;\n            letter-spacing: 4px;\n            text-transform: uppercase;\n            color: var(--muted);\n            margin-bottom: 30px;\n        }\n\n        .about-title {\n            font-family: 'Playfair Display', serif;\n            font-size: 48px;\n            font-weight: 400;\n            line-height: 1.2;\n            margin-bottom: 40px;\n        }\n\n        .about-text {\n            font-size: 14px;\n            line-height: 2.2;\n            color: var(--muted);\n        }\n\n        .about-right {\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n        }\n\n        .about-quote {\n            font-family: 'Playfair Display', serif;\n            font-size: 28px;\n            font-style: italic;\n            line-height: 1.6;\n            position: relative;\n            padding-left: 40px;\n            border-left: 1px solid var(--gold);\n        }\n\n        .about-signature {\n            margin-top: 40px;\n            padding-left: 40px;\n        }\n\n        .about-signature img {\n            height: 50px;\n            filter: invert(1) brightness(0);\n            opacity: 0.7;\n        }\n\n        /* Gallery - Asymmetric Masonry */\n        .gallery {\n            background: var(--charcoal);\n            padding: 120px 50px;\n            min-height: 100vh;\n        }\n\n        .gallery-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-end;\n            margin-bottom: 80px;\n            color: var(--cream);\n        }\n\n        .gallery-title {\n            font-family: 'Playfair Display', serif;\n            font-size: clamp(48px, 8vw, 100px);\n            font-weight: 400;\n            line-height: 0.9;\n        }\n\n        .gallery-title span {\n            font-style: italic;\n            display: block;\n            margin-left: 100px;\n        }\n\n        .gallery-filters {\n            display: flex;\n            gap: 30px;\n        }\n\n        .filter-btn {\n            background: none;\n            border: none;\n            color: var(--cream);\n            font-family: 'Space Mono', monospace;\n            font-size: 11px;\n            letter-spacing: 2px;\n            cursor: pointer;\n            opacity: 0.4;\n            transition: all 0.3s;\n            position: relative;\n        }\n\n        .filter-btn::after {\n            content: '';\n            position: absolute;\n            bottom: -5px;\n            left: 0;\n            width: 0;\n            height: 1px;\n            background: var(--gold);\n            transition: width 0.3s;\n        }\n\n        .filter-btn:hover,\n        .filter-btn.active {\n            opacity: 1;\n        }\n\n        .filter-btn.active::after {\n            width: 100%;\n        }\n\n        .gallery-grid {\n            display: grid;\n            grid-template-columns: repeat(12, 1fr);\n            gap: 20px;\n            grid-auto-flow: dense;\n        }\n\n        .gallery-item {\n            position: relative;\n            overflow: hidden;\n            cursor: pointer;\n        }\n\n        .gallery-item::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.7));\n            z-index: 1;\n            opacity: 0;\n            transition: opacity 0.4s;\n        }\n\n        .gallery-item:hover::before {\n            opacity: 1;\n        }\n\n        .gallery-item:nth-child(6n+1) { grid-column: span 5; grid-row: span 2; }\n        .gallery-item:nth-child(6n+2) { grid-column: span 4; }\n        .gallery-item:nth-child(6n+3) { grid-column: span 3; }\n        .gallery-item:nth-child(6n+4) { grid-column: span 3; grid-row: span 2; }\n        .gallery-item:nth-child(6n+5) { grid-column: span 5; }\n        .gallery-item:nth-child(6n+6) { grid-column: span 4; }\n\n        .gallery-item img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            filter: grayscale(100%);\n            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .gallery-item:hover img {\n            filter: grayscale(0%);\n            transform: scale(1.05);\n        }\n\n        .gallery-item-number {\n            position: absolute;\n            bottom: 20px;\n            left: 20px;\n            font-size: 10px;\n            letter-spacing: 2px;\n            color: var(--cream);\n            opacity: 0;\n            z-index: 2;\n            transition: opacity 0.4s;\n        }\n\n        .gallery-item:hover .gallery-item-number {\n            opacity: 0.7;\n        }\n\n        /* Contact - Minimal Split */\n        .contact {\n            min-height: 100vh;\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n        }\n\n        .contact-left {\n            background: var(--cream);\n            padding: 100px 80px;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n        }\n\n        .contact-label {\n            font-size: 10px;\n            letter-spacing: 4px;\n            text-transform: uppercase;\n            color: var(--muted);\n            margin-bottom: 40px;\n        }\n\n        .contact-title {\n            font-family: 'Playfair Display', serif;\n            font-size: clamp(36px, 5vw, 64px);\n            font-weight: 400;\n            line-height: 1.2;\n            margin-bottom: 50px;\n        }\n\n        .contact-title span {\n            font-style: italic;\n        }\n\n        .contact-email {\n            font-family: 'Playfair Display', serif;\n            font-size: 24px;\n            color: var(--charcoal);\n            text-decoration: none;\n            position: relative;\n            display: inline-block;\n        }\n\n        .contact-email::after {\n            content: '';\n            position: absolute;\n            bottom: -2px;\n            left: 0;\n            width: 100%;\n            height: 1px;\n            background: var(--gold);\n            transform: scaleX(0);\n            transform-origin: right;\n            transition: transform 0.4s;\n        }\n\n        .contact-email:hover::after {\n            transform: scaleX(1);\n            transform-origin: left;\n        }\n\n        .social-links {\n            display: flex;\n            gap: 25px;\n            margin-top: 60px;\n        }\n\n        .social-link {\n            font-size: 11px;\n            letter-spacing: 2px;\n            color: var(--muted);\n            text-decoration: none;\n            transition: color 0.3s;\n        }\n\n        .social-link:hover {\n            color: var(--charcoal);\n        }\n\n        .contact-right {\n            position: relative;\n            overflow: hidden;\n        }\n\n        .contact-image {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            filter: grayscale(50%);\n        }\n\n        .contact-overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: linear-gradient(135deg, transparent 50%, rgba(26,26,26,0.3));\n        }\n\n        /* Footer */\n        .footer {\n            background: var(--charcoal);\n            padding: 60px 50px;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            color: var(--cream);\n        }\n\n        .footer-logo {\n            font-family: 'Italiana', serif;\n            font-size: 12px;\n            letter-spacing: 4px;\n            opacity: 0.6;\n        }\n\n        .footer-copy {\n            font-size: 10px;\n            letter-spacing: 2px;\n            opacity: 0.4;\n        }\n\n        /* Lightbox */\n        .lightbox {\n            display: none;\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(26,26,26,0.98);\n            z-index: 1000;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .lightbox.active {\n            display: flex;\n        }\n\n        .lightbox img {\n            max-width: 85%;\n            max-height: 85%;\n            object-fit: contain;\n        }\n\n        .lightbox-close {\n            position: absolute;\n            top: 40px;\n            right: 50px;\n            background: none;\n            border: none;\n            color: var(--cream);\n            font-size: 12px;\n            letter-spacing: 3px;\n            cursor: pointer;\n            opacity: 0.6;\n            transition: opacity 0.3s;\n        }\n\n        .lightbox-close:hover {\n            opacity: 1;\n        }\n\n        .lightbox-nav {\n            position: absolute;\n            top: 50%;\n            transform: translateY(-50%);\n            background: none;\n            border: none;\n            color: var(--cream);\n            font-size: 24px;\n            cursor: pointer;\n            opacity: 0.4;\n            transition: opacity 0.3s;\n            padding: 30px;\n        }\n\n        .lightbox-nav:hover {\n            opacity: 1;\n        }\n\n        .lightbox-prev { left: 30px; }\n        .lightbox-next { right: 30px; }\n\n        .lightbox-counter {\n            position: absolute;\n            bottom: 40px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 11px;\n            letter-spacing: 3px;\n            color: var(--cream);\n            opacity: 0.5;\n        }\n\n        /* Responsive */\n        @media (max-width: 1024px) {\n            .hero-images {\n                display: none;\n            }\n\n            .hero-text {\n                position: relative;\n                left: 0;\n                padding: 0 30px;\n            }\n\n            .about {\n                grid-template-columns: 1fr;\n                padding: 80px 30px;\n                gap: 60px;\n            }\n\n            .gallery {\n                padding: 80px 20px;\n            }\n\n            .gallery-grid {\n                grid-template-columns: repeat(6, 1fr);\n            }\n\n            .gallery-item:nth-child(6n+1),\n            .gallery-item:nth-child(6n+4) { grid-column: span 3; grid-row: span 1; }\n            .gallery-item:nth-child(6n+2),\n            .gallery-item:nth-child(6n+3),\n            .gallery-item:nth-child(6n+5),\n            .gallery-item:nth-child(6n+6) { grid-column: span 3; }\n\n            .contact {\n                grid-template-columns: 1fr;\n            }\n\n            .contact-right {\n                height: 50vh;\n            }\n        }\n\n        @media (max-width: 600px) {\n            .hero-top, .hero-bottom {\n                padding: 20px;\n            }\n\n            .nav-minimal {\n                display: none;\n            }\n\n            .gallery-header {\n                flex-direction: column;\n                align-items: flex-start;\n                gap: 30px;\n            }\n\n            .gallery-title span {\n                margin-left: 30px;\n            }\n\n            .gallery-grid {\n                grid-template-columns: 1fr 1fr;\n            }\n\n            .gallery-item:nth-child(n) {\n                grid-column: span 1;\n                grid-row: span 1;\n            }\n\n            .gallery-item:nth-child(3n+1) {\n                grid-column: span 2;\n            }\n\n            .contact-left {\n                padding: 60px 30px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\">\n        <!-- Content rendered here -->\n    </div>\n\n    <div class=\"lightbox\" id=\"lightbox\">\n        <button class=\"lightbox-close\">CLOSE</button>\n        <button class=\"lightbox-nav lightbox-prev\">&#8592;</button>\n        <button class=\"lightbox-nav lightbox-next\">&#8594;</button>\n        <img src=\"\" alt=\"Gallery Image\">\n        <div class=\"lightbox-counter\"><span id=\"lb-current\">1</span> / <span id=\"lb-total\">1</span></div>\n    </div>\n\n    <script>\n    (function() {\n        let currentState = null;\n        let currentCategory = 'all';\n        let lightboxImages = [];\n        let lightboxIndex = 0;\n\n        function escapeHtml(text) {\n            if (!text) return '';\n            const div = document.createElement('div');\n            div.textContent = text;\n            return div.innerHTML;\n        }\n\n        function formatName(name) {\n            const parts = (name || '').split(' ');\n            if (parts.length >= 2) {\n                return `${parts[0]}<span>${parts.slice(1).join(' ')}</span>`;\n            }\n            return name;\n        }\n\n        function buildGalleryImages(data, category) {\n            let images = [];\n            if (category === 'all') {\n                images = data.brandLeadingMedia || [];\n            } else if (data.leadingMedia_ByPhotographyCategory && data.leadingMedia_ByPhotographyCategory[category]) {\n                images = data.leadingMedia_ByPhotographyCategory[category];\n            }\n\n            lightboxImages = images;\n\n            return images.slice(0, 12).map((img, i) => `\n                <div class=\"gallery-item\" data-index=\"${i}\">\n                    <img src=\"${img}\" alt=\"Portfolio ${i + 1}\" loading=\"lazy\">\n                    <span class=\"gallery-item-number\">${String(i + 1).padStart(2, '0')}</span>\n                </div>\n            `).join('');\n        }\n\n        function buildCategoryButtons(data) {\n            const categories = Object.keys(data.leadingMedia_ByPhotographyCategory || {});\n            let buttons = `<button class=\"filter-btn active\" data-category=\"all\">ALL</button>`;\n            categories.forEach(cat => {\n                buttons += `<button class=\"filter-btn\" data-category=\"${escapeHtml(cat)}\">${escapeHtml(cat).toUpperCase()}</button>`;\n            });\n            return buttons;\n        }\n\n        function buildSocialLinks(social) {\n            const links = [];\n            if (social.ig) links.push(`<a href=\"${social.ig}\" target=\"_blank\" rel=\"noopener\" class=\"social-link\" data-platform=\"instagram\">IG</a>`);\n            if (social.facebook) links.push(`<a href=\"${social.facebook}\" target=\"_blank\" rel=\"noopener\" class=\"social-link\" data-platform=\"facebook\">FB</a>`);\n            if (social.x) links.push(`<a href=\"${social.x}\" target=\"_blank\" rel=\"noopener\" class=\"social-link\" data-platform=\"x\">X</a>`);\n            if (social.www) links.push(`<a href=\"${social.www}\" target=\"_blank\" rel=\"noopener\" class=\"social-link\" data-platform=\"website\">WWW</a>`);\n            return links.join('');\n        }\n\n        function render(data) {\n            const container = document.getElementById('app-root');\n            const brandName = data.brandName || 'Photography';\n            const heroImages = data.brandLeadingMedia || [];\n\n            container.innerHTML = `\n                <section class=\"hero\">\n                    <div class=\"hero-top\">\n                        <div class=\"logo\">${escapeHtml(brandName)}</div>\n                        <nav class=\"nav-minimal\">\n                            <a href=\"#about\">About</a>\n                            <a href=\"#work\">Work</a>\n                            <a href=\"#contact\">Contact</a>\n                        </nav>\n                    </div>\n\n                    <div class=\"hero-center\">\n                        <div class=\"hero-text\">\n                            <h1 class=\"hero-title\">${formatName(brandName)}</h1>\n                        </div>\n                        <div class=\"hero-images\">\n                            ${heroImages.slice(0, 3).map(img => `<img src=\"${img}\" alt=\"\" class=\"hero-img\">`).join('')}\n                        </div>\n                    </div>\n\n                    <div class=\"hero-bottom\">\n                        <div class=\"hero-scroll\">\n                            <span class=\"scroll-line\"></span>\n                            SCROLL TO EXPLORE\n                        </div>\n                        <div class=\"hero-tagline\">\n                            WEDDING & PORTRAIT<br>PHOTOGRAPHY\n                        </div>\n                    </div>\n                </section>\n\n                <section class=\"about\" id=\"about\">\n                    <div class=\"about-left\">\n                        <span class=\"about-number\">01</span>\n                        <p class=\"about-label\">The Approach</p>\n                        <h2 class=\"about-title\">Capturing moments that transcend time</h2>\n                        <p class=\"about-text\">${escapeHtml(data.myPhotographyPrinciples || '')}</p>\n                    </div>\n                    <div class=\"about-right\">\n                        <blockquote class=\"about-quote\">\n                            ${escapeHtml(data.aboutText || '')}\n                        </blockquote>\n                        <div class=\"about-signature\">\n                            <img src=\"${data.accountDarkLogo || ''}\" alt=\"${escapeHtml(brandName)}\">\n                        </div>\n                    </div>\n                </section>\n\n                <section class=\"gallery\" id=\"work\">\n                    <div class=\"gallery-header\">\n                        <h2 class=\"gallery-title\">Selected <span>Works</span></h2>\n                        <div class=\"gallery-filters\">\n                            ${buildCategoryButtons(data)}\n                        </div>\n                    </div>\n                    <div class=\"gallery-grid\" id=\"gallery-grid\">\n                        ${buildGalleryImages(data, 'all')}\n                    </div>\n                </section>\n\n                <section class=\"contact\" id=\"contact\">\n                    <div class=\"contact-left\">\n                        <p class=\"contact-label\">Get in Touch</p>\n                        <h2 class=\"contact-title\">Let's create <span>something beautiful</span> together</h2>\n                        <a href=\"mailto:${data.serviceEmail}\" class=\"contact-email\">${escapeHtml(data.serviceEmail)}</a>\n                        <div class=\"social-links\">\n                            ${buildSocialLinks(data.socialHandle || {})}\n                        </div>\n                    </div>\n                    <div class=\"contact-right\">\n                        <img src=\"${heroImages[5] || heroImages[0] || ''}\" alt=\"\" class=\"contact-image\">\n                        <div class=\"contact-overlay\"></div>\n                    </div>\n                </section>\n\n                <footer class=\"footer\">\n                    <div class=\"footer-logo\">${escapeHtml(brandName)}</div>\n                    <div class=\"footer-copy\">&copy; ${new Date().getFullYear()} ALL RIGHTS RESERVED</div>\n                </footer>\n            `;\n\n            attachEventListeners(data);\n        }\n\n        function attachEventListeners(data) {\n            // Smooth scroll\n            document.querySelectorAll('a[href^=\"#\"]').forEach(link => {\n                link.addEventListener('click', (e) => {\n                    e.preventDefault();\n                    const target = document.querySelector(link.getAttribute('href'));\n                    if (target) target.scrollIntoView({ behavior: 'smooth' });\n                });\n            });\n\n            // Filter buttons\n            document.querySelectorAll('.filter-btn').forEach(btn => {\n                btn.addEventListener('click', () => {\n                    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));\n                    btn.classList.add('active');\n                    currentCategory = btn.dataset.category;\n                    document.getElementById('gallery-grid').innerHTML = buildGalleryImages(data, currentCategory);\n                    attachGalleryListeners();\n                    window.myop_cta_handler('category-selected', { category: currentCategory });\n                });\n            });\n\n            // Gallery\n            attachGalleryListeners();\n\n            // Lightbox\n            const lightbox = document.getElementById('lightbox');\n            lightbox.querySelector('.lightbox-close').addEventListener('click', closeLightbox);\n            lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });\n            lightbox.querySelector('.lightbox-prev').addEventListener('click', (e) => { e.stopPropagation(); navigateLightbox(-1); });\n            lightbox.querySelector('.lightbox-next').addEventListener('click', (e) => { e.stopPropagation(); navigateLightbox(1); });\n\n            // Social links\n            document.querySelectorAll('.social-link').forEach(link => {\n                link.addEventListener('click', () => {\n                    window.myop_cta_handler('social-link-clicked', { platform: link.dataset.platform, url: link.href });\n                });\n            });\n\n            // Contact email\n            const emailLink = document.querySelector('.contact-email');\n            if (emailLink) {\n                emailLink.addEventListener('click', () => {\n                    window.myop_cta_handler('contact-clicked', { email: data.serviceEmail });\n                });\n            }\n        }\n\n        function attachGalleryListeners() {\n            document.querySelectorAll('.gallery-item').forEach(item => {\n                item.addEventListener('click', () => {\n                    openLightbox(parseInt(item.dataset.index));\n                });\n            });\n        }\n\n        function openLightbox(index) {\n            lightboxIndex = index;\n            const lightbox = document.getElementById('lightbox');\n            lightbox.querySelector('img').src = lightboxImages[index];\n            document.getElementById('lb-current').textContent = index + 1;\n            document.getElementById('lb-total').textContent = lightboxImages.length;\n            lightbox.classList.add('active');\n            window.myop_cta_handler('gallery-image-clicked', { imageUrl: lightboxImages[index], index });\n        }\n\n        function closeLightbox() {\n            document.getElementById('lightbox').classList.remove('active');\n        }\n\n        function navigateLightbox(direction) {\n            lightboxIndex += direction;\n            if (lightboxIndex < 0) lightboxIndex = lightboxImages.length - 1;\n            if (lightboxIndex >= lightboxImages.length) lightboxIndex = 0;\n            document.getElementById('lightbox').querySelector('img').src = lightboxImages[lightboxIndex];\n            document.getElementById('lb-current').textContent = lightboxIndex + 1;\n        }\n\n        // Public API\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            currentState = data;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action, payload) {\n            console.log('CTA:', action, payload);\n        };\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            \"__type\": \"Pictime.Interfaces.webMyLPWWWDTO\",\n            \"brandName\": \"nirav patel\",\n            \"accountName\": \"nirav patel\",\n            \"country\": \"United States\",\n            \"serviceEmail\": \"nikusp@gmail.com\",\n            \"socialHandle\": {\n                \"ig\": \"https://www.instagram.com/niravpatelweddings/\",\n                \"facebook\": \"https://www.facebook.com/Nirav-Photography-114491138574349/\",\n                \"x\": \"https://twitter.com/nikusp\",\n                \"www\": \"http://niravpatelphotography.com/\"\n            },\n            \"brandLeadingMedia\": [\n                \"https://pictime7eus1public-pub-hdf3hecqdpaqeuev.a02.azurefd.net/pictures/48/783/48783218/ordinte9y629glwa5m/smallres/11354225253.jpg\",\n                \"https://pictime7eus1public-pub-hdf3hecqdpaqeuev.a02.azurefd.net/pictures/48/783/48783218/ordinte9y629glwa5m/smallres/11354225375.jpg\",\n                \"https://pictime7eus1public-pub-hdf3hecqdpaqeuev.a02.azurefd.net/pictures/48/783/48783218/ordinte9y629glwa5m/smallres/11354226835.jpg\",\n                \"https://pictime7eus1public-pub-hdf3hecqdpaqeuev.a02.azurefd.net/pictures/48/783/48783218/ordinte9y629glwa