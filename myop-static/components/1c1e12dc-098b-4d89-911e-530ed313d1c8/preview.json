        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <title>Delete Confirmation Modal</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link\n            href=\"https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap\"\n            rel=\"stylesheet\">\n    <style>\n        :root {\n            --grey-20: #D3D1D5;\n            --white: #FFF;\n            --bg-color: #ffffff;\n            --hover-bg: #f4f4f5;\n            --border-color: #e5e5e5;\n            --text-color: #18181b;\n            --text-secondary: #71717a;\n            --accent-red: #ef4444;\n            --purple-5: #F0E8FF;\n            --purple-10: #DECCFF;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            width: 100%;\n            height: auto;\n            min-height: 400px;\n            overflow: visible;\n            background: transparent;\n            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n            font-size: 13px;\n            color: #18181b;\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n        }\n\n        /* Buttons */\n        .button {\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            gap: 6px;\n            padding: 8px 16px;\n            font-weight: 500;\n            font-size: 13px;\n            border-radius: 6px;\n            border: 1px solid var(--grey-20);\n            transition: all 0.15s ease;\n            cursor: pointer;\n            font-family: 'DM Sans', sans-serif;\n            background-color: var(--bg-color);\n            color: var(--text-color);\n        }\n\n        .button:hover:not(:disabled) {\n            border-color: var(--purple-10);\n            background: var(--purple-5);\n        }\n\n        .button:disabled {\n            opacity: 0.4;\n            cursor: not-allowed;\n        }\n\n        /* Delete Confirmation Modal */\n        .modal-content {\n            background: var(--bg-color);\n            border-radius: 8px;\n            width: 90%;\n            max-width: 440px;\n            padding: 24px;\n        }\n\n        .modal-icon {\n            width: 100px;\n            height: 101px;\n            margin-bottom: 16px;\n        }\n\n        @keyframes wiggleX {\n            0% {\n                opacity: 1;\n                transform: translateX(0) rotate(0deg);\n            }\n\n            100% {\n                opacity: 1;\n                transform: translateX(3px) rotate(2deg);\n            }\n        }\n\n        @keyframes wiggleXBox {\n            0% {\n                transform: translateX(0) rotate(30deg) translate(0px, 0px);\n            }\n\n            100% {\n                transform: translateX(3px) rotate(32deg) translate(0px, 0px);\n            }\n        }\n\n        .modal-title {\n            font-size: 18px;\n            font-weight: 600;\n            color: var(--text-color);\n            margin-bottom: 12px;\n            line-height: 1.3;\n        }\n\n        .modal-description {\n            font-size: 13px;\n            color: var(--text-color);\n            line-height: 1.6;\n            margin-bottom: 8px;\n        }\n\n        .modal-warning {\n            font-size: 13px;\n            color: var(--text-color);\n            font-weight: 500;\n            margin-bottom: 16px;\n        }\n\n        .modal-confirmation-label {\n            display: block;\n            font-size: 11px;\n            font-weight: 600;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n            color: var(--text-secondary);\n            margin-bottom: 8px;\n        }\n\n        .modal-confirmation-input {\n            width: 100%;\n            height: 40px;\n            padding: 8px 12px;\n            border: 1px solid var(--border-color);\n            border-radius: 6px;\n            font-size: 13px;\n            font-family: 'DM Sans', sans-serif;\n            color: var(--text-color);\n            background-color: var(--bg-color);\n            margin-bottom: 20px;\n            transition: all 0.15s ease;\n        }\n\n        .modal-confirmation-input:focus {\n            outline: none;\n            border-color: var(--purple-10);\n            box-shadow: 0 0 0 3px var(--purple-5);\n        }\n\n        .modal-confirmation-input::placeholder {\n            color: var(--text-secondary);\n            font-style: italic;\n        }\n\n        .modal-actions {\n            display: flex;\n            gap: 8px;\n            justify-content: flex-start;\n        }\n\n        .modal-btn-delete {\n            display: flex;\n            height: 32px;\n            padding: 6px 12px;\n            justify-content: center;\n            align-items: center;\n            gap: 4px;\n            border-radius: 6px;\n            background: var(--grey-90, #3E3D3E);\n            border: none;\n            color: var(--white, #FFF);\n            text-align: right;\n            font-family: \"DM Sans\";\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 18px;\n        }\n\n        .modal-btn-delete:hover:not(:disabled) {\n            background: #2a2929;\n        }\n\n        .modal-btn-delete:disabled {\n            background: var(--grey-10, #E5E4E4);\n            color: var(--grey-40, #B6B5B7);\n            text-align: right;\n            font-family: \"DM Sans\";\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 18px;\n            cursor: not-allowed;\n        }\n\n        .modal-btn-cancel {\n            display: flex;\n            height: 32px;\n            padding: 6px 12px;\n            justify-content: center;\n            align-items: center;\n            gap: 4px;\n            border-radius: 6px;\n            border: 1px solid var(--grey-20, #D3D1D5);\n            background: var(--white, #FFF);\n            color: var(--black, #0A090A);\n            text-align: right;\n            font-family: \"DM Sans\";\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 18px;\n        }\n\n        .modal-btn-cancel:hover {\n            background: var(--purple-5);\n            border-color: var(--purple-10);\n        }\n\n        /* Loader */\n        #loader-container {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 200px;\n        }\n\n        .loader-spinner {\n            width: 32px;\n            height: 32px;\n            border: 3px solid var(--grey-20);\n            border-top-color: var(--purple-10);\n            border-radius: 50%;\n            animation: spin 0.8s linear infinite;\n        }\n\n        @keyframes spin {\n            to { transform: rotate(360deg); }\n        }\n\n        /* App Root - hidden by default until data loads */\n        #app-root {\n            opacity: 0;\n            transition: opacity 0.2s ease;\n        }\n\n        #app-root.loaded {\n            opacity: 1;\n        }\n    </style>\n</head>\n\n<body>\n\n<!-- Loader Container -->\n<div id=\"loader-container\">\n    <div class=\"loader-spinner\"></div>\n</div>\n\n<!-- App Root -->\n<div id=\"app-root\">\n<!-- Delete Confirmation Modal Content -->\n<div class=\"modal-content\">\n    <svg class=\"modal-icon\" width=\"100\" height=\"101\" viewBox=\"0 0 100 101\" fill=\"none\"\n         xmlns=\"http://www.w3.org/2000/svg\">\n        <rect x=\"52.752\" y=\"15.9131\" width=\"26.2266\" height=\"26.2266\" rx=\"4\" transform=\"rotate(30 52.752 15.9131)\"\n              fill=\"url(#paint0_linear_10727_54167)\"\n              style=\"transform-origin: 57.8653px 15.0264px; animation: wiggleXBox 1s ease-in-out infinite alternate;\" />\n        <path\n                d=\"M24.1367 42.4391H75.819L72.2521 82.3009C71.8829 86.4263 68.4259 89.5878 64.2839 89.5878H35.6718C31.5298 89.5878 28.0728 86.4263 27.7036 82.3009L24.1367 42.4391Z\"\n                fill=\"#F5F3F3\" />\n        <path d=\"M82.1653 42.8817L17.8555 42.8817\" stroke=\"#0A090A\" stroke-miterlimit=\"10\"\n              stroke-linecap=\"square\" />\n        <path d=\"M49.3555 52.7511V78.0242\" stroke=\"#0A090A\" stroke-miterlimit=\"10\" stroke-linecap=\"square\" />\n        <path d=\"M35.7461 52.7511L36.7181 78.0242\" stroke=\"#0A090A\" stroke-miterlimit=\"10\"\n              stroke-linecap=\"square\" />\n        <path d=\"M62.9642 52.7511L61.9922 78.0242\" stroke=\"#0A090A\" stroke-miterlimit=\"10\"\n              stroke-linecap=\"square\" />\n        <path\n                d=\"M17.3359 43.0306H22.1373L25.3098 82.6874C25.714 87.7391 29.9315 91.6327 34.9993 91.6327H63.7095C68.7774 91.6327 72.9948 87.7391 73.399 82.6874L76.5716 43.0306H81.6458\"\n                stroke=\"#0A090A\" stroke-miterlimit=\"10\" stroke-linecap=\"square\" />\n        <path d=\"M27.002 12.0244C31.052 11.0416 40.322 10.7608 45.002 17.5\" stroke=\"black\" stroke-linecap=\"round\"\n              stroke-linejoin=\"round\" style=\"animation: wiggleX 1s ease-in-out infinite alternate;\" />\n        <path d=\"M29.002 17.8496C31.477 17.1944 37.142 17.0072 40.002 21.5\" stroke=\"black\" stroke-linecap=\"round\"\n              stroke-linejoin=\"round\" style=\"animation: wiggleX 1s ease-in-out infinite alternate;\" />\n        <defs>\n            <linearGradient id=\"paint0_linear_10727_54167\" x1=\"83.6609\" y1=\"15.9131\" x2=\"56.9744\" y2=\"43.4704\"\n                            gradientUnits=\"userSpaceOnUse\">\n                <stop offset=\"0.08\" stop-color=\"#FF8651\" />\n                <stop offset=\"0.504183\" stop-color=\"#FFBEA8\" />\n                <stop offset=\"0.97139\" stop-color=\"#A397F5\" />\n            </linearGradient>\n        </defs>\n    </svg>\n\n    <h2 class=\"modal-title\" id=\"modal-title\">Delete <span id=\"modal-entity-type\">environment</span></h2>\n\n    <p class=\"modal-description\">\n        Deleting this <span id=\"modal-entity-type-desc\">environment</span> will remove it permanently.\n    </p>\n\n    <p class=\"modal-warning\">\n        Are you sure you want to delete the <span id=\"modal-entity-type-warning\">environment</span>\n        \"<span id=\"modal-entity-name\">Environment Name</span>\"?\n    </p>\n\n    <label class=\"modal-confirmation-label\" id=\"modal-confirmation-label\">\n        ENTER THE WORD \"DELETE\" TO DELETE THIS ENVIRONMENT\n    </label>\n    <input\n            type=\"text\"\n            class=\"modal-confirmation-input\"\n            id=\"delete-confirmation-input\"\n            placeholder='Type \"DELETE\"'\n            autocomplete=\"off\"\n    />\n\n    <div class=\"modal-actions\">\n        <button class=\"button modal-btn-delete\" id=\"modal-btn-delete\" disabled>\n            Delete\n        </button>\n        <button class=\"button modal-btn-cancel\" id=\"modal-btn-cancel\">\n            No, keep editing\n        </button>\n    </div>\n</div>\n</div><!-- End App Root -->\n\n<script>\n    (function() {\n        // ==========================================\n        // PRIVATE SCOPE\n        // ==========================================\n\n        // Private state\n        let entityTypeState = 'environment';\n        let entityNameState = 'Production Environment';\n        let configState = {};\n        let isInitialized = false;\n\n        // Cache DOM elements\n        const elements = {\n            loaderContainer: document.getElementById('loader-container'),\n            appRoot: document.getElementById('app-root'),\n            deleteConfirmationInput: document.getElementById('delete-confirmation-input'),\n            modalEntityType: document.getElementById('modal-entity-type'),\n            modalEntityTypeDesc: document.getElementById('modal-entity-type-desc'),\n            modalEntityTypeWarning: document.getElementById('modal-entity-type-warning'),\n            modalEntityName: document.getElementById('modal-entity-name'),\n            modalConfirmationLabel: document.getElementById('modal-confirmation-label'),\n            modalBtnDelete: document.getElementById('modal-btn-delete'),\n            modalBtnCancel: document.getElementById('modal-btn-cancel')\n        };\n\n        // Private helper functions\n        function hideLoader() {\n            elements.loaderContainer.style.display = 'none';\n            elements.appRoot.classList.add('loaded');\n        }\n\n        function render() {\n            // Update entity type in all relevant places\n            elements.modalEntityType.textContent = entityTypeState;\n            elements.modalEntityTypeDesc.textContent = entityTypeState;\n            elements.modalEntityTypeWarning.textContent = entityTypeState;\n            elements.modalConfirmationLabel.textContent = `ENTER THE WORD \"DELETE\" TO DELETE THIS ${entityTypeState.toUpperCase()}`;\n\n            // Update entity name in UI\n            elements.modalEntityName.textContent = entityNameState;\n\n            // Reset input and button state\n            elements.deleteConfirmationInput.value = '';\n            elements.modalBtnDelete.disabled = true;\n\n            reportHeight();\n        }\n\n        function reportHeight() {\n            const container = document.querySelector('.modal-content');\n            if (container) {\n                setTimeout(() => {\n                    window.myop_cta_handler('heightChange', { height: container.scrollHeight });\n                }, 100);\n            }\n        }\n\n        function handleDeleteConfirmation() {\n            console.log('Component: Delete confirmed for:', entityTypeState, entityNameState);\n            window.myop_cta_handler('delete', { entityType: entityTypeState, entityName: entityNameState });\n        }\n\n        function handleCancel() {\n            console.log('Component: Delete cancelled');\n            window.myop_cta_handler('cancel', {});\n        }\n\n        function handleInput() {\n            const inputValue = elements.deleteConfirmationInput.value.trim();\n            elements.modalBtnDelete.disabled = inputValue !== 'DELETE';\n        }\n\n        // ==========================================\n        // PUBLIC API - Only 2 global functions\n        // ==========================================\n\n        /**\n         * Initialize component with data OR receive updates from host\n         */\n        window.myop_init_interface = function(data) {\n            if (arguments.length > 0) {\n                console.log('Component: myop_init_interface() called with:', data);\n\n                // Handle initialization data\n                if (data.entityType !== undefined) {\n                    entityTypeState = data.entityType;\n                }\n                if (data.entityName !== undefined) {\n                    entityNameState = data.entityName;\n                }\n                if (data.config !== undefined) {\n                    configState = data.config;\n                }\n\n                // Handle action-based updates\n                if (data.action) {\n                    switch (data.action) {\n                        case 'setEntityType':\n                            if (data.payload && data.payload.entityType) {\n                                entityTypeState = data.payload.entityType;\n                            }\n                            break;\n\n                        case 'setEntityName':\n                            if (data.payload && data.payload.entityName) {\n                                entityNameState = data.payload.entityName;\n                            }\n                            break;\n\n                        case 'reset':\n                            elements.deleteConfirmationInput.value = '';\n                            elements.modalBtnDelete.disabled = true;\n                            break;\n\n                        default:\n                            console.warn('Component: Unknown action:', data.action);\n                    }\n                }\n\n                // Attach event listeners only once\n                if (!isInitialized) {\n                    elements.deleteConfirmationInput.addEventListener('input', handleInput);\n                    elements.modalBtnDelete.addEventListener('click', handleDeleteConfirmation);\n                    elements.modalBtnCancel.addEventListener('click', handleCancel);\n                    isInitialized = true;\n                }\n\n                render();\n                hideLoader();\n                return data;\n            }\n            // Getter: Return current state\n            return { entityType: entityTypeState, entityName: entityNameState, config: configState };\n        };\n\n        /**\n         * Handle user actions and communicate back to the host application\n         * @param {string} action_id - The action identifier\n         * @param {object} payload - The action payload\n         */\n        window.myop_cta_handler = function(action_id, payload) {\n            console.log('Component: myop_cta_handler called with:', action_id, payload);\n            // This function is overridden by the host application\n        };\n\n        console.log('Component loaded, waiting for myop_init_interface() call');\n\n    })(); // End IIFE\n</script>\n\n<!-- Preview/Mock Data for Development -->\n<script id=\"myop_preview\">\n    setTimeout(() => {\n        window.myop_init_interface({\n            entityType: 'environment',\n            entityName: 'Production Environment'\n        });\n    });\n</script>\n</body>\n\n</html>"
        }
