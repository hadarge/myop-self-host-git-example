  "version": "0.2.9",
  "item": {
    "name": "Publish modal (Playground)",
    "id": "4f56bab9-d5e3-44f4-91b9-49afc9577dde",
    "organizationId": "myop2000-0000-0000-0000-000000000000",
    "consume_variant": [
      {
        "name": "Version 14",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":450,\"height\":460}'>\n    <title>Publish Success Modal</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n    <script type=\"myop/types\">\n        // =============================================================================\n    // MYOP COMPONENT TYPE DEFINITIONS\n    // =============================================================================\n\n    /**\n     * Data structure passed to myop_init_interface(data)\n     */\n    interface MyopInitData {\n        title?: string;\n        subtitle?: string;\n        componentId?: string;\n        shareUrl?: string;\n        linkedinShareUrl?: string;\n        whatsappShareUrl?: string;\n    }\n\n    /**\n     * Actions and payloads for myop_cta_handler(action, payload)\n     */\n    interface MyopCtaPayloads {\n        'build_your_own': {};\n        'navigate_to_playground': {};\n        'see_live': { componentId?: string };\n        'share': { componentId?: string };\n        'share_linkedin': { componentId?: string };\n        'share_whatsapp': { componentId?: string };\n    }\n\n    // =============================================================================\n    // DO NOT EDIT BELOW - Standard Myop type declarations\n    // =============================================================================\n\n    declare function myop_init_interface(): MyopInitData;\n    declare function myop_init_interface(data: MyopInitData): void;\n\n    declare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n        action: K,\n        payload: MyopCtaPayloads[K]\n    ): void;\n    </script>\n    <style>\n        :root {\n            --Black: #0A090A;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        html,\n        body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            font-family: \"DM Sans\", -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n        }\n\n        @keyframes twinkle {\n\n            0%,\n            100% {\n                opacity: 1;\n                transform: scale(1);\n            }\n\n            50% {\n                opacity: 0.75;\n                transform: scale(0.92);\n            }\n        }\n\n        @keyframes float {\n\n            0%,\n            100% {\n                transform: translateY(0);\n            }\n\n            50% {\n                transform: translateY(-2px);\n            }\n        }\n\n        @keyframes sparkle {\n\n            0%,\n            100% {\n                opacity: 1;\n                transform: scale(1) rotate(0deg);\n            }\n\n            50% {\n                opacity: 0.85;\n                transform: scale(1.05) rotate(5deg);\n            }\n        }\n\n        .star-1 {\n            animation: twinkle 4s ease-in-out infinite;\n            transform-origin: center;\n        }\n\n        .star-2 {\n            animation: float 5s ease-in-out infinite;\n            transform-origin: center;\n        }\n\n        .star-3 {\n            animation: sparkle 4.5s ease-in-out infinite;\n            transform-origin: center;\n        }\n\n        .star-4 {\n            animation: twinkle 3.5s ease-in-out infinite 0.5s;\n            transform-origin: center;\n        }\n\n        .star-5 {\n            animation: float 4s ease-in-out infinite 1s;\n            transform-origin: center;\n        }\n\n        @keyframes gentle-bounce {\n\n            0%,\n            100% {\n                transform: translateY(0);\n            }\n\n            50% {\n                transform: translateY(-2px);\n            }\n        }\n\n        .pc-icon {\n            animation: gentle-bounce 3s ease-in-out infinite;\n            transform-origin: center bottom;\n        }\n\n        #app-root {\n            padding: 29px;\n            padding-bottom: 0;\n            display: flex;\n            flex-direction: column;\n            width: 100%;\n        }\n\n        .icon-container {\n            margin-bottom: 22px;\n        }\n\n        .icon-container svg {\n            width: 90px;\n            height: 90px;\n        }\n\n        .modal-title {\n            overflow: hidden;\n            color: var(--Black, #0A090A);\n            text-overflow: ellipsis;\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 22px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 29px;\n            margin-bottom: 0;\n            width: 100%;\n        }\n\n        .modal-subtitle {\n            overflow: hidden;\n            color: var(--Black, #0A090A);\n            text-overflow: ellipsis;\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 22px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 29px;\n            margin-bottom: 22px;\n            width: 100%;\n        }\n\n        .button-row {\n            display: flex;\n            gap: 7px;\n            margin-bottom: 22px;\n        }\n\n        .share-section {\n            margin-bottom: 18px;\n        }\n\n        .share-label {\n            color: var(--SURFACE-0, #1C1B1F);\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 300;\n            line-height: 24px;\n            margin-bottom: 10px;\n        }\n\n        .share-icons {\n            display: flex;\n            gap: 8px;\n        }\n\n        .share-icon-btn {\n            width: 32px;\n            height: 32px;\n            border-radius: 6px;\n            border: 1px solid #e0e0e0;\n            background: white;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            transition: all 0.2s;\n        }\n\n        .share-icon-btn:hover {\n            background: var(--Purple-5, #F0E8FF);\n            border: 1px solid var(--Purple-10, #DECCFF);\n        }\n\n        .share-icon-btn svg {\n            width: 18px;\n            height: 18px;\n        }\n\n        .next-step-row {\n            display: flex;\n            width: calc(100% + 58px);\n            margin-left: -29px;\n            margin-right: -29px;\n            padding: 16px;\n            align-items: center;\n            justify-content: center;\n            gap: 16px;\n            margin-top: auto;\n            background: linear-gradient(90deg, rgba(255, 134, 81, 0.15), rgba(255, 190, 168, 0.15), rgba(163, 151, 245, 0.15));\n            border-radius: 0 0 14px 14px;\n        }\n\n        .next-step-text {\n            color: var(--SURFACE-0, #1C1B1F);\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 16px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 24px;\n        }\n\n        .btn-gradient-border {\n            position: relative;\n            background: white;\n            border: 1px solid #e0e0e0;\n            z-index: 1;\n        }\n\n        .btn-gradient-border.animating {\n            border: 1px solid transparent;\n        }\n\n        .btn-gradient-border.animating::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            border-radius: 7px;\n            background: conic-gradient(from 0deg,\n                    #FF8651 0deg,\n                    #FFBEA8 calc(var(--draw-progress) * 0.33),\n                    #A397F5 calc(var(--draw-progress) * 0.66),\n                    #FF8651 var(--draw-progress),\n                    transparent var(--draw-progress),\n                    transparent 360deg);\n            z-index: -2;\n            animation: draw-border 0.8s ease-out forwards;\n        }\n\n        .btn-gradient-border.animating::after {\n            content: '';\n            position: absolute;\n            top: 1px;\n            left: 1px;\n            right: 1px;\n            bottom: 1px;\n            border-radius: 6px;\n            background: white;\n            z-index: -1;\n        }\n\n        .btn-gradient-border:hover {\n            border: 1px solid transparent;\n        }\n\n        .btn-gradient-border:hover::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            border-radius: 7px;\n            background: conic-gradient(from var(--rotate-angle, 0deg),\n                    #FF8651,\n                    #FFBEA8,\n                    #A397F5,\n                    #FF8651);\n            z-index: -2;\n            animation: rotate-gradient 4s linear infinite;\n        }\n\n        .btn-gradient-border:hover::after {\n            content: '';\n            position: absolute;\n            top: 1px;\n            left: 1px;\n            right: 1px;\n            bottom: 1px;\n            border-radius: 6px;\n            background: linear-gradient(90deg, rgba(255, 134, 81, 0.15), rgba(255, 190, 168, 0.15), rgba(163, 151, 245, 0.15));\n            z-index: -1;\n        }\n\n        @property --draw-progress {\n            syntax: '<angle>';\n            initial-value: 0deg;\n            inherits: false;\n        }\n\n        @property --rotate-angle {\n            syntax: '<angle>';\n            initial-value: 0deg;\n            inherits: false;\n        }\n\n        @keyframes draw-border {\n            0% {\n                --draw-progress: 0deg;\n            }\n\n            50% {\n                --draw-progress: 360deg;\n            }\n\n            100% {\n                --draw-progress: 720deg;\n            }\n        }\n\n        @keyframes rotate-gradient {\n            0% {\n                --rotate-angle: 0deg;\n            }\n\n            100% {\n                --rotate-angle: 360deg;\n            }\n        }\n\n        .btn {\n            padding: 9px 18px;\n            height: 34px;\n            border-radius: 7px;\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 13px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 16px;\n            cursor: pointer;\n            transition: all 0.2s;\n        }\n\n        .btn-primary {\n            background: #1a1a1a;\n            color: white;\n            border: 1px solid #1a1a1a;\n        }\n\n        .btn-primary:hover {\n            background: #9747FF;\n            border-color: #9747FF;\n        }\n\n        .btn-secondary {\n            background: white;\n            color: #1a1a1a;\n            border: 1px solid #e0e0e0;\n        }\n\n        .btn-secondary:hover {\n            background: var(--Purple-5, #F0E8FF);\n            border: 1px solid var(--Purple-10, #DECCFF);\n        }\n\n        .btn-copied {\n            border-radius: 6px;\n            border: 1px solid var(--Grey-20, #D3D1D5);\n            background: var(--Green-10, #DCFF89);\n        }\n\n        .btn-copied:hover {\n            border: 1px solid var(--Grey-20, #D3D1D5);\n            background: var(--Green-10, #DCFF89);\n        }\n    </style>\n</head>\n\n<body>\n    <div id=\"app-root\">\n        <div class=\"icon-container\">\n            <svg width=\"100\" height=\"100\" viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                <rect x=\"11.8301\" y=\"33\" width=\"75.6311\" height=\"48.2752\" rx=\"3.11101\" fill=\"white\" stroke=\"black\"\n                    st