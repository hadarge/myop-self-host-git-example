tId: modalData.componentId });\n                    });\n\n                    document.getElementById('pick-another-btn').addEventListener('click', () => {\n                        window.myop_cta_handler('navigate_to_playground', {});\n                    });\n\n                    document.getElementById('linkedin-btn').addEventListener('click', () => {\n                        if (modalData.linkedinShareUrl) {\n                            window.open(modalData.linkedinShareUrl, '_blank');\n                        }\n                        window.myop_cta_handler('share_linkedin', { componentId: modalData.componentId });\n                    });\n\n                    document.getElementById('whatsapp-btn').addEventListener('click', () => {\n                        if (modalData.whatsappShareUrl) {\n                            window.open(modalData.whatsappShareUrl, '_blank');\n                        }\n                        window.myop_cta_handler('share_whatsapp', { componentId: modalData.componentId });\n                    });\n\n                    document.getElementById('build-own-btn').addEventListener('click', () => {\n                        window.myop_cta_handler('build_your_own', {});\n                    });\n\n                    // Drawing animation on load\n                    const buildBtn = document.getElementById('build-own-btn');\n                    buildBtn.classList.add('animating');\n                    setTimeout(() => {\n                        buildBtn.classList.remove('animating');\n                    }, 800);\n\n                    isInitialized = true;\n                }\n            }\n\n            // Public API\n            window.myop_init_interface = function(data) {\n                if (data === undefined) {\n                    return modalData;\n                }\n                initializeComponent(data);\n            };\n\n            window.myop_cta_handler = function(action_id, payload) {\n                console.log('CTA Handler:', action_id, payload);\n            };\n        })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            title: \"Great work!\",\n            subtitle: \"You took a real piece of the product and made it your own.\",\n            componentId: \"comp-123\",\n            shareUrl: \"https://myop.dev/app/comp-123\",\n            linkedinShareUrl: \"https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Fplayground.myop.dev%2Fstocks%3Fcomp-123\",\n            whatsappShareUrl: \"https://wa.me/?text=https%3A%2F%2Fplayground.myop.dev%2Fstocks%3Fcomp-123\"\n        });\n    </script>\n</body>\n\n</html>"
