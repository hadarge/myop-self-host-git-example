          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Header & Insights Component</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            width: 100%;\n            height: 100%;\n            background: transparent;\n            overflow: hidden;\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;\n        }\n\n        /* Loader Styles */\n        #loader-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            min-height: 200px;\n            width: 100%;\n        }\n\n        .loader-spinner {\n            width: 32px;\n            height: 32px;\n            border: 3px solid rgba(80, 255, 238, 0.3);\n            border-top-color: #50FFEE;\n            border-radius: 50%;\n            animation: spin 0.8s linear infinite;\n        }\n\n        .loader-text {\n            margin-top: 12px;\n            color: #717182;\n            font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 14px;\n        }\n\n        @keyframes spin {\n            to { transform: rotate(360deg); }\n        }\n\n        /* App Container - Hidden by default */\n        #app-root {\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n\n        #app-root.visible {\n            opacity: 1;\n        }\n\n        .main-container {\n            width: 100%;\n            max-width: 1223px;\n            padding: 24px 5px;\n            margin: 0 auto;\n            background: transparent;\n            display: flex;\n            flex-direction: column;\n            gap: 24px;\n        }\n\n        .header {\n            display: flex;\n            flex-direction: column;\n            align-items: flex-start;\n            gap: 12px;\n            flex-shrink: 0;\n        }\n\n        .welcome-title {\n            color: #363740;\n            font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 32px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 48px;\n            letter-spacing: 0.406px;\n        }\n\n        .stats-row {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 12px;\n            align-items: center;\n        }\n\n        .stat-item {\n            display: flex;\n            height: 32px;\n            padding: 0 12px;\n            align-items: center;\n            gap: 6px;\n            border-radius: 16777200px;\n            border: 1px solid rgba(0, 0, 0, 0.05);\n            background: #FFF;\n            font-size: 14px;\n            white-space: nowrap;\n        }\n\n        .stat-icon {\n            width: 14px;\n            height: 14px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            flex-shrink: 0;\n        }\n\n        .stat-icon svg {\n            width: 14px;\n            height: 14px;\n        }\n\n        .stat-value {\n            color: #363740;\n            font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 700;\n            line-height: 20px;\n            letter-spacing: -0.15px;\n        }\n\n        .stat-label {\n            color: #717182;\n            font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 20px;\n            letter-spacing: -0.15px;\n        }\n\n        .action-cards {\n            display: grid;\n            grid-template-columns: repeat(3, 1fr);\n            gap: 16px;\n            width: 100%;\n        }\n\n        .action-card {\n            display: flex;\n            min-height: 80px;\n            padding: 16px 20px;\n            justify-content: space-between;\n            align-items: center;\n            border-radius: 10px;\n            border: 1px solid rgba(0, 105, 95, 0.05);\n            background: linear-gradient(0deg, rgba(80, 255, 238, 0.10) 0%, rgba(80, 255, 238, 0.10) 100%), #FFF;\n            cursor: pointer;\n            transition: all 0.2s ease;\n        }\n\n        .action-card:hover {\n            border-radius: 10px;\n            background: #50FFEE;\n            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.10), 0 1px 2px -1px rgba(0, 0, 0, 0.10);\n        }\n\n        .action-card-content {\n            display: flex;\n            align-items: center;\n            gap: 16px;\n            flex: 1;\n            min-width: 0;\n        }\n\n        .action-icon {\n            width: 44px;\n            height: 44px;\n            background: white;\n            border-radius: 10px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            flex-shrink: 0;\n        }\n\n        .action-icon svg {\n            width: 22px;\n            height: 22px;\n        }\n\n        .action-text {\n            flex: 1;\n            min-width: 0;\n        }\n\n        .action-text h3 {\n            color: #141415;\n            font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 14px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 20px;\n            letter-spacing: -0.15px;\n            margin-bottom: 2px;\n        }\n\n        .action-text p {\n            color: #363740;\n            font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n            font-size: 12px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 16px;\n        }\n\n        .action-arrow {\n            width: 24px;\n            height: 24px;\n            color: #0a8270;\n            flex-shrink: 0;\n        }\n\n        @media (max-width: 768px) {\n            .main-container {\n                padding: 16px 16px;\n            }\n\n            .welcome-title {\n                font-size: 24px;\n                line-height: 36px;\n            }\n\n            /* Hide stats row on mobile */\n            .stats-row {\n                display: none;\n            }\n\n            /* Mobile: Icon-only buttons in a single row */\n            .action-cards {\n                grid-template-columns: repeat(3, 1fr);\n                gap: 12px;\n            }\n\n            .action-card {\n                min-height: auto;\n                padding: 6px;\n                justify-content: center;\n                aspect-ratio: 1;\n            }\n\n            /* Remove blue background on mobile hover but keep shadow */\n            .action-card:hover {\n                background: linear-gradient(0deg, rgba(80, 255, 238, 0.10) 0%, rgba(80, 255, 238, 0.10) 100%), #FFF;\n                box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.10), 0 1px 2px -1px rgba(0, 0, 0, 0.10);\n            }\n\n            .action-card-content {\n                gap: 0;\n                justify-content: center;\n            }\n\n            /* Remove white background, no container size */\n            .action-icon {\n                width: auto;\n                height: auto;\n                background: transparent;\n                border-radius: 0;\n            }\n\n            /* Increase icon size to 30px */\n            .action-icon svg {\n                width: 30px;\n                height: 30px;\n            }\n\n            /* Hide text and arrow on mobile */\n            .action-text {\n                display: none;\n            }\n\n            .action-arrow {\n                display: none;\n            }\n        }\n    </style>\n</head>\n<body>\n    <!-- Loader Container - Visible by default -->\n    <div id=\"loader-container\">\n        <div class=\"loader-spinner\"></div>\n        <div class=\"loader-text\">Loading...</div>\n    </div>\n\n    <!-- App Root - Hidden by default -->\n    <div id=\"app-root\">\n        <div class=\"main-container\">\n            <div class=\"header\">\n                <h1 class=\"welcome-title\" id=\"welcomeTitle\">Welcome!</h1>\n                <div class=\"stats-row\">\n                    <div class=\"stat-item\">\n                        <div class=\"stat-icon\">\n                            <svg viewBox=\"0 0 14 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                <g clip-path=\"url(#clip0_9170_855)\">\n                                <path d=\"M5.79651 9.04311C5.74443 8.84124 5.63921 8.65701 5.49178 8.50959C5.34436 8.36217 5.16013 8.25694 4.95826 8.20486L1.37951 7.28203C1.31845 7.2647 1.26471 7.22793 1.22645 7.17729C1.18818 7.12665 1.16748 7.06492 1.16748 7.00145C1.16748 6.93798 1.18818 6.87624 1.22645 6.8256C1.26471 6.77497 1.31845 6.73819 1.37951 6.72086L4.95826 5.79745C5.16006 5.74542 5.34424 5.64028 5.49166 5.49297C5.63907 5.34566 5.74434 5.16155 5.79651 4.95978L6.71934 1.38103C6.7365 1.31973 6.77323 1.26573 6.82394 1.22726C6.87466 1.18879 6.93656 1.16797 7.00022 1.16797C7.06387 1.16797 7.12577 1.18879 7.17649 1.22726C7.2272 1.26573 7.26394 1.31973 7.28109 1.38103L8.20334 4.95978C8.25542 5.16166 8.36064 5.34589 8.50806 5.49331C8.65549 5.64073 8.83972 5.74595 9.04159 5.79803L12.6203 6.72028C12.6819 6.73726 12.7362 6.77395 12.7748 6.82474C12.8135 6.87553 12.8345 6.93761 12.8345 7.00145C12.8345 7.06529 12.8135 7.12736 12.7748 7.17815C12.7362 7.22894 12.6819 7.26564 12.6203 7.28261L9.04159 8.20486C8.83972 8.25694 8.65549 8.36217 8.50806 8.50959C8.36064 8.65701 8.25542 8.84124 8.20334 9.04311L7.28051 12.6219C7.26335 12.6832 7.22662 12.7372 7.1759 12.7756C7.12519 12.8141 7.06329 12.8349 6.99963 12.8349C6.93598 12.8349 6.87407 12.8141 6.82336 12.7756C6.77265 12.7372 6.73591 12.6832 6.71876 12.6219L5.79651 9.04311Z\" stroke=\"currentColor\" stroke-width=\"1.16667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M11.6667 1.75V4.08333\" stroke=\"currentColor\" stroke-width=\"1.16667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M12.8333 2.91797H10.5\" stroke=\"currentColor\" stroke-width=\"1.16667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M2.33325 9.91797V11.0846\" stroke=\"currentColor\" stroke-width=\"1.16667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M2.91667 10.5H1.75\" stroke=\"currentColor\" stroke-width=\"1.16667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                </g>\n                                <defs>\n                                <clipPath id=\"clip0_9170_855\">\n                                <rect width=\"14\" height=\"14\" fill=\"white\"/>\n                                </clipPath>\n                                </defs>\n                            </svg>\n                        </div>\n                        <span><span class=\"stat-value\" id=\"experienceValue\">0</span> <span class=\"stat-label\" id=\"experienceLabel\">Experience</span></span>\n                    </div>\n                    <div class=\"stat-item\">\n                        <div class=\"stat-icon\">\n                            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                                <path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"></path>\n                                <circle cx=\"9\" cy=\"7\" r=\"4\"></circle>\n                                <path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"></path>\n                                <path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path>\n                            </svg>\n                        </div>\n                        <span><span class=\"stat-value\" id=\"membersValue\">0</span> <span class=\"stat-label\" id=\"membersLabel\">Members</span></span>\n                    </div>\n                    <div class=\"stat-item\">\n                        <div class=\"stat-icon\">\n                            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                                <path d=\"M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z\"></path>\n                            </svg>\n                        </div>\n                        <span><span class=\"stat-value\" id=\"skillsValue\">0</span> <span class=\"stat-label\" id=\"skillsLabel\">Skills</span></span>\n                    </div>\n                    <div class=\"stat-item\">\n                        <div class=\"stat-icon\">\n                            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                                <path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"></path>\n                                <polyline points=\"22 4 12 14.01 9 11.01\"></polyline>\n                            </svg>\n                        </div>\n                        <span><span class=\"stat-value\" id=\"projectsValue\">0</span> <span class=\"stat-label\" id=\"projectsLabel\">Projects</span></span>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"action-cards\" id=\"actionCards\">\n                <div class=\"action-card\" data-action=\"addMember\">\n                    <div class=\"action-card-content\">\n                        <div class=\"action-icon\">\n                            <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                <path d=\"M13.3333 17.5V15.8333C13.3333 14.9493 12.9821 14.1014 12.357 13.4763C11.7319 12.8512 10.884 12.5 9.99996 12.5H4.99996C4.1159 12.5 3.26806 12.8512 2.64294 13.4763C2.01782 14.1014 1.66663 14.9493 1.66663 15.8333V17.5\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M7.49996 9.16667C9.34091 9.16667 10.8333 7.67428 10.8333 5.83333C10.8333 3.99238 9.34091 2.5 7.49996 2.5C5.65901 2.5 4.16663 3.99238 4.16663 5.83333C4.16663 7.67428 5.65901 9.16667 7.49996 9.16667Z\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M15.8334 6.66797V11.668\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M18.3334 9.16797H13.3334\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                            </svg>\n                        </div>\n                        <div class=\"action-text\">\n                            <h3>Add New Member</h3>\n                            <p>Invite someone to your team</p>\n                        </div>\n                    </div>\n                    <svg class=\"action-arrow\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                        <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line>\n                        <polyline points=\"12 5 19 12 12 19\"></polyline>\n                    </svg>\n                </div>\n\n                <div class=\"action-card\" data-action=\"viewHighlights\">\n                    <div class=\"action-card-content\">\n                        <div class=\"action-icon\">\n                            <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                <path d=\"M2.5 2.5V15.8333C2.5 16.2754 2.67559 16.6993 2.98816 17.0118C3.30072 17.3244 3.72464 17.5 4.16667 17.5H17.5\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M15 14.1667V7.5\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M10.8334 14.168V4.16797\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M6.66663 14.168V11.668\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                            </svg>\n                        </div>\n                        <div class=\"action-text\">\n                            <h3>View Highlights</h3>\n                            <p>Insights & team trends</p>\n                        </div>\n                    </div>\n                    <svg class=\"action-arrow\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                        <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line>\n                        <polyline points=\"12 5 19 12 12 19\"></polyline>\n                    </svg>\n                </div>\n\n                <div class=\"action-card\" data-action=\"shareTeam\">\n                    <div class=\"action-card-content\">\n                        <div class=\"action-icon\">\n                            <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                <path d=\"M15 6.66797C16.3807 6.66797 17.5 5.54868 17.5 4.16797C17.5 2.78726 16.3807 1.66797 15 1.66797C13.6193 1.66797 12.5 2.78726 12.5 4.16797C12.5 5.54868 13.6193 6.66797 15 6.66797Z\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M5 12.5C6.38071 12.5 7.5 11.3807 7.5 10C7.5 8.61929 6.38071 7.5 5 7.5C3.61929 7.5 2.5 8.61929 2.5 10C2.5 11.3807 3.61929 12.5 5 12.5Z\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M15 18.332C16.3807 18.332 17.5 17.2127 17.5 15.832C17.5 14.4513 16.3807 13.332 15 13.332C13.6193 13.332 12.5 14.4513 12.5 15.832C12.5 17.2127 13.6193 18.332 15 18.332Z\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M7.15833 11.2578L12.85 14.5745\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                                <path d=\"M12.8417 5.42578L7.15833 8.74245\" stroke=\"#363740\" stroke-width=\"1.66667\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                            </svg>\n                        </div>\n                        <div class=\"action-text\">\n                            <h3>Share Team</h3>\n                            <p>Copy link to share</p>\n                        </div>\n                    </div>\n                    <svg class=\"action-arrow\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                        <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line>\n                        <polyline points=\"12 5 19 12 12 19\"></polyline>\n                    </svg>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n(function() {\n    // ==========================================\n    // PRIVATE SCOPE - Hidden from global\n    // ==========================================\n    \n    // Private state\n    let userNameState = 'User';\n    let statsState = {\n        experience: { value: '0', label: 'Experience' },\n        members: { value: 0, label: 'Members' },\n        skills: { value: 0, label: 'Skills' },\n        projects: { value: 0, label: 'Projects' }\n    };\n    let isInitialized = false;\n    \n    // DOM references\n    const loaderContainer = document.getElementById('loader-container');\n    const appRoot = document.getElementById('app-root');\n    \n    // Private helper functions\n    function hideLoader() {\n        if (loaderContainer) {\n            loaderContainer.style.display = 'none';\n        }\n        if (appRoot) {\n            appRoot.classList.add('visible');\n        }\n    }\n    \n    function showLoader() {\n        if (loaderContainer) {\n            loaderContainer.style.display = 'flex';\n        }\n        if (appRoot) {\n            appRoot.classList.remove('visible');\n        }\n    }\n    \n    function updateUserName() {\n        const titleElement = document.getElementById('welcomeTitle');\n        if (titleElement) {\n            titleElement.textContent = `Welcome, ${userNameState}!`;\n        }\n    }\n    \n    function updateStats() {\n        // Update experience\n        const expValue = document.getElementById('experienceValue');\n        const expLabel = document.getElementById('experienceLabel');\n        if (expValue && statsState.experience) {\n            expValue.textContent = statsState.experience.value;\n        }\n        if (expLabel && statsState.experience) {\n            expLabel.textContent = statsState.experience.label;\n        }\n\n        // Update members\n        const membersValue = document.getElementById('membersValue');\n        const membersLabel = document.getElementById('membersLabel');\n        if (membersValue && statsState.members) {\n            membersValue.textContent = statsState.members.value;\n        }\n        if (membersLabel && statsState.members) {\n            membersLabel.textContent = statsState.members.label;\n        }\n\n        // Update skills\n        const skillsValue = document.getElementById('skillsValue');\n        const skillsLabel = document.getElementById('skillsLabel');\n        if (skillsValue && statsState.skills) {\n            skillsValue.textContent = statsState.skills.value;\n        }\n        if (skillsLabel && statsState.skills) {\n            skillsLabel.textContent = statsState.skills.label;\n        }\n\n        // Update projects\n        const projectsValue = document.getElementById('projectsValue');\n        const projectsLabel = document.getElementById('projectsLabel');\n        if (projectsValue && statsState.projects) {\n            projectsValue.textContent = statsState.projects.value;\n        }\n        if (projectsLabel && statsState.projects) {\n            projectsLabel.textContent = statsState.projects.label;\n        }\n    }\n    \n    function renderUI() {\n        updateUserName();\n        updateStats();\n    }\n    \n    function handleActionClick(event) {\n        // Find the closest action card\n        const card = event.target.closest('.action-card');\n        if (!card) return;\n\n        const action = card.dataset.action;\n        \n        if (action && typeof window.myop_cta_handler === 'function') {\n            console.log('Component: Action clicked:', action);\n            window.myop_cta_handler('actionClick', { action: action });\n        }\n    }\n    \n    function attachEventListeners() {\n        const actionCards = document.querySelectorAll('.action-card');\n        actionCards.forEach(card => {\n            card.addEventListener('click', handleActionClick);\n        });\n    }\n    \n    function initializeComponent(data) {\n        console.log('Component: Initializing with data:', data);\n        \n        if (data.userName) {\n            userNameState = data.userName;\n        }\n        if (data.stats) {\n            statsState = { ...statsState, ...data.stats };\n        }\n        \n        // Attach event listeners only once\n        if (!isInitialized) {\n            attachEventListeners();\n            isInitialized = true;\n        }\n        \n        renderUI();\n        hideLoader();\n    }\n    \n    // ==========================================\n    // PUBLIC API - Only 2 functions are global\n    // ==========================================\n    \n    /**\n     * Initialize component with data or handle action-based updates\n     * \n     * Data structure for initialization:\n     * {\n     *   userName: 'John Doe',\n     *   stats: {\n     *     experience: { value: '5 years', label: 'Experience' },\n     *     members: { value: 12, label: 'Members' },\n     *     skills: { value: 8, label: 'Skills' },\n     *     projects: { value: 23, label: 'Projects' }\n     *   }\n     * }\n     * \n     * Action-based updates:\n     * - { action: 'updateUserName', payload: 'New Name' }\n     * - { action: 'updateStats', payload: { ... } }\n     * - { action: 'updateStat', payload: { key: 'members', value: 15, label: 'Members' } }\n     * - { action: 'setData', payload: { userName: '...', stats: {...} } }\n     */\n    window.myop_init_interface = function(data) {\n        // Getter: Return current state when called without arguments\n        if (arguments.length === 0) {\n            return { \n                userName: userNameState, \n                stats: statsState \n            };\n        }\n        \n        // Handle action-based updates\n        if (data && data.action) {\n            console.log('Component: Received action:', data.action);\n            \n            switch (data.action) {\n                case 'updateUserName':\n                    userNameState = data.payload;\n                    updateUserName();\n                    break;\n                    \n                case 'updateStats':\n                    statsState = { ...statsState, ...data.payload };\n                    updateStats();\n                    break;\n                    \n                case 'updateStat':\n                    // Update a single stat\n                    if (data.payload && data.payload.key && statsState[data.payload.key]) {\n                        statsState[data.payload.key] = {\n                            value: data.payload.value,\n                            label: data.payload.label || statsState[data.payload.key].label\n                        };\n                        updateStats();\n                    }\n                    break;\n                    \n                case 'setData':\n                    initializeComponent(data.payload);\n                    break;\n                    \n                default:\n                    console.warn('Component: Unknown action:', data.action);\n            }\n            \n            return data;\n        }\n        \n        // Standard initialization with data object\n        initializeComponent(data);\n        return data;\n    };\n    \n    /**\n     * CTA Handler - Called by component to communicate events to host\n     * \n     * Events sent:\n     * - actionClick: { action: 'addMember' | 'viewHighlights' | 'shareTeam' }\n     * \n     * Note: This function is meant to be overridden by the host application.\n     * The component calls this function when user interactions occur.\n     */\n    window.myop_cta_handler = function(action_id, payload) {\n        console.log('Component: CTA triggered (no host handler set):', action_id, payload);\n        // Default implementation - host should override this\n    };\n    \n    // Initialize on DOM ready (but don't hide loader - wait for data)\n    if (document.readyState === 'loading') {\n        document.addEventListener('DOMContentLoaded', function() {\n            console.log('Component: Header & Insights ready, waiting for data...');\n        });\n    } else {\n        console.log('Component: Header & Insights ready, waiting for data...');\n    }\n    \n})(); // IIFE - Everything above is encapsulated\n    </script>\n\n    <!-- Preview/Mock Data Script -->\n    <script id=\"myop_preview\">\n        setTimeout(() => {\n            window.myop_init_interface({\n                userName: \"John Doe\",\n                stats: {\n                    experience: { value: \"5 years\", label: \"Experience\" },\n                    members: { value: 12, label: \"Members\" },\n                    skills: { value: 8, label: \"Skills\" },\n                    projects: { value: 23, label: \"Projects\" }\n                }\n            });\n        }, 500);\n    </script>\n</body>\n</html>"
        }
      }
    ]
  }
