{
  "version": "0.2.9",
  "item": {
    "name": "eToro 2",
    "id": "2098cfba-5124-48ff-b87d-6cd71c14cf7a",
    "organizationId": "myop2000-0000-0000-0000-000000000000",
    "consume_variant": [
      {
        "id": "b58499be-5596-4ff5-b569-a7f917de8193",
        "name": "Default Version",
        "loader": {
          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":400,\"height\":600}'>\n\n    <script type=\"myop/types\">\n// =============================================================================\n// MYOP COMPONENT TYPE DEFINITIONS\n// =============================================================================\n\n/**\n * Data structure passed to myop_init_interface(data)\n */\ninterface MyopInitData {\n  /** Whether the \"Don't show this again\" checkbox is checked */\n  dontShowAgain?: boolean;\n}\n\n/**\n * Actions and payloads for myop_cta_handler(action, payload)\n */\ninterface MyopCtaPayloads {\n  'activate-staking': void;\n  'dont-show-again-changed': { checked: boolean };\n  'learn-more-clicked': void;\n}\n\n// =============================================================================\n// DO NOT EDIT BELOW - Standard Myop type declarations\n// =============================================================================\n\ndeclare function myop_init_interface(): MyopInitData;\ndeclare function myop_init_interface(data: MyopInitData): void;\n\ndeclare function myop_cta_handler<K extends keyof MyopCtaPayloads>(\n  action: K,\n  payload: MyopCtaPayloads[K]\n): void;\n    </script>\n\n    <style>\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n\n        html, body {\n            width: 100%;\n            margin: 0;\n            padding: 0;\n        }\n\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n        }\n\n        #app-root {\n            width: 100%;\n            background: #FFFFFF;\n            border-radius: 24px;\n            padding: 40px 32px 32px;\n            position: relative;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n\n        .illustration {\n            width: 238px;\n            height: 238px;\n            margin-bottom: 24px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            position: relative;\n        }\n\n        .illustration-svg {\n            width: 100%;\n            height: 100%;\n            object-fit: contain;\n        }\n\n        .title {\n            font-size: 22px;\n            font-weight: 700;\n            color: #2c2c2c;\n            text-align: center;\n            line-height: 28px;\n            margin-bottom: 20px;\n            letter-spacing: -0.25px;\n            font-family: etoro-general-font, 'Open Sans', arial, sans-serif;\n        }\n\n        .description {\n            font-size: 16px;\n            font-weight: 400;\n            line-height: 20px;\n            color: #6B7280;\n            text-align: center;\n            margin-bottom: 32px;\n            max-width: 340px;\n        }\n\n        .description strong {\n            color: #1F2937;\n            font-weight: 600;\n        }\n\n        .checkbox-container {\n            display: flex;\n            align-items: center;\n            gap: 10px;\n            margin-bottom: 24px;\n            cursor: pointer;\n            user-select: none;\n            align-self: flex-start;\n        }\n\n        .checkbox-wrapper {\n            position: relative;\n            width: 24px;\n            height: 24px;\n        }\n\n        .checkbox {\n            appearance: none;\n            width: 24px;\n            height: 24px;\n            border: 2px solid #22C55E;\n            border-radius: 6px;\n            background: transparent;\n            cursor: pointer;\n            position: relative;\n            margin: 0;\n        }\n\n        .checkbox:checked {\n            background: #22C55E;\n        }\n\n        .checkbox:checked::after {\n            content: '';\n            position: absolute;\n            left: 50%;\n            top: 50%;\n            width: 6px;\n            height: 11px;\n            border: solid white;\n            border-width: 0 2.5px 2.5px 0;\n            transform: translate(-50%, -60%) rotate(45deg);\n        }\n\n        .checkbox-label {\n            font-size: 15px;\n            color: #6B7280;\n            cursor: pointer;\n        }\n\n        .activate-button {\n            width: 100%;\n            background: #0EB12E;\n            border: none;\n            border-radius: 28px;\n            color: #FFFFFF;\n            font-size: 14px;\n            font-weight: 700;\n            line-height: 45px;\n            padding: 0 15px;\n            cursor: pointer;\n            margin-bottom: 16px;\n            transition: transform 0.1s, box-shadow 0.2s;\n            box-shadow: 0 4px 12px rgba(63, 185, 35, 0.25);\n        }\n\n        .activate-button:hover {\n            transform: translateY(-1px);\n            box-shadow: 0 6px 16px rgba(34, 197, 94, 0.3);\n        }\n\n        .activate-button:active {\n            transform: translateY(0);\n        }\n\n        .disclaimer {\n            font-size: 13px;\n            color: #6B7280;\n            text-align: center;\n            line-height: 1.5;\n        }\n\n        .disclaimer a {\n            color: #22C55E;\n            text-decoration: none;\n            font-weight: 600;\n        }\n\n        .disclaimer a:hover {\n            text-decoration: underline;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"app-root\">\n        <div class=\"illustration\">\n            <svg viewBox=\"0 0 675 630\" class=\"illustration-svg\" xmlns=\"http://www.w3.org/2000/svg\">\n                <!-- SVG content loaded dynamically -->\n            </svg>\n        </div>\n\n        <h1 class=\"title\">Earn passive income<br>with staking</h1>\n\n        <p class=\"description\">\n            Staking lets you earn passive income effortlessly by helping secure blockchain networks. <strong>It's free to enable and takes just one click.</strong> With no work or expertise required, staking is the easiest way to put your crypto to work.\n        </p>\n\n        <label class=\"checkbox-container\" id=\"checkboxContainer\">\n            <div class=\"checkbox-wrapper\">\n                <input type=\"checkbox\" class=\"checkbox\" id=\"dontShowCheckbox\">\n            </div>\n            <span class=\"checkbox-label\">Don't show this again</span>\n        </label>\n\n        <button class=\"activate-button\" id=\"activateBtn\">Activate Staking</button>\n\n        <p class=\"disclaimer\">\n            Staking is not risk-free and access to the staked crypto assets may be limited <a href=\"#\" id=\"learnMoreLink\">Learn More</a>\n        </p>\n    </div>\n\n    <script>\n    (function() {\n        let currentState = {\n            dontShowAgain: false\n        };\n\n        function render(data) {\n            currentState = { ...currentState, ...data };\n\n            const checkbox = document.getElementById('dontShowCheckbox');\n            if (checkbox) {\n                checkbox.checked = currentState.dontShowAgain || false;\n            }\n        }\n\n        function loadSVG() {\n            fetch('https://user-components-assets.s3.eu-south-1.amazonaws.com/2098cfba-5124-48ff-b87d-6cd71c14cf7a/pasted-xml-2026-03-01T11-02-43.xml')\n                .then(response => response.text())\n                .then(svgContent => {\n                    const svgContainer = document.querySelector('.illustration svg');\n                    if (svgContainer) {\n                        // Remove XML declaration and outer svg tag, keep only the content\n                        const cleanSVG = svgContent\n                            .replace(/<\\?xml[^?]*\\?>/g, '')\n                            .replace(/^[\\s\\S]*?<svg[^>]*>/i, '')\n                            .replace(/<\\/svg>[\\s\\S]*$/i, '');\n                        svgContainer.innerHTML = cleanSVG;\n                    }\n                })\n                .catch(err => console.error('Failed to load SVG:', err));\n        }\n\n        function attachEventListeners() {\n            const activateBtn = document.getElementById('activateBtn');\n            const checkbox = document.getElementById('dontShowCheckbox');\n            const learnMoreLink = document.getElementById('learnMoreLink');\n\n            if (activateBtn) {\n                activateBtn.addEventListener('click', () => {\n                    window.myop_cta_handler('activate-staking', undefined);\n                });\n            }\n\n            if (checkbox) {\n                checkbox.addEventListener('change', (e) => {\n                    currentState.dontShowAgain = e.target.checked;\n                    window.myop_cta_handler('dont-show-again-changed', {\n                        checked: e.target.checked\n                    });\n                });\n            }\n\n            if (learnMoreLink) {\n                learnMoreLink.addEventListener('click', (e) => {\n                    e.preventDefault();\n                    window.myop_cta_handler('learn-more-clicked', undefined);\n                });\n            }\n        }\n\n        window.myop_init_interface = function(data) {\n            if (!data) return currentState;\n            render(data);\n        };\n\n        window.myop_cta_handler = function(action_id, payload) {\n            // Will be overridden by host application\n        };\n\n        // Initialize\n        attachEventListeners();\n        loadSVG();\n    })();\n    </script>\n\n    <script id=\"myop_preview\">\n        window.myop_init_interface({\n            dontShowAgain: false\n        });\n    </script>\n</body>\n</html>\n"
        }
      }
    ]
  }
