          "type": "HTMLLoader",
          "shadowRootMode": "localFrame",
          "HTML": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"myop:size\" content='{\"width\":\"100%\",\"height\":\"100%\"}'>\n    <title>Organization Settings</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: \"DM Sans\", -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;\n            background-color: #ffffff;\n            color: #0A090A;\n            line-height: 1.5;\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n        }\n\n        /* App Styles */\n        .outer-wrapper {\n            padding-left: 8px;\n            width: 100%;\n        }\n\n        .container {\n            width: 100%;\n        }\n\n        /* Header Container */\n        .header-container {\n            display: flex;\n            width: 373px;\n            height: 62px;\n            padding: 19px 20px 19px 20px;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            align-self: stretch;\n            position: relative;\n        }\n\n        /* Mobile border - full width */\n        .header-container::after {\n            content: '';\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            right: 0;\n            margin-left: calc(-50vw + 50%);\n            margin-right: calc(-50vw + 50%);\n            height: 1px;\n            background-color: #e5e5e5;\n        }\n\n        /* Desktop only - left align, no border, different size */\n        @media (min-width: 769px) {\n            .header-container {\n                width: 1438px;\n                height: 64px;\n                padding: 20px;\n                align-items: flex-start;\n            }\n\n            .header-container::after {\n                display: none;\n            }\n        }\n\n        /* Content Container */\n        .content-container {\n            display: flex;\n            padding: 16px;\n            flex-direction: column;\n            align-items: stretch;\n            gap: 20px;\n            flex: 1 0 0;\n            align-self: stretch;\n            width: 100%;\n        }\n\n        /* Header */\n        .page-title {\n            color: #0A090A;\n            font-family: \"DM Sans\", sans-serif;\n            font-size: 24px;\n            font-style: normal;\n            font-weight: 400;\n            line-height: 32px;\n        }\n\n        /* Cards Grid */\n        .cards-grid {\n            display: grid;\n            width: 660px;\n            row-gap: 24px;\n            column-gap: 24px;\n            flex-shrink: 0;\n            grid-template-rows: repeat(1, minmax(0, 1fr));\n            grid-template-columns: repeat(2, minmax(0, 1fr));\n            margin-right: auto;\n        }\n\n        .card {\n            border: 1px solid #e5e5e5;\n            border-radius: 12px;\n            padding: 20px;\n            cursor: pointer;\n            transition: border-color 0.2s ease, box-shadow 0.2s ease;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n        }\n\n        .card:hover {\n            border-color: #8039FD;\n        }\n\n        .card:hover .card-title {\n            color: #8039FD;\n        }\n\n        .card:hover .card-icon svg path {\n            stroke: #8039FD;\n        }\n\n        .card:hover .card-link {\n            color: #8039FD;\n        }\n\n        .card-header {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            margin-bottom: 4px;\n        }\n\n        .card-icon {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .card-icon svg path {\n            transition: stroke 0.2s ease;\n        }\n\n        .card-title {\n            font-size: 14px;\n            font-weight: 500;\n            color: #0A090A;\n            transition: color 0.2s ease;\n        }\n\n        .card-value {\n            font-size: 14px;\n            font-weight: 400;\n            color: #5A595B;\n            margin-bottom: 16px;\n        }\n\n        .card-link {\n            display: flex;\n            align-items: center;\n            gap: 4px;\n            font-size: 14px;\n            font-weight: 400;\n            color: #0A090A;\n            text-decoration: none;\n            cursor: pointer;\n            transition: color 0.2s ease;\n        }\n\n        .card-link-arrow {\n            font-size: 14px;\n        }\n\n        /* Divider */\n        .divider {\n            height: 1px;\n            background-color: #e5e5e5;\n            align-self: stretch;\n        }\n\n        /* Organization Details Section */\n        .org-details-container {\n            display: flex;\n            flex-direction: column;\n            align-items: flex-start;\n            gap: 16px;\n            align-self: stretch;\n        }\n\n        .section-title {\n            font-size: 16px;\n            font-weight: 700;\n            color: #3E3D3E;\n        }\n\n        .details-grid {\n            display: flex;\n            flex-direction: column;\n            gap: 16px;\n        }\n\n        .detail-item {\n            display: flex;\n            flex-direction: column;\n            gap: 4px;\n        }\n\n        .detail-label {\n            font-size: 14px;\n            font-weight: 600;\n            color: #3E3D3E;\n        }\n\n        .detail-value {\n            font-size: 14px;\n            font-weight: 400;\n            color: #3E3D3E;\n        }\n\n        /* Responsive - Tablet */\n        @media (max-width: 768px) {\n            .cards-grid {\n                width: 100%;\n                height: auto;\n                grid-template-columns: 1fr;\n                grid-template-rows: auto;\n                gap: 16px;\n            }\n\n            .header-container {\n                padding: 16px 16px 8px 12px;\n            }\n\n            .content-container {\n                padding: 0 12px 20px 12px;\n                gap: 16px;\n            }\n\n            .outer-wrapper {\n                padding-left: 4px;\n            }\n        }\n\n        /* Responsive - Mobile */\n        @media (max-width: 480px) {\n            .page-title {\n                font-size: 24px;\n                line-height: 32px;\n            }\n\n            .header-container {\n                padding: 12px 12px 8px 8px;\n            }\n\n            .content-container {\n                padding: 16px;\n                gap: 14px;\n            }\n\n            .outer-wrapper {\n                padding-left: 0;\n            }\n\n            .card {\n                padding: 16px;\n            }\n\n            .card-header {\n                gap: 6px;\n            }\n\n            .card-value {\n                margin-bottom: 12px;\n            }\n\n            .org-details-container {\n                gap: 12px;\n            }\n\n            .details-grid {\n                gap: 12px;\n            }\n\n            .section-title {\n                font-size: 15px;\n            }\n        }\n    </style>\n</head>\n\n<body>\n    <!-- App -->\n    <div id=\"app-root\">\n        <div class=\"outer-wrapper\">\n            <div class=\"container\">\n                <!-- Header Container -->\n                <div class=\"header-container\">\n                    <h1 class=\"page-title\">Organization settings</h1>\n                </div>\n\n                <!-- Content Container -->\n                <div class=\"content-container\">\n                    <!-- Cards -->\n                    <div class=\"cards-grid\">\n                        <!-- Members & Seats Card -->\n                        <div class=\"card\" id=\"members-card\" data-action=\"members_seats_clicked\">\n                            <div class=\"card-content\">\n                                <div class=\"card-header\">\n                                    <div class=\"card-icon\">\n                                        <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\"\n                                            xmlns=\"http://www.w3.org/2000/svg\">\n                                            <path\n                                                d=\"M13.3333 17.5V15.8333C13.3333 14.9493 12.9821 14.1014 12.357 13.4763C11.7319 12.8512 10.884 12.5 9.99996 12.5H4.99996C4.1159 12.5 3.26806 12.8512 2.64294 13.4763C2.01782 14.1014 1.66663 14.9493 1.66663 15.8333V17.5\"\n                                                stroke=\"#0A090A\" stroke-width=\"1.66667\" stroke-linecap=\"round\"\n                                                stroke-linejoin=\"round\" />\n                                            <path\n                                                d=\"M13.3334 2.60669C14.0482 2.792 14.6812 3.20941 15.1331 3.79341C15.585 4.37741 15.8302 5.09493 15.8302 5.83336C15.8302 6.57178 15.585 7.28931 15.1331 7.8733C14.6812 8.4573 14.0482 8.87471 13.3334 9.06002\"\n                                                stroke=\"#0A090A\" stroke-width=\"1.66667\" stroke-linecap=\"round\"\n                                                stroke-linejoin=\"round\" />\n                                            <path\n                                                d=\"M18.3334 17.5001V15.8334C18.3328 15.0948 18.087 14.3774 17.6345 13.7937C17.182 13.2099 16.5485 12.793 15.8334 12.6084\"\n                                                stroke=\"#0A090A\" stroke-width=\"1.66667\" stroke-linecap=\"round\"\n                                                stroke-linejoin=\"round\" />\n                                            <path\n                                                d=\"M7.49996 9.16667C9.34091 9.16667 10.8333 7.67428 10.8333 5.83333C10.8333 3.99238 9.34091 2.5 7.49996 2.5C5.65901 2.5 4.16663 3.99238 4.16663 5.83333C4.16663 7.67428 5.65901 9.16667 7.49996 9.16667Z\"\n                                                stroke=\"#0A090A\" stroke-width=\"1.66667\" stroke-linecap=\"round\"\n                                                stroke-linejoin=\"round\" />\n                                        </svg>\n                                    </div>\n                                    <div class=\"card-title\">Members & Seats</div>\n                                </div>\n                                <div class=\"card-value\" id=\"seats-value\">— of — seats used</div>\n                            </div>\n                            <div class=\"card-link\" id=\"members-link\">\n                                <span>Manage access and invitations</span>\n                                <span class=\"card-link-arrow\">›</span>\n                            </div>\n                        </div>\n\n                        <!-- Billing & Plan Card -->\n                        <div class=\"card\" id=\"billing-card\" data-action=\"billing_plan_clicked\">\n                            <div class=\"card-content\">\n                                <div class=\"card-header\">\n                                    <div class=\"card-icon\">\n                                        <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\"\n                                            xmlns=\"http://www.w3.org/2000/svg\">\n                                            <path\n                                                d=\"M16.6667 4.16663H3.33341C2.41294 4.16663 1.66675 4.91282 1.66675 5.83329V14.1666C1.66675 15.0871 2.41294 15.8333 3.33341 15.8333H16.6667C17.5872 15.8333 18.3334 15.0871 18.3334 14.1666V5.83329C18.3334 4.91282 17.5872 4.16663 16.6667 4.16663Z\"\n                                                stroke=\"#0A090A\" stroke-width=\"1.66667\" stroke-linecap=\"round\"\n                                                stroke-linejoin=\"round\" />\n                                            <path d=\"M1.66675 8.33337H18.3334\" stroke=\"#0A090A\" stroke-width=\"1.66667\"\n                                                stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n                                        </svg>\n                                    </div>\n                                    <div class=\"card-title\">Billing & Plan</div>\n                                </div>\n                                <div class=\"card-value\" id=\"plan-value\">—</div>\n                            </div>\n                            <div class=\"card-link\" id=\"billing-link\">\n                                <span>Change plan</span>\n                                <span class=\"card-link-arrow\">›</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Divider -->\n                    <div class=\"divider\"></div>\n\n                    <!-- Organization Details Container -->\n                    <div class=\"org-details-container\">\n                        <div class=\"section-title\">Organization Details</div>\n                        <div class=\"details-grid\">\n                            <div class=\"detail-item\">\n                                <span class=\"detail-label\">Organization Name</span>\n                                <span class=\"detail-value\" id=\"org-name\">—</span>\n                            </div>\n                            <div class=\"detail-item\">\n                                <span class=\"detail-label\">Owner Email</span>\n                                <span class=\"detail-value\" id=\"owner-email\">—</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        (function() {\n            // Private state\n            let organizationData = null;\n            let isInitialized = false;\n\n            // DOM references\n            const seatsValueEl = document.getElementById('seats-value');\n            const planValueEl = document.getElementById('plan-value');\n            const orgNameEl = document.getElementById('org-name');\n            const ownerEmailEl = document.getElementById('owner-email');\n            const membersCardEl = document.getElementById('members-card');\n            const billingCardEl = document.getElementById('billing-card');\n            const membersLinkEl = document.getElementById('members-link');\n            const billingLinkEl = document.getElementById('billing-link');\n\n            // Private functions\n            function render() {\n                if (!organizationData) return;\n\n                // Update seats\n                if (organizationData.totalSeats === -1) {\n                    seatsValueEl.textContent = `${organizationData.seatsUsed} seat${organizationData.seatsUsed !== 1 ? 's' : ''} used (unlimited)`;\n                } else {\n                    seatsValueEl.textContent = `${organizationData.seatsUsed} of ${organizationData.totalSeats} seats used`;\n                }\n\n                // Update plan\n                planValueEl.textContent = organizationData.planName;\n\n                // Update organization details\n                orgNameEl.textContent = organizationData.organizationName;\n                ownerEmailEl.textContent = organizationData.ownerEmail;\n            }\n\n            function initialize(data) {\n                organizationData = data;\n\n                // Toggle role-based visibility\n                const appRootEl = document.getElementById('app-root');\n                if (data.currentUserRole === 'member') {\n                    appRootEl.classList.add('role-member');\n                } else {\n                    appRootEl.classList.remove('role-member');\n                }\n\n                // Attach event listeners only once\n                if (!isInitialized) {\n                    const handleMembersClick = () => {\n                        window.myop_cta_handler('members_seats_clicked', {\n                            organizationId: organizationData.organizationId\n                        });\n                    };\n\n                    const handleBillingClick = () => {\n                        window.myop_cta_handler('billing_plan_clicked', {\n                            organizationId: organizationData.organizationId,\n                            currentPlan: organizationData.planName\n                        });\n                    };\n\n                    membersCardEl.addEventListener('click', handleMembersClick);\n                    billingCardEl.addEventListener('click', handleBillingClick);\n\n                    isInitialized = true;\n                }\n\n                render();\n            }\n\n            // Public API\n            window.myop_init_interface = function(data) {\n                // Getter mode\n                if (arguments.length === 0) {\n                    return { organization: organizationData };\n                }\n\n                // Action-based updates\n                if (data.action) {\n                    switch (data.action) {\n                        case 'setData':\n                            initialize(data.payload);\n                            break;\n                        case 'updateSeats':\n                            if (organizationData) {\n                                organizationData.seatsUsed = data.payload.seatsUsed;\n                                organizationData.totalSeats = data.payload.totalSeats;\n                                render();\n                            }\n                            break;\n                        case 'updatePlan':\n                            if (organizationData) {\n                                organizationData.planName = data.payload.planName;\n                                render();\n                            }\n                            break;\n                        default:\n                            console.warn('[OrgSettings] Unknown action:', data.action);\n                    }\n                    return data;\n                }\n\n                // Simple initialization\n                if (data.organization) {\n                    initialize(data.organization);\n                }\n\n                return data;\n            };\n\n            window.myop_cta_handler = function(action_id, payload) {\n                console.log('[OrgSettings CTA]', action_id, payload);\n            };\n\n            console.log('[OrgSettings] Component ready');\n        })();\n    </script>\n\n    <!-- Mock data for preview -->\n    <script id=\"myop_preview\" type=\"text/javascript\">\n        const currentState = window.myop_init_interface();\n        if (!currentState.organization) {\n            window.myop_init_interface({\n                organization: {\n                    organizationId: 'org-123',\n                    organizationName: 'Acme Corp',\n                    ownerEmail: 'alex@company.com',\n                    seatsUsed: 2,\n                    totalSeats: 3,\n                    planName: 'Starter Plan'\n                }\n            });\n        }\n    </script>\n</body>\n\n</html>"
        }
